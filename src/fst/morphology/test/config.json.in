{
    "analyser": "@abs_builddir@/../../analyser-gt-norm.hfstol",
    "generator": "@abs_builddir@/../../generator-gt-norm.hfstol",
    "nouns": {
        "lexcfile": "@abs_srcdir@/../stems/nouns.lexc",
        "lemmatags": ["+N+Sg+Nom", "+N+Pl+Nom", "+N+NomAg+Sg+Nom", "+N+NomAg+Pl+Nom", "+N+G3+Sg+Nom", "+N+G7+Sg+Nom"],
        "exclusions": ["(CmpN/Onlu|ShCmp|\\+Cmp/SplitR|\\+V\\+|AGAdj|AHKASAS|NOT-TO-LEMMATEST|ALLGUOVT|\\+Use/MT|RHyph|Cmp/Sh|Rnoun)"]
    },
    "adjectives": {
        "lexcfile": "@abs_srcdir@/../stems/adjectives.lexc",
        "lemmatags": ["+A+Sg+Nom", "+A+Attr", "+A+Pl+Nom"],
        "exclusions": ["(FINJU|\\+Use/MT|Lex|Sub)"]
    },
    "propernouns": {
        "lexcfile": "@abs_srcdir@/../stems/sme-propernouns.lexc",
        "lemmatags": ["+N+Prop+Sg+Nom", "+N+Prop+Pl+Nom", "+N+Prop+Attr"],
        "exclusions": ["(ProperNoun|\\+Use/MT)"]
    },
    "verbs": {
        "lexcfile": "@abs_srcdir@/../stems/verbs.lexc",
        "lemmatags": ["+V+Inf"],
        "exclusions": ["(STRAYFORMS|ENDLEX|\\+Neg|\\+Use/MT)"]
    }
}
