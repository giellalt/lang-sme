                  r Grademark v -> r v , 
                  r Grademark z -> r z , 
                  r Grademark ž -> r ž , 
                  s Grademark k -> s k , 
                  s Grademark m -> s m , 
                  s Grademark p -> s p , 
                  s Grademark t -> s t , 
                  š Grademark k -> š k , 
                  š Grademark m -> š m , 
                  š Grademark t -> š t , 
                  š Grademark v -> š v , 
                  t Grademark k -> t k , 
                  t Grademark m -> t m , 
                  v Grademark d -> v d , 
                  v Grademark g -> v g , 
                  v Grademark j -> v j , 
                  v Grademark k -> v k , 
                  v Grademark l -> v l , 
                  v Grademark p -> v p , 
                  v Grademark r -> v r , 
                  v Grademark s -> v s , 
                  v Grademark t -> v t , 
                  v Grademark z -> v z , 
                  v Grademark ž -> v ž ,
                  v Grademark d n -> v d n ,
                  i Grademark b m -> i b m ,
                  i Grademark d n -> i d n ,
                  i Grademark s k -> i s k ,
                  i Grademark s t -> i s t , 
                  i Grademark h l -> i h l ,
                  i Grademark h m -> i h m ,
                  i Grademark g ŋ -> i g ŋ ,
                  v Grademark h l -> v h l ,
                  i Grademark h n -> i h n ,
                  r Grademark b m -> r b m ,
                  r Grademark d n -> r d n ,
                  l Grademark l j -> l l j ,
                  l Grademark d n -> l d n ,
                  l Grademark b m -> l b m ,
                  r Grademark d n j -> r d n j ,
                  v Grademark d n j -> v d n j || Vow _ Vow ] ;

define negverb i -> i i || .#. _ .#. ;
define finvow o -> u , e -> i || _ .#. ;

define dh [ ð -> đ ] ; 
define EA  æ -> e a  ;
define ea [ Æ -> E a ] ;
define aa  å -> o  ;
define finali  [ e -> i || _ .#. ] ;

define secondi [ i -> e || Vow Cns Cns _ ] ;

define Cleanup [ 2 -> 0 ] ;

echo << Combining >>

read regex [ finalcons 
.o. preasp
!.o. ppHP    
!.o. DDJ    
.o. gh
.o. WeakXY
!.o. StrongXY
.o. EA
.o. ea
.o. aa
.o. negverb
.o. finvow
.o. finali
.o. secondi 
.o. Cleanup ] ;

save stockfleth2sme.hfst

! How to compile (in this folder):
! make -f make-stockfleth
! or eventually
