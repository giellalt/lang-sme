ADD:real-hallan (&real-hallan) TARGET Der/PassS IF (0 HALLA-PASS-V OR DER/ALLA-PASS-V + Der/alla OR DER/ALLA-PASS-V + Der/adda OR DER/H-DER/ALLA-PASS-V + Der/h + Der/alla OR DER/H-DER/ALLA-PASS-V + Der/h + Der/adda)(NEGATE 0 <spelled>) ;

ADD:real-hallan (&real-hallan) TARGET (Imprt Sg1) IF (0 HALLA-PASS-V OR DER/ALLA-PASS-V OR DER/H-DER/ALLA-PASS-V + Der/h + Der/alla OR DER/ALLA-PASS-V OR DER/H-DER/ALLA-PASS-V + Der/h + Der/adda OR HALLA-PASS-V)(NEGATE 0 <spelled>)(NEGATE *1 ("!")) ;
COPY:real-hallan (TV SUGGEST) EXCEPT (Ex/V Ex/TV IV Der/PassS &real-hallan) TARGET (Der/Pass &real-hallan) ;
	## Mii gĂĄvnnaimet elliid mat ledje jĂĄpmĂĄn, main ledje borahallon seaibbit, bealjit ja vel juolggit ge.

ADD:real-hallan (&real-hallan) TARGET (Imprt Pl1 Dial/-KJ) IF (0 HALLA-PASS-V)(NEGATE *1 ("!"))(NEGATE 0 <spelled>) ;
COPY:real-hallan (Inf SUGGEST) EXCEPT (Imprt Pl1 Dial/-KJ &real-hallan) TARGET (Imprt Pl1 Dial/-KJ &real-hallan) ;
	## Dat ferte oainnahallot ovdal go sĂĄhttit bĂĄhÄit dan, lohkĂĄ son.

COPY:real-hallan (PrfPrc SUGGEST) EXCEPT (Imprt Sg1 &real-hallan) TARGET (Imprt Sg1 &real-hallan) ;
	##  Lojes gumpe Lea mĂĄĆga vahkku ĂĄigi dan rĂĄjes go gumppe ĂĄlggos beakkehii KĂĄrĂĄĆĄjoga guovllus, ja Gaup atnĂĄge imaĆĄin go gumpe lea dan rĂĄjes sihke vuddjon biilii, ja maiddĂĄi oainnahallon viesuid lahka.
	## DuĆĄĆĄe 40 mehtera Kjell Ăstmo viesus eret, lea gumpe oainnahallon ja vuhtton maĆĆebĂĄrgga. Kjell Ăstmo giettis, RĂĄvdojoganjĂĄrggas, KĂĄrĂĄĆĄjogas, lea gumpe sihke vuhtton ja oainnahallon maĆĆebĂĄrgga eahkeda.
	
	
	# Some early real word error rules
	# --------------------------------
	
 # barggan > barggĂĄn+A+Sg+Nom
 

ADD:real-barggan-barggĂĄn (&real-barggan-barggĂĄn) TARGET ("bargat" V TV Ind Prs Sg1) IF (-1 GRADE-ADV OR ("man" Adv) OR ("mii" Pron Rel Sg Acc Known) OR ("leat" Ind Sg1));
	## Lean barggan.

ADD:real-barggan-barggĂĄn (&real-barggan-barggĂĄn) TARGET ("bargat" V TV Ind Prs Sg1) IF (-1 Inf LINK -1 AUX);
	## Fertet leat barggan ja ÄĂĄjehit ahte don nagodat bargat, ja de leage maid buoret bargu vuordimis. 

ADD:real-barggan-barggĂĄn (&real-barggan-barggĂĄn) TARGET ("bargat" V TV Ind Prs Sg1) IF (1 CC OR COMMA LINK 1 (A Sg Nom) OR (A <AttrPred> Attr));
	## Jus don livÄÄet riegĂĄdan beaivvi ovdal, de livÄÄet don rikkis, nĂĄvccalaĆĄ, barggan, smĂĄÄĂĄhkes ja buoremielalaĆĄ olmmoĆĄ.
	
ADD:real-barggan-barggĂĄn (&real-barggan-barggĂĄn) TARGET ("bargat" V TV Ind Prs Sg1) IF (-1 CC OR COMMA LINK -1 (A Sg Nom) OR (A <AttrPred> Attr));

COPY:real-barggan-barggĂĄn ("barggĂĄn" A Sg Nom SUGGEST) EXCEPT ("bargat" V TV Ind Prs Sg1) TARGET (&real-barggan-barggĂĄn) ;

 # buollat > buollĂĄt

ADD:real-buollat-buollĂĄt (&real-buollat-buollĂĄt) TARGET ("buolla" N Sg Nom PxSg2) OR  ("buolladit" Imprt ConNeg) OR ("buolladit" Imprt Sg2) OR ("buolladit" Ind Prs ConNeg) OR ("buollahit" Ind Prs ConNeg) IF (*-1 ("mii" Pron Indef Sg) OR ("son" Pers Pl3 Nom) OR VFIN + <aux> BARRIER NOT-ADV-PCLE);

COPY:real-buollat-buollĂĄt ("buollĂĄt" V IV Inf SUGGEST) EXCEPT ("buolla" N Sg Nom PxSg2) OR  ("buolladit" Imprt ConNeg) OR ("buolladit" Imprt Sg2) OR ("buolladit" Ind Prs ConNeg) OR ("buollahit" Ind Prs ConNeg)  TARGET &real-buollat-buollĂĄt IF (*-1 ("mii" Pron Indef Sg) OR ("son" Pers Pl3 Nom)) ;


	# fallut = bli sterkere (falli) vs. fallĂĄt (tilby)
	# ------------------------------------------------

ADD:xreal-fallo-fĂĄllo (&real-fallo-fĂĄllo) TARGET ("fallut" V IV Imprt ConNegII) OR ("fallut" V IV Ind Prt Pl3) IF (*0 (N Sg Nom) - Sem/Hum BARRIER NPNHA - (A <AttrPred> Sg Nom));
	## Sidjiide maid fallo psykiatralaĆĄ veahkki, go leat vĂĄsihan katastrofa, maiddĂĄi lagaĆĄolbmuide fallo dĂĄt veahkki.
	
COPY:real-fallo-fĂĄllo ("fĂĄllat" Ex/V Ex/TV Der/PassS V IV Ind Prs Sg3 SUGGEST) EXCEPT ("fallut" V IV Imprt ConNegII &real-fallo-fĂĄllo) OR ("fallut" V IV Ind Prt Pl3 &real-fallo-fĂĄllo) TARGET (&real-fallo-fĂĄllo) ;


 # sĂĄbmĂĄi > sabmĂĄi (skimtes)

ADD:xreal-sĂĄbmĂĄi-sabmĂĄi (&real-sĂĄbmĂĄi-sabmĂĄi) TARGET ("sĂĄbmĂĄi" A Sg Nom) OR ("sĂĄpmi" N Sg Ill Err/Confused-ASgNom) OR ("sĂĄpmi" N Sg Ill) IF (*1 (Prop Sg Nom) + Sem/Plc BARRIER NOT-ADV-PCLE - ("ieĆĄ"));

COPY:xreal-sĂĄbmĂĄi-sabmĂĄi ("sabmĂĄt" V IV Ind Prt Sg3 SUGGEST) EXCEPT ("sĂĄbmĂĄi" A Sg Nom) OR ("sĂĄpmi" N Sem/Hum_Lang Sg Ill Err/Confused-ASgNom) OR ("sĂĄpmi" N Sg Ill) TARGET &real-sĂĄbmĂĄi-sabmĂĄi ;
	## Ja ii manannge ĆĄat guhkĂĄ go ovddabealde sĂĄbmĂĄi ieĆĄ RĂĄdjeoaivi, mii lea dego Äuorvvasmearka gaskku dĂĄn meahcceguovllu.
	## Ja ii mannange vehĂĄ badjelas moadde diimmu go ovddabealde sĂĄbmĂĄi BĂĄlojĂĄvri, mii lea okta ÄĂĄbbĂĄseamus jĂĄvrriin dĂĄn guovllus.


    # Compound errors
	# ===============

LIST COMPOUND = (".*#.*"r) ;


