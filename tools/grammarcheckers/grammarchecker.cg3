ADD:xmsyn-acc-to-velggolaÅĄ (&msyn-acc-to-velggolaÅĄ) TARGET ("velggolaÅĄ") IF (-1 CURRENCY OR Sem/Money LINK -1 Num) ; 

ADDRELATION:msyn-acc-to-velggolaÅĄ (RIGHT $2) (Num &msyn-acc-to-velggolaÅĄ) TO (*1 ( "velggolaÅĄ" &msyn-acc-to-velggolaÅĄ));
 
ADD:xmsyn-acc-to-comp (&msyn-acc-to-comp) TARGET Num IF (NOT 0 Acc OR Nom OR ACC-NUM-ATTR LINK 1 Sem/Measr OR MEASURE OR Sem/Time OR CURRENCY LINK 1 ("maÅÅil") OR ("maÅÅel") OR ("ovdal") OR ("maÅÅelaÅĄ") OR ("ovdalaÅĄ") OR Comp OR ADV-COMP-FUNCTION ) (NEGATE 0 Gen LINK 1 Sem/Measr OR MEASURE OR Sem/Time OR CURRENCY LINK 1 Comp OR ADV-COMP-FUNCTION LINK 1 Loc)(NOT 0 (Num Arab)) ;  #2nd
    ## MÃĄhtte lea viÄa jagi nuorat go mun. PROBLEM
    ## Dat ÅĄattai guovtti mehtera guhkit go galggaÅĄii.
    ## Son vuvddii daid bohccuid viÄa ruvnno hÃĄlbbibui.
    #$ Kisumu ÃĄssit muitalit, ahte friijasit golgi ÅĄaddu fÃĄrredaddÃĄ Kisumu ja Homabay gaskkas, mii leat {200} kilomehtera mÃĄddelis go Kisumu.
ADD:xmsyn-acc-to-comp (&msyn-acc-to-comp) TARGET Num IF (NOT 0 Acc OR ACC-NUM-ATTR LINK 1 Sem/Measr OR MEASURE LINK *1 Gen OR Acc BARRIER GRAMCHK-NPNHA LINK 1 ADV-COMP-FUNCTION ) ;  #2nd
	# difficult to searching for
    
ADD:xmsyn-acc-to-comp (&msyn-acc-to-comp) TARGET Num IF (NOT 0 Acc OR ACC-NUM-ATTR LINK 1 Sem/Measr OR MEASURE LINK *1 Loc BARRIER GRAMCHK-NPNHA  LINK *1 ("eret") BARRIER GRAMCHK-S-BOUNDARY ) ;  #2nd

COPY:msyn-acc-to-comp (Num Sg Acc SUGGEST) EXCEPT (Num Sg Gen) OR (Num Sg Loc Attr) OR (Num Sg Ill Attr) OR (Num Sg Nom) TARGET (Num &msyn-acc-to-comp) ;  #2nd
	#$ MÃĄhtte lea vihtta jagi nuorat go mun.
    #$ MÃĄhtte lea viÄa jagi nuorat mus.    
    ## LÃĄsse lea riegÃĄdan viÄa jagi ovdal go mon. DISAMBPROBLEM: "viÄa" Po is chosen
    ## Dat dÃĄhpÃĄhuvai viÄa jagi maÅÅil. - DuommÃĄ: why is this example here?
    ## ÃdjÃĄ viessu lea guovtti miilla bajÃĄbeale mÃĄrkana.
    ## Mun oidnen guovÅūÅūa golmma kilomehtera dÃĄbbelis.
    ## Guovdageaidnu lea golmma miilla duoin eret.
    ## Guovdageaidnu lea golmma miilla KÃĄrÃĄÅĄjogas eret.
    ## Guovdageaidnu lea golmma miilla duoin viesuin eret.
    ## ÃdjÃĄ viessu lea guovtti miilla mÃĄrkana bajÃĄbeale.

    #$ Guovdageaidnu lea golbma miilla duoin eret.
    #$ Guovdageaidnu lea golbma miilla KÃĄrÃĄÅĄjogas eret.
    #$ Guovdageaidnu lea golbma miilla duoin viesuin eret.
    #$ ÃdjÃĄ viessu lea guokte miilla mÃĄrkana bajÃĄbeale.
    #R: Nickel1994:486 "I Ãļst brukes ogsÃĨ genitiv i forbindelse med komparasjon, dersom komparativen er predikativ i steningen, og det andre sammanligningsleddet stÃĨr i lokativ: MÃĄhtte lea viÄa jagi nuorat mus."
    # in errors.xml

ADD:xmsyn-acc-to-comp (&msyn-acc-to-comp) TARGET Comp OR ADV-COMP-FUNCTION IF (-1 Sem/Measr OR MEASURE OR Sem/Time OR CURRENCY LINK -1 Num)(NEGATE 0 &msyn-acc-to-adv);

ADDRELATION:msyn-acc-to-comp (RIGHT $2) (Num &msyn-acc-to-comp) TO (*1 Comp OR ADV-COMP-FUNCTION LINK 0 &msyn-acc-to-comp);


