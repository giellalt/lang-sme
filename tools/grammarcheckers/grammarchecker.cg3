LIST HUMAN-ACTIVITY-V = "bassit" "bealuĆĄtit" "beaskidit" "beastit" "bivdit" "boaldit" "botket" "buktit" "buvttadit" "Äaskit" "Äatnat" "ÄĂĄjehit" "ÄĂĄllit" "Äoaggit" "Äoavdit" "Äugget" "Äuohppat" "dearvvahit" "deavdit" "devdnet" "dikĆĄut" "divvut" "doarrĂĄdallat" "doidit" "dubmet" "duddjot" "duvdilit" "ferdnet" "gĂĄhkket" "gĂĄrvodit" "gĂĄsttaĆĄit" "gĂĄvkat" "geahÄÄat" "gilvit" "goarrut" "goddit" "goÄÄit" "gohÄÄut" "goikadit" "goivet" "gokÄat" "gottihit" "guldalit" "guolĂĄstit" "hĂĄbmet" "hervet" "hoigat" "hoitĂĄt" "hukset" "huĆĄkut" "juhkat" "juksat" "juogadit" "juohkit" "lĂĄibut" "lĂĄktadit" "loaiddastit" "luddet" "merket" "mihtidit" "murret" "nannet" "nĂĄitalit" "njuoskadit" "oahpahit" "ohcat" "rahpat" "rĂĄhkadit" "rĂĄidnet" "rĂĄtkit" "registreret" "rekruteret" "ruohkkat" "sĂĄddet" "sĂĄltet" "sĂĄrgut" "sihkkut" "skihtardit" "skoalkalit" "tevdnet" "vadjat" "veahkehit" "vikĆĄet" "vuoÄÄudit" "vuosehit" "vuoidat" "vuoiddadit" "vuoitit" "vuostĂĄivĂĄldit" "vuoĆĄĆĄat" "vurket" ;

  # in contrast to abstract "activities" and static verbs.
  # According to the rules choosing Loc or Com, all activity-verbs do not select TOOL, ABSTR-TOOL, CONCEPT or HUMAN in (Pl Loc).

LIST BODY-ACTIVITY-V = "borrat" "ÄiekÄat" "Äujuhit" "Äuorbmat" "gullat" "guoskkahit" "lihkahit" "lihkastahttit" "njĂĄvkkadit" "njĂĄvkkastit" "oaidnit" "seavvit" ;

    # These verbs can also have BODY as a tool. The verb-set belongs to the superset of dynamic-verbs, so they will also work with TOOL and ABSTR-TOOL in Com. "Giehta" is in both the TOOL-set and the BODY-set because it selects in Com to a lot of verbs.

LIST PLACING-ACTIVITY-V = "bidjat" "buonjostit" ;

#LIST HUNTING-ACTIVITY-V = "bivdit" "goddit" "luossa-bivdit" ;

#LIST FOOD-ACTIVITY-V = "ferdnet" ;

#LIST WORKING-ACTIVITY-V = ;

LIST WRITING-ACTIVITY-V = "ÄĂĄllit" ;

LIST HANDICRAFT-ACTIVITY-V = "buddet" "botnit" "goarrut" "hervet" "vadjat" "vikĆĄet" ;

SET ACTIVITY-V = BODY-ACTIVITY-V OR WRITING-ACTIVITY-V OR PLACING-ACTIVITY-V OR HUMAN-ACTIVITY-V OR HANDICRAFT-ACTIVITY-V ;

#LIST DADJAT = "dadjat" "lohkat" ;
# This set is for  cealkkavĂĄstta: DADJAT + Acc + Inf - Not in use for the time being

LIST HUPMAT =  "dĂĄikit" "dĂĄrostit" "digĂĄĆĄtallat" "digaĆĄtit" "duoldat"  "hĂĄladit" "hĂĄleĆĄtit" "hĂĄllat" "hoallat" "humadit" "hupmat" "logaldallat" "mĂĄidnut" "mĂĄinnaĆĄit" "muitaladdat" "njurgut" "oaivvildit" "savkalit" "sĂĄgastaddat" "sĂĄgastallat" "sĂĄgastit" "sĂĄmĂĄstit" "sĂĄmistit" "sĂĄrdnidit" "sĂĄrdnut" "sĂĄrtnodit" "solĆŸat" "suomastit" ;
# These should not take HUMAN as object

LIST VERBAL-ACTIVITY =  "ĂĄrvalit" "cealkit" "Äilget" "basuhit" "cuoigut" "Äuorvut" "Äurvet"  "dadjat" "gielistit" "gilljut" "gopmulit" "hĂĄladit" "hĂĄleĆĄtit" "hĂĄllat" "hoallat" "huikit" "huikkĂĄdit" "jearrat" "juoigat" "kommenteret" "lĂĄvlut" "lohkat"  "muitalit"  "rĂĄvvet" "sivdnidit" "vĂĄruhit" "vĂĄstidit" ;

