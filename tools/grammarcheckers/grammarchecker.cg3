    # gaskan	gaskat+V+IV+Der/NomAct+N+Sg+Nom	0,000000
    
LIST GASKKAS-V = "bissut" "juohkit" "juohkin" "juohkĂĄsit" "juogadit" "juohkaĆĄuvvat" "earru" "earuhit" "distinkĆĄuvdna" "erohus" "sirdin" "sierralĂĄganvuohta" ;

ADD:lex-gaskan-gaskkas (&lex-gaskan-gaskkas) TARGET ("gaskan") IF (0 Po OR Adv OR Pr OR (N Sg Nom))(-1 Gen OR Acc LINK 0 Pl OR DUPRON LINK -1 BOS);
	## LĂĄvlluid gaskan son hupmĂĄ politihka birra muhto sĂĄgĂĄt leat maid oahppĂĄsat ja somĂĄt. DĂĄt ferte bissut munno gaskan. 
	
ADD:lex-gaskan-gaskkas (&lex-gaskan-gaskkas) TARGET ("gaskan") IF (0 Po OR Adv OR Pr OR (N Sg Nom))(-1 Gen OR Acc LINK -1  CC LINK -1 (N Gen) OR (N Acc) OR (Pron Gen) OR (Pron Acc));
	## JiellevĂĄri ja Johkamohki gaskan ledje bohccot.
    
ADD:lex-gaskan-gaskkas (&lex-gaskan-gaskkas) TARGET ("gaskan") IF (0 Po OR Adv OR Pr OR (N Sg Nom))(-1 Gen OR Acc LINK 0 Pl OR DUPRON LINK *-1 GASKKAS-V BARRIER S-BOUNDARY);

COPY:lex-gaskan-gaskkas ("gaskkas" Po SUGGEST) EXCEPT ("gaskan" Po &lex-gaskan-gaskkas) OR ("gaskan" Pr &lex-gaskan-gaskkas) OR ("gaskan" Adv &lex-gaskan-gaskkas) OR ("gaskan" N Sg Nom &lex-gaskan-gaskkas) TARGET (&lex-gaskan-gaskkas);    
