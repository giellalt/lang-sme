SUBSTITUTE PrfPrc (Â§TH PrfPrc) TARGET V IF (p (V <TH-Acc-Any><TH-PrfPrc>))(NOT 0 @SUBJ)(NEGATE 0 Â§TH) ;
	## Olbmot balle ieĆŸaset gozihuvvon, ja gĂĄibidedje dieÄuid, go eai luohttĂĄn eisevĂĄlddiide.

SUBSTITUTE Actio (Â§TH Actio) TARGET V IF (0 (Actio Ess))(p (V <TH-Acc-Any><TH-AktioEss>))(NOT 0 @SUBJ)(NEGATE 0 Â§TH) ;

SUBSTITUTE Actio (Â§TH Actio) TARGET V IF (0 (Actio Loc))(p (V <TH-AktioLoc>))(NOT 0 @SUBJ)(NEGATE 0 Â§TH) ;

SUBSTITUTE V (Â§TH V) TARGET Inf IF (p (V <TH-Acc-Any><TH-Inf>) OR (V <AG-Acc-Ani><TH-Inf>))(NOT 0 @SUBJ)(NEGATE 0 Â§TH) ;
	## Muhto son goitge balai daid ĆĄaddat heajos ovdamearkan ĂĄssiide.

SUBSTITUTE Pron (Â§TH Pron) TARGET Pron IF (p (V <TH-Acc-Any><TH-Inf>))(0 Acc OR Gen)(NEGATE 0 Â§ANYROLE) ;
	##
SUBSTITUTE N (Â§TH N) TARGET N IF (p (V <TH-Acc-Any><TH-Inf>))(0 Acc OR Gen)(NEGATE 0 Â§ANYROLE) ;

