	# eanet iige eannehit (= rekke)
    # -----------------------------

ADD:xreal-eannet-eanet (&real-eannet-eanet) TARGET ("eannehit") IF (0 (V IV Imprt ConNeg) OR (V IV VGen) OR (V IV Imprt Sg2) OR (V IV Ind Prs ConNeg)) (*-1 VFIN BARRIER GRAMCHK-S-BOUNDARY LINK NOT 0 NOT-V ) ; 

ADD:xreal-eannet-eanet (&real-eannet-eanet) TARGET ("eannehit") IF (0 (V IV Imprt ConNeg) OR (V IV VGen) OR (V IV Imprt Sg2) OR (V IV Ind Prs ConNeg))  (*-2 NOT-V LINK *1 V + PrfPrc OR V + Inf OR V + ConNeg BARRIER ("eannehit")) ;

COPY:real-eannet-eanet ("eanet" Adv SUGGEST) EXCEPT ("eannehit" V IV Imprt ConNeg Gram/3syll) OR ("eannehit" V IV VGen Gram/3syll) OR ("eannehit" V IV Imprt Sg2 Gram/3syll) OR ("eannehit" V IV Ind Prs ConNeg Gram/3syll) TARGET (V &real-eannet-eanet) ;

COPY:real-eannet-eanet ("eanet" A Attr SUGGEST) EXCEPT ("eannehit" V IV Imprt ConNeg Gram/3syll) OR ("eannehit" V IV VGen Gram/3syll) OR ("eannehit" V IV Imprt Sg2 Gram/3syll) OR ("eannehit" V IV Ind Prs ConNeg Gram/3syll) TARGET (V &real-eannet-eanet) ;
	## EarenoamĂĄĆŸit jus ii luohte eannet ieĆŸat intuiĆĄuvdnii ja jierpmĂĄlaĆĄvuhtii, de mannĂĄ duinna hui bures.


	# dohko vs. dohkko (doahkkut - klumpen)
	# -------------------------------------

ADD:xreal-dohkko-dohko (&real-dohkko-dohko) TARGET ("doahkkut" V IV Ind Prt Pl3) OR ("doahkkut" Ex/V Ex/IV Der/PassS V IV Ind Prs Sg3) OR ("doahkkut" Ex/V Ex/IV Der/PassS V IV Ind Prs ConNeg) OR ("doahkkut" V IV Imprt ConNegII) OR ("doahkkut" V IV ConNegII) OR ("doahkkut" V IV Ind Prs Du1) OR ("dohko" Err/Orth Adv) IF (*1 VFIN) ;

ADD:xreal-dohkko-dohko (&real-dohkko-dohko) TARGET ("doahkkut" V IV Ind Prt Pl3) OR ("doahkkut" Ex/V Ex/IV Der/PassS V IV Ind Prs Sg3) OR ("doahkkut" Ex/V Ex/IV Der/PassS V IV Ind Prs ConNeg) OR ("doahkkut" V IV Imprt ConNegII) OR ("doahkkut" V IV ConNegII) OR ("doahkkut" V IV Ind Prs Du1) OR ("dohko" Err/Orth Adv) IF (1 ("gosa")) ;
	## Njulge kĂĄrta dakkĂĄr sadjĂĄi gokko lea jalgat Bonja kĂĄrtta nu ahte davvi guovlu kĂĄrttas ja kompĂĄssa davvi guovlu heiveba oktii Bija kompĂĄssaduolbba ravdda nu ahte mannĂĄ dan bĂĄikkis gos leat dĂĄl, dohkko gosa ĂĄiggut Bonja kompĂĄssajorbbĂĄ nu ahte sĂĄzut jorbbĂĄs ĆĄaddet dĂĄssĂĄlaga davvisĂĄzuiguin kĂĄrttas Heivet kompĂĄssa davvinjuola, gĂĄhta sisa Mannannjuolla ÄĂĄjeha gosa galggat mannat
	
ADD:xreal-dohkko-dohko (&real-dohkko-dohko) TARGET ("doahkkut" V IV Ind Prt Pl3) OR ("doahkkut" Ex/V Ex/IV Der/PassS V IV Ind Prs Sg3) OR ("doahkkut" Ex/V Ex/IV Der/PassS V IV Ind Prs ConNeg) OR ("doahkkut" V IV Imprt ConNegII) OR ("doahkkut" V IV ConNegII) OR ("doahkkut" V IV Ind Prs Du1) OR ("dohko" Err/Orth Adv) IF (*0 <TH-Ill-Any> OR <LO-Ill-Any> OR <DE-Ill-*Ani> OR <DE-Ill-Plc> OR <TH-Nom-Any><PO-Ill-Any> OR <TH-Acc-Any><DE-Ill-*Ani> BARRIER GRAMCHK-S-BOUNDARY) ;
	## Dohkko sĂĄhttĂĄle buot heargegilvaleaddjit oassĂĄlastit.
	## MĂĄnĂĄt sĂĄhttet dohkko gahÄÄat ja duĆĄĆĄat.

COPY:real-dohkko-dohko ("dohko" Adv SUGGEST) EXCEPT ("doahkkut" V IV Ind Prt Pl3 &real-dohkko-dohko) OR ("doahkkut" Ex/V Ex/IV Der/PassS V IV Ind Prs Sg3 &real-dohkko-dohko) OR ("doahkkut" Ex/V Ex/IV Der/PassS V IV Ind Prs ConNeg &real-dohkko-dohko) OR ("doahkkut" V IV Imprt ConNegII &real-dohkko-dohko) OR ("doahkkut" V IV ConNegII &real-dohkko-dohko) OR ("doahkkut" V IV Ind Prs Du1 &real-dohkko-dohko) TARGET (V &real-dohkko-dohko) ;
COPY:real-dohkko-dohko (SUGGEST) EXCEPT (Err/Orth &real-dohkko-dohko) TARGET (Adv &real-dohkko-dohko) ;
			



