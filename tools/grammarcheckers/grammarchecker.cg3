	# measta (Adv) vs. meastta (N) PĂŒree, Muss
	# ------------------------------------------

	
ADD:xreal-meastta-measta (&real-meastta-measta) TARGET ("meastta" N Sg Nom) OR ("measta" Err/Orth Adv)(*1 A + Attr BARRIER NPNH);  
COPY:real-meastta-measta ("measta" Adv SUGGEST) EXCEPT ("meastta" N Sg Nom &real-meastta-measta) OR ("measta" Err/Orth Adv &real-meastta-measta) TARGET (&real-meastta-measta) ; 
	## Meastta  seamma stuora ruĆĄkesguovĆŸa gĂĄvdo  maiddĂĄi KamtsjatkanjĂĄrggas ja Parammushirsullos RuoĆĄĆĄas, muhto diet guovĆŸa, mii gohÄoduvvo kamtsjatkaguovĆŸan, ii leat dohkkehuvvon sierra vuolleĆĄlĂĄdjan.
	## NjĂĄlla lea meastta jĂĄvkan Norgga duoddariin.
	## Nuppelogi oahppis lea okta oahppi oĆŸĆŸon meastta buoremus ĂĄrvosĂĄni , earĂĄt fas eai leat ceavzĂĄn fĂĄgas ja oassi fas jur bĂĄs lĂĄdje ceavzĂĄn fĂĄgas.
	## Guovdageainnus finai guolĂĄstusministtar Helga Pedersen geahÄÄame dan oÄÄa Diehtosiidda mii lea juo meastta gĂĄrvvis.
	## â Muhto, doai han leahppi duĆĄĆĄe guÄa jahkĂĄsaÄÄat, eahppi go doai leat meastta nuora nĂĄitalit?
		
	# muhtumin vs. muhtomin
	# ---------------------

	
ADD:xreal-muhttomin-muhtumin (&real-muhttomin-muhtumin) TARGET ("muhtumin" Err/Orth Adv Sem/Time) OR ("muohttit" Ex/V Ex/IV Der/PassS V) OR ("muhttot" V IV Actio Ess) OR ("muhttit" Ex/V Ex/TV Der/PassS V IV Actio Ess) OR ("muhttot" Ex/V Ex/IV Der/NomAct N Ess) OR ("muhttot" Ex/V Ex/IV Der/NomAct Sem/Act N Ess) OR ("muhttit" Ex/V Ex/TV Der/PassS Ex/V Ex/IV Der/NomAct N Ess) OR ("muohttit" Ex/V Ex/IV Der/PassS Ex/V Ex/IV Der/NomAct N Ess) (*0 VFIN BARRIER GRAMCHK-S-BOUNDARY);  

COPY:&real-muhttomin-muhtumin ("muhtumin" Adv SUGGEST) EXCEPT ("muhtumin" Err/Orth Adv &real-muhttomin-muhtumin) OR ("muohttit" Ex/V Ex/IV Der/PassS V &real-muhttomin-muhtumin) OR ("muhttot" V IV Actio Ess &real-muhttomin-muhtumin) OR ("muhttit" Ex/V Ex/TV Der/PassS V IV Actio Ess &real-muhttomin-muhtumin) OR ("muhttot" Ex/V Ex/IV Der/NomAct N Ess &real-muhttomin-muhtumin) OR ("muhttot" Ex/V Ex/IV Der/NomAct Sem/Act N Ess &real-muhttomin-muhtumin) OR ("muhttit" Ex/V Ex/TV Der/PassS Ex/V Ex/IV Der/NomAct N Ess &real-muhttomin-muhtumin) OR ("muohttit" Ex/V Ex/IV Der/PassS Ex/V Ex/IV Der/NomAct N Ess &real-muhttomin-muhtumin) TARGET (&real-muhttomin-muhtumin) ;
	## DĂĄl duddjo duĆĄĆĄe muhttomin. Oahppi atnĂĄ giela muhttomin. â 
	## Dan guovtti suohkanis ii gĂĄvdno odne makkĂĄrlĂĄgan plĂĄna mo galget ovddidit SĂĄmegiela suohkanin, dat lea heahpat ja muhttomin dat orru maid nu ahte suohkaniid bealis leat mĂĄĆgii bargan sin vuostĂĄ geat leat bargan sĂĄmegielain, dadjĂĄ Olav Andersen. 
	## MUOHTTAGIS: SkuohtanjĂĄrgga ovdaolmmoĆĄ Mikkel Nils Sara dadjĂĄ sin dĂĄrkilin, muhto muhttomin sĂĄhttĂĄ leat vĂĄttis ja de ĆĄaddĂĄ gieÄaid bassalit muohttagis.


	# muoĆ§ĂĄs iige muoĆ§Ć§ĂĄs 
    # -------------------
    
ADD:xreal-muoĆ§Ć§ĂĄs-muoĆ§ĂĄs  (&real-muoĆ§Ć§ĂĄs-muoĆ§ĂĄs ) TARGET ("muoĆ§Ć§ĂĄ") IF (0 (N Sg Nom PxSg3)) (*1 Po BARRIER GRAMCHK-NPNH) ;
ADD:xreal-muoĆ§Ć§ĂĄs-muoĆ§ĂĄs  (&real-muoĆ§Ć§ĂĄs-muoĆ§ĂĄs ) TARGET ("muoĆ§Ć§ĂĄi") IF (0 (A Attr) OR (A Sg Loc) OR (A Sg Nom PxSg3) OR (A Sg Gen PxSg3) OR (A Sg Acc PxSg3)) (*1 Po BARRIER GRAMCHK-NPNH) ;

