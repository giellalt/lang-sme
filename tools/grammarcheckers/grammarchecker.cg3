    # erret (isolere) vs. earret
    # --------------------------
    # condition:

ADD:real-erret-earret (&real-erret-earret) TARGET  ("erret") IF (0 Inf OR (Prs Sg2) OR (Prs Pl1) OR (VGen) OR (Imprt) OR (ConNeg))(1 ("earأ،"));
    ## Eandalit ؤچأ،hppes beana lea buot divraseamos borramuإ،, ؤچأ،llأ، Kitti erret earأ، dأ،n nuppi mأ،tkkereivves Thailأ،nddas.


ADD:real-erret-earret (&real-erret-earret) TARGET  ("erret") IF (0 Inf OR (Prs Sg2) OR (Prs Pl1) OR (VGen) OR (Imprt) OR (ConNeg))(1 (N Nom) OR CS)(*-1 (V Neg) OR (N Acc) OR (Pers Sg2) OR (Pers Pl1) BARRIER NOT-ADV-PCLE);
	## Stuoradikki gielddalأ،vdegotti eanetlohku, buot bellodagat {erret} Ovddأ،dusbellodat, leat aitto mearridan vuoruhit riikaviidosaإ، sأ،mi beaiveaviissaid ovddideami sأ،megillii ja dأ،rogillii.
	## Jus geavaha guokte dahje eambbo dain molssaeavttuin mat leat namuhuvvon dأ،s dalle dat rehkanastojuvvo duإ،إ،e oؤ‘asnaga biilla listohattis 56,25 proseantta, {erret} go geavaha el-biilla fitnodatbiilan maid vuodjأ، badjel 40 000 km mas goitge rehkkenastojuvvo 75 proseantta biilla listohattis oؤ‘asnaga.
	## Sus eai lean daؤ‘i eambbo kommentأ،rat politiija rأ،إ‹ggأ،إ،tusevttohussii, {erret} ahte son berre oaإ¾إ¾ut ؤچohkkأ،t dalle go heive su bargodillأ،i.
	## Ovttaveardأ،saإ،vuoؤ‘alأ،ga 13 آ§:s eahpenjulges vealaheapmi meroإ،tallo fas dakkأ،r dilأ،laإ،vuohtan, mas formأ،lalaؤچؤچat ovttaveardأ،saإ، njuolggadusa, vuoؤ‘uإ،tusa dahje geavadaga dihte olmmoإ، gأ،rtأ، fuonit sajأ،dahkii earأ،id ektui sutnje laktأ،seaddji siva dihte {erret} dalle go njuolggadusas, vuoؤ‘uإ،tusas dahje geavadagas lea dohkkehahtti mihttomearri ja dan ollaإ،uvvamii adnon vuogit leat أ،إ،إ،أ،laؤچؤچat ja dأ،rbbaإ،laؤچؤچat.
	## Dasa lassin dutkanraporttas bukto ovdan ahte suomagiela geavaheapmi bargoeallimis adno juo nu ؤچielggaإ،in buot earأ، أ،mmأ،hiin, erret muhtin lأ،dje sأ،pmelaإ،vuhtii laktأ،seaddji أ،mmأ،hiin.
	## Kvalitatiiva jearahallamiin nuoraiguin boahtأ، ovdan ahte Sأ،megiela 1 ja 2 informأ،nttat, erret guokte, أ،lo sأ،mأ،stit sأ،megielat vأ،hnemiin / vأ،hnemiiguin.
	
ADD:real-erret-earret (&real-erret-earret) TARGET  ("erret") IF (0 Inf OR (Prs Sg2) OR (Prs Pl1) OR (VGen) OR (Imprt) OR (ConNeg))(1 (N Nom))(-1 CS OR Rel);	
	## Finnmأ،rkkus dأ،إ¾a borgأ،riidda maid (dalأ،) Fuoؤ‘ؤ‘o- ja sأ،ivaguoli direktorأ،hta dohkkehii cuoإ‹omأ،nu 20. b. 1983, mearrida ahte erret giliأ،ssit, galget boazosأ،pmelaؤچؤچain ealأ،husaset doaimmas leat vuosttasvuoigatvuohta fierbmebivddu ؤچujuheamis.
	## Lanjaid, nissoniid gearddis, leatge navdأ،n juste fal daid beakkأ،lmasaid mielde, geat erret Mari ledje nugo Maria Bonnevie, Ane Dahl Torp ja Bertine Zetlitz, earret earأ،.



COPY:real-erret-earret ("earret" Pr SUGGEST) EXCEPT ("erret" V TV Inf &real-erret-earret) OR ("erret" V TV Ind Prs Sg2 &real-erret-earret) OR ("erret" V TV Ind Prs Pl1 &real-erret-earret) OR ("erret" Ex/V TV Der/d V VGen &real-erret-earret) OR ("erret" Ex/V TV Der/d V Imprt Sg2 &real-erret-earret) OR ("erret" Ex/V TV Der/d V Imprt ConNeg &real-erret-earret) OR ("erret" Ex/V TV Der/d V Ind Prs ConNeg &real-erret-earret) OR ("erret" Ex/V TV Der/h V VGen &real-erret-earret) OR ("erret" V TV Der/h V Imprt Sg2 &real-erret-earret) OR ("erret" Ex/V TV Der/h V Imprt ConNeg &real-erret-earret) OR ("erret" Ex/V TV Der/h V Ind Prs ConNeg &real-erret-earret) TARGET (&real-erret-earret) ;
    # in errors.xml
    
    
