	#!! ## moadde kerdi > moddii

ADD:xmsyn-num_geardde-Ill (&msyn-num_geardde-Ill) TARGET (Num Sg Nom) OR (Num Sg Gen) OR (Num Sg Ill Attr) OR (Num Sg Loc Attr) OR ("galle" Adv) IF (1 ("geardi" N Sg Gen Allegro) OR ("geardde" Adv) LINK NEGATE 1 ("eanet" Adv) OR ("eambbo") OR Der/Comp)
(0 ("okta") OR ("guokte") OR ("golbma") OR ("njeallje") OR ("vihtta") OR ("guhtta") OR ("moadde") OR ("galle") OR ("mÃĄÅga"));
	#$ RÃĄÄÄehusa ÃĄigumuÅĄ lea ahte mearradoallu galgÃĄ ÅĄaddat	viÄa geardde stuorÃĄbun ovdal 2050.
	#$ Lassin oÅūÅūot buhtadusa aktiivvalaÅĄ oassÃĄlastima ovddas lÃĄvdegodde- ja dievasÄoahkkimiin, mii vÃĄstida 1,5 geardde 2.2.1 mÃĄksomeriid.
	## Juo, man galle geardde?
	## SÃĄmedikki dievasÄoahkkimat dollojuvvojit dÃĄbÃĄlaÄÄat	njealje geardde jagis.
	## DÃĄn ÃĄigge ÃĄidna sÃĄmegielat aviisa lea Norggas almmustuvvi Avvir, mii almmustuvvÃĄ guovtti geardde vahkus.

ADDRELATION (DELETE1) (Num &msyn-num_geardde-Ill) TO (1 ("geardi" N Sg Gen Allegro) OR ("geardde" Adv)) ;

COPY:xmsyn-num_geardde-Ill ("moddii" Adv SUGGEST) EXCEPT ("moadde" Pron Indef Attr &msyn-num_geardde-Ill) TARGET ("moadde" &msyn-num_geardde-Ill);
	## Bileahtaid konsertii vuvde badjel 500, mii lea guokte geardde eanet go maÅimus jagiid.

COPY:xmsyn-num_geardde-Ill ("maÅgii" Adv SUGGEST) EXCEPT ("mÃĄÅga" Pron Indef Nom &msyn-num_geardde-Ill) TARGET ("mÃĄÅga" &msyn-num_geardde-Ill);

