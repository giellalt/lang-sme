	#$ Bengtsson rĂĄÄĂĄstattai gerresiid.
	#$ Bengtsson rĂĄÄĂĄstattai daid.
	# in errors.xml
	

ADD:xreal-rĂĄÄastaddat (&real-rĂĄÄastaddat) TARGET ("rahtat" Ex/V TV Der/st Der/adda) OR ("raÄastit" Ex/V TV Der/adda) OR ("rĂĄÄistit" Ex/V IV Der/adda) IF (*0 Nom + Sem/Hum OR Nom + Sem/Mal OR Nom + Sem/Fem OR Nom + Sem/Sur OR Nom + Sem/Org OR Nom +  Pers OR Nom + Dem BARRIER GRAMCHK-S-BOUNDARY)  (NEGATE *0  Acc + Sem/Hum OR Acc + Sem/Mal OR Acc + Sem/Fem OR Acc + Sem/Sur OR Acc + PPRON-NOM-NOT-DAT OR Acc + Sem/Obj-clo OR Acc + Sem/Clth OR Acc + Sem/Clthpart BARRIER GRAMCHK-S-BOUNDARY ) ;

COPY:real-rĂĄÄastaddat ("rĂĄÄastaddat" V IV SUGGEST) EXCEPT ("raÄastit" Ex/V TV Der/adda V &real-rĂĄÄastaddat) BEFORE Ind TARGET (V &real-rĂĄÄastaddat) ;
	## Bengtsson raÄastattai visot omiid.
	#$ Bengtsson raÄastattai visot olbmuid.
	# in error.xml


	# raÄastallat vs. rĂĄÄastallat vs. rĂĄÄĂĄstallat
    # -------------------------------------------



ADD:xreal-raÄastallat (&real-raÄastallat) TARGET ("rĂĄÄastallat") OR ("rĂĄÄistit" Ex/V IV Der/alla) OR ("rĂĄÄastit" Ex/V IV Der/alla V) OR ("rĂĄhtat" Ex/V IV Der/st Ex/V Der/alla V) IF (*0 (Nom) + Sem/Hum OR (Nom) + Sem/Mal OR (Nom) + Sem/Fem OR (Nom) + Sem/Sur OR (Nom) +  Pers OR (Nom) + Dem BARRIER GRAMCHK-S-BOUNDARY)  (*0 (N Acc) BARRIER GRAMCHK-S-BOUNDARY LINK 0 BEDCLOTHES OR CLOTHES OR Sem/Clth OR Sem/Obj-clo OR ("sĂĄvdnji"))  ;

COPY:real-raÄastallat ("raÄastit" Ex/V TV Der/alla SUGGEST) EXCEPT ("rĂĄÄastallat" Ex/V IV &real-raÄastallat) OR ("rĂĄÄistit" Ex/V IV Der/alla) OR ("rĂĄÄastit" Ex/V IV Der/alla) OR ("rĂĄhtat" Ex/V IV Der/st Ex/V Der/alla) BEFORE V TARGET (V &real-raÄastallat) ;
	## Bengtsson rĂĄÄastalai sĂĄvnnjiid.
	#$ Bengtsson raÄastalai daid.
	## Bengtsson rĂĄÄĂĄstalai sĂĄvnnjiid.
	#$ Bengtsson raÄastalai gerresiid.
	# in error.xml
	
ADD:xreal-rĂĄÄastallat (&real-rĂĄÄastallat) TARGET ("rahtat" Ex/V TV Der/st Der/alla) OR ("raÄastit" Ex/V TV Der/alla) IF (*0 Nom + Sem/Hum OR Nom + Sem/Mal OR Nom + Sem/Fem OR Nom + Sem/Sur OR Nom + Sem/Org OR Nom + Pers OR Nom + Dem BARRIER GRAMCHK-S-BOUNDARY) (NEGATE *0 Acc BARRIER GRAMCHK-S-BOUNDARY LINK 0 Sem/Hum OR Sem/Mal OR Sem/Fem OR Sem/Sur OR PPRON-NOM-NOT-DAT OR BEDCLOTHES OR CLOTHES OR ("sĂĄvdnji") OR Dem) ;

COPY:real-rĂĄÄastallat ("rĂĄÄastit" Ex/V IV Der/alla SUGGEST) EXCEPT ("raÄastit" Ex/V TV Der/alla &real-rĂĄÄastallat) BEFORE V TARGET (V &real-rĂĄÄastallat) ;
	## Bengtsson raÄastalai visot omiid. 
	#$ Bengtsson raÄastalai visot olbmuid.
	# raÄastallat - sprette
	# rĂĄÄastallat (+Acc) = ville rĂ„ over noe, pĂ„stĂ„ at man eier det
	# rĂĄÄastit (+Acc) = kamuflere, tildekke, dekke)
	# rĂĄÄistit IV Der/Com (+Com+Sem/Ani)
	# rahtat+V+TV+Der/st+V+Der/alla+V+Inf
	# raÄastallat	rahtat+V+TV+Der/st+V+Der/alla+V+Ind+Prs+Pl1
	# raÄastallat	raÄastit+V+TV+Der/alla+V+Inf
	# raÄastallat	raÄastit+V+TV+Der/alla+V+Ind+Prs+Pl1
	# in error.xml

ADD:xreal-rĂĄÄĂĄstallat (&real-rĂĄÄĂĄstallat) TARGET ("rĂĄhtat" Ex/V TV Der/st Der/alla) OR ("rĂĄÄastit" Ex/V TV Der/alla) OR ("rĂĄÄastallat") OR ("rĂĄÄastit" Ex/V IV Der/alla V) OR ("rĂĄhtat" Ex/V IV Der/st Ex/V Der/alla V) IF (*0 Com + Sem/Hum OR Com + Sem/Mal OR Com + Sem/Fem OR Com + Sem/Sur OR Com + Sem/Org OR Com +  Pers OR Com + Dem BARRIER GRAMCHK-S-BOUNDARY ) ;

COPY:real-rĂĄÄĂĄstallat ("rĂĄÄistit"  SUGGEST) EXCEPT ("rĂĄÄastit" TV &real-rĂĄÄĂĄstallat) BEFORE V TARGET (V &real-rĂĄÄĂĄstallat) ;
