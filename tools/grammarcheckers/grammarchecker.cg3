(NEGATE 0 (V Sg3) LINK *-1 (N Pl Nom) LINK *-1 COPULAS LINK *-1 CS BARRIER NPNHA - @HAB - (Sem/Hum Loc) - @SUBJ>) #subclause subjects
(NEGATE 0 Inf LINK -1 SUBJ LINK -1 BECAUSE-WHEN LINK -1 <*Inf> + VFIN) #questions with auxiliaries
(NEGATE 0 Inf LINK *-1 (N Nom) -  Px - AUX OR (Pron Nom) BARRIER NOT-ADV LINK *-1 V + <*Inf> BARRIER NPNHA - ConNeg - (Imprt Sg2) - PrfPrc - ("nugo")) 
(NEGATE 0 <vdic> LINK *1 (Sem/Hum Nom Sg) BARRIER NPNHA); #speaker of the indirect clause
	## Sii boahtit skuvlii muitalit mo jienastit, ja vأ،ldin skoviid mielde go nuorat leat daid gأ،rvأ،sit deavdأ،n.
	#$ Go joatkkaoahpahuslأ،hka biddjui doibmii 1.1.1976, de galge buot ovddeإ، gymnأ،sat, fidnoskuvllat ja gأ،vpeskuvllat {gohؤچoduvvot} joatkkaskuvlan.
	#$ Dأ،vjأ، mearridit ruoإ§abeali ؤچearut guovlluid gosa lea guhkki johttit ja soamehis guohtonguovllut lohkأ، Romssa {fylkamأ،nni plأ،nadirektevre}, Per Elvestad.
	#$ Gأ،vcci jagi doarrun ieإ¾as أ،hؤچi doalu oaإ¾إ¾ut ruovttoluotta {lea} loahpahuvvon, ja dat diehttelasat أ،vvuduvvui.
	#$ Boazodoallolأ،ga evttohusastis celkkii datte riikkaadvokأ،hta Kjerschow ahte barggadettiin أ،vdnasiiguin ؤچأ،jehuvvui ahte "eai lean lأ،hkateknalaإ، dahje earأ، vأ،ttisvuoؤ‘at dahje bilideamit {goؤ‘ؤ‘it} evttohussii lasأ،husaid dahje spiehkastagaid maid Finnmأ،rkku fylkka sierralأ،gan dilأ،laإ،vuoؤ‘at gأ،ibidedje".
	## Guovddأ،إ، fأ،galaإ، fأ،ttأ،t {lea} ovdamearkka dihte joؤ‘iheapmi, ovdأ،nanpsykologiija, didaktihkka, stoahkan, oahppan, dieؤ‘alaإ، metodat, sأ،mi bajأ،sgeassin, أ،rbevirolaإ، mأ،httu, kommunikaإ،uvdna, etihkka, profeإ،uvdnamأ،httu ja nu ain.
	#$ Kvenat {lea} minoritehta Norggas, ja Norgga eisevأ،lddit leat danne geatnegahttojuvvon gأ،httet ja ovddidit kvena kultuvrra ja giela.
	## Skotstind siskkit guovllut {lea} ovdal adnon geassejagi guohtumin, muhto guovllus lea lossat johtit.
	#$ Jus atnأ، ahte lea vأ،ivi go ii ovdأ،n seamma tأ،vttas go olbmأ،t {sأ،httأ،} dovdot suohtas sأ،rdnut soapmأ،siin, skuvladivإ،إ،أ،r ovdamearkka dihte lea buorre olmmoإ، geasa jorgasit.
	#$ Ahte stأ،hta أ،mmأ،tolbmuin muhtumin lea leamaإ، veahأ، moivi ja eahpeؤچielga {gأ،ttut} ovdanboahtأ، ee. Finnmأ،rkku fأ،lddi juovlamأ،nu 20. b. 1834 ؤچأ،llagis maid Spilling geardduha s. 20:
	#$ Mu somأ،mus geassemuitu lea go mun ja mu oappأ،t {leimmet} geasseluomus Tyrkias.
	#$ Jأ،pminlihkohisvuoؤ‘at dagahan lossa morraإ،a.
	#$ Dakkأ،r bأ،ikkis gos leat ollu stuora muorat dehe beazit {lea} hui somأ، bأ،lkut muohtaؤچأ،giid. #STILL TO BE FIXED
	#$ Dأ،n geaإ¾il mii ja lأ،gideaddjit {mearrideimmet} ahte أ،igut lأ،gidit earأ،lأ،gan konseartta.
	#$ Dieؤ‘ut {lea} mأ،إ‹ggadieؤ‘alaإ، ؤچأ،la-rأ،idu, man Davviriikkaid Sأ،mi Instituhtta lea almmustahttأ،n 1974 rأ،jes.
	#$ Ii han sأ،megiella duohtavuoؤ‘as leat earأ، go bustأ،vat maid {sأ،httأ،} sأ،tnin rأ،hkadit ja sأ،niin sأ،httأ، cealkagiid rأ،hkadit.
	#$ Ovddamearkka dihte mo diehttit {mieؤ‘iha} go buohcci vai lea go son duoؤ‘aid nuppi oaivilis.
	## selvehit makkأ،r vuoigatvuoؤ‘at lea sأ،megiela hأ،rrأ،i.
	#$ Son muitala ahte sii oإ¾إ¾o hirbmat stuorra beroإ،tumi olbmuin go {beakkehii} ahte sii vuovdet sأ،mi borramuإ،a.
	## Mii sأ،httit ؤچأ،hkأ،hit unna bargguid, muhto mii fertet plأ،net guhkes أ،iggi ovdalgihtii jus {leat} sأ،valdagat mat gأ،ibidit stuora nأ،vccaid mis.
	## Sii eai leat konkluderen movtge vel, muhto sii hأ،liidat nannet servviid bأ،ikkأ،laإ، fakkiin.
	#$ Galget go sii fأ،rret gأ،vpogii vai orrut gilأ،إ¾is.
	## Dan ovddas sii ledjet sأ،dden dieؤ‘u Olmmأ،ivأ،kki ieإ¾as poastaolbmأ،, Asbjأ¸rn Solberg, mielde ahte sii eat aiggu rievdadit dأ،n أ،إ،إ،is.
	## Son ؤچأ،jehii govaid buotlأ،gan borramuإ،ain maid sii luonddus vieإ¾إ¾et.
	## Sii eai leat konkluderen movtge vel, muhto sii {hأ،liidat} nannet servviid bأ،ikkأ،laإ، fakkiin.
	#$ Vuosttaإ، vأ،ibmoأ،إ،إ،i lea sأ،mi nuoraid birra, erenomأ،إ¾it dievdduid, go vأ،sihan ahte eai oro liikkأ، viإ،إ،alat go nieiddat {gazzat} oahpu, vuoi eai go duostta geahؤچؤچalit. 

	# capital letter subject

ADD:syn-number_congruence-subj-verb (&syn-number_congruence-subj-verb) TARGET (V Ind Prs) - ConNeg OR (V Ind Prt) - ConNeg OR (V Cond) OR (V Neg Ind) IF (*-1 (Pron Sem/Hum Pers Pl3 Nom) OR (N Pl Nom) - Err/Lex BARRIER NOT-ADV-PCLE OR (Adv Subqst) OR (N Sg Loc Sem/Plc) OR CS LINK 0 ("<[A-ZؤŒإ أپ].*>"r) - Prop LINK NOT 0 (N Sg Nom) OR @COMP-CS< OR VFIN)(NEGATE 0 (Prt Sg2) - BE OR Pl3 OR (Prs Pl1) + IT-UNEVEN-VERBS - Der/adda - ("<.*at>r") OR &realآ OR (Nآ Sg) - Px OR Adv OR BE + (Prs Pl1))(NEGATE 0 PrfPrc)(*-1 (Pron Sem/Hum Pers Pl3 Nom) OR (N Pl Nom) BARRIER NOT-ADV-PCLE - (N Sg Loc Sem/Plc) OR CS LINK NOT 0 @COMP-CS< OR VFIN LINK NEGATE *-1 (Pron Sem/Hum Pers Pl1 Nom) OR (Pron Sem/Hum Pers Du1 Nom))(NEGATE 0 Sg3 LINK *-1 (N Pl Nom) + (Prop Sem/Org) OR (N Pl Nom) + (Prop Sem/Obj) OR (N Pl Nom) + (Prop Sem/Plc) BARRIER NOT-ADV-PCLE - (N Sg Loc Sem/Plc) OR CS)(NEGATE 0 Du3 LINK *1 Sem/Human BARRIER NOT-ADV-PCLE LINK 1 CC LINK 1 Sem/Human)(NEGATE 0 Adv)(NEGATE *1 (Pron Pers Sg1 Nom) BARRIER NOT-ADV-PCLE - CC - COMMA - (N Nom) - (Prop Gen) - (Prop Acc) - (Prop Attr))
(NEGATE 0 ("<.*lit>"r))
(NEGATE 0 N + Err/Orth-any) # mأ،naide
(NEGATE 0 NUMCONGR-EXCEPT) # erret
(NEGATE 0 Sg3 + COPULAS LINK *1 (N Nom Sg) + Sem/Group + Sem/Hum OR (N Nom Sg) + Sem/Rule BARRIER NPNHA - (N Acc)) # Astoأ،iggeveahkit lea buorre ortnet
(NEGATE 0 Du3 LINK *-1 Sem/Human + (N Pl Nom) OR Sem/Ani + (N Pl Nom) BARRIER NOT-ADV-PCLE)
(NEGATE 0 Du3 LINK *-1 Sem/Org + (N Pl Nom) BARRIER NOT-ADV-PCLE LINK -1 (Prop Gen) LINK -1 CC LINK -1 (Prop Gen))
(NEGATE 0 Du3 LINK *-1 Sem/Human + (N Pl Nom) OR ("bealli" N Pl Nom) BARRIER NOT-ADV-PCLE);
	## Geavahuvvon 3 270 970 ru Ohcanأ،igemearit lea guovvamأ،nu 1. b, cuoإ‹omأ،nu 1. b ja ؤچakؤچamأ،nu 1. b. ja golggotmأ،nu 25. b.
