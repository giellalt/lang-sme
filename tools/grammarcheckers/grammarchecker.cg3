LIST PLACE-V = "ĂĄssat" "buolvvastallat" "buolvvastit" "Äippostallat" "ÄohkkĂĄt" "Äohkahit" "ÄuoĆŸĆŸut" "ÄuÄÄodit" "morihit" "gohÄÄĂĄt" "gullĂĄt" "morrĂĄnit" "orrut" "orodit" "stuorrut" "veallĂĄt" "veallahit" ;
  # Those get only not locative if the target is a member TOOL, ABSTR-TOOL or ANIMATE or CONCEPT. Selects more locatives than ONLY-PLACE-LOC-V

LIST DIRECTION-V = "ÄĂĄhkat" "Äohkkedit" "gahÄahit" "mohkkasit" "velledit" "veallĂĄnit" "snugormastit"  "guossat" "guossalit" "loktanit" ;
