	## ErenoamĂĄĆŸit Guovdageainnu bargiguoktĂĄ - Elle-MĂĄrjĂĄ Vars ja Inger Margrethe Olsen - lei varra somĂĄ deaivat
	## Lea varra dĂĄrbbaĆĄlaĆĄ plĂĄnet buoret dĂĄn ĂĄigodaga.

ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (*-1 COPULAS + Sg3 BARRIER NOT-ADV-PCLE - @ADVL>)(1 Inf OR (? ".*it"r))(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen)) ;
	## Mun lĂĄvlen â Farsan â ja maiddĂĄi â Partyjoik â doppe, lei varra cajehit ahte sahtan leat hui duohtavas ja maiddĂĄi leat veahĂĄs mielaheapme.
    
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (*0 Nom BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN LINK *0 Sg3 BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN)(NEGATE *0 Sem/Body + Loc OR Sem/Body + (Sg Acc PxSg3) BARRIER GRAMCHK-S-BOUNDARY OR COMMA OR CC)(NEGATE -1 CC OR CS LINK -1 BOS LINK 3 CC LINK 1 (N Nom Sg))(NEGATE 1 Rel LINK *1 VFIN)(NEGATE -1 MO-MANge LINK 2 VFIN)(NEGATE 0 SUBJ LINK *1 Sg3 BARRIER NOT-ADV-PCLE)(NEGATE 0 SUBJ LINK *-1 ConNeg BARRIER NOT-ADV-PCLE LINK *-1 (Neg Sg3) BARRIER NOT-ADV-PCLE)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - (A Ess))(NEGATE -1 @>N LINK *-1 Sem/Body + Nom OR Sem/Aniprod + Nom BARRIER (*) - COMMA - CC - (A Ess))(NEGATE -1 (Gen @>N) + Sem/Hum OR (Gen @>N) + Sem/Ani OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Lang OR (Prop Sem/Plc Sg Gen @>N) OR (Attr @>N) OR (Pron Refl Gen) OR ("ollu") OR ("veahĂĄĆĄ"))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH)(NEGATE *-1 Sg3 BARRIER NPNHA LINK NEGATE *-1 SUBJ BARRIER NPNHA)(NEGATE -1 BECAUSE-WHEN LINK 2 EOS)(NEGATE -1 ("guhte") LINK NOT *1 VFIN)(NEGATE *0 (Ind Sg3) + VARRA-SUBJ-V BARRIER NOT-ADV-PCLE)(NEGATE 1 VARRA-COMP-N);
	#$ Triumf Äilge ahte varra gal galmmasin bissu varasin vaikko man guhkĂĄ, muhto vĂĄttisvuohta lea ahte beatnagiid galgĂĄ geasset hĂĄrjehit.
	#$ Son fuomĂĄĆĄii suorganemiin ahte lei varra mii golggai ja njuoskadii oane-bottas visot su buvssa.
	#$ Son ÄierrugoÄii ja vikkai jĂĄmalgit go dovddai movt varra golggai.
	#$ Ja de das ĂĄlgĂĄ golgat ruoÄÄi dahe varra eanet go gierdĂĄ olmmoĆĄ, ja de lea das vĂĄralaĆĄ, dainna lĂĄgiin leat olu jĂĄpmĂĄn SĂĄmis nissonat, go leat nu hĂĄrve dakkĂĄrat, geat dihtet dasa rĂĄÄi
	
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (*-1 BE + Sg3 BARRIER NPNHAPcle LINK NEGATE -1 QUANT-PRON LINK -1 ("nu") OR ("nĂĄ") OR ("nie") OR ("nuo"))(*1 THAT-CS BARRIER (*) - COMMA)(NEGATE *0 Sem/Body + Loc OR Sem/Body + (Sg Acc PxSg3) BARRIER GRAMCHK-S-BOUNDARY OR COMMA OR CC)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE -1 MO-MANge LINK 2 VFIN)(NEGATE -1 @>N LINK *-1 Sem/Body + Nom OR Sem/Aniprod + Nom BARRIER (*) - COMMA - CC - (A Ess))(NEGATE -1 (Gen @>N) + Sem/Hum OR (Gen @>N) + Sem/Ani OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen) OR ("ollu") OR ("veahĂĄĆĄ"))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH)(NEGATE -1 BECAUSE-WHEN LINK 2 EOS);
	## Lea maiddĂĄi varra ahte deattut ja deaddonorpmat navdojuvvojit leat eisevĂĄlddiid bĂĄggodoaibman, mii fas suolĂĄda fuomĂĄĆĄumi das ahte doaibma ja boazolohku lea boazoeaiggĂĄdiid ieĆŸaset ovddasvĂĄstĂĄdus.
	#$ doppe nu ollu lea varra ahteâŠ
	## Dasa lea nappo dalle dat varra, ahte ii bastte
    
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (NEGATE -1 QUANT-PRON)(*1 BE + Sg3 BARRIER NPNHAPcle LINK 1 ("nu") OR ("nĂĄ") OR ("nie") OR ("nuo") LINK 1 THAT-CS)(NEGATE *0 Sem/Body + Loc OR Sem/Body + (Sg Acc PxSg3) BARRIER GRAMCHK-S-BOUNDARY OR COMMA OR CC)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE -1 MO-MANge LINK 2 VFIN)(NEGATE -1 @>N LINK *-1 Sem/Body + Nom OR Sem/Aniprod + Nom BARRIER (*) - COMMA - CC - (A Ess))(NEGATE -1 (Gen @>N) + Sem/Hum OR (Gen @>N) + Sem/Ani OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen) OR ("ollu") OR ("veahĂĄĆĄ"))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH)(NEGATE -1 BECAUSE-WHEN LINK 2 EOS);
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (NEGATE -1 QUANT-PRON)(*1 BE + Sg3 BARRIER NPNHAPcle LINK 1 ("nu ahte"))(NEGATE *0 Sem/Body + Loc OR Sem/Body + (Sg Acc PxSg3) BARRIER GRAMCHK-S-BOUNDARY OR COMMA OR CC)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE -1 MO-MANge LINK 2 VFIN)(NEGATE -1 @>N LINK *-1 Sem/Body + Nom OR Sem/Aniprod + Nom BARRIER (*) - COMMA - CC - (A Ess))(NEGATE -1 (Gen @>N) + Sem/Hum OR (Gen @>N) + Sem/Ani OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen) OR ("ollu") OR ("veahĂĄĆĄ"))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH)(NEGATE -1 BECAUSE-WHEN LINK 2 EOS);
	## Varra lea nu ahte muhtumat bilidit buohkaid ovddas ja dat lea hui suddu.
    
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (*1 BE + Sg3 BARRIER NPNHAPcle LINK *1 THAT-CS BARRIER (*) - COMMA - Adv - Inf - PrfPrc)(NEGATE -1 QUANT-PRON LINK -1 ("nu") OR ("nĂĄ") OR ("nie") OR ("nuo")); #(NEGATE *0 Sem/Body + Loc OR Sem/Body + (Sg Acc PxSg3) BARRIER GRAMCHK-S-BOUNDARY OR COMMA OR CC)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE -1 MO-MANge LINK 2 VFIN)(NEGATE -1 @>N LINK *-1 Sem/Body + Nom OR Sem/Aniprod + Nom BARRIER (*) - COMMA - CC - (A Ess))(NEGATE -1 (Gen @>N) + Sem/Hum OR (Gen @>N) + Sem/Ani OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen) OR ("ollu") OR ("veahĂĄĆĄ"))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH)(NEGATE -1 BECAUSE-WHEN LINK 2 EOS);
	## Varra lea leamaĆĄ nu ahte sii geat eai loggon darffi, veahkahalle earĂĄ bargguiguin.
    
	# vĂĄrra N
	
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (-1 ("stuoris" Attr)) ;	
	## DĂĄkkĂĄr dĂĄlkkĂĄdagat dagahit riddoorohagaide vĂĄttisvuoÄaid, nu movt Gielas ja StĂĄlonjĂĄrga Romssa fylkkas, gos lea stuorit {varra} lĂĄsset guohtumiid go HelgelĂĄndda olggut guovlluin. 
	#$ Wayne Anthoney manus lea earĂĄlĂĄgĂĄn go klassihkkalaĆĄ Macbeth, ii leat {unnit} varra gal, muhto lea mihĂĄ suohttaseabbo. 
    
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (1 THAT-CS) (-1 BE LINK NEGATE -1 QUANT-PRON LINK -1 ("nu") OR ("nĂĄ") OR ("nie") OR ("nuo"))(*1 THAT-CS BARRIER (*) - COMMA) ;	
	## Guovllut leat gĂĄrĆŸĆŸit, ja danne leage varra ahte maiddĂĄi earĂĄ guovllut guoÄohuvvojit.
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (1 BE LINK 1 THAT-CS) ;
    
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (*-1 (Pron Sem/Hum Pers Pl1 Nom) OR (Pron Sem/Hum Pers Pl3 Nom) OR BOS BARRIER NOT-ADV-PCLE)(1 BE + Inf)(NEGATE *0 Sem/Body + Loc OR Sem/Body + (Sg Acc PxSg3) BARRIER GRAMCHK-S-BOUNDARY OR COMMA OR CC)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE -1 MO-MANge LINK 2 VFIN)(NEGATE -1 @>N LINK *-1 Sem/Body + Nom OR Sem/Aniprod + Nom BARRIER (*) - COMMA - CC - (A Ess))(NEGATE -1 (Gen @>N) + Sem/Hum OR (Gen @>N) + Sem/Ani OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen) OR ("ollu") OR ("veahĂĄĆĄ"))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH)(NEGATE -1 BECAUSE-WHEN LINK 2 EOS);
	## SĂĄmegiela dĂĄfus vuosttasgieallan, de fĂĄgalaĆĄ analysajoavku Äujuha dasa ahte mii {varra} leat juksamin daid oahppiid bajimuĆĄ logu guÄet sĂĄhttet vĂĄlljet sĂĄmegiela vuosttasgiellan otnĂĄĆĄ fĂĄlaldagaid ja ortnegiid mielde. 

	
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (-1 NOT-V + Ind LINK NEGATE *-1 (N Nom) BARRIER NOT-ADV-PCLE LINK *-1 ("ii" Ind Sg3) BARRIER NOT-ADV-PCLE - ConNeg)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE *1 VARRA-SUBJ-V + ConNeg)(NEGATE *1 ConNeg + <Inf> BARRIER NOT-ADV-PCLE LINK 1 VARRA-SUBJ-V + Inf); 
	## Ja go jurddaĆĄa maid sii leat vĂĄsihan, dat gal ii varra leat nu imaĆĄ
	#$ Dasgo dan ii leat oaĆŸĆŸi iige varra almmustahttĂĄn dutnje, muhte mu ĂhÄÄi almmis.
	#$ Dat gal lea buorre dĂĄlkkas, dat gal ii varra beasa golgat ja dat ĂĄlgĂĄ savvot
    
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (*1 NON-VARRA-SUBJ-V + (Ind Sg3) OR NON-VARRA-SUBJ-V + (Ind Pl3) BARRIER NOT-ADV-PCLE - ConNeg)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE *1 VARRA-SUBJ-V + ConNeg)(NEGATE *1 ConNeg + <Inf> BARRIER NOT-ADV-PCLE LINK 1 VARRA-SUBJ-V + Inf)(NEGATE -1  VARRA-ATTR-A);	
	## Varra jĂĄhkii ahte mun lea gilvaleaddji sus.
	#$ gillon varra gĂĄvdnĂĄ johtolaga
    
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (1 Adv OR Pcle LINK 1 Adv OR Pcle LINK *1 NON-VARRA-SUBJ-V + (Ind Sg3) OR NON-VARRA-SUBJ-V + (Ind Pl3) BARRIER NOT-ADV-PCLE - ConNeg)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE *1 VARRA-SUBJ-V + ConNeg)(NEGATE *1 ConNeg + <Inf> BARRIER NOT-ADV-PCLE LINK 1 VARRA-SUBJ-V + Inf);	
	## Varra dalle maid gĂĄvdnet sivaid manne bargit eai biso teĂĄhteris?
	
