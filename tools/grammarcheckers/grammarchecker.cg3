	# -ccii vs. -zzi
	# --------------
LIST ZZ-VERBS = (".*zzit"r V) ;

#DELETE SECOND ROUND

ADD:xreal-vĂĄzzi-vĂĄccii (&real-vĂĄzzi-vĂĄccii) TARGET ZZ-VERBS IF (0 (Ex/V Ex/IV Der/NomAg N Sg Acc) OR (Ex/V Ex/IV Der/NomAg N Sg Gen) OR (Ex/V Ex/IV Der/NomAg N Sg Nom))(NEGATE *0 VFIN BARRIER GRAMCHK-S-BOUNDARY) ;
COPY:syn-ccii-not-zzi (V IV Ind Prt Sg3 SUGGEST) EXCEPT (Ex/V Ex/IV Der/NomAg N Sg Acc &real-vĂĄzzi-vĂĄccii) OR (Ex/V Ex/IV Der/NomAg N Sg Gen &real-vĂĄzzi-vĂĄccii) OR (Ex/V Ex/IV Der/NomAg N Sg Nom &real-vĂĄzzi-vĂĄccii) TARGET (&real-vĂĄzzi-vĂĄccii) ;
	## ???leago seammĂĄ go vĂĄccii?

ADD:xreal-vĂĄzzi-vĂĄccii (&real-vĂĄzzi-vĂĄccii) TARGET ("vĂĄzzi" A Sg Nom) OR ("vĂĄzzi" A Sg Gen) OR ("vĂĄzzi" A Sg Acc) OR ("vĂĄzzi" N NomAg Sg Nom) OR ("vĂĄzzi" N NomAg Sg Acc) OR ("vĂĄzzi" N NomAg Sg Gen) IF (NEGATE *0 VFIN BARRIER GRAMCHK-S-BOUNDARY) ;
ADD:xreal-vĂĄzzi-vĂĄccii (&real-vĂĄzzi-vĂĄccii) TARGET ("vĂĄzzi" A Sg Nom) OR ("vĂĄzzi" A Sg Gen) OR ("vĂĄzzi" A Sg Acc) OR ("vĂĄzzi" N NomAg Sg Nom) OR ("vĂĄzzi" N NomAg Sg Acc) OR ("vĂĄzzi" N NomAg Sg Gen) IF (*-1 Nom + Sem/Hum OR Nom + Sem/Org OR Sem/Sur OR Sem/Fem OR Sem/Mal BARRIER GRAMCHK-S-BOUNDARY) ;
COPY:real-vĂĄzzi-vĂĄccii ("vĂĄzzit" V IV Ind Prt Sg3 SUGGEST) EXCEPT ("vĂĄzzi" A Sg Nom &real-vĂĄzzi-vĂĄccii) OR ("vĂĄzzi" A Sg Gen &real-vĂĄzzi-vĂĄccii) OR ("vĂĄzzi" A Sg Acc &real-vĂĄzzi-vĂĄccii) OR ("vĂĄzzi" N NomAg Sg Nom &real-vĂĄzzi-vĂĄccii) OR ("vĂĄzzi" N NomAg Sg Acc &real-vĂĄzzi-vĂĄccii) OR ("vĂĄzzi" N NomAg Sg Gen &real-vĂĄzzi-vĂĄccii) TARGET (&real-vĂĄzzi-vĂĄccii) ;
	## Gaup vĂĄzzi  neavttĂĄrskuvlla StĂĄda TeĂĄhterallaskuvllas, ja eksĂĄmena vĂĄlddii 1978:is.
	# in errors.xml
	
	# ga (Prt Du3) vs. ba (Foc/ba)
    # ----------------------------

ADD:xmsyn-ba-ga (&msyn-ba-ga) TARGET (Ind Prt Du3 Err/Orth) IF (*0 (Pron Du3 Nom) OR (N Nom) BARRIER GRAMCHK-S-BOUNDARY)(0 Foc/ba) ;

COPY:msyn-ba-ga (SUGGEST) EXCEPT (Err/Orth &msyn-ba-ga) TARGET (V &msyn-ba-ga) ;
	## JoÄiheaddji guovttosges oaÄÄuiba jo ĂĄnsoruossa, mii lea ÄuovvovaĆĄ ĂĄnsu maĆĆĂĄ gollemedĂĄlja.
	## Guokte Budejju nisu leigga rĂĄhkadan vĂĄimmu suinniiguin ja rĂĄsiiguin man siste soai ÄohkkĂĄiba ja nĂĄvddaĆĄeigga iÄitborramuĆĄa.
	## Jienasteddjiide sĂĄhttĂĄ ĆĄaddat vĂĄttis ĂĄddet, mo olgeĆĄ- ja ovddĂĄdusbellodat sĂĄhtiba ovddidit oktasaĆĄ sĂĄmepolitihkka  jus dĂĄt bellodagat fidnejit rĂĄÄÄehus vĂĄlddi boahtte ÄavÄÄa Stuorradikke vĂĄlggain.
	#$ Jienasteddjiide sĂĄhttĂĄ ĆĄaddat vĂĄttis ĂĄddet, mo olgeĆĄ- ja ovddĂĄdusbellodat sĂĄhtiba ovddidit oktasaĆĄ sĂĄmepolitihkka  jus dĂĄt bellodagat fidnejit rĂĄÄÄehus vĂĄlddi boahtte ÄavÄÄa Stuorradikke vĂĄlggain.
	## Son gohÄui ÄĂĄhcegoaivu maid veahkkin doallat, ja soai jotkkiiba bĂĄtti nu guhkĂĄs go sĂĄhtiiga. 
	## OlmmĂĄi ÄĂĄjehii bĂĄhppii Äuvges ja sevdnjes bĂĄikkiid, ja go lei geargan ÄĂĄjeheames de soai galggaiba boradit. 
	## SpiidnegolgodĂĄvda panihkka Dan maid soai bijaiba erenomĂĄĆŸit merkii lei man stuorra stuibmi lei KĂĄrĂĄĆĄjoga SĂĄmi Radio redakĆĄuvnnas go spiidnegolgodĂĄvda lea boahtĂĄn FinnmĂĄrkui.
	## LĂĄbĂĄn guoimmastalai ieĆŸĂĄ burrain : jus soai oaĆŸĆŸuba ĂnnĂĄ akto doaresbeallĂĄi omd. girkogĂĄrddi duohkĂĄi , de 	soai galgĂĄba 	gĂĄvudit ja guldalit leĆŸĆŸet go das siehppagat vai leĆĄ go duĆĄĆĄe hinci .
