	##  Jus eat livÄÄe sirdit mearkka vulosguvlui, de guovllu 25:s illĂĄ livÄÄii bivdoguovlu oarjjabeal-deanu, ja dat varra livÄÄii menddo vuoigatmeahttun, Äilge Rollstad.
	## Otne varra ii leat nu somĂĄ leat eret Deanus, ja mii journalisttat fertet vĂĄldit olu dasa siva, dajai son Äujuhettiin ahte varra lea leamaĆĄ menddo olu negatiiva media beroĆĄtupmi gildii.
    
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (*-1 (Sg3 Loc) + Sem/Human BARRIER NOT-ADV-PCLE LINK *-1 COPULAS + Sg3 OR ("ii" Sg3) BARRIER NOT-ADV-PCLE)(*1 (Sg Nom @<SPRED) BARRIER NPNHA - ConNeg)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE *1 VARRA-SUBJ-V + ConNeg)(NEGATE *1 ConNeg + <Inf> BARRIER NOT-ADV-PCLE LINK 1 VARRA-SUBJ-V + Inf);
	## OvllĂĄ muitala ahte sin ruovttus eai atnĂĄn juoigama suddun, ja danne leage sus varra nu buorre dovdu go juoigĂĄ.

ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (*1 (Sg3 Loc) + Sem/Human OR (N Loc) + Sem/Human BARRIER NOT-ADV-PCLE - @>N LINK *1 COPULAS + Sg3 OR ("ii" Sg3) BARRIER NOT-ADV-PCLE LINK *1 (Sg Nom @<SPRED) BARRIER NPNHA - ConNeg)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE *1 VARRA-SUBJ-V + ConNeg)(NEGATE *1 ConNeg + <Inf> BARRIER NOT-ADV-PCLE LINK 1 VARRA-SUBJ-V + Inf);
	## MuittĂĄn oktii go muhtin inspektevra boÄii mu lusa ja logai ahte varra dan oahppis ii lean vuoigatvuohta sĂĄmegieloahpahussii, de vĂĄstidin duĆĄĆĄe

    
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (*-1 COPULAS + Sg3 OR ("ii" Sg3) BARRIER NOT-ADV-PCLE - ConNeg)(*1 NON-VARRA-SPRED-A + (A Sg Nom) BARRIER NOT-ADV-PCLE)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE *1 VARRA-SUBJ-V + ConNeg)(NEGATE *1 ConNeg + <Inf> BARRIER NOT-ADV-PCLE LINK 1 VARRA-SUBJ-V + Inf);
