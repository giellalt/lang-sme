#DELETEآ SECONDآ ROUND

ADD:xmsyn-sgloc-attr (&msyn-sgloc-attr) TARGET (A Sg Loc) OR (N Sg Loc) IF (0 IS-ES-A OR IS-A-A OR IS-AS-A)(NEGATE 0 ("guovddأ،إ،") LINK *1 (N Loc))(*1 N BARRIER NPNH)(NEGATE 0 (N Ess)) ; #2ndround
	#$ Sأ،B evttohus duste ollislaإ،vuoؤ‘a olbmo eallimis, gos mii dأ،httot nannet doaimmaid sihke mأ،nأ،id, nuoraid ja vuorrasiid vأ،ras, dasa lassin lea vel giella أ،إ‹giruإ،إ،an guovddأ،إ¾is min evttohusas.
   ## Snoranuohtti lea gehppes ja أ،lkis veahkkeneavvu.
   ## Riehpponjohka lea ؤچأ،jehuvvon dأ،s ovdamearkan danin go doppe leat eanemus soahpameahttunvuoؤ‘at leamaإ،, muhto maiddأ،i danin go lea أ،lkis ipmirdahtti duogأ،إ، dأ،kkأ،r soahpameahttunvuoؤ‘aide.
   ## Kulturlأ،gain lea dehأ،laإ، ؤچuokkis Soria Moria-cealkأ،muإ،as ؤچaؤ‘ahuvvon, mas lea deattuhuvvon ahte rأ،ؤ‘ؤ‘ehus hأ،liida vأ،ldit atnui أ،lkis, dأ،bأ،laإ، kulturlأ،ga mas boahtأ، ovdan ahte almmolaإ، eisevأ،lddiin lea kultursuorgأ،i ovddasvأ،stأ،dus.
   ## Dأ،n kurssa fokus Dأ،n kurssa ulbmil lea ؤچalmmustahttit, ؤچأ،jehit ja oahpahit nuoraide ahte gأ،vdnojit أ،lkis, hأ،lbbes ja joؤ‘أ،nis biepmut earret go nu gohؤچoduvvon
   ## Stuorimus erohus doaibmavugiid gaskka lea doaluin mat dأ،lvet guoؤ‘ohit siseatnamis, ja doaluin mat dأ،lvet atnet oarjjabeale riddoeatnamiid {goavis} dأ،lkkأ،dat guovlluin.
   ## Bأ،ktenjuohtan lea hui {raإ،is} kulturmuitu, maid sأ،httأ، vahأ،guhttit viivvuhis johtolagain guovllus, ja dakkaviؤ‘e nannejuvvui ja viiddiduvvui dat sأ،vzaأ،idi mii lea rأ،hkaduvvon rأ،ddjet viivvuhis johtolaga. 
   ## Sأ،mi searvvuإ،vuogأ،dagas eai leat أ،rbevirolaؤچؤچat {ؤچavgadis} sohkabeliid mielde juhkkojuvvon barggut dahje أ،rvuؤچeahkkأ،las. 
   ## Sأ،meradio teaksta TV آ« s 11.12.98 lei ؤچuovvovaإ، ipmirmeahttumis kompromissa hأ،stalus Ole Henrik Maggas ؤچأ،ziid- ja eananvuoigatvuhtii: آ«Mun vأ،ivivuoؤ‘ain dieؤ‘أ،n ahte sأ،mit sأ،httet إ،addat hilgut sأ،miid vuoigatvuoؤ‘aid Finnmأ،rkku rittuinآ».
   ## â€“ Lأ،vlagis leat jaskadis oasit ja eanet rocka oasit. 
   ## Odne vurkejit divrasis sأ،mi dأ،idaga heajos lanjain, ja mii bأ،llat ahte oasit das sأ،httet billaإ،uvvat. 
	 
ADD:xmsyn-sgloc-attr (&msyn-sgloc-attr) TARGET (A Sg Loc) IF (0 IS-ES-A OR IS-A-A)(1 COMMA OR CC LINK 1 Attr); 
   ## Fitnodaga ulbmil lea ordnet buot gأ،rvvisin أ،lkis, aktiivvalaإ،, buotlأ،gan ja luonddu ustitlaإ، olgoأ،immu eallima - ja sihkkarastit olgoأ،immu luonddu ja kulturvuoؤ‘u.
COPY:msyn-sgloc-attr (Attr SUGGEST) EXCEPT (Sg Loc &msyn-sgloc-attr) TARGET (A &msyn-sgloc-attr) ;     
    
