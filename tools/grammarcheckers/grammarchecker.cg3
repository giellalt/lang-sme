	# passive Prt Sg3 - active Prt Sg3
	# --------------------------------

ADD:syn-PassPrtSg3-PrtSg3 (&syn-PassPrtSg3-PrtSg3) TARGET (Der/PassS IV Ind Prt Sg3) + UT-VERBS IF (0 Ex/IV)(*-1 (Pron Sem/Hum Sg Nom) OR (N Sem/Hum Sg Nom) OR (Pron Pers Sg3 Nom));
	## Maإ‹إ‹el go vأ،lgabohtosat ؤچilge, de lea son gأ،rtan viؤ‘at sadjأ،i Ellen Inga O. Hأ¦tta maإ‹أ،beallai, gii gal baicca {gizzui} ollu go oaؤچؤچui liigejienaid.

COPY:syn-PassPrtSg3-PrtSg3 (SUGGEST) EXCEPT (Ex/V Ex/IV  Der/PassS &syn-PassPrtSg3-PrtSg3) TARGET (&syn-PassPrtSg3-PrtSg3) ;

	# passive Prs Pl1 - active Prs Pl1
	# --------------------------------

ADD:syn-PassPrsPl1-PrtPl1 (&syn-PassPrsPl1-PrtPl1) TARGET (Der/PassS Ind Prs Pl1) + UT-VERBS IF (*-1 (Pron Pers Pl1 Nom) BARRIER NOT-ADV-PCLE);
	##  Go mii {ؤچurvot} nuoraide de galge vأ،stidit.

COPY:syn-PassPrsPl1-PrtPl1 (TV SUGGEST) EXCEPT (Ex/V Ex/TV Der/PassS IV &syn-PassPrsPl1-PrtPl1) AFTER V TARGET (&syn-PassPrsPl1-PrtPl1) ;


	# soaitit + inf or PrcPrf
	# -----------------------

ADD:syn-inf-after-soaitit (&syn-inf-after-soaitit) TARGET GRAMCHK-VFIN IF (*-1 SOAITIT BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN OR FMAINV OR CLB OR Inf OR CC)(NOT 0 Inf OR PrfPrc OR Pl3-INF-V + (Ind Prs Pl3) OR (Ind Prs Pl1) OR Pl3-INF-V + (Ind Prt Sg2))(NEGATE 0 MOVEMENT-V LINK 0 VGen OR (Imprt Sg2) OR (ConNeg))(NEGATE 0 Adv LINK 1 Adv)(NEGATE 0 Neg);
	#$ Muhtun dأ،hpأ،husain sأ،httet maiddأ،i bأ،ikkأ،laإ، dilأ،laإ،vuoؤ‘at lea dakkأ،rat, ahte stuorأ،t skuvla sأ،htأ،إ،ii addit buoret fأ،laldaga sأ،megielas.
	#$ sأ،httأ، ja dأ،httu bargat ovttas nuppiiguin, geas lea buorre miella ja liikojit ovttas bargat
	
COPY:syn-inf-after-soaitit (Inf SUGGEST) EXCEPT (Ind Prs Sg1) OR (Ind Prs Sg2) OR (Ind Prs Sg3) OR (Ind Prs Du1) OR (Ind Prs Du2) OR (Ind Prs Du3) OR (Ind Prs Pl1) OR (Ind Prs Pl2) OR (Ind Prs Pl3) OR (Imprt Pl2) TARGET (Prs &syn-inf-after-soaitit) OR (Imprt &syn-inf-after-soaitit)(NEGATE 0 BE + (Ind Prs Sg1) LINK NEGATE *-1 ("mun"))(NEGATE 0 SOAITIT) ;
COPY:syn-inf-after-soaitit (Prt ConNeg SUGGEST) EXCEPT (Ind Prt Sg1) OR (Ind Prt Sg2) OR (Ind Prt Sg3) OR (Ind Prt Du1) OR (Ind Prt Du2) OR (Ind Prt Du3) OR (Ind Prt Pl1) OR (Ind Prt Pl2) OR (Ind Prt Pl3) TARGET (Prt &syn-inf-after-soaitit) (NEGATE 0 SOAITIT) ;
COPY:syn-inf-after-soaitit (PrfPrc SUGGEST) EXCEPT (Ind Prs Sg1) TARGET BE + (Ind Prs Sg1 &syn-inf-after-soaitit)(NEGATE *-1 ("mun"))(NEGATE 0 SOAITIT) ;
	#$ Dat soittii ge {lean} juste eatni ja أ،hؤچi sivva! # Ritva should it be leamaإ، instead of lean??
	## Boahtte hأ،ve soaittأ،n vأ،lddأ،n govven- dahje filbmenbarggu. Boahtte hأ،ve soaittأ،n vأ،ldit/vأ،ldأ،n govven- dahje filbmenbarggu.
	#TEST
	#$ Eai duإ،إ،e olggosoaidnit rأ،hkadettiin, muhto maiddai ؤچأ،cis ii galgan ؤچohkamis oaidnit goal lea ealli loddi ja goal lea ؤچohkanloddi, dahje hأ،pma nu go muhtimat dadjet.
	## Dأ،t lea smأ،vit mأ،nأ،ide rأ،hkaduvvon, danne leat dأ،s lأ،vlagat maidda mأ،nأ،t sأ،httet doaإ،kkut  gieؤ‘aid, ja maiddai  leat das lأ،vlagat maidda mأ،nأ،t sأ،httet lihkadit go gullet lأ،vlagiid.
	#$ Ferten jأ،pmأ،n أ،hkuid ja أ،djأ،id geavahit gaskaoapmin vai beasan jienastit Sأ،mediggأ،i, jearrأ، Jorunn. 
	# in errors.xml
	
ADD:syn-inf-after-soaitit (&syn-inf-after-soaitit) TARGET SOAITIT IF (*1 &syn-inf-after-soaitit BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN OR FMAINV OR CLB OR Inf OR CC);

ADDRELATION (LEFT) (&syn-inf-after-soaitit) - SOAITIT TO (*-1 &syn-inf-after-soaitit + SOAITIT) ;
	
    # attribute vs. predicative adjective 
    # -----------------------------------
    # D: gأ،rzzidit njuolggadusa roavis-roaves -lأ،gأ،n pأ،raide (ja soames iezأ، nai), maid olbmot lأ،vejit cأ،llit vearrut?
LIST MODALS = "leat" "إ،addat" "fertet" "galgat" "dأ،idit" "soaitit" "veadjit" "أ،igut" "mأ،httit" "oaإ¾إ¾ut" "sأ،httit" "berret" ;



ADD:xmsyn-attr-not-pred (&msyn-attr-not-pred) TARGET A - Loc - Acc IF (NOT 0 Attr OR (N Gen) OR ABBR OR @<SPRED LINK NEGATE 0 (Sg Nom) LINK 0 ADJ_ATTR/NOM OR Comp OR Superl)(*1 CNOUN OR A BARRIER NOT-ADJ-CC OR BECAUSE-WHEN LINK NOT 0 PrfPrc)(NEGATE 1 COMMA)(NOT 1 Rel) (NEGATE 0 CONGRUENCE-A OR ("riekta") OR ("duoؤ‘as") OR Ord - ("nubbi")) (NEGATE *0 MODALS BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN OR Rel) (NEGATE 0 A LINK 1 COMMA OR CC LINK NOT 1 Attr OR Gen)(NEGATE 1 CC LINK 1 Gen LINK 1 Po) (NEGATE 0 Ess LINK NOT *0 GRAMCHK-VFIN BARRIER GRAMCHK-S-BOUNDARY OR CLB)(NEGATE 0 Superl LINK 0 (Adv Superl))(NEGATE 0 Attr LINK NOT 0 Attr)(NEGATE 1 EOS)(NEGATE 0 (N Sg Ill) OR Adv)(NEGATE 0 <TH-Inf> LINK *1 Inf BARRIER NOT-ADV - ADVLCASE)(NEGATE 0 (A Sem/Hum Pl Gen))(NEGATE 0 (A Sg Acc) OR <AttrPred>);
	#$ Dأ،kkأ،r toponymalaإ، seaguhemiin أ،sahuvvui gielalaإ، nammamأ،lle mas nammaoasit seaguhuvvojedje giellarأ،jiid rastأ، nu ahte primأ،ra bأ،ikenamma lei sأ،megillii muhto dأ،rogiela ovdamerrosa {lasihemiin} sأ،mi namma sirdojuvvui maiddأ،i dأ،rogiela adnui.
	#$ Eat illut vuos, eisevأ،lddit leat ovdal lohpidan midjiide buhtadusa, ja leat alu beahtahallan, lohke sأ،mi {oahppovأ،illagiid} searvvi ovddasteaddjit maإ‹إ‹أ، ؤچoahkkima Norgga justiisaministariin mannan gaskavahku.
    #$ Dأ،id dihte ferte jأ،hkkit ahte Guovdageainnu suohkanii orro eanemus {أ،vkkأ،laإ،} ovttasbargat Vest-Finnmark Regionrأ¥d guvlui, vaikko Stأ،da ja Finnmأ،rkku fylkkagielda ovdal leat defineren Guovdageainnu oassin Sis-Finnmأ،rkku Guovllus.
   #$ أپsodagain ja rأ،idoviesuin jأ،vkأ، eanemus {liekkas} robi ja lovtta bokte.
	#$ Govva lea oainnأ،t mihأ، eambbo ivdnأ،i go dat maid son oaidnأ،.
    # Dat rieban maid mii lأ،vet hأ،rdit, lea boares, ؤچalmmehis - muhto hui {belljes} rieban mii orru duos Riebanvأ،ris, ؤچilgii Vilge.
    #$ Su musihkka lea poehtalaإ، ja das lea roavis harmoniija. - example does not work because of dis: "roavvi" Sem/Plc N Sg Gen PxSg3 is choosen instead of the adjective reading
    #$ Kulturbأ،lkkaإ،upmi geigejuvvo Kirstti Palttoi maإ‹إ‹eleappos أ،lggogeasis.
    #$ lohkanloatna sأ،httأ، unnut eanemusat kr. 16 500 jahkأ،i
    #$ Mas dovvdat erehusa goal lea Guovdageaidnulaإ، gii lea riegأ،dan ja bajasإ،addan Guovdageainnus ja goal lea sisafأ،rrejeaddji.
    #$ Oؤ‘ؤ‘a studeanttaide fأ،ttarortnetveahkki ja doarjja go lea amas ja oؤ‘as bأ،ikأ،i.  
    #$ Go buot bivdoأ،vdnasat leat gأ،rvأ،sat, ii leat go vuorddaإ،it goas ja gokko buorre loddensuddi إ،adda.
    #$ Son lea ieإ، nai mأ،إ‹gga hأ،ve beahtahallan go lea bivdأ،n veahki, ja أ،vإ¾إ¾uha danin suohkana dأ،l duoؤ‘as nissonأ،إ،إ،iid bearrأ،igeahؤچؤچagoahtit.
    # in errors.xml
  
ADD:xmsyn-attr-not-pred (&msyn-attr-not-pred) TARGET (A) IF (NOT 0 Attr OR Gen OR @<SPRED OR ABBR LINK NOT 0 (Sg Nom) LINK 0 ADJ_ATTR/NOM OR Comp OR Superl LINK 0 (Sg Nom) LINK *1 CNOUN OR A BARRIER GRAMCHK-NPNH)(NOT 1 Rel) (NEGATE 0 CONGRUENCE-A OR ("riekta") OR Ord - ("nubbi"))(NEGATE *0 MODALS BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN) (NEGATE 0 A LINK 1 COMMA OR CC LINK NOT 1 Attr OR Gen)(NEGATE 0 (N Sg Ill) OR Adv OR <AttrPred>) ;
     #D!
	#$Seamma lea maiddai maإ‹emus maid dahkkأ، ovddal mannأ، fas sisa vissui.
    #$ Go buot bivdoأ،vdnasat leat gأ،rvأ،sat, ii leat go vuorddaإ،it goas ja gokko buorre loddensuddi إ،adda.
  
ADD:xmsyn-attr-not-pred (&msyn-attr-not-pred) TARGET (A Sg) IF (NOT 0 Attr OR Gen OR ABBR OR @<SPRED LINK NOT 0 (Sg Nom) LINK 0 ADJ_ATTR/NOM OR Comp OR Superl LINK 1 COMMA OR CC LINK *1 CNOUN OR A BARRIER GRAMCHK-NPNHA)(NOT 1 Rel)  (NEGATE 0 CONGRUENCE-A OR Ord - ("nubbi") OR (Adv Sem/Time)) (NEGATE *0 MODALS BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN) (NEGATE 0 A LINK 1 COMMA OR CC LINK NOT 1 Attr OR Gen)(NEGATE 0 (N Sg Ill) OR Adv OR <AttrPred>) ; 
     #D!
     #$ Nils Einar Samuelsen gullأ، DAN eanemus konservatiiva {suorgأ،i} dain mأ،إ‹gga lestadiأ،nalaإ، surggiin.
     #$ Lars Heaika geavai {maإ‹emuإ¾إ¾ii}, logat sadjأ،i dأ،n beaivve.
COPY:attr-not-pred (Attr SUGGEST) EXCEPT (Sg Pl Nom &msyn-attr-not-pred) OR (Sg Gen Err/Orth-nom-gen &msyn-attr-not-pred) OR (Sg Nom &msyn-attr-not-pred) AFTER A TARGET (&msyn-attr-not-pred) ;
	#$ Suoma sأ،miid guovddأ،إ،searvvis gal lea diehtu das, ahte gal sأ،pmelaؤچؤچat hأ،leإ،tit sأ،meأ،إ،إ،iin viإ،إ،alit, nu Sأ،medikki vejolaإ،vuoؤ‘ain, dan doaibmavugiin, go maiddأ،i muhtun أ،إ،إ،iid serviid ؤچoahkkimiin, earأ، ؤچoahkkanemiin jnv.
