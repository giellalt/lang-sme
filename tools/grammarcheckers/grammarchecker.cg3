LIST CONC-4B = (".*ؤ‘bm.*"r) (".*ؤ‘gإ‹.*"r) (".*ibm.*"r) (".*idn.*"r) (".*igإ‹.*"r) (".*lbm.*"r) (".*ldn.*"r) (".*lgإ‹.*"r) (".*vdn.*"r) ;
