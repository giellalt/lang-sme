ADD:syn-number_congruence-subj-verb (&syn-number_congruence-subj-verb) TARGET (V Ind Prs) - ConNeg OR (V Ind Prt) - ConNeg OR (V Cond) OR (V Neg Ind) OR IT-EVEN-VERBS + Inf OR UT-VERBS + VFIN IF
(*-1 (Pron Sem/Hum Pers Pl3 Nom) OR (N Pl Nom) - Err/Lex BARRIER NOT-ADV-PCLE OR (Adv Subqst) OR (N Sg Loc Sem/Plc) OR CS LINK NOT 0 @COMP-CS< OR VFIN OR Inf OR Adv OR &real OR Loc OR (Nom PxSg2) + Sem/Hum OR (Der/NomAg N Pl Nom) + IT-EVEN-VERBS OR (N Sg Nom) - Px LINK *-1 BOS OR (":") OR (";") OR ("/") OR ("â€¹") OR ("â€“") OR COMMA OR CS - ("earأ، go") - SUCH-AS OR CC OR (Adv Subqst) OR (Pron Rel) OR (N Loc) OR Interr BARRIER NOT-ADV-PCLE - Attr - @>N - ("guovdi" Der/Dimin) - ("guovddأ،إ،") - (Prop N Sg Nom) - @ADVL> - Gen - Acc OR (Pron Sem/Hum Pers Pl1 Nom) OR (Pron Sem/Hum Pers Du1 Nom) LINK NOT *-1 ("seammأ،"))
(NEGATE 0 (Sg Ill)) # ؤچigإ‹أ،i
(NEGATE 0 ("<.*lit>"r))
(NEGATE 0 N + Err/Orth-any) # mأ،naide
(NEGATE 0 NUMCONGR-EXCEPT)  # erret
(NEGATE 0 (Prt Sg2) - BE OR Pl3 OR (Prs Pl1) - ("<.*at>r") + IT-UNEVEN-VERBS - Der/adda OR (Cond Prs Sg2) + AT-VERBS OR &realآ OR (Nآ Sg) - Px OR Adv)(NEGATE 0 PrfPrc OR BE + (Prs Pl3) OR BE + (Prs Pl1) OR BE + (Prs Sg2))(NEGATE 0 Inf OR (V Pl1) LINK -1 <TH-Inf> OR <*Inf>)
(NEGATE 0 Inf OR (V Pl1) LINK -1 SUBJ OR (N Nom) LINK *-1 <*Inf> + VFIN BARRIER NPNHA - SUBJ - CC)
(NEGATE 0 Inf OR (V Pl1) LINK -1 SUBJ OR (N Nom) LINK *-1 CC BARRIER NPNHA - SUBJ LINK -1 SUBJ OR (N Nom) LINK *-1 <*Inf> + VFIN BARRIER NPNHA - SUBJ)
(NEGATE 0 Inf OR (V Pl1) LINK -1 SUBJ OR (N Nom) LINK *-1 CC BARRIER NPNHA - SUBJ LINK -1 SUBJ OR (N Nom) LINK *-1 CC OR COMMA BARRIER NPNHA - SUBJ LINK -1 SUBJ OR (N Nom) LINK *-1 <*Inf> + VFIN BARRIER NPNHA - SUBJ)
(NEGATE 0 Sg3 LINK *-1 (N Pl Nom) + (Prop Sem/Org) OR (N Pl Nom) + (Prop Sem/Obj) OR (N Pl Nom) + (Prop Sem/Plc) BARRIER NOT-ADV-PCLE - (N Sg Loc Sem/Plc) OR CS)(NEGATE 0 Adv)
(NEGATE 0 Sg3 LINK *1 (N Sg Nom) BARRIER (*) - Attr - (A Sg Loc) LINK NOT 0 PrfPrc OR Px LINK NEGATE 1 CC OR COMMA LINK 1 (N Nom))
(NEGATE 0 Du3 LINK *1 Sem/Human BARRIER NOT-ADV-PCLE LINK 1 CC LINK 1 Sem/Human)
(NEGATE 0 Du3 LINK *-1 Sem/Human + (N Pl Nom) OR Sem/Ani + (N Pl Nom) OR ("bealli" N Pl Nom) BARRIER NOT-ADV-PCLE)
(NEGATE 0 Du3 LINK -1 Sem/Human LINK *-1 CC BARRIER NPNHA LINK -1 Sem/Human)
(NEGATE 0 Pl1 LINK -1 Sem/Human + (Nom Pl) LINK *-1 CC BARRIER NPNHA LINK -1 I + Nom)
(NEGATE 0 Pl1 LINK -1 Sem/Human + Nom LINK *-1 CC BARRIER NPNHA LINK -1 Sem/Human + Nom LINK *-1 CC BARRIER NPNHA  - (Pron Pers Acc) LINK -1 I + Nom)
(NEGATE 0 Pl1 LINK -1 Sem/Human + Nom LINK *-1 CC BARRIER NPNHA LINK -1 Sem/Human + Nom LINK *-1 CC OR COMMA BARRIER NPNHA LINK -1 Sem/Human + Nom LINK *-1 CC OR COMMA OR (";") OR (":") LINK -1 I + Nom)
(NEGATE 0 Pl1 LINK -1 (N Nom) LINK *-1 (Pers Pl1 Gen) BARRIER (*) - Attr - Gen - (A Sg Nom) - GRADE-ADV LINK *-1 CC LINK -1 I + Nom)
(NEGATE 0 Pl2 LINK -1 Sem/Human + (Nom Pl) LINK *-1 CC BARRIER NPNHA - (Pers Gen) - (Pers Acc) LINK -1 YOU + Nom)
(NEGATE 0 Pl2 LINK -1 Sem/Human + (Nom Pl) LINK *-1 CC BARRIER NPNHA - (Pers Gen) - (Pers Acc) LINK -1 Sem/Human + (Nom Pl) LINK *-1 CC BARRIER NPNHA LINK -1 YOU + Nom)
(NEGATE 0 Pl2 LINK *-1 (N Pl Nom) - Err/Lex BARRIER NOT-ADV-PCLE OR (N Sg Loc Sem/Plc) OR CS LINK *-1 (Pron Pers Pl2 Nom) BARRIER NOT-COMMA)
(NEGATE 0 Pl2 LINK -1 (N Nom) LINK *-1 (Pers Pl2 Gen) BARRIER (*) - Attr - Gen - (A Sg Nom) - GRADE-ADV LINK *-1 CC LINK -1 YOU + Nom)
(NEGATE 0 Du1 LINK -1 Sem/Human + (Nom Sg) LINK *-1 CC BARRIER NPNHA - (Pers Gen) - (Pers Acc) LINK -1 WE-2 + Nom OR I + Nom)
(NEGATE 0 Du2 LINK -1 Sem/Human + (Nom Sg) LINK *-1 CC BARRIER NPNHA - (Pers Gen) - (Pers Acc) LINK *-1 YOU-2 + Nom OR YOU + Nom)
(NEGATE 0 Sg3 - COPULAS LINK -1 Sem/Hum + (Pl Nom) LINK *3 (N Nom Sg) - Sem/Group BARRIER NPNHA - (N Acc))
(NEGATE 0 Sg3 + COPULAS LINK *1 (N Nom Sg) + Sem/Group + Sem/Hum OR (N Nom Sg) + Sem/Rule BARRIER NPNHA - (N Acc)) # Astoأ،iggeveahkit lea buorre ortnet
(NEGATE 0 Inf LINK -1 (N Nom) OR (A Nom) LINK *-1 BE BARRIER  NOT-ADV - CC - (N Nom) LINK 0 Sg3 OR Pl3)
(NEGATE 0 Inf LINK -1 (N Nom) LINK *-1 BECAUSE-WHEN OR XGO BARRIER NPNH LINK -1 (A Nom) LINK -1 COMPGO LINK *-1 COPULAS BARRIER  NOT-ADV - CC - (N Nom) LINK 0 Sg3 OR Pl3 OR ConNeg OR Inf OR PrfPrc) # eai oro liikkأ، viإ،إ،alat go nieiddat gazzat
(NEGATE 0 Inf LINK -1 SUBJ + Pl LINK *-1 CC BARRIER NOT-ADV-PCLE LINK -1 COMMA LINK *-1 Inf BARRIER GRAMCHK-S-BOUNDARY LINK *-1 (V Pl3) + AUX)
(NEGATE *1 (Pron Pers Sg1 Nom) BARRIER NOT-ADV-PCLE - CC - COMMA - (N Nom) - (Prop Gen) - (Prop Acc) - (Prop Attr))
(NEGATE *1 (A Sg Nom) BARRIER NOT-ADV-PCLE LINK 1 Inf)
(NEGATE 0 Inf LINK -1 (N Nom) LINK *-1 COPULAS BARRIER NPNHA - CC LINK *-1 (@HAB) OR @ADVL + Loc OR PUNCT OR CS BARRIER (*) - AUX - (V Neg)) #ADVL eai lean SUBJ CC SUBJ Inf #HAB leat SPRED CC SPRED Inf
