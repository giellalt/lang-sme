LIST LAHKA-ASAHUS = "alimusriekti" "Odeldiggi" "Stuoradiggi" "Stuorradiggi" "stuoradiggi" "stuorradiggi" "vuolleriekti" ;

LIST LAHKA-POST = "bokte" "olis" "mielde" "vuoÄul" ;

SET NOT-LAHKA = N - LAHKA ;


LIST GIELDA = "fylkkagielda" "gielda" "guovddĂĄĆĄgielda" "hĂĄlddaĆĄangielda" "riddogielda" "ruovttugielda" "sĂĄmegielda" "SĂĄmegielda" "vuotnagielda" ;

