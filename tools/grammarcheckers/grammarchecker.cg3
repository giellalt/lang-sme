LIST DOUBLE-CONSONANT-UT-VERB = (".*skut"r V) (".*skut"r V*) ;

#DELETE uncommon	
ADD:xmsyn-kkun-kon (&msyn-kkun-kon) TARGET DOUBLE-CONSONANT-UT-VERB IF (0 (Ind Prs Sg1))(*-1 ("lohkki") OR ("lohkat") BARRIER GRAMCHK-S-BOUNDARY OR PrfPrc) ;
COPY:msyn-kkun-kon (PrfPrc SUGGEST) EXCEPT (Ind Prs Sg1 &msyn-kkun-kon) TARGET (&msyn-kkun-kon) ;
	## Muhtin biktasiid lohke baskkun  skĂĄhppii heaĆgĂĄt, eaige ĆĄat heiven.
	# in errors.xml
	
	# Sg3 should be ConNeg
	# --------------------
	
	
ADD:msyn-Sg3-ConNeg (&msyn-Sg3-ConNeg) TARGET (V Cond Prs Sg3) - Err/Any OR BE + Sg3 - Err/Any IF (*-1 Neg BARRIER NOT-NP-HEAD-COMMA-CC-Adv-Neg OR (Sg Nom) LINK NEGATE 1 COMMA OR (".*ge"r)) (NEGATE *-1C (Pron Sg3 Nom) OR Rel BARRIER (*) - Adv - Pcle  LINK *-1 Neg BARRIER NOT-NP-HEAD-COMMA-CC-Adv-Neg)(NEGATE 0 ConNeg - Err/Orth)(NEGATE -1 COMMA OR Rel);
	##  NĂĄhkkedikĆĄun ja - goarrun lea nu ĂĄrbevirolaĆĄ bargu ahte earĂĄlĂĄgan oahpahus go dat man lĂĄhkai lea ohppojuvvon boares ĂĄiggi rĂĄjes, ii {buoridivÄÄii} sĂĄmiid ruhtadili iige dat heiveĆĄii kultuvrralaĆĄ progrĂĄmmii nu mo skuvla dan lea jurddaĆĄan.
	## Ale, son lea hui nuoskkis odne, nissonĂĄĆĄĆĄi,Â» Ăne beasahallĂĄ.

ADD:msyn-Sg3-ConNeg (&msyn-Sg3-ConNeg) TARGET (V Neg) IF (1 &msyn-Sg3-ConNeg);

COPY:msyn-Sg3-ConNeg (ConNeg SUGGEST) EXCEPT Sg3 OR (Err/Orth Sg3) TARGET (V &msyn-Sg3-ConNeg) IF (NOT 0 Neg) ;

ADDRELATION:msyn-Sg3-ConNeg (LEFT $2) (ConNeg &msyn-Sg3-ConNeg) TO (-1 (Neg &msyn-Sg3-ConNeg)) ;

    ## Juos in mĂĄhtĂĄĆĄii ÄĂĄllit ja lĂĄvlut, livÄÄen eahpelihkostuvvan olmmoĆĄ. Juos in mĂĄhtĂĄĆĄe ÄĂĄllit ja lĂĄvlut, livÄÄen eahpelihkostuvvan olmmoĆĄ.
    ## In mun nu bures ja inge nu ÄĂĄbbĂĄt mĂĄhtĂĄĆĄii ÄĂĄllit ja lĂĄvlut, jos livÄÄen eahpelihkostuvvan olmmoĆĄ.
    ## DĂĄn guovllus eai galggaĆĄii leat boranĂĄvddit, ja dĂĄid mĂĄĆemuĆĄ jĂĄgiid leat bivdit bĂĄhÄÄĂĄn ĂĄlbasiid Dielddasullos.
    ## DĂĄn olis jearrĂĄ Anti sĂĄmediggerĂĄÄis maid lea sĂĄmediggerĂĄÄÄi bargan bissehit dan ahte nationĂĄla luondduluossavuotna, BĂĄhÄaveaivuotna, ii billistuvvoĆĄii  mirkobĂĄzahusaid geaĆŸil maid MĂĄtta-VĂĄrjjaga ruvkedoaibma luoitĂĄ? -"billistit" Ex/V Ex/TV Der/PassL V IV Cond Prs ConNeg
    ## Muhto go dan spesiĂĄlasuorggi fysihka diimmuid vĂĄlljejit oahppit dainna vai besset dinet ja oahpaheaddji lea ordnen sidjiide bĂĄlkkĂĄ vai ieĆĄ beassĂĄ dinet, de iibat dĂĄnge jurdaga sĂĄhtĂĄĆĄii doalvut ovddos :
    ## - Buohkanassii in       sĂĄhtĂĄĆĄii leat ĆĄat eambo duhtavaĆĄ, loahpaha son
    # in errors.xml

	# conneg not 3rd sg
	# -----------------
	

ADD:xmsyn-Sg3-ConNeg (&msyn-Sg3-ConNeg) TARGET (V Prs Sg3) IF (0 Ind OR Cond)(-1 (V Neg Sg3) LINK NOT 0 Sup LINK NEGATE 1 COMMA OR (".*ge"r))(NEGATE 0 ConNeg)(NEGATE -1 COMMA OR Rel);	#CHECK change tag to &msyn-Sg3-ConNeg
	## Meahccebiila vuodjĂĄ hĂĄrve olggobealde luotta go biila ii lea rĂĄhkaduvvon dan gierdat, muhto ATV:in sĂĄhttĂĄ ĂĄlkit vuodjit juohke saji.
	## Amma Anne G ii suhttĂĄ munnje, jus in ÄĂĄle nu ÄĂĄbbĂĄt go ĂĄiggoĆĄii?
	## Dat ii leat rĂĄÄÄehusa vuollĂĄsaĆĄ orgĂĄna, ja rĂĄÄÄehusas ii lea danne ovddasvĂĄstĂĄdus SĂĄmedikki politihkalaĆĄ doaimmas dahje dain politihkalaĆĄ mearrĂĄdusain maid SĂĄmediggi dahkĂĄ.
	## Omd. go vuodjit biilla ( dahje skohtera dahje njealljejuvlaga ) mis ii galgĂĄ leat badjel 0,2 promille alkohola varas. 
	## Don fertet duĆĄĆĄe dohkkehit ahte ii dĂĄhpĂĄhuvvĂĄ nu ollu juste dĂĄl. 
	## Jus duĆĄĆĄe veardidivÄÄii sojahangehÄosiid bokte, iige vĂĄlddĂĄĆĄii vuhtii stuorit
	## antesedeanta pro:ii, muhto antesedeanta ii adnoĆĄii , go pro almmatge birge dan haga.
	#$ ) ii ii ii (.
	## Jus bĂĄrdni dupmehallet seksualalaĆĄ oktavuhttin ja veagalvĂĄldin, de sahtta son Äohkka giddagassii olles 15 jĂĄgi, muhttu politi-inspektĂžra Are Meedbye lohkĂĄ ahte dat ii lea realistalaĆĄ, ja sus ii leat makkarge oaivvil man guhkka raĆggaĆĄtus sahtta ĆĄaddet. 
COPY:msyn-Sg3-ConNeg (ConNeg SUGGEST) EXCEPT (Sg3 Err/Orth &msyn-Sg3-ConNeg) TARGET (&msyn-Sg3-ConNeg) IF (NOT 0 Neg) ;	

	
	# double inchoative ĂĄlgit + -goahtit
	# ----------------------------------
	# two ways of fixing
	# ĂĄlgen mun ballat
	# mun ballagohten
	# HOW TO DISPLAY BOTH WAYS?
	
ADD:xsyn-double-inchoative (&syn-double-inchoative) TARGET BEGIN IF (*1 (Ex/V TV Der/InchL) BARRIER GRAMCHK-S-BOUNDARY OR VFIN LINK NEGATE 1 ("d") OR ("dii") OR ("dmu") OR ("dbm") OR (Num Sg Loc));
	## Go leimme mihtidan nu mĂĄĆga rusttega ahte ĂĄlggiime ollet lohppi, ĂĄlgen mun ballagoahtit.
	#$ mon ĂĄlggĂĄn boahtte vahku bargagoahtit d. 700 #CHECK D?
	
ADD:xsyn-double-inchoative (&syn-double-inchoative) TARGET (Ex/V TV Der/InchL) IF (*-1 &syn-double-inchoative BARRIER GRAMCHK-S-BOUNDARY);
	
COPY:double-inchoative (SUGGEST) EXCEPT (Ex/V TV Der/InchL) TARGET (&syn-double-inchoative) IF (*-1 &syn-double-inchoative BARRIER GRAMCHK-S-BOUNDARY) ;


ADDRELATION:double-inchoative ($2 RIGHT) (&syn-double-inchoative) TO (-1 (&syn-double-inchoative));


	# indirect question
	# -----------------
	
LIST INDIRECT-QST-V = "imaĆĄtit" "imaĆĄtallat" "jearrat" "jearralit" ; # Positiv
LIST INDIRECT-SPEECH-V = "dadjat" "diehtit" "jurddaĆĄit" ; # Neg dahje/vai
	# Mun in dieÄe boaÄĂĄngo ihttin.  Neg
	# Mun dieÄĂĄn dĂĄl boaÄĂĄngo ihttin dahje odne.


ADD:xsyn-add-go (&syn-add-go) TARGET GRAMCHK-VFIN IF (*-1 INDIRECT-QST-V BARRIER GRAMCHK-S-BOUNDARY1 OR GRAMCHK-VFIN OR MO-MANge OR CC OR CS OR THEN-CS-ADV LINK 0 V LINK NEGATE *0 OBJ BARRIER NPNHA)(NOT 0 Qst) (NEGATE 1 BECAUSE-WHEN) (NEGATE -*1 ("manin") OR ("manne") OR ("makkĂĄr") OR Rel BARRIER GRAMCHK-S-BOUNDARY)(NEGATE -1 SUBJ LINK -1 COMMA);
	#$ Mon gal eahpidan, ahte ollen obban dohko beaiveÄuovggas.
	## Fertejedjen jearrat lea dien olbmos vehĂĄge jearga bĂĄhcĂĄn.
	#$ Mon gal jearan mo galggan boahtit.
	#$ Go seamma gaĆŸaldagat jerrojuvvui jagis 1950, de vĂĄstidii duĆĄĆĄe 13,6 % ahte sii geavahit sĂĄmegiela ruovttus.
	#$ Mana eatnis jearrat, son soaitĂĄ muitit man birra dat lea.
