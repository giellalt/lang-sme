COPY:xmsyn-num_geardde-Ill ("njelljii" Adv SUGGEST) EXCEPT ("njeallje" Num Sg Nom &msyn-num_geardde-Ill) OR ("njeallje" Num Sg Gen &msyn-num_geardde-Ill) OR ("njeallje" Num Sg Loc Attr &msyn-num_geardde-Ill) OR ("njeallje" Num Sg Ill Attr &msyn-num_geardde-Ill) TARGET ("njeallje" &msyn-num_geardde-Ill);
