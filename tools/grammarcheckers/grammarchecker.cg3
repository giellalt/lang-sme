	# ii in superlative followed by negation verb
	# --------------------------------------------
	
#	Nickel
# 1. amaset boahtit
# 2: amas eat boadeآ آ (CS)
# 3: amas (sii) boahtit
# 4: amas eai boahtit

#DELETE SECOND ROUND

ADD:xsyn-double-negation (&syn-double-negation) TARGET NOT-V IF (0 (V IV Neg Sup) LINK NOT 0 Sg3)(1 ("ii")); 
	#in errors.xml
COPY:syn-double-negation ("amas" CS SUGGEST) EXCEPT ("ii" V IV Neg Sup Pl3) OR ("ii" V IV Neg Sup Pl2) OR ("ii" V IV Neg Sup Pl1) OR ("ii" V IV Neg Sup Du3) OR ("ii" V IV Neg Sup Du2) OR ("ii" V IV Neg Sup Du1) OR ("ii" V IV Neg Sup Sg3) OR ("ii" V IV Neg Sup Sg2) OR ("ii" V IV Neg Sup Sg1) TARGET (Sup &syn-double-negation) ;

ADD:syn-double-negation (&syn-double-negation) TARGET NOT-V IF (-1 (V IV Neg Sup) LINK NOT 0 Sg3);
	## this should get the green line, but does not need to be corrected
	## ؤŒiegain lea botken buot mأ،ؤ‘iid amaset eat beasa vuojأ،niiguin luomejekkiide. 
	## â€“ Go mأ،nأ،id أ،lo galgأ، ؤچalmmis doallat, amaset eai إ،atta biilla vuollai, vأ،idala Gerd ja Biret-أ،hkku lea ovtta oaivilis. 
	
ADDRELATION (RIGHT $2) (Sup &syn-double-negation) TO (*1 &syn-double-negation + NOT-V);

