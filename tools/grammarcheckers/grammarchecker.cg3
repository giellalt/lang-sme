    # usually in partitive constructions

LIST LOC_BIRRA-V = "cealkit" "dadjat" "oaivvildit" "meidnet" "ĂĄrvalit" "evttohit" "Äilget" "jĂĄhkkit" "doaivut" "ĂĄrvidit";

LIST LOC_BIRRA-N = "cealkĂĄmuĆĄ" "dadjamuĆĄ" "muitalus" "oaivil" "meinnet" "ĂĄrvalus" "evttohus" "oaidnu" "kommeanta" ;

SET LOC_BIRRA = LOC_BIRRA-V OR LOC_BIRRA-N ;

#DELETE SECOND ROUND

ADD:xmsyn-plcom-plloc  (&msyn-plcom-plloc) TARGET (Pl Com) IF (0 Sem/Hum LINK *-1 ("muhtin" Pl) OR ("soamis" Pl) OR ("ollus" Pl) OR ("olus" Pl) OR ("olugat" Pl) OR ("ollugat" Pl)  BARRIER GRAMCHK-NPNHA OR Num LINK 0 Nom);
	## Muhtimat olggobeale olbmuiguin dadjet ahte ii leat dĂĄrbu loddet. Muhtimat olggobeale olbmuin dadjet ahte ii leat dĂĄrbu loddet.

ADD:xmsyn-plcom-plloc  (&msyn-plcom-plloc) TARGET (Pl Com) IF (0 NP-HEAD LINK *-1 OASSI OR (Num Sg Nom) OR (Num Sg Acc) OR LOC_BIRRA OR ("ollu") BARRIER GRAMCHK-NPNHA OR MO-MANge OR (":") OR (";") OR (",") OR Adv OR Sem/Measr OR Sem/Time) (NEGATE 0 ("dat" Attr))(NEGATE -1 Num) ;
	#$ GARRA BARGU : Nils Evald Biti lea 10 jagi       Äohken  dieÄuid sĂĄmiid birra geat dollejedje Alaskai 100 jagi dassĂĄi bohccuiguin ja bearraĆĄiiguin. 
	## Dat sĂĄhttet leat oassin ĂĄrvvoĆĄtallamiiguin.
	## Muhtin biirres leat gĂĄvcci obbalaÄÄat 12 vĂĄlljejuvvon ĂĄirasiiguin leamaĆĄ nissonolbmot, ja earĂĄ biirres leat buohkat geat leat vĂĄlljejuvvon leamaĆĄ dievddut.
	## SĂĄmediggi sĂĄhttĂĄ maid buktit cealkĂĄmuĆĄaid guovlluid dearvvaĆĄvuoÄafitnodagaid jahkedieÄĂĄhusaiguin ja plĂĄnaĂĄrvalusaiguin
	#$ Dalle ĂĄrvideimmet movt min Äohkanlottiiguin lea geavvan.
	#$ Ja mot galgĂĄ sĂĄhttit ovttastahttit 2. ja 3. diviĆĄuvnna ÄikÄiid 16 jahkĂĄsaĆĄ ÄikÄiiguin - maid vĂĄrĂĄs SĂĄmi Cup eandalii lea?XXX
	#$ 775 mill. bihttĂĄ vĂĄstidit 48.500 siiddu duppal linnjagaskkaiguin dahje bealguÄat mehter alla bĂĄberlĂĄtna. XXX
	#$ Sii elle lotnolasealĂĄhusain; guolĂĄstemiin, meahccebivdduin, eanandoaluin, duddjomiin, huksenbargguiguin ja ollu earĂĄ doaimmaiguin mat ĂĄigges ĂĄigĂĄi ain adde lassibirgejumi.XXX
	#$ Stuoradiggi lea ratifiseren ILO-konvenĆĄuvnna ĂĄlgoĂĄlbmogiid birra, mii ea.ea. cealkĂĄ: âDĂĄid ĂĄlbmogiid oahpahusprogrĂĄmmaid ja -bĂĄlvalusaid galgĂĄ ovddidit ja ollaĆĄuhttit singuin veahkkĂĄlagaid."
	
ADD:xmsyn-plcom-plloc  (&msyn-plcom-plloc) TARGET (Pl Com) IF (0 NP-HEAD LINK *-1 CC OR COMMA BARRIER GRAMCHK-NPNHA LINK -1 (&msyn-plcom-plloc) OR (Pl Loc) LINK *-1 OASSI OR (Num Sg Nom) OR (Num Sg Acc) OR LOC_BIRRA OR ("ollu") BARRIER GRAMCHK-NPNHA)(NEGATE -1 Num) ;
COPY:msyn-plcom-plloc (Loc SUGGEST) EXCEPT (Com &msyn-plcom-plloc) TARGET (N &msyn-plcom-plloc) ;
	## SĂĄmediggi sĂĄhttĂĄ maid buktit cealkĂĄmuĆĄaid guovlluid dearvvaĆĄvuoÄafitnodagaid jahkedieÄĂĄhusaiguin ja plĂĄnaĂĄrvalusaiguin
	## SĂĄmediggi sĂĄhttĂĄ maid buktit cealkĂĄmuĆĄaid guovlluid dearvvaĆĄvuoÄafitnodagaid jahkedieÄĂĄhusain ja plĂĄnaĂĄrvalusaiguin
  	## Ollu daid bivdovugiiguin guhkimus leaĆĄ gevahuvvon...
  	## RuoĆ§as boÄii loahpas vĂĄstadusa SĂĄmi OahpahusguovddĂĄĆŸis, Johkamohkis, muhto ii fal nu ollu earĂĄiguin.
  	
	# passive Prt Sg3 - active Prt Sg3
	# --------------------------------

ADD:syn-PassPrtSg3-PrtSg3 (&syn-PassPrtSg3-PrtSg3) TARGET (Der/PassS IV Ind Prt Sg3) + UT-VERBS IF (0 Ex/IV)(*-1 (Pron Sem/Hum Sg Nom) OR (N Sem/Hum Sg Nom) OR (Pron Pers Sg3 Nom));
	## MaĆĆel go vĂĄlgabohtosat Äilge, de lea son gĂĄrtan viÄat sadjĂĄi Ellen Inga O. HĂŠtta maĆĂĄbeallai, gii gal baicca {gizzui} ollu go oaÄÄui liigejienaid.

COPY:syn-PassPrtSg3-PrtSg3 (SUGGEST) EXCEPT (Ex/V Ex/IV  Der/PassS &syn-PassPrtSg3-PrtSg3) TARGET (&syn-PassPrtSg3-PrtSg3) ;

	# passive Prs Pl1 - active Prs Pl1
	# --------------------------------

ADD:syn-PassPrsPl1-PrtPl1 (&syn-PassPrsPl1-PrtPl1) TARGET (Der/PassS Ind Prs Pl1) + UT-VERBS IF (*-1 (Pron Pers Pl1 Nom) BARRIER NOT-ADV-PCLE);
	##  Go mii {Äurvot} nuoraide de galge vĂĄstidit.

COPY:syn-PassPrsPl1-PrtPl1 (TV SUGGEST) EXCEPT (Ex/V Ex/TV Der/PassS IV &syn-PassPrsPl1-PrtPl1) AFTER V TARGET (&syn-PassPrsPl1-PrtPl1) ;


	# soaitit + inf or PrcPrf
	# -----------------------

ADD:syn-inf-after-soaitit (&syn-inf-after-soaitit) TARGET GRAMCHK-VFIN IF (*-1 SOAITIT BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN OR FMAINV OR CLB OR Inf OR CC)(NOT 0 Inf OR PrfPrc OR Pl3-INF-V + (Ind Prs Pl3) OR (Ind Prs Pl1) OR Pl3-INF-V + (Ind Prt Sg2))(NEGATE 0 MOVEMENT-V LINK 0 VGen OR (Imprt Sg2) OR (ConNeg))(NEGATE 0 Adv LINK 1 Adv)(NEGATE 0 Neg)(NEGATE 0 <spelled> - VFIN);
	#$ Muhtun dĂĄhpĂĄhusain sĂĄhttet maiddĂĄi bĂĄikkĂĄlaĆĄ dilĂĄlaĆĄvuoÄat lea dakkĂĄrat, ahte stuorĂĄt skuvla sĂĄhtĂĄĆĄii addit buoret fĂĄlaldaga sĂĄmegielas.
	#$ sĂĄhttĂĄ ja dĂĄhttu bargat ovttas nuppiiguin, geas lea buorre miella ja liikojit ovttas bargat
	
COPY:syn-inf-after-soaitit (Inf SUGGEST) EXCEPT (Ind Prs Sg1) OR (Ind Prs Sg2) OR (Ind Prs Sg3) OR (Ind Prs Du1) OR (Ind Prs Du2) OR (Ind Prs Du3) OR (Ind Prs Pl1) OR (Ind Prs Pl2) OR (Ind Prs Pl3) OR (Imprt Pl2) TARGET (Prs &syn-inf-after-soaitit) OR (Imprt &syn-inf-after-soaitit)(NEGATE 0 BE + (Ind Prs Sg1) LINK NEGATE *-1 ("mun"))(*-1 SOAITIT BARRIER GRAMCHK-S-BOUNDARY) ;

COPY:syn-inf-after-soaitit (Prt ConNeg SUGGEST) EXCEPT (Ind Prt Sg1) OR (Ind Prt Sg2) OR (Ind Prt Sg3) OR (Ind Prt Du1) OR (Ind Prt Du2) OR (Ind Prt Du3) OR (Ind Prt Pl1) OR (Ind Prt Pl2) OR (Ind Prt Pl3) TARGET (Prt &syn-inf-after-soaitit) (NEGATE 0 SOAITIT) ;

COPY:syn-inf-after-soaitit (PrfPrc SUGGEST) EXCEPT (Ind Prs Sg1) TARGET BE + (Ind Prs Sg1 &syn-inf-after-soaitit)(NEGATE *-1 ("mun"))(NEGATE 0 SOAITIT) ;
	#$ Dat soittii ge {lean} juste eatni ja ĂĄhÄi sivva! # Ritva should it be leamaĆĄ instead of lean??
	## Boahtte hĂĄve soaittĂĄn vĂĄlddĂĄn govven- dahje filbmenbarggu. Boahtte hĂĄve soaittĂĄn vĂĄldit/vĂĄldĂĄn govven- dahje filbmenbarggu.
	#TEST
	#$ Eai duĆĄĆĄe olggosoaidnit rĂĄhkadettiin, muhto maiddai ÄĂĄcis ii galgan Äohkamis oaidnit goal lea ealli loddi ja goal lea Äohkanloddi, dahje hĂĄpma nu go muhtimat dadjet.
	## DĂĄt lea smĂĄvit mĂĄnĂĄide rĂĄhkaduvvon, danne leat dĂĄs lĂĄvlagat maidda mĂĄnĂĄt sĂĄhttet doaĆĄkkut  gieÄaid, ja maiddai  leat das lĂĄvlagat maidda mĂĄnĂĄt sĂĄhttet lihkadit go gullet lĂĄvlagiid.
	#$ Ferten jĂĄpmĂĄn ĂĄhkuid ja ĂĄdjĂĄid geavahit gaskaoapmin vai beasan jienastit SĂĄmediggĂĄi, jearrĂĄ Jorunn. 
	# in errors.xml
	
ADD:syn-inf-after-soaitit (&syn-inf-after-soaitit) TARGET SOAITIT IF (*1 &syn-inf-after-soaitit BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN OR FMAINV OR CLB OR Inf OR CC)(NEGATE 0 SOAITIT);

ADDRELATION ($2 LEFT) (&syn-inf-after-soaitit) TO (*-1 &syn-inf-after-soaitit + SOAITIT) ;
	
    # attribute vs. predicative adjective 
    # -----------------------------------
    # D: gĂĄrzzidit njuolggadusa roavis-roaves -lĂĄgĂĄn pĂĄraide (ja soames iezĂĄ nai), maid olbmot lĂĄvejit cĂĄllit vearrut?
LIST MODALS = "leat" "ĆĄaddat" "fertet" "galgat" "dĂĄidit" "soaitit" "veadjit" "ĂĄigut" "mĂĄhttit" "oaĆŸĆŸut" "sĂĄhttit" "berret" ;



ADD:xmsyn-attr-not-pred (&msyn-attr-not-pred) TARGET A - Loc - Acc IF (NOT 0 Attr OR (N Gen) OR ABBR OR @<SPRED LINK NEGATE 0 (Sg Nom) LINK 0 ADJ_ATTR/NOM OR Comp OR Superl)(*1 CNOUN OR A BARRIER NOT-ADJ-CC OR BECAUSE-WHEN LINK NOT 0 PrfPrc)(NEGATE 0 (Ind Prs) OR (Ind Prt))(NEGATE 1 COMMA)(NOT 1 Rel) (NEGATE 0 CONGRUENCE-A OR ("riekta") OR ("duoÄas") OR Ord - ("nubbi")) (NEGATE *0 MODALS BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN OR Rel) (NEGATE 0 A LINK 1 COMMA OR CC LINK NOT 1 Attr OR Gen)(NEGATE 1 CC LINK 1 Gen LINK 1 Po) (NEGATE 0 Ess LINK NOT *0 GRAMCHK-VFIN BARRIER GRAMCHK-S-BOUNDARY OR CLB)(NEGATE 0 Superl LINK 0 (Adv Superl))(NEGATE 0 Attr LINK NOT 0 Attr)(NEGATE 1 EOS)(NEGATE 0 (N Sg Ill) OR Adv)(NEGATE 0 <TH-Inf> LINK *1 Inf BARRIER NOT-ADV - ADVLCASE)(NEGATE 0 (A Sem/Hum Pl Gen))(NEGATE 0 (A Sg Acc) OR <AttrPred> OR Der/Car);
	#$ DĂĄkkĂĄr toponymalaĆĄ seaguhemiin ĂĄsahuvvui gielalaĆĄ nammamĂĄlle mas nammaoasit seaguhuvvojedje giellarĂĄjiid rastĂĄ nu ahte primĂĄra bĂĄikenamma lei sĂĄmegillii muhto dĂĄrogiela ovdamerrosa {lasihemiin} sĂĄmi namma sirdojuvvui maiddĂĄi dĂĄrogiela adnui.
	#$ Eat illut vuos, eisevĂĄlddit leat ovdal lohpidan midjiide buhtadusa, ja leat alu beahtahallan, lohke sĂĄmi {oahppovĂĄillagiid} searvvi ovddasteaddjit maĆĆĂĄ Äoahkkima Norgga justiisaministariin mannan gaskavahku.
    #$ DĂĄid dihte ferte jĂĄhkkit ahte Guovdageainnu suohkanii orro eanemus {ĂĄvkkĂĄlaĆĄ} ovttasbargat Vest-Finnmark RegionrĂ„d guvlui, vaikko StĂĄda ja FinnmĂĄrkku fylkkagielda ovdal leat defineren Guovdageainnu oassin Sis-FinnmĂĄrkku Guovllus.
   #$ Ăsodagain ja rĂĄidoviesuin jĂĄvkĂĄ eanemus {liekkas} robi ja lovtta bokte.
	#$ Govva lea oainnĂĄt mihĂĄ eambbo ivdnĂĄi go dat maid son oaidnĂĄ.
    # Dat rieban maid mii lĂĄvet hĂĄrdit, lea boares, Äalmmehis - muhto hui {belljes} rieban mii orru duos RiebanvĂĄris, Äilgii Vilge.
    #$ Su musihkka lea poehtalaĆĄ ja das lea roavis harmoniija. - example does not work because of dis: "roavvi" Sem/Plc N Sg Gen PxSg3 is choosen instead of the adjective reading
    #$ KulturbĂĄlkkaĆĄupmi geigejuvvo Kirstti Palttoi maĆĆeleappos ĂĄlggogeasis.
    #$ lohkanloatna sĂĄhttĂĄ unnut eanemusat kr. 16 500 jahkĂĄi
    #$ Mas dovvdat erehusa goal lea GuovdageaidnulaĆĄ gii lea riegĂĄdan ja bajasĆĄaddan Guovdageainnus ja goal lea sisafĂĄrrejeaddji.
    #$ OÄÄa studeanttaide fĂĄttarortnetveahkki ja doarjja go lea amas ja oÄas bĂĄikĂĄi.  
    #$ Go buot bivdoĂĄvdnasat leat gĂĄrvĂĄsat, ii leat go vuorddaĆĄit goas ja gokko buorre loddensuddi ĆĄadda.
    #$ Son lea ieĆĄ nai mĂĄĆgga hĂĄve beahtahallan go lea bivdĂĄn veahki, ja ĂĄvĆŸĆŸuha danin suohkana dĂĄl duoÄas nissonĂĄĆĄĆĄiid bearrĂĄigeahÄÄagoahtit.
    # in errors.xml
  
ADD:xmsyn-attr-not-pred (&msyn-attr-not-pred) TARGET (A) IF (NOT 0 Attr OR Gen OR @<SPRED OR ABBR LINK NOT 0 (Sg Nom) LINK 0 ADJ_ATTR/NOM OR Comp OR Superl LINK 0 (Sg Nom) LINK *1 CNOUN OR A BARRIER GRAMCHK-NPNH)(NOT 1 Rel) (NEGATE 0 CONGRUENCE-A OR ("riekta") OR Ord - ("nubbi"))(NEGATE *0 MODALS BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN) (NEGATE 0 A LINK 1 COMMA OR CC LINK NOT 1 Attr OR Gen)(NEGATE 0 (N Sg Ill) OR Adv OR <AttrPred> OR Der/Car) ;
     #D!
	#$Seamma lea maiddai maĆemus maid dahkkĂĄ ovddal mannĂĄ fas sisa vissui.
    #$ Go buot bivdoĂĄvdnasat leat gĂĄrvĂĄsat, ii leat go vuorddaĆĄit goas ja gokko buorre loddensuddi ĆĄadda.
  
ADD:xmsyn-attr-not-pred (&msyn-attr-not-pred) TARGET (A Sg) IF (NOT 0 Attr OR Gen OR ABBR OR @<SPRED LINK NOT 0 (Sg Nom) LINK 0 ADJ_ATTR/NOM OR Comp OR Superl LINK 1 COMMA OR CC LINK *1 CNOUN OR A BARRIER GRAMCHK-NPNHA)(NOT 1 Rel)  (NEGATE 0 CONGRUENCE-A OR Ord - ("nubbi") OR (Adv Sem/Time)) (NEGATE *0 MODALS BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN) (NEGATE 0 A LINK 1 COMMA OR CC LINK NOT 1 Attr OR Gen)(NEGATE 0 (N Sg Ill) OR Adv OR <AttrPred> OR Der/Car) ; 
     #D!
     #$ Nils Einar Samuelsen gullĂĄ DAN eanemus konservatiiva {suorgĂĄi} dain mĂĄĆgga lestadiĂĄnalaĆĄ surggiin.
     #$ Lars Heaika geavai {maĆemuĆŸĆŸii}, logat sadjĂĄi dĂĄn beaivve.
COPY:attr-not-pred (Attr SUGGEST) EXCEPT (Sg Pl Nom &msyn-attr-not-pred) OR (Sg Gen Err/Orth-nom-gen &msyn-attr-not-pred) OR (Sg Nom &msyn-attr-not-pred) AFTER A TARGET (&msyn-attr-not-pred) ;
	#$ Suoma sĂĄmiid guovddĂĄĆĄsearvvis gal lea diehtu das, ahte gal sĂĄpmelaÄÄat hĂĄleĆĄtit sĂĄmeĂĄĆĄĆĄiin viĆĄĆĄalit, nu SĂĄmedikki vejolaĆĄvuoÄain, dan doaibmavugiin, go maiddĂĄi muhtun ĂĄĆĄĆĄiid serviid Äoahkkimiin, earĂĄ Äoahkkanemiin jnv.
    ## Su musihkka lea poehtalaĆĄ ja das lea {roavis} ja ihĂĄna ÄĂĄppa ja fiinna, alit ja dassĂĄ lassin oalle vealtameahttun bĂĄruhĂĄmat harmoniija.-- DIS error roavis..
    ## Mii leat dĂĄvjĂĄ sĂĄgastallan dĂĄn golmma alit, rukses, ruonĂĄ ja ihĂĄna stuorra diĆgga birra. 
    #$ Go ealga orrugoÄii Guovdageainnus, fuomaĆĄeddje dieÄus maiddai dan bivddu.
    #$ Duvle fitne Johkamohki SĂĄmeskuvlla 1.-6. luohkĂĄ oahppit min guossis.
    # need a good example

		
	# Pred not Attr (adjectives)
	# --------------------------
	#DELETEÂ SECONDÂ ROUND	

ADD:xsyn-attr-sgnom (&syn-attr-sgnom) TARGET (A Attr) IF (*-1 COPULAS BARRIER V OR GRAMCHK-S-BOUNDARY LINK *-1 Nom) (NEGATE *1 N BARRIER NOT-Attr - PrfPrc)(NEGATE 1 CC OR COMMA LINK 1 A LINK 1 N)(NEGATE 1 (A Attr) OR ? LINK *1 N BARRIER NPNH)(NEGATE 1 (A Sg Nom) OR (Pron Pers))(NEGATE 0 ("visot") OR ("buot") LINK 1 Pron LINK *1 N)(NEGATE 0 PRED-ATTR-ADJ OR (A Arab Ord Attr))(NEGATE 1 COMMA OR CC LINK 1 (A Attr) OR PRED-ATTR-ADJ)(NOT 0 (A Sg Nom) OR <AttrPred>)(NEGATE 1 COMMA OR ("-") LINK 1 BUT-CC LINK *1 (A Attr) BARRIER NPNHA)(NEGATE 0 Superl LINK 1 CC LINK 1 ("eanet" Superl) OR ("eanemus") LINK 1 A LINK 1 N)(NEGATE 1 (Num Attr) LINK 1 N)(NEGATE 0 ("eanet") LINK 1 PrfPrc)(NEGATE 0 Gen LINK 1 Po);
	#$ MĂĄĆga duhĂĄt nuora, geain ledje skuvlauniforpmat ja Norgga ja Myanmar leavggat, ÄuĆŸĆŸo dego ÄikĆan geaidnorĂĄvddain girdihĂĄmmanis gitta Nay Pyi Taw gĂĄvpogii â mii lea Myanmar {oÄÄa} huksejuvvon oaivegĂĄvpot.
	#$ 1992 rĂĄjes lea datte olgunastinlĂĄvdegoddi {eanet} adnon gulaskuddanĂĄsahussan moanaid oktavuoÄain, ee. mohtorfievrojohtolaga j.s. oÄÄ lĂĄhkaĂĄsahusaid gĂĄrvvisteamis.
	#$ NepĂĄlas leat badjel 60 etnalaĆĄ joavkku, ja doppe hubmojuvvojit unnimusat 69 giela, ja nappo lea ge okta dain eanemus {mĂĄĆggakultuvrralaĆĄ}, mĂĄĆggagielat ja mĂĄĆggaoskkot servodagain mĂĄilmmis.
	#$ Dat lea maiddĂĄi dat {vĂĄddĂĄseamos} ja eanemus eahperealisttalaĆĄ lohpĂĄdus.
	#$ Gro Harlem Brundtland leage okta Norgga buot eanemus dovddus politihkkĂĄriin {maĆimuĆĄ} moaddelot jagi.
    #$ Dat mii lea buot {eanemus} {dĂĄrbbaĆĄlaĆĄ} min servvodagas, lea bargosajiid hĂĄhkat ja nuoraid oaĆŸĆŸut vĂĄldit oahpu.
	#$ Ăhku biejus leat mii dĂĄl guldaleame mot dalle doloĆĄ ĂĄiggi geavai go ĂĄhkku ja earĂĄ sĂĄhpannieiddat ledje meahccĂĄi lĂĄhppon, ja go buoidda Äere ja guokte vilgesĂĄhpanbĂĄrtni sin doppe gĂĄvdne ja hĂĄste sin ieĆŸaset bieju lusa vuolgit.
    #$ Su musihkka lea poehtalaĆĄ ja das lea roavis ja ihĂĄna ÄĂĄppa ja {fiinna}, alit ja dassĂĄ lassin oalle vealtameahttun bĂĄruhĂĄmat harmoniija.
	## Su musihkka lea poehtalaĆĄ ja das lea roavis ja ihĂĄna {ÄĂĄppa} ja {fiinna}.
	#$ SĂĄmi mĂĄilmmiartista Sofia Jannok lea duostilis, Äeahpes nuorra nieida gii ii bala mĂĄtkkoĆĄtit.
    ## SpĂĄbba ii leat geahppa nu go lĂĄve.
    #$ DikĆĄui gullet gĂĄrrenmirkovĂĄttut, geahppa psykalaĆĄ vĂĄttut, nugo depreĆĄuvnnat ja ballu.
    #$ Lea go duohta ahte leat visot dĂĄid govaid ieĆĄ rĂĄhkadan?
    #$ Danne ĂĄvĆŸĆŸuhan buohkaid dan geavahit, go dat leat boares, geahppa ja oanehis sĂĄtni, lohkĂĄ SĂĄmedikki giellastivrra joÄiheaddji Rolf Olsen.
    #$ LĂĄrin lei stuorĂĄmus buot 10. luohkĂĄ bĂĄrtniin. --- is stuorĂĄmos wrong here Ritva?
    #$ De lei muhtin skuvla-beaivi go son lei earenoamĂĄĆĄ vĂĄibbas. - Ritva is earenoamĂĄĆĄ ok here?
    ## Su namma lea Emma Elliane, lea beare 16 jagi boares ja lea ge jo almmuhan vuosttaĆĄ CD-skearru.
    #$ Dat rieban maid mii lĂĄvet hĂĄrdit, lea boares, {Äalmmehis} - muhto hui belljes rieban mii orru duos RiebanvĂĄris, Äilgii Vilge.
	    
ADD:xsyn-attr-sgnom (&syn-attr-sgnom) TARGET (A Attr) IF (1 CC OR COMMA LINK 1 &syn-attr-sgnom)(NEGATE 0 <AttrPred>);
	## Su musihkka lea poehtalaĆĄ ja das lea roavis ja ihĂĄna {ÄĂĄppa} ja fiinna.
COPY:syn-attr-sgnom (A Sg Nom SUGGEST) EXCEPT (A Attr &syn-attr-sgnom) TARGET (A &syn-attr-sgnom) ;
	#$ Dat rieban maid mii lĂĄvet hĂĄrdit, lea {boares}, Äalmmehis - muhto hui belljes rieban mii orru duos RiebanvĂĄris, Äilgii Vilge.
		
