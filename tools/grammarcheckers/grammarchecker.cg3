LIST RASTA-PLACE = "أ،vإ¾إ¾i" "أ،hpi" "deatnu"آ "ؤچoalbmi" "eatnu" "geaidnu" "gurra" "jeaggi" "jأ،vri" "johka" "johtolat" "leahki" "luodda" "luobbal" "mأ،ؤ‘idja" "moallasأ،hcu" "nuorri" "roahؤچi" "rأ،dji" "rأ،إ،إ،a" "raإ§إ§i" "reservأ،htta" "ruovddأ،إ،" "savu" "savvon" "skurؤچu" "vأ،ggi" "إ،allju" ; #mearra?
LIST BADJEL-PLACE = "buolإ¾a" "buovda" "buolda" "ؤچavil" "ؤچielgi" "ؤچearru" "ؤچorru" "duottar" "dievvأ،" "etnan" "eana" "geaidnu" "maras" "gobba" "njأ،rga"  "rأ،إ،إ،a" "vأ،rri"  ;
LIST ؤŒAؤگA-PLACE = "أ،vإ¾إ¾i" "vuovdi" "vuopmi" "soavvu" "rohtu" "lأ،njas" ;
LIST MIELDE-PLACE = "إ،aldi" "ؤچأ،hci" "sildi" ;

