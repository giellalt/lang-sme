LIST MUITALIT = "ĂĄrvalit" "bivdit" "boagustit" "cealkit" "cuoigut" "Äilget" "Äurvet" "Äuorvut" "dadjat" "geardduhit" "gielistit" "gilljut" "hĂĄllat" "hoallat" "huikit" "huikkĂĄdit" "imaĆĄtallat" "jearrat" "jievĆŸat"  "juoigat" "jurdilit" "jurddaĆĄit" "kommenteret" "lĂĄvlut" "lasihit" "loahpahit" "lohkat" "lohpidit" "mĂĄidnut" "mĂĄinnaĆĄit" "muitalit" "muittuhit" "nĂĄgget" "njĂĄvggĂĄdit" "oaivvildit" "rĂĄvvet" "savkalit" "sĂĄrdnidit" "ĆĄuohkihit" "vĂĄidalit" "vĂĄruhit" "vĂĄstidit" ;
