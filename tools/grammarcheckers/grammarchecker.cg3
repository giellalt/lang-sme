    # Spacing errors
    # --------------

# Note that some of these rules some times have to span windows â but
# still go exactly one word â which is a little complicated in
# CG. Therefore, we define some templates for going exactly one word
# to the left/right:
TEMPLATE prevWordCrossSent = (-1 (*)) OR (-1 (>>>) LINK *-2< (<<<) BARRIER (<<<)) ;
TEMPLATE nextWordCrossSent = (1 (*))  OR (0  (<<<) LINK *1>  (>>>) BARRIER (>>>) LINK 1 (*)) ;
# In the above template, the first test is the regular, non-spanning
# case â it just goes exactly one word to the right and matches
# anything.
#
# The second test, if the first one didn't match, will only run from
# the last cohort of a window, and will link to the first word of the
# following window. The "0 (<<<)" means "we're the last word", while
# the (>>>) matches the invisible first cohort of the following window
# (and the BARRIER ensures we only cross exactly one window
# boundary). Then we match anything on the following cohort, which is
# the first real cohort of the window.
#
# See http://beta.visl.sdu.dk/cg3/single/#test-spanning for some
# documentation on the < and > modifiers, and
# http://beta.visl.sdu.dk/cg3/single/#templates on templates. The
# below rules use these templates like
# (T:nextWordCrossSent LINK 0 (<someTag>))

## ( ÃĄddejumi

	# Clean up potential punctuation error tagging before making real errors of them
	# ------------------------------------------------------------------------------

	# Remove the <NoSpaceAfterPunctMark> tag if followed by a quote sign:
SUBSTITUTE:RemopveNoSpaceAfterPunctMark (<NoSpaceAfterPunctMark>) (*) TARGET CLB IF (T:nextWordCrossSent LINK 0 QMARK );
#SUBSTITUTE:RemopveNoSpaceAfterPunctMark (<NoSpaceAfterPunctMark>) (*) TARGET ABBR IF (1 PUNCT-RIGHT );

SUBSTITUTE:RemoveNoSpaceAfterPunctMark (<NoSpaceAfterPunctMark>) (*) TARGET ("!") IF (T:nextWordCrossSent LINK 0 ("!"));
	## RÃĄhkat seaguhusa bohttalii, ja biddju de viesu lusa ja de!!!

SUBSTITUTE:RemoveNoSpaceAfterPunctMark (<NoSpaceAfterPunctMark>) (*) TARGET ("?") IF (T:nextWordCrossSent LINK 0 ("?"));

	# Error tags on bad punctuation or missing/extra spaces
	# -----------------------------------------------------

ADD:space-after-paren-beg      (&space-after-paren-beg)       TARGET (<spaceAfterParenBeg>) ;
ADD:space-after-paren-beg-link (&space-after-paren-beg COERROR) TARGET (*) IF (-1 (<spaceAfterParenBeg>) ) ;
ADDRELATION:space-after-paren-beg-rel (RIGHT) (&space-after-paren-beg) TO (1 (COERROR) LINK 0 (&space-after-paren-beg)) ;
COPY:space-after-paren-beg-sugg (VSTR:"$1$2"S SUGGESTWF) TARGET ("<(.*)>"r &space-after-paren-beg) IF
        (1 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;
	## ÃĄddejumi )

ADD:space-before-paren-end      (&space-before-paren-end)       TARGET (<spaceBeforeParenEnd>);
ADD:space-before-paren-end-link (&space-before-paren-end COERROR) TARGET (*) IF (1 (<spaceBeforeParenEnd>) );
ADDRELATION:space-before-paren-end-rel (LEFT) (&space-before-paren-end) TO (-1 (COERROR) LINK 0 (&space-before-paren-end) );
COPY:space-before-paren-end-sugg (VSTR:"$2$1"S SUGGESTWF) TARGET ("<(.*)>"r &space-before-paren-end) IF
        (-1 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;
	## Son gii njeaidÃĄ skÃĄluid ÅĄaddÃĄ eret vuolgit. De galgÃĄ fas cegget skÃĄluid ja ÃĄlgit gaikut.

ADD:space-before-punct-mark (&space-before-punct-mark) TARGET (<SpaceBeforePunctMark>)(NEGATE -1 <SpaceOnRightSide>);
	#$ Paltto (s. 37) ÂŦmÃĄnÃĄt sturrot/mun ieÅĄ boarÃĄsmuvanÂŧ {?}?
ADD:space-before-punct-mark-link (&space-before-punct-mark COERROR) TARGET (*) IF (1 (<SpaceBeforePunctMark>) );
ADDRELATION:space-before-punct-mark-rel (LEFT) (&space-before-punct-mark) TO (-1 (COERROR) LINK 0 (&space-before-punct-mark) );
COPY:space-before-punct-mark-sugg (VSTR:"$2$1"S SUGGESTWF) TARGET ("<(.*)>"r &space-before-punct-mark) IF
        (-1 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;
	## vuosttu  ceggejit
	## ÃĄlgit gaikut.  Stoagus joatkÃĄ
	## maid lea bargu.  â Mun barggan

ADD:double-space-before (&double-space-before)     (<doubleSpaceBefore>);
ADD:double-space-before-link (&double-space-before COERROR) TARGET (*) IF (T:nextWordCrossSent LINK 0 (<doubleSpaceBefore>)) ;
ADDRELATION:double-space-before-rel ($2) (*) FROM (T:nextWordCrossSent LINK 0 (<doubleSpaceBefore>)) ;
ADDRELATION:double-space-before-rel (LEFT) (COERROR) FROM (T:nextWordCrossSent LINK 0 (<doubleSpaceBefore>)) ;
COPY:double-space-before (VSTR:"$2\ $1"S SUGGESTWF) TARGET ("<(.*)>"r &double-space-before) IF
        (T:prevWordCrossSent LINK 0 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;
	# Test sentence: 'Sanner,gii rÃĄÄÄehusas.gii lÃĄvvardaga?Bonju dÃĄn!Lassin.'
	## Sanner,gii                       - works
	## rÃĄÄÄehusas.Europride-festivÃĄla   - does not work
	## lÃĄvvardaga?Bonju                 - does not work
	## rÃĄidovÃĄzzimis!Lassin             - does not work

	# 1. Add error tag on punctuation
LIST no-space-after-punct-OK-before = (")") ("/") ("!") ("?") (","); # ÂŦjna.)Âŧ is OK

#ADD:no-space-after-punct (&no-space-after-punct-mark) TARGET (<NoSpaceAfterPunctMark>) IF (T:nextWordCrossSent) (NOT 1 no-space-after-punct-OK-before)(NEGATE 0 (A Arab));

ADD:no-space-after-punct (&no-space-after-punct-mark) TARGET (<NoSpaceAfterPunctMark>) IF (T:nextWordCrossSent LINK NOT 0 no-space-after-punct-OK-before)(NEGATE 0 (A Arab))(NEGATE 0 Sem/Sign LINK 1 Sem/Sign LINK 1 Sem/Sur)(NEGATE 1 (Num Arab Sg) OR (Num Sem/ID) LINK -1 (";") LINK -1 (Num Arab Sg) LINK *-1 ("ahki") BARRIER (*) - (Num Arab Sg) - (Num Sem/ID) - (";"))(NEGATE 0 (ABBR Gram/IAbbr) LINK 1 COMMA OR CITATION)(NEGATE 0 ("!") LINK 1 ("!"))(NEGATE 0 Sem/Date OR ABBR LINK 1 COMMA OR (";") OR (":"))(NEGATE 0 ("..."))(NEGATE 0 COMMA LINK 1 ("." CLB))(NEGATE 0 ( "." CLB) OR ( "?" CLB) OR ( "!" CLB) OR ( "," CLB) LINK *1> ("Âŧ") OR (""") OR ("'")) (NEGATE 0 ( "?" CLB) OR ( "!" CLB) LINK *1> ( "?" CLB) OR ( "!" CLB))(NEGATE 0 (")") LINK -1 ABBR)(NEGATE 0 ABBR LINK 1 (")")) ;
	#$ ErenoamÃĄÅūit ruoÅ§a gÃĄldut ÄuoÄÄuhit ahte sÃĄmiin ii leat leamaÅĄ ieÅūaset metÃĄlladiÅggaid buvttadus. Muhtin girjjis sÃĄmi kultuvrra birra ÄuoÄÄuhuvvo ahte ÂŦDatni lea ÃĄidna metÃĄlla maid sÃĄmit leat ieÅūa gieÄahallan....Âŧ ja Vaapsteguovllus muitala nuppi girji: ÂŦMetÃĄllas eai rÃĄhkadan sÃĄmit makkÃĄrge ruovttodoallobiergasa. Visot maid dÃĄrbbaÅĄii, son osttii, ja dat ii lean ollu ge.Âŧ
	#$ RÃĄhkat seaguhusa bohttalii, ja biddju de viesu lusa ja de!!!
    #$ ILS ÃĄrvvoÅĄtalai buot geahÄÄalemiid mannan giÄa maid {4.}, 7. ja 10. luohkÃĄid ja vuoÄÄokurssa oahppit ÄaÄahedje.
    #$ DÃĄs buvttÃĄn dÃĄl ieÅūan ÄÃĄllosiid; jearahallamiid ÂŦmearrasÃĄmehoavddainÂŧ {H.}J. Leonardsen, ja Nordkapp SÃĄmiid Searvvi joÄiheddjiin, Ivar Utsi.
    #$ BeaivegirjenotÃĄhtat agis {1;1â3;6.4} leat oktiibuot logi ieÅĄguÄege sturrosaÅĄ ÄÃĄllingirjji, muhto guorahallanÃĄigodaga rÃĄddjema dihte {gÄ. s. 54} geavahan dÃĄs ovcci vuosttaÅĄ girjji agi 3;0.6 rÃĄdjÃĄi, seamma ahkÃĄi goas maÅimus videobÃĄtti materiÃĄla lea bÃĄddejuvvon.
    #$ DÃĄt dovdomearkkat leat maid boazodoalu muohtakarakteriseremis, mas omd. geavahit dajaldagaid assÃĄs geardni dan sadjÃĄi go dÃĄrkilis mihtidemiin, ahte lea omd. 10 cm geardni (Eira {et al.}, 2011, sisa sÃĄddejuvvon).

	# 2. Add error tag + COERROR on the following word (part 1 of extending the blue underline to the following word):

ADD:no-space-after-punct-link (&no-space-after-punct-mark COERROR) TARGET (*) IF (T:prevWordCrossSent LINK 0 (&no-space-after-punct-mark) LINK NOT 0 (COERROR))(NEGATE 1 (Num Arab Sg) OR (Num Sem/ID) LINK -1 (";") LINK -1 (Num Arab Sg) LINK *-1 ("ahki") BARRIER (*) - (Num Arab Sg) - (Num Sem/ID) - (";"))(NEGATE 0 (Num Arab Sg) OR (Num Sem/ID) LINK -1 (";") LINK -1 (Num Arab Sg) OR (Num Sem/ID) LINK -1 ("ahki"))(NEGATE 0 COMMA LINK -1 (ABBR Gram/IAbbr))(NEGATE 0 ("!") LINK 1 ("!"))(NEGATE 0 COMMA LINK 1 ("." CLB))(NEGATE 0 ( "." CLB) OR ( "?" CLB) OR ( "!" CLB) LINK *1> ("Âŧ"))(NEGATE 0 ( "?" CLB) OR ( "!" CLB) LINK *1> ( "?" CLB) OR ( "!" CLB))(NEGATE 0 (")") LINK -1 ABBR)(NEGATE 0 ABBR LINK 1 (")"))  ;
	#$ Agi 2;0 rÃĄjes guorahallanÃĄigodaga loahpageahÄai, ahkkÃĄi 2;10, mÃĄnnÃĄ geavaha 3. persovnna hÃĄmis muhtumin geahnohisdÃĄsat mÃĄddaga.
	#$ Don oainnÃĄt vuolimusas galle sÃĄni galggat ivdnet juohke cealkagis,.

	# 3. Add RIGHT relation on the punctuation (part 2 of extending the blue underline to the following word,
	#    also ensures that the correction will replace the word, not be appended to it):
ADDRELATION:no-space-after-punct-rel (RIGHT) (COERROR) FROM (T:prevWordCrossSent LINK 0 (<NoSpaceAfterPunctMark>)) ;
	# 4. Add suggestions
COPY:no-space-after-punct-sugg (VSTR:"$1\ $2"S SUGGESTWF) TARGET ("<(.*)>"r &no-space-after-punct-mark) IF
        (T:nextWordCrossSent LINK 0 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;

	# No space before parentheses - 1: add error tag on the target cohort:
ADD:no-space-before-parenthesis (&no-space-before-parent-start) TARGET (<NoSpaceBeforeParenBeg>) ;
	## VuoigatvuoÄa LÃĄvdegotti(SVL).
	#$ VuoigatvuoÄa LÃĄvdegotti (SVL).

	# No space before parentheses - 2: add error tag + link on the preceding cohort:
ADD:no-space-before-parenthesis (&no-space-before-parent-start COERROR) TARGET (*) IF ( 1 (&no-space-before-parent-start))(NEGATE 0 <NoSpaceBeforeParenBeg> ) ; # the preceding cohort

	# No space before parentheses - 3: add LEFT relation:
ADDRELATION:no-before-after-parenthesis (LEFT) (COERROR) FROM ( 1 (<NoSpaceBeforeParenBeg>)) ;

	# No space before parentheses - 4: Add suggestions
COPY:no-space-before-parenthesis (VSTR:"$2\ $1"S SUGGESTWF) TARGET ("<(.*)>"r &no-space-before-parent-start) IF
        (-1 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;


	# No space after parentheses - 1: add error tag on the target cohort:
ADD:no-space-after-parenthesis (&no-space-after-parent-end) TARGET (<NoSpaceAfterParenEnd>)(NEGATE 1 CLB OR PUNCT)(NEGATE 0 <LastCohortOfParagraph>) ;
	## VuoigatvuoÄa LÃĄvdegotti(SVL)Äilgehus.
	#$ VuoigatvuoÄa LÃĄvdegotti(SVL).

	# No space after parentheses - 2: add error tag + link on the following cohort:
ADD:no-space-after-parenthesis (&no-space-after-parent-end COERROR) TARGET (*) IF (-1 (&no-space-after-parent-end))(NEGATE 0 <NoSpaceAfterParenEnd> ) ; # the folloowing cohort

	# No space after parentheses - 3: add RIGHT relation:
ADDRELATION:no-space-after-parenthesis (RIGHT) (COERROR) FROM (-1 (<NoSpaceAfterParenEnd>)) ;

	# No space after parentheses - 4: Add suggestions
COPY:no-space-after-parenthesis (VSTR:"$1\ $2"S SUGGESTWF) TARGET ("<(.*)>"r &no-space-after-parent-end) IF
        (1 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;


