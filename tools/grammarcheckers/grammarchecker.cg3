COPY:syn-pers-refl-congruence (PxDu3 SUGGEST) EXCEPT (PxSg1 &syn-pers-refl-congruence) OR (PxSg2 &syn-pers-refl-congruence) OR (PxSg3 &syn-pers-refl-congruence) OR  (PxDu1 &syn-pers-refl-congruence) OR (PxDu2 &syn-pers-refl-congruence) OR (PxPl1 &syn-pers-refl-congruence) OR (PxPl2 &syn-pers-refl-congruence) OR (PxPl3 &syn-pers-refl-congruence) TARGET ("ieÅĄ" Refl &syn-pers-refl-congruence) IF (-1 (Pron Pers Du3));

COPY:syn-pers-refl-congruence (PxPl1 SUGGEST) EXCEPT (PxSg1 &syn-pers-refl-congruence) OR (PxSg2 &syn-pers-refl-congruence) OR (PxSg3 &syn-pers-refl-congruence) OR (PxDu1 &syn-pers-refl-congruence) OR (PxDu2 &syn-pers-refl-congruence) OR (PxDu3 &syn-pers-refl-congruence) OR (PxPl2 &syn-pers-refl-congruence) OR (PxPl3 &syn-pers-refl-congruence) TARGET ("ieÅĄ" Refl &syn-pers-refl-congruence) IF (-1 (Pron Pers Pl1));

COPY:syn-pers-refl-congruence (PxPl2 SUGGEST) EXCEPT (PxSg1 &syn-pers-refl-congruence) OR (PxSg2 &syn-pers-refl-congruence) OR (PxSg3 &syn-pers-refl-congruence) OR (PxDu1 &syn-pers-refl-congruence) OR (PxDu2 &syn-pers-refl-congruence) OR (PxDu3 &syn-pers-refl-congruence) OR (PxPl1 &syn-pers-refl-congruence) OR (PxPl3 &syn-pers-refl-congruence) TARGET ("ieÅĄ" Refl &syn-pers-refl-congruence) IF (-1 (Pron Pers Pl2)); 

COPY:syn-pers-refl-congruence (PxPl3 SUGGEST) EXCEPT (PxSg1 &syn-pers-refl-congruence) OR (PxSg2 &syn-pers-refl-congruence) OR (PxSg3 &syn-pers-refl-congruence) OR (PxDu1 &syn-pers-refl-congruence) OR (PxDu2 &syn-pers-refl-congruence) OR (PxDu3 &syn-pers-refl-congruence) OR (PxPl1 &syn-pers-refl-congruence) OR (PxPl2 &syn-pers-refl-congruence) TARGET ("ieÅĄ" Refl &syn-pers-refl-congruence) IF (-1 (Pron Pers Pl3));



ADD:syn-pers-refl-congruence (&syn-pers-refl-congruence) TARGET (Pron Pers) IF (1 &syn-pers-refl-congruence);

