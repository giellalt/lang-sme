LIST DN-NOUNS = (".*dn.*"r N) ; # d/t-meattأ،hus
ADD:xmsyn-gen-nom (&msyn-gen-nom) TARGET DN-NOUNS IF (0 (N Sg Gen) OR (N Sg Acc) LINK 0 Sem/Hum) (1 Sem/Fem OR Sem/Mal)(*1 Sg3 + V BARRIER GRAMCHK-S-BOUNDARY) ;	 #2nd
