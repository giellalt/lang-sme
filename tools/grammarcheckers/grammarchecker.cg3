#DELETE uncommon
ADD:xreal-njaإ‹gأ،t (&real-njaإ‹gأ،t) TARGET ("njaإ‹gahit" Ind Prs ConNeg) OR ("njaإ‹gahit" Imprt Sg2) OR ("njaإ‹gahit" Imprt ConNeg) OR ("njaإ‹gat" V IV Inf) IF (*-1 (V <TH-Inf>) OR (V <Inf>) BARRIER GRAMCHK-S-BOUNDARY)(NEGATE *0 OBJ BARRIER NPNHA);
COPY:real-njaإ‹gأ،t ("njaإ‹gأ،t" V Inf SUGGEST) EXCEPT ("njaإ‹gahit" Ind Prs ConNeg &real-njaإ‹gأ،t) OR ("njaإ‹gahit" Imprt Sg2 &real-njaإ‹gأ،t) OR ("njaإ‹gahit" Imprt ConNeg &real-njaإ‹gأ،t) OR ("njaإ‹gahit" V IV Inf &real-njaإ‹gأ،t) TARGET (&real-njaإ‹gأ،t) ;
	## Hأ،liidan vأ،rra duإ،إ،e njaإ‹gat dأ،s. &real-njaإ‹gأ،t ligge utstrekt

	# nuorain (nuorrat) vs. (nuoran skjemme, skjemmes)
	# ------------------------------------------------

#DELETE uncommon	
ADD:xreal-nuorain (&real-nuorain) TARGET ("nuorrat" V TV Ind Prs Sg1) - <spelled> (*0 <TH-Com-Any>);  
