	## Go jo orrun bأ،ikkis gos juohke beaivvi lei nu bأ،hkka, de ledje min skuvlafeaskأ،rat olggobealde skuvlavisti, muitala Sarah.
	## {Gأ،magoarrun} ii leange nu أ،lkes bargu, mus ledje suorbmat ja hأ،rdut bأ،vؤچؤچagan jo vuosttas guovtti sأ،vnnji maإ‹إ‹أ،. Oؤ‘ؤ‘a cd:s vielljat ja oabbأ، mielde.

	# previous Prt Sg1 OR PAST-V

LIST PAST-V = "muitit" "vajأ،lduhttit" ;

ADD:real-DerNomActSgGen-PrtSg1 (&real-DerNomActSgGen-PrtSg1) TARGET UT-VERBS IF (0 (Actio Gen) OR (Actio Nom) OR (Der/NomAct N Sg Nom) OR (Der/NomAct N Sg Gen Allegro) OR (Der/NomAct N Ess) OR (Der/NomAg N Ess) OR (Der/NomAct N Sg Loc South Err/Orth))(NEGATE 0 (N Nom) - Actio - Der/NomAct)(*-1 (Pers Nom Sg1) OR CS OR CC OR THEN-CS-ADV OR BOS BARRIER NOT-ADV-PCLE - Com - Loc - ("â€“") LINK *-1 CC OR CS OR Rel OR Interr OR MO-MANge OR ("maid" Adv) LINK *-1 (V Prt) OR PAST-V + Prs)(NEGATE 1 CC LINK *1 (N Nom) BARRIER NPNH)(NEGATE 1 COMMA LINK *1 (N Nom) BARRIER NPNH LINK 1 CC LINK *1 (N Nom) BARRIER NPNH)(NEGATE -1 CC LINK -1 N)(NEGATE *1 Rel OR Interr OR ("mii" Pron) BARRIER NOT-COMMA)(NEGATE 1 Rel OR Interr OR Po)(NEGATE 0 Der/l OR Der/h OR Der/Pass)(NEGATE *1 @<SPRED BARRIER NOT-ADV-PCLE - BE + Ind OR COMMA)(NEGATE 1 BE + Ind LINK *1 Adv BARRIER NOT-ADV-PCLE)(NEGATE -1 ConNeg LINK -1 Neg LINK -1 Loc)(NEGATE 1 PrfPrc)(NEGATE 0 <AG-Nom-Ani> LINK *-1 BE + Ind OR BE + Cond OR BE + (Pot) OR CAN + Ind OR CAN + Cond OR NOT-V + Ind BARRIER NOT-ADV-PCLE - (Pers Nom) - (Adv Sem/Time) - (Adv Sem/Plc) - @OBJ> - @ADVL - (N Loc) - (N Ill) - (N Sg Acc PxSg3) - (N Sg Gen PxSg3) LINK NOT -1 SUBJ + Sem/Animate)(NEGATE 0 (A Ess) LINK -1 GRADE-ADV)(NEGATE 0 &real-DerNomActSgGen-PrfPrc OR (Sg1) - SUGGEST)(NEGATE *1 (V Sg3) BARRIER NOT-ADV-PCLE - @ADVL - @>P - Gen - Acc - @N< -  Symbol)(NEGATE 0 <cohort-with-dynamic-compound>)(NEGATE -1 ("earأ، go") LINK -1 COPULAS) ;
    ## Jearahallamat ledje أ،lgoأ،lggus jurddaإ،uvvon veahأ، summal jearahallamin gos mun dieؤ‘usge {أ،igun} guoskkahit vأ،ldofأ،ttأ،id, muhto goitge ledje rahpasat vaikke makkأ،r lahkonanvugiide.
    ## Ja dat lei ge maid mun {oaإ¾إ¾un}, olles mأ،ilmmi bargosadjin, mأ،ilmmi davimus universitehtas sأ،megiel-baJrin.

	# <TH-FS-Qst> + V + go

ADD:real-DerNomActSgGen-PrtSg1 (&real-DerNomActSgGen-PrtSg1 &real-DerNomActSgGen-PrsSg1) TARGET UT-VERBS IF (0 (Actio Gen) OR (Actio Nom) OR (Der/NomAct N Sg Nom) OR (Der/NomAct N Sg Gen Allegro) OR (Der/NomAct N Ess) OR (Der/NomAg N Ess) OR (Der/NomAct N Sg Loc South Err/Orth))(1 BECAUSE-WHEN)(*-1 VFIN + (<TH-FS-Qst>) BARRIER NOT-ADV-PCLE - Com - Loc - ("â€“"))(NEGATE 1 CC OR COMMA LINK *1 (N Nom) BARRIER NPNH)(NEGATE -1 CC LINK -1 N)(NEGATE *1 Rel OR Interr OR ("mii" Pron) BARRIER NOT-COMMA)(NEGATE 1 Rel OR Interr OR Po)(NEGATE 0 Der/l OR Der/h OR Der/Pass OR PrfPrc)(NEGATE *1 @<SPRED BARRIER NOT-ADV-PCLE - BE + Ind)(NEGATE 1 BE + Ind LINK *1 Adv BARRIER NOT-ADV-PCLE)(NEGATE -1 ConNeg LINK -1 Neg LINK -1 Loc)(NEGATE 1 PrfPrc)(NEGATE 0 <AG-Nom-Ani> LINK *-1 BE + Ind OR BE + Cond OR BE + (Pot) OR CAN + Ind OR CAN + Cond OR NOT-V + Ind BARRIER NOT-ADV-PCLE - (Pers Nom) - (Adv Sem/Time) - (Adv Sem/Plc) - @OBJ> - @ADVL - (N Loc) - (N Ill) - (N Sg Acc PxSg3) - (N Sg Gen PxSg3) LINK NOT -1 SUBJ + Sem/Animate)(NEGATE 0 (A Ess) LINK -1 GRADE-ADV)(NEGATE 0 &real-DerNomActSgGen-PrsSg1 OR &real-DerNomActSgGen-PrfPrc OR (Sg1))(NEGATE *1 (V Sg3) BARRIER NOT-ADV-PCLE - @ADVL - @>P - Gen - Acc - @N< -  Symbol)(NEGATE 0 <cohort-with-dynamic-compound>)(NEGATE -1 ("earأ، go") LINK -1 COPULAS) ;
    ## Go bohten deike jerre orrun go goaؤ‘is ja leago mus TV ja nu ain.

	# CC + previous Sg1 Prt verb

ADD:real-DerNomActSgGen-PrtSg1 (&real-DerNomActSgGen-PrtSg1) TARGET UT-VERBS - Der/d IF (0 (Actio Gen) OR (Actio Nom) OR (Der/NomAct N Sg Nom) OR (Der/NomAct N Sg Gen Allegro) OR (Der/NomAct N Ess) OR (Der/NomAct N Sg Loc South Err/Orth))(*-1 CC OR COMMA OR CS OR THEN-CS-ADV BARRIER (*) - ("sihke") OR ("de") LINK *-1 PrfPrc OR (Prt ConNeg) OR (Ind Prt Sg1) OR PAST-V + (Prs Sg1) BARRIER NOT-ADV-PCLE - Inf - COMMA - Gen - Acc - ("olu") - SUBJ - @ADVL)(NEGATE 1 CC LINK *1 N BARRIER NPNHA)(NEGATE 0 (N Sg Nom) LINK -1 CC OR COMMA LINK -1 (N Sg Nom))(NEGATE 1 COMMA OR CC LINK 1 N LINK 1 CC LINK *1 N BARRIER NOT-Attr)(NEGATE *-1 CC BARRIER NOT-ADV-PCLE - @ADVL> LINK -1 N)(NEGATE -1 CC LINK -1 COMMA LINK -1 (N Sg Nom))(NEGATE *1 Rel OR Interr OR ("mii" Pron) BARRIER NOT-COMMA)(NEGATE 1 Rel OR Interr OR Po OR Num OR Sem/ID)(NEGATE *1 VFIN BARRIER NOT-ADV-PCLE - N - A)(NEGATE 0 Der/l OR Der/h OR Der/Pass OR &real-DerNomActSgGen-PrfPrc)(NEGATE -1 Pr)(NEGATE 1 Po);
	## Dat gal livؤچؤچui borran olbmo, {gaikkodan}, jos livؤچؤچui leamaإ، luovos.
	##  â€“ Lean hأ،rjehallan olu, sihke lأ،vlun ja juoigan, mun muittأ،n goit visot bajiloaivvi. #lأ،vlun  ---> lأ،vlon
	## Go nekten Giegas, de {oaإ¾إ¾un} rأ،vvagiid neaktit nu unnأ،n go vejolaإ،.
	## Danne go in munge goit إ،addan nu hirbmat vأ،ivأ،i go oaإ¾إ¾un dأ،id suohttasiid!

	# with a semantic role dependent right after

ADD:real-DerNomActSgGen-PrtSg1 (&real-DerNomActSgGen-PrtSg1) TARGET UT-VERBS - Der/d IF (0 (Actio Gen) OR (Actio Nom) OR (Der/NomAct N Sg Nom) OR (Der/NomAct N Sg Gen Allegro) OR (Der/NomAct N Ess) OR (Der/NomAct N Sg Loc South Err/Orth))(c آ§ANYROLE)(*1 CC BARRIER CC OR CS OR VFIN LINK 1 (Ind Prt Sg1))(NEGATE 1 CC LINK 1 N)(NEGATE 1 COMMA LINK 1 N LINK 1 CC LINK 1 N)(NEGATE *-1 CC BARRIER NOT-ADV-PCLE - @ADVL> LINK -1 N)(NEGATE -1 CC LINK -1 COMMA LINK -1 (N Sg Nom))(NEGATE *1 Rel OR Interr OR ("mii" Pron) BARRIER NOT-COMMA)(NEGATE 1 Rel OR Interr OR Po OR Num OR Sem/ID)(NEGATE 0 Der/l OR Der/h OR Der/Pass OR PrfPrc OR &real-DerNomActSgGen-PrfPrc)(NEGATE -1 Pr)(NEGATE 1 Po);
    ## â€“ Ja de orrun Malagas vel bealnjealjأ،t jagi ja bargen norgga fitnodaga ovddas, ؤچilge son. #orrun ---> orron

	# ii leat/lea + Comp go jأ،hkkit/doaivvut/dadjat

ADD:real-DerNomActSgGen-PrtSg1 (&real-DerNomActSgGen-PrtSg1) TARGET UT-VERBS - Der/d IF (0 (Actio Gen) OR (Actio Nom) OR (Der/NomAct N Sg Nom) OR (Der/NomAct N Sg Gen Allegro) OR (Der/NomAct N Ess) OR (Der/NomAg N Ess) OR (Der/NomAct N Sg Loc South Err/Orth))(*-1 (Pers Nom Sg1) BARRIER NOT-ADV-PCLE LINK -1 BECAUSE-WHEN LINK -1 (A Nom) OR (A Der/Comp) OR Adv - THEN-CS-ADV LINK *-1 (Neg V) BARRIER (*) - ConNeg - (V Sg3) - Adv - Pcle)(NEGATE 1 CC OR COMMA LINK *1 (N Nom) BARRIER NPNH)(NEGATE -1 CC LINK -1 N)(NEGATE *1 Rel OR Interr OR ("mii" Pron) BARRIER NOT-COMMA)(NEGATE 1 Rel OR Interr OR Po)(NEGATE 0 Der/l OR Der/h OR Der/Pass OR PrfPrc)(NEGATE *1 @<SPRED BARRIER NOT-ADV-PCLE - BE + Ind)(NEGATE 1 BE + Ind LINK *1 Adv BARRIER NOT-ADV-PCLE)(NEGATE 0 <cohort-with-dynamic-compound>);
    ## Seavdnjadasas ii lea nu issoras go mun doaivun.

COPY:real-DerNomActSgGen-PrtSg1 (V TV Ind Prt Sg1 SUGGEST) EXCEPT (Ex/V TV Actio Gen &real-DerNomActSgGen-PrtSg1) OR (Ex/V TV Actio Nom &real-DerNomActSgGen-PrtSg1) OR (Ex/V TV Der/NomAct N Sg Nom &real-DerNomActSgGen-PrtSg1) OR (Ex/V TV Der/NomAct N Sg Gen &real-DerNomActSgGen-PrtSg1) OR (Ex/V TV Der/NomAct N Ess &real-DerNomActSgGen-PrtSg1) OR (Ex/V TV Der/NomAg N Ess &real-DerNomActSgGen-PrtSg1) OR (Ex/V TV Der/NomAct N Sg Loc South Err/Orth &real-DerNomActSgGen-PrtSg1) TARGET (Ex/V TV &real-DerNomActSgGen-PrtSg1) ;


COPY:real-DerNomActSgGen-PrtSg1 (V IV Ind Prt Sg1 SUGGEST) EXCEPT (Ex/V IV Actio Gen &real-DerNomActSgGen-PrtSg1) OR (Ex/V IV Actio Nom &real-DerNomActSgGen-PrtSg1) OR (Ex/V IV Der/NomAct N Sg Nom &real-DerNomActSgGen-PrtSg1) OR (Ex/V IV Der/NomAct N Sg Gen &real-DerNomActSgGen-PrtSg1) OR (Ex/V IV Der/NomAct N Ess &real-DerNomActSgGen-PrtSg1) OR (Ex/V IV Der/NomAct N Sg Loc South Err/Orth &real-DerNomActSgGen-PrtSg1) TARGET (Ex/V IV &real-DerNomActSgGen-PrtSg1) ;
