(NEGATE *-1 (Num Sem/Year) BARRIER NOT-Attr - PrfPrc)
(NEGATE *-1 (Num Rom) BARRIER NOT-Attr - PrfPrc)
(NEGATE *-1 Num BARRIER NOT-Attr - PrfPrc LINK -1 KLASS OR NUMMAR OR COUNTABLE)
(NEGATE *-1 (Arab Ord) BARRIER NPNHA OR Num)
(NEGATE *-1 (Num Sem/ID) BARRIER NPNHA OR Num)
(NEGATE *-1 Num BARRIER NPNHA LINK 0 ("aktan" Adv))
(NEGATE *-1 Num BARRIER NPNHA LINK 1 Dem)
(NEGATE *-1 (Num "<[آ§].*>"r) OR (Num "<.*%>"r) OR ("%") BARRIER NPNHA - Num)
(NEGATE *-1 (Num "<.*[0123456789]-.*>"r) BARRIER NPNHA OR Num)
(NEGATE *-1 (Num Sg Nom) BARRIER NPNHA LINK -1 BE + Sg3 OR BE + Du3 OR BE + Pl3 LINK -1 (Dem Pl Loc) OR (Pers Pl3 Loc) OR (Pers Pl2 Loc) OR (Pers Pl1 Loc)) 
(NEGATE -1 JAHKASAS LINK -1 (Num)) 
(NEGATE -1 NUMUNIT LINK -1 PLURAL-QUANTIFIERS OR Num)
