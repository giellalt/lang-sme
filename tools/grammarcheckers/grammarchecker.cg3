ADD:xreal-vÃĄzzi-vÃĄccii (&real-vÃĄzzi-vÃĄccii) TARGET ("vÃĄzzi" A Sg Nom) OR ("vÃĄzzi" A Sg Gen) OR ("vÃĄzzi" A Sg Acc) OR ("vÃĄzzi" N NomAg Sg Nom) OR ("vÃĄzzi" N NomAg Sg Acc) OR ("vÃĄzzi" N NomAg Sg Gen) IF (NEGATE *0 VFIN BARRIER GRAMCHK-S-BOUNDARY) ;
ADD:xreal-vÃĄzzi-vÃĄccii (&real-vÃĄzzi-vÃĄccii) TARGET ("vÃĄzzi" A Sg Nom) OR ("vÃĄzzi" A Sg Gen) OR ("vÃĄzzi" A Sg Acc) OR ("vÃĄzzi" N NomAg Sg Nom) OR ("vÃĄzzi" N NomAg Sg Acc) OR ("vÃĄzzi" N NomAg Sg Gen) IF (*-1 Nom + Sem/Hum OR Nom + Sem/Org OR Sem/Sur OR Sem/Fem OR Sem/Mal BARRIER GRAMCHK-S-BOUNDARY) ;
COPY:real-vÃĄzzi-vÃĄccii ("vÃĄzzit" V IV Ind Prt Sg3 SUGGEST) EXCEPT ("vÃĄzzi" A Sg Nom &real-vÃĄzzi-vÃĄccii) OR ("vÃĄzzi" A Sg Gen &real-vÃĄzzi-vÃĄccii) OR ("vÃĄzzi" A Sg Acc &real-vÃĄzzi-vÃĄccii) OR ("vÃĄzzi" N NomAg Sg Nom &real-vÃĄzzi-vÃĄccii) OR ("vÃĄzzi" N NomAg Sg Acc &real-vÃĄzzi-vÃĄccii) OR ("vÃĄzzi" N NomAg Sg Gen &real-vÃĄzzi-vÃĄccii) TARGET (&real-vÃĄzzi-vÃĄccii) ;
