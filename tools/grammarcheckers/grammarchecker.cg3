	# lohkkanÂą(verb,conc|lohkan)
	## Romssa bealde leat plĂĄnat mat muitalit guÄe jagi lea almmolaĆĄ lohkkan guÄege orohagas.
	## JietnagirjĂĄi leat nuorat davvisĂĄmegiela nuorta- ja oarjjabeali guovlluin lohkkan ja neaktĂĄn teavsttaid.
	#"<lohkkan>"
#        "lohkka" N Sem/Obj Ess
#solution: "<lohkkan>" lohkat V TV PrfPrc Confused

ADD:real-Ess-PrfPrc (&real-Ess-PrfPrc) TARGET CONC-2 + AT-VERBS IF (0 (V PrfPrc Err/Confused-Ess))(*-1 BE OR NOT-V BARRIER CS OR ("\;") OR (":"))(NEGATE 0 Sem/Hum)(NEGATE -1 CC OR COMMA LINK -1 Ess)(NEGATE 1 CC OR COMMA LINK 1 Ess)(NEGATE -1 CC OR COMMA LINK *-1 Ess BARRIER (*) - COMMA)(NEGATE *0 (<.*-Ess-.*>r) - BE OR (<.*-Acc-.*><.*-Ess-.*>r) BARRIER NOT-ADV-PCLE - OBJ OR @ADVL)(NEGATE -1 Attr OR Gen + Sem/Human);
    ## RomiskurÄu lea jiekĆabaji suddanÄĂĄziid gohppan ceakko skurÄu, mii lea ĂĄlbmotmeahci merkejuvvon luottaid guoras.

    # coordinated subject

ADD:real-Ess-PrfPrc (&real-Ess-PrfPrc) TARGET CONC-2 + AT-VERBS IF (0 (V PrfPrc Err/Confused-Ess))(-1 (N Nom) OR (N <NomGenSg> Sg Gen) LINK *-1 CC BARRIER NOT-ADV-PCLE LINK -1 (N Nom) LINK *-1 BE OR NOT-V BARRIER CS OR ("\;") OR (":"))(NEGATE 0 Sem/Hum)(NEGATE -1 CC OR COMMA LINK -1 Ess)(NEGATE 1 CC OR COMMA LINK 1 Ess)(NEGATE -1 CC OR COMMA LINK *-1 Ess BARRIER (*) - COMMA)(NEGATE *0 (<.*-Ess-.*>r) - BE OR (<.*-Acc-.*><.*-Ess-.*>r) BARRIER NOT-ADV-PCLE - OBJ OR @ADVL)(NEGATE -1 Attr OR Gen + Sem/Human);
	## RĂĄissa joatkkaskuvllas leat badjelaĆĄ 20 oahpaheaddji ja vel girjerĂĄjusbargi lohkkan SĂĄmi kulturmĂĄhtu.


    # adjectival reading

ADD:real-Ess-PrfPrc (&real-Ess-PrfPrc) TARGET CONC-2 + AT-VERBS IF (0 (V PrfPrc Err/Confused-Ess))(-1 GRADE-ADV-2)(NEGATE 0 Sem/Hum)(NEGATE 1 CC OR COMMA LINK 1 Ess)(NEGATE -1 CC OR COMMA LINK *-1 Ess BARRIER (*) - COMMA)(NEGATE *0 (<.*-Ess-.*>r) - BE OR (<.*-Acc-.*><.*-Ess-.*>r) BARRIER NOT-ADV-PCLE - OBJ OR @ADVL)(NEGATE -1 Attr OR Gen + Sem/Human);
    ## Sii Äuige gulul geaidnoguora ja skoalkaledje ain soppiin sabetvuÄÄui dohppan njĂĄhcomuohttaga.

	# Aktio

ADD:real-Ess-PrfPrc (&real-Ess-PrfPrc) TARGET CONC-2 + AT-VERBS IF (0 (V PrfPrc Err/Confused-Ess))(-1 Gen)(1 N)(NEGATE 1 CC  OR COMMA LINK 1 Ess)(NEGATE -1 CC  OR COMMA LINK *-1 Ess BARRIER (*) - COMMA)(NEGATE -1 Attr OR Gen + Sem/Human)(NEGATE *0 (<.*-Ess-.*>r) - BE OR (<.*-Acc-.*><.*-Ess-.*>r) BARRIER NOT-ADV-PCLE - OBJ OR @ADVL);
    ## Tipsa : Jus geahÄat dĂĄrkilit, sĂĄhtĂĄt oaidnit vĂĄrrevilttiin skurÄÄuid lassin maiddĂĄi ÄĂĄzi gohppan healbmerokkiid.

ADD:real-Ess-PrfPrc (&real-Ess-PrfPrc) TARGET CONC-2 + AT-VERBS IF (0 (V PrfPrc Err/Confused-Ess))(NEGATE 0 Sem/Hum)(1 (V Sg3) + COPULAS)(NEGATE 1 CC LINK 1 Ess)(NEGATE -1 CC OR COMMA LINK *-1 Ess BARRIER (*) - COMMA)(NEGATE *0 (<.*-Ess-.*>r) - BE OR (<.*-Acc-.*><.*-Ess-.*>r) BARRIER NOT-ADV-PCLE - OBJ OR @ADVL)(NEGATE -1 Attr OR Gen + Sem/Human);
    ## IskkĂĄriid dahje speidĂĄriid hoahkkan lea nĂĄ : Â«Ălo gearggus! #NOUN!

	# coordination

ADD:real-Ess-PrfPrc (&real-Ess-PrfPrc) TARGET CONC-2 + AT-VERBS IF (0 (V PrfPrc Err/Confused-Ess))(-1 CC LINK -1 PrfPrc LINK *-1 COPULAS OR <TH-Acc-Any><TH-PrfPrc>)(NEGATE 1 CC  OR COMMA LINK 1 Ess);
    ## Isokoski muitala ahte son lea hĂĄleĆĄtan Amoc:in, ja lohkĂĄ artistta heahpanan ja gĂĄhttan daguidis ovddas.

    # Actio Gen instead of PrfPrc

ADD:real-Ess-PrfPrc (&real-Ess-PrfPrc) TARGET CONC-2 + AT-VERBS IF (0 (V PrfPrc Err/Confused-Ess))(1C Po OR Pr)(NEGATE 1 CC  OR COMMA LINK 1 Ess);
    ## "dihte" v1 Po â Dan mii dahkat hĂĄhkkan dihte duoÄaĆĄtusaid mat dĂĄn rĂĄdjĂĄi leat leamaĆĄan vĂĄilevaÄÄat, dan ektui go ahte eanadoallit moitet dan go bohccot guhtot sin gittiin, lohkĂĄ PorsĂĄĆggu gieldda eanandoallohoavda, Ingrid Golten.

    # Actio Nom instead of PrfPrc

ADD:real-Ess-PrfPrc (&real-Ess-PrfPrc) TARGET CONC-2 + AT-VERBS IF (0 (V PrfPrc Err/Confused-Ess))(-1 (N Gen))(1 EOS OR CC)(NEGATE *0 (<.*-Ess-.*>r) - BE OR (<.*-Acc-.*><.*-Ess-.*>r) BARRIER NOT-ADV-PCLE - OBJ OR @ADVL)(NEGATE 1 CC  OR COMMA LINK 1 Ess);
    ## MateriĂĄlaid {hĂĄhkkan}Âą{hĂĄhkan} ja personsuodjalus.
    ## DieÄuid {hĂĄhkkan}Âą{hĂĄhkan}.
    ## 1.2 Diehtojuohkin lahtuide ja lahtuid {hĂĄhkkan}Âą{hĂĄhkan}.
    ## SĂĄmegielalaĆĄ giddagasbargiid {hĂĄhkkan}Âą{hĂĄhkan}.

ADD:real-Ess-PrfPrc (&real-Ess-PrfPrc) TARGET CONC-2 + AT-VERBS IF (0 (V PrfPrc Err/Confused-Ess))(-1 (N Gen) LINK -1 BOS)(*1 (V Sg3) BARRIER GRAMCHK-S-BOUNDARY OR V)(NEGATE *0 (<.*-Ess-.*>r) - BE OR (<.*-Acc-.*><.*-Ess-.*>r) BARRIER NOT-ADV-PCLE - OBJ OR @ADVL)(NEGATE 1 CC  OR COMMA LINK 1 Ess);
    ## Bargiid {hĂĄhkkan}Âą{hĂĄhkan} alit virggiide sĂĄmegielas lea leamaĆĄ vĂĄttis.
    ## 11.3.1 MĂĄnĂĄidgĂĄrdebargiid {hĂĄhkkan}Âą{hĂĄhkan}.
    ## Kap. 684 Boazodoalu RiikkaidgaskasaĆĄ fĂĄga- ja gaskkustanguovddĂĄĆĄ, poasta 1 Doaibmagolut ja 45 Stuorit dĂĄvviriid {hĂĄhkkan}Âą{hĂĄhkan} ja ĂĄimmahuĆĄĆĄan, sĂĄhttĂĄ sirdojuvvot RĂĄÄÄehus ĂĄrvala juolludit 3,3 mill. ruvnno guovddĂĄĆŸa doibmii 2009:is.
    ## Jagi 2008 juolluduvvui 650 000 ruvdno kap. 682, poastta 45 stuorit dĂĄvviriid {hĂĄhkkan}Âą{hĂĄhkan} ja ĂĄimmahuĆĄĆĄan bakte luvvodagaide ja dĂĄvviriidda daid lanjaide mĂĄid GĂĄldu â ĂlgoĂĄlbmotvuoigatvuoÄaid GelbbolaĆĄvuoÄaguovddĂĄĆĄ galgĂĄ geavahit.
    ##  Kap. 682 ĂlgoĂĄlbmotvuoigatvuoÄaid gelbbolaĆĄvuoÄaguovddĂĄĆĄ, poasta 1 Doaibmagolut ja 45 Stuorit dĂĄvviriid {hĂĄhkkan}Âą{hĂĄhkan} ja ĂĄimmahuĆĄĆĄan, sĂĄhttĂĄ sirdojuvvot RĂĄÄÄehus ĂĄrvala 2,9 mill. ruvdnosaĆĄ juolludeami guovddĂĄĆŸa 2009:i doibmii.

COPY:real-Ess-PrfPrc (SUGGEST) EXCEPT (Err/Confused-Ess &real-Ess-PrfPrc) TARGET (Err/Confused-Ess &real-Ess-PrfPrc) ;

COPY:real-Ess-PrfPrc (IV SUGGEST) EXCEPT (TV Err/Confused-Ess &real-Ess-PrfPrc) AFTER V TARGET (TV Err/Confused-Ess &real-Ess-PrfPrc) ;

COPY:real-Ess-PrfPrc (Actio Nom SUGGEST) EXCEPT (PrfPrc Err/Confused-Ess &real-Ess-PrfPrc) TARGET (Err/Confused-Ess &real-Ess-PrfPrc) ;

COPY:real-Ess-PrfPrc (Actio Gen SUGGEST) EXCEPT (PrfPrc Err/Confused-Ess &real-Ess-PrfPrc) TARGET (Err/Confused-Ess &real-Ess-PrfPrc) ;

	# ut-verbs
	# real-DerNomActSgGen-PrfPrc needs to be before real-DerNomActSgGen-PrsSg1
	# the correction can either be PrfPrc or ConNeg which are homonymous
	# --------------------------------------------------

	# "doarrun" Â§RO N <NomGenSg> Sem/Act Sg Nom

SET CLAUSE-END = CC OR CS OR COMMA OR HYPHEN OR EOS;

LIST DERNOMACT-CONFUSION = ("goargu" Ess) ("goargut" Ex/V TV Der/NomAct N Sg Nom) ("goargut" V TV PrfPrc) ("goargut" Ex/V TV Der/NomAct N Sg Gen Allegro) ("viessut" Ex/V TV Der/NomAct N Sg Nom) ("viessut" V IV Actio Nom) ("viessu" N Ess) ("viessut" Ex/V TV Der/NomAct N Sg Gen Allegro) ("viessut" V IV Actio Gen) ;


ADD:real-DerNomActSgGen-PrfPrc (&real-DerNomActSgGen-PrfPrc) TARGET UT-VERBS IF (0 (Actio Gen) OR (Actio Nom) OR (Der/NomAct N Sg Nom) OR (Der/NomAct N Sg Gen Allegro) OR (Der/NomAct N Ess) OR (Der/NomAct N Sg Loc South Err/Orth))(*-1 BE + Ind OR BE + Cond OR BE + (Pot) OR BE + (ConNeg) OR CAN + Ind OR CAN + Cond OR (V <TH-Acc-Any><TH-PrfPrc>) BARRIER NOT-ADV-PCLE - (Pers Nom) - (Adv Sem/Time) - (Adv Sem/Plc) - @OBJ> - SUBJ - @ADVL - (N Loc) - (N Ill) - (N Sg Acc PxSg3) - (N Sg Gen PxSg3) - ("dat") OR PrfPrc LINK NEGATE *-1 (N Sg Nom) OR (Dem Sg Nom) BARRIER NOT-ADV-PCLE - NOT-V + Ind LINK NOT 0 SUBJ OR Sem/Human)(NEGATE 1 CC LINK 1 N)(NEGATE -1 CC LINK -1 N)(NEGATE 0 Ess LINK 1 CC OR Foc/Neg-ge LINK *1 Ess BARRIER NPNHA)(NEGATE 1 Rel OR Interr)(NEGATE 1 Po LINK NOT 1 Gen OR EOS)(NEGATE 1 Gen OR Acc LINK 1 CC LINK 1 Gen OR Acc LINK 1 Po LINK NOT 1 Gen OR EOS)(NEGATE -1 (N Gen) OR (Pers Gen) OR (A Attr) OR BOS OR TV)(NEGATE 0 Der/l OR Der/h OR Der/Pass OR PrfPrc OR DERNOMACT-CONFUSION OR (N Sg Nom) + Sem/Plc)(NEGATE *1 @<SPRED BARRIER NOT-ADV-PCLE - BE + Ind)(NEGATE 1 BE + Ind LINK *1 Adv BARRIER NOT-ADV-PCLE)(NEGATE 1 BE + Ind LINK -2 (Pron Sg Nom) OR (N Sg Nom))(NEGATE -1 ConNeg LINK -1 Neg LINK -1 Loc)(NEGATE 1 PrfPrc)(NEGATE 0 <AG-Nom-Ani> LINK *-1 BE + Ind OR BE + Cond OR BE + (Pot) OR CAN + Ind OR CAN + Cond OR NOT-V + Ind BARRIER NOT-ADV-PCLE - (Pers Nom) - (Adv Sem/Time) - (Adv Sem/Plc) - @OBJ> - @ADVL - (N Loc) - (N Ill) - (N Sg Acc PxSg3) - (N Sg Gen PxSg3) LINK NOT *-1 SUBJ + Sem/Animate OR SUBJ + Sem/Org OR CS BARRIER NOT-ADV-PCLE)(NEGATE 0 (A Ess) LINK -1 GRADE-ADV)(NEGATE 0 @<SPRED OR (N Ess) LINK *1 CLAUSE-END BARRIER NOT-ADV-PCLE - @ADVL - Loc - Gen OR ("guhkĂĄ"))(NEGATE 0 @<SPRED LINK *1 @>P BARRIER NPNHA LINK 1 Po LINK 1 CLAUSE-END OR CC)(NEGATE 0 @<SPRED LINK 1 Adv - ("guhkĂĄ") OR Pcle LINK *1 @>N BARRIER NOT-ADV-PCLE LINK 1 @ADVL LINK 1 CLAUSE-END OR CC)(NEGATE 0 (N Sg Nom) OR (N Ess) LINK 1 Inf - <*Inf>)(NEGATE 0 (N Sg Nom) LINK *1 PrfPrc BARRIER S-BOUNDARY)(NEGATE *1 @<SPRED BARRIER NPNH - Attr)(NEGATE 0 <AG-Nom-Ani> LINK *-1 @SUBJ> - Sem/Human BARRIER S-BOUNDARY) ;
	#(NEGATE 0 (N Sem/Act Sg Nom) LINK NOT *0 SUBJ + Sem/Human BARRIER GRAMCHK-S-BOUNDARY)
	#$ Äujuhuvvo lĂĄvdegotti ÄielggadeapmĂĄi ÄuoggĂĄs 9.9.3.3 gos oaidnĂĄ ahte sĂĄhkkocealkkus lea {gohÄÄun} dihto ĂĄigemearis ÄaÄahit juo ovdalaÄÄas mearriduvvon gohÄÄuma.
    ## Danne go historjjĂĄlaÄÄat lea sĂĄmi servodat ovdĂĄnan politihkalaÄÄat, ii duĆĄĆĄe dainna go leat leamaĆĄ vuollegaĆĄvuoÄain vĂĄlddi luhtte, muhto go vel niehkkeruovddit vel beasadan leat ja sĂĄmepolitihkalaĆĄ fĂĄmut ieĆŸa leat ĂĄigun mearridit sĂĄpmelaÄÄaid dili!
    #$ Dutnje ii heive leat nu njĂĄigun, don gii leat Buhtesnieida, ja leage buoret go leat sihke searvvĂĄlaĆĄ ja movttet, juoga mii dus ii vĂĄillo. #njĂĄigun Essiv
    #$ MĂĄÄidja lea ĂĄrvvoĆĄtallojuvvon vĂĄttisin, ja dan losimus oassi lea goargĆun Noaideduoddara ala. #goargĆun
    #$ DĂĄt lei baicce gohÄÄun, skuvladirektevrras ledje viiddis, dadjat juo buot fĂĄpmudusat oahpaheddjiid virgĂĄibidjat dieid jagiid. #gohÄÄun
    ## â OÄÄa skearrus lean mun hilgun buot mĂĄid ovdal lean buvttadan ja ĂĄibbas rievdadan stiilla, dadjĂĄ son ja muitala ahte musihkka su jeÄÄe ja movttiida lĂĄittas ĂĄrgabeaivvis. #hilgun
    ## MĂĄĆga nissona goddet fuolkkit, go leat rihkkun bearraĆĄa sĂĄvaldagaiguin, ja nu maid sin gudni. #rihkkun
    ## HĂĄlddahus sĂĄhttĂĄ rihkkun Norgga lĂĄgaid go dikte Almmuheaddji OS rĂĄhkadit nissonaviissa. #rihkkun
    #$ Äujuhuvvo lĂĄvdegotti ÄielggadeapmĂĄi ÄuoggĂĄs 9.9.3.3 gos oaidnĂĄ ahte sĂĄhkkocealkkus lea gohÄÄun dihto ĂĄigemearis ÄaÄahit juo ovdalaÄÄas mearriduvvon gohÄÄuma. #gohÄÄun
    ## SĂĄmediggerĂĄÄÄi lea gohÄÄun Äoahkkimii oÄÄajagimĂĄnu 15. b. daid SĂĄmedikki ĂĄirasiiguin geat leat Gasko- ja Davvi-Norgga regionĂĄla dutkanfoanddaid stivrrain. #gohÄÄun ---> gohÄÄon
    #$ â Dat mii suhtada mu lea ahte manin lea nuohttun bissehuvvon duĆĄĆĄe bajit osiin ÄĂĄzĂĄdagas, jus lea unnĂĄn goÄÄoguolli. #nuohttun
    #$

