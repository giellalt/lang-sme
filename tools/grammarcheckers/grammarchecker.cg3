    # ahte vs. go 
    # -----------

ADD:xsyn-go-not-ahte (&syn-go-not-ahte) TARGET THAT-CS IF (*-1 (A Nom) BARRIER NOTCOMMA LINK NOT 0 PrfPrc LINK -1 BOS OR COMMA)(NEGATE -1 N LINK -1 Attr)(*1 GRAMCHK-VFIN BARRIER GRAMCHK-S-BOUNDARY)(NOT -1 BECAUSE-WHEN) (NEGATE -*1 ("nu") BARRIER NOTCOMMA OR NOT-ADV) ;
    ## Buorre ahte boaÄĂĄt. Buorre go boaÄĂĄt.
    #$ Muhtimat dain leat nu erenoamĂĄĆŸat ja ÄalbmĂĄiÄuohcci {ahte} dat leat ĆĄaddan ja meannuduvvon dego luondduipmilin (sieidin) ja olbmot leat bĂĄlvalan daid.
    #$ Lea hui duodalaĆĄ ĂĄĆĄĆĄi {ahte} journalista lea vĂĄkĆĄojuvvon ja gehÄÄon dego ĂĄittan riikka sihkarvuhtii, lohkĂĄ SĂĄmi journalisttaid searvvi joÄiheaddji Mona Solbakk.
#ADD:ahte_go (&syn-go-not-ahte) TARGET THAT-CS IF (*-1 (A Nom) OR (@<SPRED) OR Ess BARRIER GRAMCHK-VFIN)(*1 GRAMCHK-VFIN BARRIER GRAMCHK-S-BOUNDARY)(NOT -1 BECAUSE-WHEN);
    ## Dasa lei sivvan dat, ahte son ÄorbmagoÄii mu reaĆgabĂĄrtnĂĄĆŸa. Dasa lei sivvan dat, go son ÄorbmagoÄii mu reaĆgabĂĄrtnĂĄĆŸa.
    #$ Nu mo dĂĄl lea ĆĄaddan {ahte} Infonuorra lea dego diehtun sĂĄpmelaÄÄaid birra ĂĄlbmogii muÄuid, de lea stĂĄhta ovddasvĂĄstĂĄdus ruhtadit dĂĄkkĂĄr diehtojuohkima, dadjĂĄ Vibeke Larsen.


    # attributive not locative singular
    # ----------------------------------
    
#DELETEÂ SECONDÂ ROUND

ADD:xmsyn-sgloc-attr (&msyn-sgloc-attr) TARGET (A Sg Loc) OR (N Sg Loc) IF (0 IS-ES-A OR IS-A-A OR IS-AS-A)(NEGATE 0 ("guovddĂĄĆĄ") LINK *1 (N Loc))(*1 N BARRIER NPNH)(NEGATE 0 (N Ess))(NEGATE 0 (A Sg Nom) + <AttrPred>) ; #2ndround
	#$ SĂĄB evttohus duste ollislaĆĄvuoÄa olbmo eallimis, gos mii dĂĄhttot nannet doaimmaid sihke mĂĄnĂĄid, nuoraid ja vuorrasiid vĂĄras, dasa lassin lea vel giella ĂĄĆgiruĆĄĆĄan guovddĂĄĆŸis min evttohusas.
   ## Snoranuohtti lea gehppes ja ĂĄlkis veahkkeneavvu.
   ## Riehpponjohka lea ÄĂĄjehuvvon dĂĄs ovdamearkan danin go doppe leat eanemus soahpameahttunvuoÄat leamaĆĄ, muhto maiddĂĄi danin go lea ĂĄlkis ipmirdahtti duogĂĄĆĄ dĂĄkkĂĄr soahpameahttunvuoÄaide.
   ## KulturlĂĄgain lea dehĂĄlaĆĄ Äuokkis Soria Moria-cealkĂĄmuĆĄas ÄaÄahuvvon, mas lea deattuhuvvon ahte rĂĄÄÄehus hĂĄliida vĂĄldit atnui ĂĄlkis, dĂĄbĂĄlaĆĄ kulturlĂĄga mas boahtĂĄ ovdan ahte almmolaĆĄ eisevĂĄlddiin lea kultursuorgĂĄi ovddasvĂĄstĂĄdus.
   ## DĂĄn kurssa fokus DĂĄn kurssa ulbmil lea Äalmmustahttit, ÄĂĄjehit ja oahpahit nuoraide ahte gĂĄvdnojit ĂĄlkis, hĂĄlbbes ja joÄĂĄnis biepmut earret go nu gohÄoduvvon
   ## Stuorimus erohus doaibmavugiid gaskka lea doaluin mat dĂĄlvet guoÄohit siseatnamis, ja doaluin mat dĂĄlvet atnet oarjjabeale riddoeatnamiid {goavis} dĂĄlkkĂĄdat guovlluin.
   ## BĂĄktenjuohtan lea hui {raĆĄis} kulturmuitu, maid sĂĄhttĂĄ vahĂĄguhttit viivvuhis johtolagain guovllus, ja dakkaviÄe nannejuvvui ja viiddiduvvui dat sĂĄvzaĂĄidi mii lea rĂĄhkaduvvon rĂĄddjet viivvuhis johtolaga. 
   ## SĂĄmi searvvuĆĄvuogĂĄdagas eai leat ĂĄrbevirolaÄÄat {Äavgadis} sohkabeliid mielde juhkkojuvvon barggut dahje ĂĄrvuÄeahkkĂĄlas. 
   ## SĂĄmeradio teaksta TV Â« s 11.12.98 lei ÄuovvovaĆĄ ipmirmeahttumis kompromissa hĂĄstalus Ole Henrik Maggas ÄĂĄziid- ja eananvuoigatvuhtii: Â«Mun vĂĄivivuoÄain dieÄĂĄn ahte sĂĄmit sĂĄhttet ĆĄaddat hilgut sĂĄmiid vuoigatvuoÄaid FinnmĂĄrkku rittuinÂ».
   ## â LĂĄvlagis leat jaskadis oasit ja eanet rocka oasit. 
   ## Odne vurkejit divrasis sĂĄmi dĂĄidaga heajos lanjain, ja mii bĂĄllat ahte oasit das sĂĄhttet billaĆĄuvvat. 
	 
ADD:xmsyn-sgloc-attr (&msyn-sgloc-attr) TARGET (A Sg Loc) IF (0 IS-ES-A OR IS-A-A)(1 COMMA OR CC LINK 1 Attr); 
   ## Fitnodaga ulbmil lea ordnet buot gĂĄrvvisin ĂĄlkis, aktiivvalaĆĄ, buotlĂĄgan ja luonddu ustitlaĆĄ olgoĂĄimmu eallima - ja sihkkarastit olgoĂĄimmu luonddu ja kulturvuoÄu.
COPY:msyn-sgloc-attr (Attr SUGGEST) EXCEPT (Sg Loc &msyn-sgloc-attr) TARGET (A &msyn-sgloc-attr) ;     
    
    # genitive not nominative
    # -----------------------

LIST DOUBLE-CONSONANT-NOUNS = (".*httu"r N) (".*nta"r N) (".*rri"r N) (".*stud"r N) (".*stu"r N) (".*sta"r N) (".*hkka"r N) (".*tki"r N) (".*ssi"r N); #CHECK

ADD:xmsyn-sgnom-sggen (&msyn-sgnom-sggen) TARGET (N Sg Nom) IF (0 DOUBLE-CONSONANT-NOUNS + Sem/Hum)(1 ("namma")) ; #2nd
	## DĂĄhttu diehtit oÄÄa vĂĄrrepresideanta nama.
	# generalize "namma"
		
ADD:xmsyn-sgnom-sggen (&msyn-sgnom-sggen) TARGET (A Sg Nom) IF (-1 (";") OR (":") OR ("-") OR COMMA OR PUNCT-LEFT LINK *-1 N BARRIER NOT-ADJ LINK -1 Num)(NEGATE *1 V); #2nd
COPY:msyn-sgnom-sggen (Gen SUGGEST) EXCEPT (Nom &msyn-sgnom-sggen) TARGET (A &msyn-sgnom-sggen) ;	 #2nd
	## Muittalus samid birra lea jorgaluvvon mĂĄĆgga gillii; dĂĄnska, ruoĆ§a, eĆgelas, duiska, ungĂĄra, japana, franska, italia.
	# should be tested
	
# LIST X = "skĂĄbma" ;

ADD:xmsyn-sgnom-sggen (&msyn-sgnom-sggen) TARGET (N Sg Nom) IF (1 N + Acc)(-1 @CNP LINK -1 Acc);	 #2nd
	## Mun dovddan ahte lean vĂĄillahan ritnon muoraid ja {skĂĄbma} Äuovgga, lohkĂĄ Mari. 
	#$ Dasa lassin eai leat Äuoikkat givssideame, lohkĂĄba Johan Mathis Vars ja Ruth Larsen.
COPY:msyn-sgnom-sggen (Gen SUGGEST) EXCEPT (Nom &msyn-sgnom-sggen) TARGET (N &msyn-sgnom-sggen) ; #2nd
			
	# accusative not nominative
	# -------------------------

	
ADD:xsyn-sgnom-sgacc (&syn-sgnom-sgacc) TARGET (N Sg Nom) - <spelled> OR (N Err/Orth Sg Acc) IF (*-1 <TH-Acc-Any> OR <PA-Acc-Any> OR <PR-Acc-Any> BARRIER NPNHA OR Num LINK NONE c Â§TH)(0 DOUBLE-CONSONANT-NOUNS)(NEGATE 0 Â§ANYROLE - Â§AG OR (V SUGGEST))(NEGATE 0 Sem/Hum LINK *-1 <vdic> BARRIER NPNHA)(NEGATE *-1 <TH-ahte> LINK -1 COMMA LINK *-1 VFIN)(NEGATE 0 Acc - Err/Orth)(NEGATE 0 (N Sg Nom) LINK *-1 CC OR COMMA BARRIER NOT-Attr LINK -1 (N Sg Nom))(NEGATE 1 COMMA OR CC LINK 1 N LINK 1 CC LINK *1 N BARRIER NOT-Attr)(NEGATE 0 (V Ind)) ; #2nd
	## Nissonolbmot dahket  otne stuorĂĄmus {oassi} barggu mĂĄilmmis, muhto sii eai oamas eanet go 1 proseantta mĂĄilmmi riggodagaid. 
	#$ Dasa lassin lea RuoĆ§a SĂĄmediggi lohpidan doarjut riikkajoavkku 90 000.-, dieÄiha presideanta â RuoĆ§a SĂĄmediggi lea hĂĄrve dorjon riikkajoavkku ja mii leat ilolaĆĄ go dĂĄl ĂĄddet doarjaga.
	#$ Dat dagahedje ahte earit galge juhkkojuvvot nuvttĂĄ guolĂĄsteddjiide, muhto jus galggai sĂĄhttit oaĆŸĆŸut eari de biddjui mearri man olu dorski fertii unnimusat bivdĂĄn ovtta jagis, jagiin 1987:s 1989 rĂĄdjĂĄi.
	## Jagi 2004:is  rĂĄhkadii Gaup goansta mii lea ain dĂĄl okta dan goansttain FMX:s.
	## Jienasteddjiide sĂĄhttĂĄ ĆĄaddat vĂĄttis ĂĄddet, mo olgeĆĄ- ja ovddĂĄdusbellodat sĂĄhtiba ovddidit oktasaĆĄ sĂĄmepolitihkka  jus dĂĄt bellodagat fidnejit rĂĄÄÄehus vĂĄlddi boahtte ÄavÄÄa Stuorradikke vĂĄlggain.
	
ADD:xsyn-sgnom-sgacc (&syn-sgnom-sgacc) TARGET (N Sg Nom) OR (N Err/Orth Sg Acc) IF (1 CC LINK 1 Â§TH LINK p <TH-Acc-Any> OR <PA-Acc-Any> OR <PR-Acc-Any>)(0 DOUBLE-CONSONANT-NOUNS)(NEGATE 0 Â§ANYROLE - Â§AG OR (V SUGGEST))(NEGATE 0 Sem/Hum LINK *-1 <vdic> BARRIER NPNHA)(NEGATE *-1 <TH-ahte> LINK -1 COMMA LINK *-1 VFIN)(NEGATE 0 Acc - Err/Orth) ; #2nd
	## Jus mii nannet mĂĄhttu  ja diÄolaĆĄvuoÄa dĂĄid birra dutkamuĆĄaid bokte, de lea ĂĄlgoĂĄlbmogiidda ĂĄlkit ĂĄkkastallat ĂĄigumuĆĄaid ja politihka, muitala Retter.
	## NRK filbmii olles su mĂĄtki ja ÄĂĄjehedje dan TV's.
	#$ MuÄui mun gal liikon buot, muhto buoremusaid searvvis leat Eagles, Metallica, Iron Maiden, Jan Garbarek, ja Mari Boine, oaivvilda musihkka ĂĄĆgiris almmĂĄi. DUOMMĂ: ok
		
	# subject inbetween
	
ADD:xsyn-sgnom-sgacc (&syn-sgnom-sgacc) TARGET (N Sg Nom) OR (N Err/Orth Sg Acc) IF (-1 (N Nom) + Sem/Human LINK *-1 <TH-Acc-Any> OR <PA-Acc-Any> OR <PR-Acc-Any> BARRIER NPNHA OR Num)(0 DOUBLE-CONSONANT-NOUNS)(NEGATE 0 Â§ANYROLE - Â§AG OR (V SUGGEST))(NEGATE 0 Sem/Hum LINK *-1 <vdic> BARRIER NPNHA)(NEGATE *-1 <TH-ahte> LINK -1 COMMA LINK *-1 VFIN)(NEGATE 0 Acc - Err/Orth) ;	#2nd
	## Jagi 2004:is rĂĄhkadii Gaup goansta mii lea ain dĂĄl okta dan goansttain FMX:s.  

ADD:xsyn-sgnom-sgacc (&syn-sgnom-sgacc) TARGET (N Err/Orth Sg Acc) IF (lp <TH-Acc-Any>)(NEGATE 0 Sem/Hum OR Sem/Mal OR Sem/Fem OR Sem/Sur LINK *-1 <vdic> BARRIER NPNHA)(NEGATE *-1 <TH-ahte> LINK -1 COMMA LINK *-1 VFIN)(NEGATE 0 (Sg Nom) OR (Sg Acc) - Err/Orth OR (A Attr)) ; #2nd
	#$ NĂĄ mii oaĆŸĆŸut sĂĄmi ja ĂĄlgoĂĄlbmot perspektiivva buot oahpahusas.
	## SĂĄmediggi berre dĂĄs doallat vuollegis profiila.
	#$ Manne mii eai daid sĂĄhte geavahit dan sadjĂĄi go Äuovvut ameriikkalaĆĄ vieruid, loahpaha Johnsen ja muitala vuosttaĆĄ Soigosat doalut dollojuvvojedje 2003 njukÄamĂĄnus.
			
COPY:syn-sgnom-sgacc (SUGGEST) EXCEPT (Err/Orth Err/Orth-nom-acc &syn-sgnom-sgacc) OR (Err/Orth &syn-sgnom-sgacc) TARGET (Err/Orth N &syn-sgnom-sgacc) ; #2nd
COPY:syn-sgnom-sgacc (Acc SUGGEST) EXCEPT (Nom &syn-sgnom-sgacc) TARGET (N &syn-sgnom-sgacc)(NOT 0 Err/Orth) ; #2nd
	

    # nominative not genitive
    # -----------------------

ADD:xmsyn-gen-nom (&msyn-gen-nom) TARGET (N Sg Gen) IF (*-1 (Pron Dem Sg Nom) BARRIER NPNH)(*1 Der/Pass BARRIER GRAMCHK-S-BOUNDARY)(NEGATE 0 Sem/Time OR Sem/Route)(NEGATE 0 @>P LINK *1 Po BARRIER NPNHA) ;  #2nd
	## DĂĄt lea smĂĄvit mĂĄnĂĄide rĂĄhkaduvvon, danne leat dĂĄs lĂĄvlagat maiet doaĆĄkkut  gieÄaid, ja maiddai  leat das lĂĄvlagat maidda mĂĄnĂĄt sĂĄhttet lihkadit go gullet lĂĄvlagiid.
	#$ DĂĄhpĂĄhuvvĂĄ go dat {SĂĄmelĂĄga} dahje {VuoÄÄolĂĄga} bokte, ferte maĆĆil veardiduvvot lagabut.
	# needs to be tested

LIST DN-NOUNS = (".*dn.*"r N) ; # d/t-meattĂĄhus
ADD:xmsyn-gen-nom (&msyn-gen-nom) TARGET DN-NOUNS IF (0 (N Sg Gen) OR (N Sg Acc) LINK 0 Sem/Hum) (1 Sem/Fem OR Sem/Mal)(*1 Sg3 + V BARRIER GRAMCHK-S-BOUNDARY) ;	 #2nd
	## Eatni Inger Anne Siri Triumf ii loga ĂĄrvalusa ĂĄvkin su niidii gii vĂĄzzĂĄ privĂĄhta joatkkaskuvlla.
	
ADD:xmsyn-gen-nom (&msyn-gen-nom) TARGET DOUBLE-CONSONANT-NOUNS IF (0 (N Sg Gen) OR (N Sg Acc) LINK 0 Sem/Hum OR Sem/Org) (1 Sg3 + V)(-1 CS)(NEGATE *1 (N Sg Nom)) ;	 #2nd
	## Olli lohkĂĄ ĂvjovĂĄris vĂĄlgaguovllus hĂĄlidan sĂĄmegielat presideantta ja lohkĂĄ buorre go vĂĄrrepresideantta hĂĄlddaĆĄa sĂĄmegiela.
	# needs to be tested

COPY:msyn-gen-nom (Nom SUGGEST) EXCEPT (Gen &msyn-gen-nom) OR (Acc &msyn-gen-nom) TARGET (N &msyn-gen-nom) ;  #2nd	
	#in errors.xml
	
    # nominative not accusative in passive constructions
    # ----------------------------------------------



ADD:xmsyn-pron-acc-nom (&msyn-pron-acc-nom) TARGET (Pron Acc) OR (Pron Gen) IF (0 Sem/Animate)(*1 (Ind Prs Sg3) + COPULAS BARRIER NOT-ADV-PCLE LINK *1 Der/Pass LINK 0 <TH-Nom-Ani> OR <PA-Nom-Ani>) ;  #2nd
	## Dan sivas su lea Äuohpaduvvon guovtte hĂĄve sihke Oslos ahte Helssegis.
	
COPY:msyn-pron-acc-nom (Nom SUGGEST) EXCEPT (Acc &msyn-pron-acc-nom) OR (Gen &msyn-pron-acc-nom) TARGET (Pron &msyn-pron-acc-nom);  #2nd

    
    # time adverbial in accusative/genitive case
    # ------------------------------------------
