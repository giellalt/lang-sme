	#grade III
	#uhؤچؤچut

LIST CONC-2-GRADE-II  = (".*hc[aأ،eiou].*"r) (".*hؤچ[aأ،eiou].*"r) (".*hk[aأ،eiou].*"r) (".*hp[aأ،eiou].*"r) (".*ht[aأ،eiou].*"r) ;
	#ohcat, lأ،hؤچit

LIST CONC-GRADE-I  = (".*[aأ،eiou]ؤ‘[aأ،eiou].*"r) (".*[aأ،eiou]f[aأ،eiou].*"r) (".*[aأ،eiou]l[aأ،eiou].*"r) (".*[aأ،eiou]hl[aأ،eiou].*"r)
("vأ،ilut") 
(".*[aأ،eiou]m[aأ،eiou].*"r) (".*[aأ،eiou]n[aأ،eiou].*"r) (".*[aأ،eiou]nj[aأ،eiou].*"r) (".*[aأ،eiou]إ‹[aأ،eiou].*"r) (".*[aأ،eiou]r[aأ،eiou].*"r) (".*[aأ،eiou]hr[aأ،eiou].*"r) (".*[aأ،eiou]s[aأ،eiou].*"r) (".*[aأ،eiou]إ،[aأ،eiou].*"r) (".*[aأ،eiou]إ§[aأ،eiou].*"r) (".*[aأ،eou]v[aأ،eiou].*"r) (".*^[aأ،eou]*iv[aأ،eiou].*"r) (".*[aأ،eiou]z[aأ،eiou].*"r)
(".*[aأ،eiou]إ¾[aأ،eiou].*"r) (".*[aأ،eiou]g[aأ،eiou].*"r) (".*[aأ،eiou]b[aأ،eiou].*"r) (".*[aأ،eiou]j[aأ،eiou].*"r);
	# ؤ‘, f, l, hl, m, n, nj, إ‹, r, hr, s, إ،, إ§, v, z, إ¾, g, b, j leat grade I ja makkأ،r joavku


LIST CONC-3A = (".*bb.*"r) (".*dd.*"r) (".*gg.*"r) (".*zz.*"r) (".*إ¾إ¾.*"r) ;
	#grade III
	#includes ddj

LIST CONC-3A-GRADE-II = (".*[aأ،eiou]dj[aأ،eiou].*"r) ;
	# vuodjit, vuodjat

LIST CONC-3B = (".*rbm.*"r) (".*rdn.*"r) (".*rgإ‹.*"r) ;
	#grade III

LIST CONC-3C = (".*bm.*"r) (".*dn.*"r) (".*gإ‹.*"r) ;
	#grade III

LIST CONC-3C-GRADE-II = (".*[aأ،eiou]pm[aأ،eiou].*"r) (".*[aأ،eiou]tn.*"r) (".*[aأ،eiou]kإ‹[aأ،eiou].*"r) ;
	# oatnut, atnit

SET CONC-3 = CONC-3A OR CONC-3B OR CONC-3C ;

#SUBSTITUTE (V) (V GRADE III) TARGET CONC-3C-GRADE-II ;

SET CONC-GRADE-II = CONC-2-GRADE-II OR CONC-3A-GRADE-II OR CONC-3C-GRADE-II ;

LIST CONC-4A1 = (".*ؤ‘b[aأ،eiou].*"r) (".*ؤ‘g[aأ،eiou].*"r) (".*ؤ‘j[aأ،eiou].*"r) (".*ؤ‘v.*"r) ;

LIST CONC-4A2 = (".*ib[aأ،eiou].*"r) (".*ic[aأ،eiou].*"r) (".*id[aأ،eiou].*"r) (".*if[aأ،eiou].*"r) (".*ig[aأ،eiou].*"r) (".*ik[aأ،eiou].*"r) (".*il[aأ،eiou].*"r)  (".*ihl[aأ،eiou].*"r)  (".*ihm[aأ،eiou].*"r)  (".*ihn[aأ،eiou].*"r) (".*ip[aأ،eiou].*"r) (".*ir[aأ،eiou].*"r) (".*is[aأ،eiou].*"r) (".*it[aأ،eiou].*"r) (".*iv[aأ،eiou].*"r) (".*iz[aأ،eiou].*"r) ;


