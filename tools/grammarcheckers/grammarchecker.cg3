ADD:xreal-muoإ§أ،s (&real-muoإ§أ،s) TARGET ("muoإ§إ§أ،") IF (0 (N Sg Nom PxSg3)) (*1 Po BARRIER GRAMCHK-NPNH) ;
ADD:xreal-muoإ§أ،s (&real-muoإ§أ،s) TARGET ("muoإ§إ§أ،i") IF (0 (A Attr) OR (A Sg Loc) OR (A Sg Nom PxSg3) OR (A Sg Gen PxSg3) OR (A Sg Acc PxSg3)) (*1 Po BARRIER GRAMCHK-NPNH) ;

COPY:real-muoإ§أ،s ("muoإ§إ§أ،" Loc SUGGEST) EXCEPT ("muoإ§إ§أ،" N Sg Nom PxSg3) TARGET (N &real-muoإ§أ،s) ;
COPY:real-muoإ§أ،s ("muoإ§إ§أ،" N Sg Acc PxSg3 SUGGEST) EXCEPT ("muoإ§إ§أ،i" A Attr &real-muoإ§أ،s) OR ("muoإ§إ§أ،i" A Sg Loc &real-muoإ§أ،s) OR ("muoإ§إ§أ،i" A Sg Nom PxSg3 &real-muoإ§أ،s &real-muoإ§أ،s) OR ("muoإ§إ§أ،i" A Sg Acc PxSg3 &real-muoإ§أ،s) OR ("muoإ§إ§أ،i" A Sg Gen PxSg3 &real-muoإ§أ،s) TARGET (A &real-muoإ§أ،s) ;
    ## Ja bisoإ،ii hal doppe nuppiin bieؤ‘agiin ovttas ovtta gaskka â€“ de livؤچؤچii rأ،fi ajihustit go dأ،l ii leat ؤچivga ge boإ‹kime, dat lea viإ¾إ¾ojuvvon gأ،vpogii eatnis olbmuid lusa ja galgأ، orrut muoإ§إ§أ،s luhtte gitta go eatnis varrostuvvأ،.
    
	# njaإ‹gأ،t vs. njaإ‹gat
