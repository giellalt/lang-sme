	## Go Aylito Binayo oarjelulli Etiopias lei gĂĄvcci jahkĂĄsaĆĄ, de fertii heaitit skuvllas Foro gĂĄvpogis.
	## Eikjok mielas sĂĄmi lihkadussii lei dĂĄbĂĄlaĆĄ gitta 1980-logu loahpa rĂĄdjĂĄi deattuhit ahte sĂĄmenissonat eai lean vuoluĆĄtuvvon steammalĂĄhkai go davvi riikkalaĆĄ nissonat ja ahte sĂĄmeservodagas nissonat leat dĂĄsseĂĄrvosaÄÄat almmĂĄi olbmuiguin ( ## davvi-riikkalaĆĄ


COPY:compound (SUGGEST) EXCEPT (Err/SpaceCmp &msyn-compound) OR (Err/Orth Err/SpaceCmp &msyn-compound) OR (Err/Orth-nom-gen Err/SpaceCmp &msyn-compound) OR (Err/Orth-nom-acc Err/SpaceCmp &msyn-compound) OR (Err/Orth-a-ĂĄ Err/SpaceCmp &msyn-compound) OR (Err/Spellrelax Err/SpaceCmp &msyn-compound) TARGET (Err/SpaceCmp);

ADD:msyn-unspace-compound (&msyn-unspace-compound) TARGET (Err/MissingSpace) OR (Err/MissingHyph) ;
	## SĂĄmediggeĂĄirras Randi A. Skum ( NSR ) jearrĂĄ dasto odne gaĆŸaldagaid sĂĄmediggerĂĄÄÄĂĄi ahte mĂĄid lea SĂĄmediggerĂĄÄÄi dĂĄssĂĄĆŸii bargan Äoavdindihti divatgaĆŸaldaga boazodoalus ja makkĂĄr strategiija lea SĂĄmediggerĂĄÄis {ovddasguvlui} oaĆŸĆŸun dihti vuoiggalaĆĄ divatortnega boazodollui.
	## Udmurtat lea {ĂĄlgoĂĄlbmot RuoĆĄĆĄabealde}. Udmurtat lea ĂĄlgoĂĄlbmot RuoĆĄĆĄa bealde.

COPY:compound (SUGGEST) EXCEPT (Err/Orth Err/MissingSpace &msyn-unspace-compound) OR (Err/Orth-a-ĂĄ Err/MissingSpace &msyn-unspace-compound) OR (Err/Orth-nom-acc Err/MissingSpace &msyn-unspace-compound) OR (Err/Orth-nom-gen Err/MissingSpace &msyn-unspace-compound) OR (Err/MissingSpace &msyn-unspace-compound) TARGET (Err/MissingSpace &msyn-unspace-compound);
	## sihkkarastindihti

COPY:compound (SUGGEST) EXCEPT (Err/Orth Err/MissingHyph &msyn-unspace-compound) OR (Err/Orth-a-ĂĄ Err/MissingHyph &msyn-unspace-compound) OR (Err/Orth-nom-acc Err/MissingHyph &msyn-unspace-compound) OR (Err/Orth-nom-gen Err/MissingHyph &msyn-unspace-compound) OR (Err/MissingHyph &msyn-unspace-compound) TARGET (Err/MissingHyph &msyn-unspace-compound);


 # boasttu + N # FLAMMIE HELP
 
ADD:xsyn-boasttu-compound &syn-boasttu-compound TARGET ("boasttu" A Attr Err/Lex) IF (1 N - <spelled>) ;

ADD:xsyn-boasttu-compound &syn-boasttu-compound TARGET N IF (-1 ("boasttu" &syn-boasttu-compound)) ;

ADDRELATION (LEFT) (N &syn-boasttu-compound) TO (-1 ("boasttu" &syn-boasttu-compound)) ;

