LIST LOGAT = ("lohka" N Pl Nom) ("lohka" N Sg Gen PxSg2) ("lohka" N Sg Acc PxSg2)("lohkat" V TV Der/h V TV Imprt Sg2) ("lohkat" V TV Der/h V TV Imprt ConNeg)("lohkat" V TV Der/h V TV Ind Prs ConNeg)("lohkat" V TV Der/d V Imprt Sg2)("lohkat" V TV Der/d V Imprt ConNeg)("lohkat" V TV Der/d V Ind Prs ConNeg)("lohkat" V TV Ind Prs Sg2)("logahit" V TV Imprt Sg2 Gram/3syll)("logahit" V TV Imprt ConNeg)("logahit" V TV Ind Prs ConNeg Gram/3syll)("logadit" V TV Imprt Sg2 Gram/3syll)("logadit" V TV Imprt ConNeg Gram/3syll)("logadit" V TV Ind Prs ConNeg Gram/3syll);

ADD:real-logأ،t (&real-logأ،t) TARGET LOGAT IF (*1 (Sg Nom) + Sem/Hum - A - Prop OR COUNTABLE - Prop OR N + Sem/Time BARRIER NPNHA - Gen - Acc OR Dem OR Prop)(NEGATE *-1 YOU + Nom BARRIER VFIN)(NEGATE -1 (Pcle Qst) LINK -1 Adv LINK -1 BOS) ;
	#$ Maid logat geasset?
    ## Logat luohkأ،laؤچؤچaid joavkojoؤ‘iheaddji Biret Astrid Utsi muitala fas ahte okta njealljadat oassi logat luohkأ،laؤچؤچain leat oإ¾إ¾on guؤ‘eإ¾a ieإ،guؤ‘etge njأ،lmmأ،laإ، fأ،gain, nugo servodatfأ،gain, luonddu- ja birasfagain, eaإ‹galasgielas ja matematihkas.
    ## Sirpmأ، valأ،إ،tallansearvi bovde olbmuid sotnabeaivvi borgemأ،nu logat beaivvi searvat goargإ‹ut bajأ،s Rأ،stegأ،issأ،, mii lea 1066 mehtera bajأ،bealde meara.
    ## Dأ،n girjjis mii leat vأ،ldan logat kapihtala, Skuvllat.
    #$ Dأ، moadde gأ،إ¾aldaga maid sأ،htأ،إ،it smiehtadit go logat ؤچuovvovaإ، kapihtala.
    ## Skuvlenbeaivi dollojuvvo logat beaivve ؤچakؤچamأ،nus.
    ## â€¢ Leat gأ،vcci oahpposaji, ovccأ،t ja logat luohkأ، ohppiide ja skuvllas leat golbma oahpaheaddji.
	## Giellarأ،ؤ‘ؤ‘i lea bidjأ،n أ،igemearri logat beaivأ،i skأ،bmamأ،nus.
	## Soai vأ،zziba goappaإ،agat logat luohkأ،s Kأ،rأ،إ،joga nuoraidskuvllas.
	## Logat luohkأ،laؤچؤچaid joavkojoؤ‘iheaddji Biret Astrid Utsi muitala fas ahte okta njealljadat oassi logat luohkأ،laؤچؤچain leat oإ¾إ¾on guؤ‘eإ¾a ieإ،guؤ‘etge njأ،lmmأ،laإ، fأ،gain, nugo servodatfأ،gain, luonddu- ja birasfagain, eaإ‹galasgielas ja matematihkas.
	## Michael Lindblad, Sأ¥hkie Ubmi sأ،mi searvvi joؤ‘iheaddji, bovde Ubmi logat Sأ،mi vahkkui.

LIST MORE-COUNTABLE = "beaivi" "ceahkki" "geardi" ("geardde" Adv) "hأ،vvi" "kapihtal" "klأ،ssa" "luohkkأ،" ("luohkkأ،" Der/lasj) "sadji" ;


ADD:real-logأ،t (&real-logأ،t) TARGET LOGAT IF (1 MORE-COUNTABLE)(NEGATE *-1 YOU + Nom BARRIER VFIN) ;
	## Ny GIV proإ،eakta jagi 2010, das lei deaddu intensiivaoahpahus lohkamis, ؤچأ،llimis ja rehkenastimis ohppiide geain lea logat luohkأ،s fأ،galaإ، dأ،ssi vuolemusas.
	## Nu movt lea leamaإ، juo ovcci jagi, lأ،giduvvo SGP dأ،n nai jagi, ja leage logat hأ،ve go ؤچaؤ‘ahuvvo.
	## Indigenus Youth gathering ( IYG ) lأ،giduvvo logat geardde dأ،n jagأ،إ، Riddu Riؤ‘ؤ‘us, ja sii fأ،llet stuorat ja viidأ،t progrأ،mma go goassege ovdal.
	## De lأ،giduvvo Mأ،rkomeannu logat geardde.
	## Lأ،vvordaga lei son nubbin buoremus Norgalaإ،, duإ،إ،e Petter Tande إ،attai buorebut su logat sajiin.
	## Oktiibuot leat 95% buot gأ،vccأ،t, ovccأ،t ja logat luohkأ،in Finnmأ،rkku nuoraidskuvllain searvan FRI duhpأ،teastadeaddji proإ،ektii.
	## Skأ،bmamأ،nu logat beaivvi ؤچأ،lihii Finnmأ،rkku Opmodat ( FeFo ) sponsorإ،iehtadusa Finnmأ،rkku spأ،bbaؤچiekؤچan- ja ؤچuoiganbiirriin, mas lea miljovdnasaإ، أ،rvu golmma jahkأ،i ( 2010-2012 ).
	## Ja oؤ‘ؤ‘aseamos oؤ‘as ges sأ،megillii lea ؤچأ،llأ،n Egil Olli mannan mأ،nu logat beaivvi.
	#$ â€“ Mأ،id logat, ahte ii إ،atta dأ،n jagi Sأ،mi_Cupa, lea bat dat gal duohta ?
	## â€“ Mii gal eat إ،at lusttiit borrat klementiinnaid إ،at, lohket Mihkkal أپnte Oskal, Mikkel Eirik Triumf ja Martin Hأ¦tta, sii leat Guovdageainnu nuoraidskuvlla logat klأ،ssa oahppit.
	## Mأ،nأ،idأ،ittardeaddji Reidar Hjermann sأ،gastii ja bأ،lkkaإ،ii Kأ،rأ،إ،joga logat ceahki nuoraid gaskavahku Sأ،medikkis.
	#$ â€“ Min kurssaiguin lea ulbmil ahte nagodat ؤچuovvut sأ،medikki giella أ،igumuإ،aid, ja nu leatge bivdأ،n Sأ،mi_Allaskuvlla, Guovdageainnus, ovttasbargat minguin, muitala Nystad أ،إ‹girit, ja lasiha ahte go sis {logat} sأ،megiela, de lea vejolaإ، Loatnakأ،ssa bokte ohcat sihke stipeandda ja loana.
	## Lars Heaika geavai maإ‹emuإ¾إ¾ii, logat sadjأ،i dأ،n beaivve.
	## Golggotmأ،nu logat beaivvi lea vejolaإ، ؤچatnat reanttu, dieؤ‘iha Dine Penger neahttaaviisa.
	## Unna oassi stأ،hta skuvlla oahppin ؤچeavإ¾أ، logat luohkkأ، iskosa ja fidne School Leaving Certificata, man maإ‹إ‹أ، sأ،httet ohcat Universitehtaide.
	## Sirpmأ، valأ،إ،tallansearvi bovde olbmuid sotnabeaivvi borgemأ،nu logat beaivvi searvat goargإ‹ut bajأ،s Rأ،stegأ،issأ،, mii lea 1066 mehtera bajأ،bealde meara.


ADD:real-logأ،t (&real-logأ،t) TARGET LOGAT IF (-1 ("juohke"));
    ## Okta golbmasis lea bijahan oؤ‘ؤ‘a rأ،innasboaldin muorraommana, ja juohke logat lea bijahan lieggapumppa.


COPY:real-logأ،t ("logأ،t" A Ord Attr SUGGEST) EXCEPT LOGAT TARGET (&real-logأ،t) ;
