	# ===============

LIST COMPOUND = (".*#.*"r) ;


#CSLKDFJ = ؤچohkka fأ،gaؤچأ،lli
#LIWELRJ = muorra fأ،gaؤچأ،lli
#
#$$ CSLKDFJ

ADD:msyn-compound (&msyn-compound) TARGET (Err/SpaceCmp)(NEGATE 0 Err/MissingSpace) ;
	## Danne son dagai mأ،tkki {davvi Sأ،pmأ،i} ja hأ،lahii moadde badjebearraإ،a oktan herggiiguin vuolgit su mielde stuorra ؤچأ،jأ،hussii Parisii 1878.
	## Guollenأ،hkki lea أ،rbevirolaإ، materiأ،la mii geavahuvvo sihke ؤچikإ‹an ja atnu {أ،vnnasin}.
	## Suopmelaإ، oؤ‘ؤ‘aأ،ssiid deattu geaإ¾il sأ،pmelaإ، أ،ssan suttai goittotge johtilit oktii nu, ahte 1500-logus sأ،pmelaؤچؤچat eai إ،at gأ،vdnon {davvi Suomas}.
	## Earأ، ortnegatge vuoruhuvvojit, nugo fievrridandoarjja visot dehأ،laإ، buvttademiide eanadoalus, ja dat mearkkaإ،it ollu {davvi Norgga} fylkkaide.
	#$ nuorttas guvlui
	## Mannan vuossأ،rga lei illu beaivi Kأ،rأ،إ،joga MNP-bearaإ،ossodahkii.
	## Dat lea illu sأ،hka midjiide, go juovlamأ،nus bargguhisvuohta Finnmأ،rkkus lea 3,1 proseantta..
	## Muhto dattege, vaikke vel dأ،t dieؤ‘usge lea illu diehtu sidjiide geat beroإ،tit sأ،megielat girjiin, de boؤ‘ii gielddastivrra mearrأ،dus gieskat veahأ، أ،rtegis vuogi mielde.
	## Mis ii gأ،vdnon sأ،tni, mii devddii dan illu dأ،hpأ،husa.
	## Beroإ،tupmi {gأ،ktegoarrun gursii} lea buoret go goassege livؤچؤچiimet jأ،hkkأ،n, lohkأ، gursajoؤ‘iheaddji Kjellaug Isaksen.
		# what about davvi Middagstind?
	## oإ¾إ¾on bajأ،sإ،attadettiin lulli Burjatia
	## Eanأ،إ، joavkkut bohtet Lulli-Sأ،mi guovlluin, Davvi-Ammarnes guovllus gitta lulli Idre Ruoإ§as, ja Davvi-Maajejaevrie dahje Dearna guovllus gitta Davvi-Troandin Norggas.
	## Go Aylito Binayo oarjelulli Etiopias lei gأ،vcci jahkأ،saإ،, de fertii heaitit skuvllas Foro gأ،vpogis.
	## Eikjok mielas sأ،mi lihkadussii lei dأ،bأ،laإ، gitta 1980-logu loahpa rأ،djأ،i deattuhit ahte sأ،menissonat eai lean vuoluإ،tuvvon steammalأ،hkai go davvi riikkalaإ، nissonat ja ahte sأ،meservodagas nissonat leat dأ،sseأ،rvosaؤچؤچat almmأ،i olbmuiguin ( ## davvi-riikkalaإ،


COPY:compound (SUGGEST) EXCEPT (Err/SpaceCmp &msyn-compound) OR (Err/Orth Err/SpaceCmp &msyn-compound) OR (Err/Orth-nom-gen Err/SpaceCmp &msyn-compound) OR (Err/Orth-nom-acc Err/SpaceCmp &msyn-compound) OR (Err/Orth-a-أ، Err/SpaceCmp &msyn-compound) OR (Err/Spellrelax Err/SpaceCmp &msyn-compound) TARGET (Err/SpaceCmp);

ADD:msyn-unspace-compound (&msyn-unspace-compound) TARGET (Err/MissingSpace) OR (Err/MissingHyph) ;
	## Sأ،mediggeأ،irras Randi A. Skum ( NSR ) jearrأ، dasto odne gaإ¾aldagaid sأ،mediggerأ،ؤ‘ؤ‘أ،i ahte mأ،id lea Sأ،mediggerأ،ؤ‘ؤ‘i dأ،ssأ،إ¾ii bargan ؤچoavdindihti divatgaإ¾aldaga boazodoalus ja makkأ،r strategiija lea Sأ،mediggerأ،ؤ‘is {ovddasguvlui} oaإ¾إ¾un dihti vuoiggalaإ، divatortnega boazodollui.
	## Udmurtat lea {أ،lgoأ،lbmot Ruoإ،إ،abealde}. Udmurtat lea أ،lgoأ،lbmot Ruoإ،إ،a bealde.

COPY:compound (SUGGEST) EXCEPT (Err/Orth Err/MissingSpace &msyn-unspace-compound) OR (Err/Orth-a-أ، Err/MissingSpace &msyn-unspace-compound) OR (Err/Orth-nom-acc Err/MissingSpace &msyn-unspace-compound) OR (Err/Orth-nom-gen Err/MissingSpace &msyn-unspace-compound) OR (Err/MissingSpace &msyn-unspace-compound) TARGET (Err/MissingSpace &msyn-unspace-compound);
	## sihkkarastindihti

COPY:compound (SUGGEST) EXCEPT (Err/Orth Err/MissingHyph &msyn-unspace-compound) OR (Err/Orth-a-أ، Err/MissingHyph &msyn-unspace-compound) OR (Err/Orth-nom-acc Err/MissingHyph &msyn-unspace-compound) OR (Err/Orth-nom-gen Err/MissingHyph &msyn-unspace-compound) OR (Err/MissingHyph &msyn-unspace-compound) TARGET (Err/MissingHyph &msyn-unspace-compound);


# compound or not:

LIST UNLIKELY-COMPOUNDS-1PART = "kultuvra" ;
LIST UNLIKELY-COMPOUNDS-2PART = (".*vierru"r) ;

ADD:msyn-addhyphen (&msyn-addhyphen) TARGET Actio IF (0 Nom LINK 1 CC LINK NOT 0 (@CVP) LINK 1 N + COMPOUND - Prop OR N + <cohort-with-dynamic-compound> - Prop) (NEGATE -1C (&msyn-compound))(NEGATE 0 UNLIKELY-COMPOUNDS-1PART LINK 1 CC LINK 1 UNLIKELY-COMPOUNDS-2PART)(NEGATE 0 Gen LINK 3 Po)(NEGATE 0 $$WORD LINK 2 $$WORD OR (".*$$WORD"r)) ;
