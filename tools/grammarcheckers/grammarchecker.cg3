	# أ،llut (Adv pأ¥ skrأ¥) vs. allut (V)
	# ----------------------------------

	
ADD:xreal-allut-أ،llut (&real-allut-أ،llut) TARGET ("أ،llut" Err/Orth-a-أ، Adv) OR ("allut" V IV Inf) OR ("alludit" V TV Ind Prs ConNeg) OR ("alludit" V TV Imprt ConNeg) OR ("allut" V IV Ind Prs Pl1) OR ("allut" V IV Imprt Pl1) OR ("alludit" V TV VGen) OR ("allut" V IV Imprt Pl2) OR ("alludit" V TV Imprt Sg2) OR ("allut" Ex/V Ex/IV Der/NomAg N Pl Nom) IF (NEGATE *0 ("!"))(NEGATE *-1 NOT-V LINK NOT *1 ConNeg) ;
COPY:real-allut-أ،llut ("أ،llut" Adv SUGGEST) EXCEPT ("أ،llut" Err/Orth-a-أ، Adv &real-allut-أ،llut) OR ("allut" V IV Inf &real-allut-أ،llut) OR ("alludit" V TV Ind Prs ConNeg &real-allut-أ،llut) OR ("alludit" V TV Imprt ConNeg &real-allut-أ،llut) OR ("allut" V IV Ind Prs Pl1 &real-allut-أ،llut) OR ("allut" V IV Imprt Pl1 &real-allut-أ،llut) OR ("alludit" V TV VGen &real-allut-أ،llut) OR ("allut" V IV Imprt Pl2 &real-allut-أ،llut) OR ("alludit" V TV Imprt Sg2 &real-allut-أ،llut) OR ("allut" Ex/V Ex/IV Der/NomAg N Pl Nom &real-allut-أ،llut) TARGET (&real-allut-أ،llut) ;		
	## Buoidun boahtأ، das ahte biebmooppalaإ،vuohta lea allut gosa nu guvlui.
