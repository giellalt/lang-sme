    # in errors.xml
  
ADD:xmsyn-attr-not-pred (&msyn-attr-not-pred) TARGET (A) IF (NOT 0 Attr OR Gen OR @<SPRED OR ABBR LINK NOT 0 (Sg Nom) LINK 0 ADJ_ATTR/NOM OR Comp OR Superl LINK 0 (Sg Nom) LINK *1 CNOUN OR A BARRIER GRAMCHK-NPNH)(NOT 1 Rel) (NEGATE 0 CONGRUENCE-A OR ("riekta") OR Ord - ("nubbi"))(NEGATE *0 MODALS BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN) (NEGATE 0 A LINK 1 COMMA OR CC LINK NOT 1 Attr OR Gen)(NEGATE 0 (N Sg Ill) OR Adv OR <AttrPred>) ;
     #D!
	#$Seamma lea maiddai maÅemus maid dahkkÃĄ ovddal mannÃĄ fas sisa vissui.
    #$ Go buot bivdoÃĄvdnasat leat gÃĄrvÃĄsat, ii leat go vuorddaÅĄit goas ja gokko buorre loddensuddi ÅĄadda.
  
ADD:xmsyn-attr-not-pred (&msyn-attr-not-pred) TARGET (A Sg) IF (NOT 0 Attr OR Gen OR ABBR OR @<SPRED LINK NOT 0 (Sg Nom) LINK 0 ADJ_ATTR/NOM OR Comp OR Superl LINK 1 COMMA OR CC LINK *1 CNOUN OR A BARRIER GRAMCHK-NPNHA)(NOT 1 Rel)  (NEGATE 0 CONGRUENCE-A OR Ord - ("nubbi") OR (Adv Sem/Time)) (NEGATE *0 MODALS BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN) (NEGATE 0 A LINK 1 COMMA OR CC LINK NOT 1 Attr OR Gen)(NEGATE 0 (N Sg Ill) OR Adv OR <AttrPred>) ; 
     #D!
     #$ Nils Einar Samuelsen gullÃĄ DAN eanemus konservatiiva {suorgÃĄi} dain mÃĄÅgga lestadiÃĄnalaÅĄ surggiin.
     #$ Lars Heaika geavai {maÅemuÅūÅūii}, logat sadjÃĄi dÃĄn beaivve.
COPY:attr-not-pred (Attr SUGGEST) EXCEPT (Sg Pl Nom &msyn-attr-not-pred) OR (Sg Gen Err/Orth-nom-gen &msyn-attr-not-pred) OR (Sg Nom &msyn-attr-not-pred) AFTER A TARGET (&msyn-attr-not-pred) ;
	#$ Suoma sÃĄmiid guovddÃĄÅĄsearvvis gal lea diehtu das, ahte gal sÃĄpmelaÄÄat hÃĄleÅĄtit sÃĄmeÃĄÅĄÅĄiin viÅĄÅĄalit, nu SÃĄmedikki vejolaÅĄvuoÄain, dan doaibmavugiin, go maiddÃĄi muhtun ÃĄÅĄÅĄiid serviid Äoahkkimiin, earÃĄ Äoahkkanemiin jnv.
