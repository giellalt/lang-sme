	## Varra lei Kamأ¸yvأ¦ra
	## Geaidnohuksemiidda ii varra lean vuostehأ،hku soaؤ‘i ovdal.	
	
ADD:xreal-vأ،rra (&real-vأ،rra) TARGET ("varra" Sg Nom) OR ("vأ،rra" Adv Err/Spellrelax) IF (*1 (IV Ind Sg3) BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN)(-1 ("gal") LINK *-1 ("dat" Pcle) OR (Pron Sg Nom) BARRIER NOT-ADV-PCLE)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	## Dat gal varra ؤچihkkui muhtun skuffii.
	## Manne lei nu deaإ§alaإ، diktit fylkkamأ،nni dأ،n mearrأ،dusa formأ،laؤچؤچat geahؤچؤچalit ( mii gal varra ii dahkkon ) ?
    
ADD:xreal-vأ،rra (&real-vأ،rra) TARGET ("varra" Sg Nom) OR ("vأ،rra" Adv Err/Spellrelax) IF (1 ("vel") OR ("maiddأ،i") LINK 1 @>N)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	## Oؤ‘ؤ‘a, goalmmأ،t ja varra vel maإ‹imuإ، essayؤچoakkأ،ldat آ« cafe Boddu آ» rأ،iddus lea dأ،l ilbman.
	## Gelddolaإ،, ja varra vel issoras vuordأ،muإ،.
    
ADD:xreal-vأ،rra (&real-vأ،rra) TARGET ("varra" Sg Nom) OR ("vأ،rra" Adv Err/Spellrelax) IF (1 ("danin") OR ("danin go"))(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	##  ) na varra danin go sii leat munnje dan sأ،megiela oahpahan nu, ahte dat dihtet ahte munnje sأ،httأ، jo muhtin veardde goittotge hأ،llat dan.	
	
ADD:xreal-vأ،rra (&real-vأ،rra) TARGET ("varra" Sg Nom) OR ("vأ،rra" Adv Err/Spellrelax) IF (NEGATE *-1 (Ind Sg3) BARRIER GRAMCHK-S-BOUNDARY)(*1 ("danne") BARRIER (*) - BE + (Ind Sg3))(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	## آ Varra danne Canoa Quebradas lea veadjetmeahttun doapmat
	## Varra leige danne son ja su ustibat أ،lggahedje ge Mأ،rkomeanuid.
    
ADD:xreal-vأ،rra (&real-vأ،rra) TARGET ("varra" Sg Nom) OR ("vأ،rra" Adv Err/Spellrelax) IF (-1 ("gal"))(*1 (IV Ind Sg3) BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN LINK 1 @>N OR (A Attr) OR Adv OR Pcle LINK 1 @>N OR (A Attr) OR Adv OR Pcle LINK 1 SUBJ OR N + (Sg Nom))(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	## Gal varra lei veahأ، erenoamaإ، deaivvadeapmi mu ja Hedningarna joavkku gaskkas, mojohallأ، Wimme hilbeslأ،hkai go mun joatkأ،n sأ،gastallama Hedningarna joavkku ovttasbarggus.
	
