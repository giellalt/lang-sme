	# VERBS IN ATTRIBUTIVE POSITION: reduce valencies
	# -----------------------------------------------

LIST PRFPRC-ATTR-V = ("ballat") ;
	
SUBSTITUTE (V <TH-Loc-Any>) V TARGET PRFPRC-ATTR-V + PrfPrc IF (1 Sem/Ani OR Sem/Hum)(NEGATE *-1 BE BARRIER VFIN OR Inf) ;
SUBSTITUTE (V <TH-AktioLoc>) V TARGET PRFPRC-ATTR-V + PrfPrc IF (1 Sem/Ani OR Sem/Hum)(NEGATE *-1 BE BARRIER VFIN OR Inf) ;
SUBSTITUTE (V <TH-Acc-Any><TH-Inf>) V TARGET PRFPRC-ATTR-V + PrfPrc IF (1 Sem/Ani OR Sem/Hum)(NEGATE *-1 BE BARRIER VFIN OR Inf) ;
SUBSTITUTE (V <TH-Acc-Any><TH-PrfPrc>) V TARGET PRFPRC-ATTR-V + PrfPrc IF (1 Sem/Ani OR Sem/Hum)(NEGATE *-1 BE BARRIER VFIN OR Inf) ;
SUBSTITUTE (V <TH-Acc-Any><TH-AktioEss>) V TARGET PRFPRC-ATTR-V + PrfPrc IF (1 Sem/Ani OR Sem/Hum)(NEGATE *-1 BE BARRIER VFIN OR Inf) ;
SUBSTITUTE (V <TH-Acc-Impers>) V TARGET PRFPRC-ATTR-V + PrfPrc IF (1 Sem/Ani OR Sem/Hum)(NEGATE *-1 BE BARRIER VFIN OR Inf) ;
SUBSTITUTE (V <TH-Com-Impers>) V TARGET PRFPRC-ATTR-V + PrfPrc IF (1 Sem/Ani OR Sem/Hum)(NEGATE *-1 BE BARRIER VFIN OR Inf) ;
SUBSTITUTE (V <TH-ahte>) V TARGET PRFPRC-ATTR-V + PrfPrc IF (1 Sem/Ani OR Sem/Hum)(NEGATE *-1 BE BARRIER VFIN OR Inf) ;
SUBSTITUTE (V <TH-jus>) V TARGET PRFPRC-ATTR-V + PrfPrc IF (1 Sem/Ani OR Sem/Hum)(NEGATE *-1 BE BARRIER VFIN OR Inf) ;
SUBSTITUTE (V <TH-go>) V TARGET PRFPRC-ATTR-V + PrfPrc IF (1 Sem/Ani OR Sem/Hum)(NEGATE *-1 BE BARRIER VFIN OR Inf) ;
	## Dan oanehis ĂĄigodagas mii boanddain lea bargat earĂĄ dan botta go oamit leat guohtumis fertejit sii guoÄohit ballan omiid.

