	# أ،idna predicative?
	# -------------------
	
	## Fuomأ،إ، ahte muhtun namaid oktavuoؤ‘as goallossأ،hcu sأ،httأ، leat أ،idna mii ovdanbuktأ، nama(id) ja fuolkevuoؤ‘anamahusa gaskavuoؤ‘a. (ؤŒأ،llinrأ،vagirji, p.26)
	
#DELETE people want to right this
ADD:xsyn-not-aidna (&syn-not-aidna) TARGET ("أ،idna") IF (*1 Rel BARRIER NOT-COMMA OR VFIN)(NEGATE 1 N);
ADD:xsyn-not-aidna (&syn-not-aidna) TARGET Rel IF (*-1 ("أ،idna") BARRIER NOT-COMMA OR (Rel &syn-not-aidna) LINK NEGATE 1 N)(*-1 ("أ،idna" &syn-not-aidna)) ;
ADD:xsyn-not-aidna (&syn-not-aidna) TARGET V IF (0 Sg3 OR Pl3) (*-1 Rel BARRIER V LINK *-1 ("أ،idna") BARRIER NOT-COMMA)(*-1 ("أ،idna" &syn-not-aidna) BARRIER (V &syn-not-aidna));
    ## أپidna gii vأ،ilu dأ،n govas lea bussevuoddji.	Ii vأ،illo earأ، go bussevuoddji dأ،n govas. Vأ،ilu duإ،إ،e bussevuoddji dأ،n govas.
    #$ Dat lea أ،idna vejolaإ،vuohta, mii gأ،vdno.
    #$ Son lei vأ،rra أ،idna oahppi olles nuoraid-skuvllas gii ؤچuovui politihka ja buvttii politihkalaإ، oaiviliid oahpaheddjiide.
    
COPY:syn-not-aidna ("earأ،" Pron Indef Sg Nom SUGGEST) EXCEPT ("أ،idna" A Attr) OR ("أ،idna" Pron Indef Sg Nom) TARGET (A Attr &syn-not-aidna) OR (Pron Indef &syn-not-aidna) ;
COPY:syn-not-aidna ("go" CS SUGGEST) EXCEPT ("gii" Pron Rel Sg Nom) OR ("mii" Pron Rel Sg Nom) OR ("gii" Pron Rel Pl Nom) OR ("gii" Pron Rel Pl Nom) OR ("gii" Pron Rel Sg Gen) OR ("mii" Pron Rel Sg Gen) OR ("gii" Pron Rel Pl Gen) OR ("gii" Pron Rel Pl Gen) TARGET (Rel &syn-not-aidna) ;
COPY:syn-not-aidna (ConNeg SUGGEST) EXCEPT (Sg3) OR (Pl3) TARGET (V &syn-not-aidna) ; 

ADDRELATION:syn-not-aidna (RIGHT $2)("أ،idna" &syn-not-أ،idna) TO (*1 (Rel &syn-not-أ،idna)) ;
ADDRELATION:syn-not-aidna (RIGHT $3)("أ،idna" &syn-not-أ،idna) TO (*1 (V &syn-not-أ،idna)) ;
