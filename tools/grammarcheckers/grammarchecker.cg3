	# okta dain
	
ADD:real-PrtPl3-PrsSg3 (&real-PrtPl3-PrsSg3) TARGET UT-VERBS - <spelled> IF (0 (ConNegII) OR (Ind Prs Du1) OR (Ind Prt Pl3) OR (Imprt ConNegII))(-1 (Dem Pl Loc) LINK -1 ONE + (Num Sg Nom)) (NEGATE *-1 NOT-V BARRIER COMMA OR GRAMCHK-S-BOUNDARY OR CS)(NEGATE 0 (V Sg3) - Err/Orth) ;
    ## DĂĄt njeallje juolggi gullet oktii, ja jus okta dain vĂĄilo, de dutki ferte jearrat alddis lea go son guorahallamin sĂĄmi boazodoalu.


ADD:real-PrtPl3-PrsSg3 (&real-PrtPl3-PrsSg3) TARGET UT-VERBS - <spelled> - Der/h - Der/d  IF (0 (ConNegII) OR (Ind Prs Du1) OR (Ind Prt Pl3) OR (Imprt ConNegII))(*1 (N Sg Nom) - Px - Guess - Coll  - Err/Any - PL3-N - <spelled> OR (Pron Indef Sg Nom) - ("unnĂĄn") - ("mĂĄĆga") - ("moadde") OR (N <NomGenSg> Sg Acc) - @<OBJ - @OBJ> - @>P - Err/Any - @>N OR (N <NomGenSg> Sg Gen) - @>P  - Err/Any - @>N OR (A Sg Nom @<SPRED) BARRIER GRAMCHK-S-BOUNDARY OR CS OR CC OR COMMA OR VFIN OR Inf OR Arab OR (N Coll Nom) OR Num OR ("mĂĄĆga") OR ("moadde") LINK NOT 0 (N Pl Nom) OR (A Attr) OR PrfPrc OR Sem/Org OR Gen - <NomGenSg> - ("juoga") OR @<OBJ OR @OBJ> OR @>P OR @>N OR @-FSUBJ> OR Po OR (Sg Loc) LINK NEGATE 1 CC OR COMMA LINK *1 (N Nom) BARRIER NPNH)(NEGATE *-1 NOT-V BARRIER COMMA OR GRAMCHK-S-BOUNDARY OR CS OR CC OR ConNeg)(NEGATE *-1 (Pl Nom) OR DAT-PRON +  Nom OR (Pers Pl3 Nom) OR (Sem/Org Nom) OR (Prop Sem/Obj Sg Nom) OR (Sg Nom) + Sem/Group OR (V Neg) BARRIER GRAMCHK-S-BOUNDARY OR VFIN OR THEN-CS-ADV OR CS OR CC)(NEGATE -1 COMMA LINK *-1 VFIN BARRIER S-BOUNDARY LINK *-1 Rel BARRIER S-BOUNDARY LINK -1 (N Pl Nom) OR DAT-PRON +  Nom OR (Pers Pl3 Nom) OR (Sem/Org Nom) OR (Prop Sem/Obj Sg Nom) OR (Sg Nom) + Sem/Group)(NEGATE *0 (Pron Pers Du1 Nom) BARRIER NOT-ADV-PCLE - (Adv Subqst))(NEGATE *1 (Pl Nom) OR (Pers Pl3 Nom) OR (Sem/Org Nom) OR (Prop Sem/Obj Sg Nom) OR (Sg Nom) + Sem/Group OR ("dat" Pron Dem Sg Nom) - @>N  OR ("diet" Pron Dem Sg Nom) - @>N OR Num - ONE OR Arab BARRIER NPNHAPcle - PrfPrc - Inf - (Actio Ess))(NEGATE *-1 (N Sg Com) OR (N Pl Loc) - Sem/Hum - Dem BARRIER NOT-ADV-PCLE LINK -1 ("eanemus"))(NEGATE *1 (N Sg Nom) BARRIER GRAMCHK-S-BOUNDARY OR CC OR CS OR COMMA OR VFIN OR Inf OR Arab OR Num LINK 1 COMMA OR CC LINK 1 (N Nom) LINK NEGATE 1 VFIN)(NEGATE -1 CC LINK *-1 (Prt Pl3) BARRIER NPNHA - Gen - Acc - @ADVL)
(NEGATE -1 CC LINK -1 COMMA LINK *-1 (Prt Pl3) BARRIER NPNHA - CITATION - Gen - Acc - @ADVL)
