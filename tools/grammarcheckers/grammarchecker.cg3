	# Pers + Refl congruence
	
LIST xSg1 = Sg1 PxSg1 ; 
LIST xSg2 = Sg2 PxSg2 ; 
LIST xSg3 = Sg3 PxSg3 ; 
LIST xDu1 = Du1 PxDu1 ; 
LIST xDu2 = Du2 PxDu2 ; 
LIST xDu3 = Du3 PxDu3 ; 
LIST xPl1 = Pl1 PxPl1 ;
LIST xPl2 = Pl2 PxPl2 ; 
LIST xPl3 = Pl3 PxPl3 ;  


SET PxPersPers = xSg1 OR xSg2 OR xSg3 OR xDu1 OR xDu2 OR xDu3 OR xPl1 OR xPl2 OR xPl3; #then match on &&Either

#List xSg3 = Sg3 PxSg3 ; could be written as a regex as List xSg3 = /^(?:Px)?Sg3$/r ; but why...
	
ADD:syn-pers-refl-congruence (&syn-pers-refl-congruence) TARGET ("ieإ،" Refl) + &&PxPersPers IF (-1 (Pron Pers) LINK NEGATE 0 &&PxPersPers OR @<OBJ OR ADVLCASE)(NEGATE 1 Po);
	## Doppe go geahؤچؤچأ، ivdnأ،s إ،addofأ،laldagaid sin ieإ¾as hأ،llu iskat daiguin visot sأ،httأ، morihit ieإ،alddes. 
	## Oskkoldatkritihkas ferte danin leat vuoؤ‘ؤ‘u maid ovttaskas osku sأ،httأ، dohkkehit dego sin ieإ¾as. 
	## Makkأ،r jovkui ieإ، vأ،lljet gullat, dat lea du ieإ¾as vأ،lga ja nu sأ،htأ،t das maid vأ،lljet geassأ،dit, vaikko dat maid ii soaitte duإ،إ،e أ،lki. 
	## Son jearai vuos lea go Sأ،medikki dievasؤچoahkkimis luohttأ،muإ، dأ،lأ، rأ،ؤ‘ؤ‘أ،i joؤ‘ihit buإ،eahtain, mii ii leat sin ieإ¾as. 
	## Lea sin ieإ¾as sivva ahte dorohallet, go bahkkejit sarvأ، lusa go lea rahkame, dadjأ، son. Dalle han vأ،ldet dan alcceset go dat lea dego du ieإ¾as, muitala son. 
	## Buot dأ،in lea sin ieإ¾as mearkkaإ،upmi ekologalaإ، dأ،ssأ،laإ،vuhtii ja biologalaإ، mannui. 
	## Musihkkabargobأ،jiin lea mielde Guovssahas-eamiأ،lbmotjoavku, mii oahpaha sin ieإ¾as أ،rbevirolaإ، dأ،nsuma ja musihkka.
	#$ Geahؤچؤچaleimmet gal mأ،إ‹gii su lusa muhto son ii hأ،liidan min ieإ¾as lahka. 
	#$ Son seavestii mu ieإ¾as beavdأ،i, nu sihkkarit ja lunddolaؤچؤچat ahte mannen duoؤ‘aidge ؤچohkkأ،t seamma beavdأ،i inge oppa jurdilange daؤ‘e eanet. 
	#$ Dalle soaitأ، searvi leat almmuhan govaid dus ieإ¾as neahttasiidui. 
	#$ Oahpahusdirektevrra أ،إ،إ،emeannudeaddji logai vel munnje ieإ¾as diehtit ahte mun han إ،attan aإ‹kke juo lohkat, vaikko stipeandda haga, ja danin ii juolludan munnje maidege.
	
COPY:syn-pers-refl-congruence (PxSg1 SUGGEST) EXCEPT (PxSg2 &syn-pers-refl-congruence) OR (PxSg3 &syn-pers-refl-congruence) OR (PxDu1 &syn-pers-refl-congruence) OR (PxDu2 &syn-pers-refl-congruence) OR (PxDu3 &syn-pers-refl-congruence) OR (PxPl1 &syn-pers-refl-congruence) OR (PxPl2 &syn-pers-refl-congruence) OR (PxPl3 &syn-pers-refl-congruence) TARGET ("ieإ،" Refl &syn-pers-refl-congruence) IF (-1 (Pron Pers Sg1));

COPY:syn-pers-refl-congruence (PxSg2 SUGGEST) EXCEPT (PxSg1 &syn-pers-refl-congruence) OR (PxSg3 &syn-pers-refl-congruence) OR (PxDu1 &syn-pers-refl-congruence) OR (PxDu2 &syn-pers-refl-congruence) OR (PxDu3 &syn-pers-refl-congruence) OR (PxPl1 &syn-pers-refl-congruence) OR (PxPl2 &syn-pers-refl-congruence) OR (PxPl3 &syn-pers-refl-congruence) TARGET ("ieإ،" Refl &syn-pers-refl-congruence) IF (-1 (Pron Pers Sg2));

COPY:syn-pers-refl-congruence (PxSg3 SUGGEST) EXCEPT (PxSg1 &syn-pers-refl-congruence) OR (PxSg2 &syn-pers-refl-congruence) OR (PxDu1 &syn-pers-refl-congruence) OR (PxDu2 &syn-pers-refl-congruence) OR (PxDu3 &syn-pers-refl-congruence) OR (PxPl1 &syn-pers-refl-congruence) OR (PxPl2 &syn-pers-refl-congruence) OR (PxPl3 &syn-pers-refl-congruence) TARGET ("ieإ،" Refl &syn-pers-refl-congruence) IF (-1 (Pron Pers Sg3));

COPY:syn-pers-refl-congruence (PxDu1 SUGGEST) EXCEPT (PxSg1 &syn-pers-refl-congruence) OR (PxSg2 &syn-pers-refl-congruence) OR (PxSg3 &syn-pers-refl-congruence) OR  (PxDu2 &syn-pers-refl-congruence) OR (PxDu3 &syn-pers-refl-congruence) OR (PxPl1 &syn-pers-refl-congruence) OR (PxPl2 &syn-pers-refl-congruence) OR (PxPl3 &syn-pers-refl-congruence) TARGET ("ieإ،" Refl &syn-pers-refl-congruence) IF (-1 (Pron Pers Du1));

COPY:syn-pers-refl-congruence (PxDu2 SUGGEST) EXCEPT (PxSg1 &syn-pers-refl-congruence) OR (PxSg2 &syn-pers-refl-congruence) OR (PxSg3 &syn-pers-refl-congruence) OR  (PxDu1 &syn-pers-refl-congruence) OR (PxDu3 &syn-pers-refl-congruence) OR (PxPl1 &syn-pers-refl-congruence) OR (PxPl2 &syn-pers-refl-congruence) OR (PxPl3 &syn-pers-refl-congruence) TARGET ("ieإ،" Refl &syn-pers-refl-congruence) IF (-1 (Pron Pers Du2));

COPY:syn-pers-refl-congruence (PxDu3 SUGGEST) EXCEPT (PxSg1 &syn-pers-refl-congruence) OR (PxSg2 &syn-pers-refl-congruence) OR (PxSg3 &syn-pers-refl-congruence) OR  (PxDu1 &syn-pers-refl-congruence) OR (PxDu2 &syn-pers-refl-congruence) OR (PxPl1 &syn-pers-refl-congruence) OR (PxPl2 &syn-pers-refl-congruence) OR (PxPl3 &syn-pers-refl-congruence) TARGET ("ieإ،" Refl &syn-pers-refl-congruence) IF (-1 (Pron Pers Du3));

COPY:syn-pers-refl-congruence (PxPl1 SUGGEST) EXCEPT (PxSg1 &syn-pers-refl-congruence) OR (PxSg2 &syn-pers-refl-congruence) OR (PxSg3 &syn-pers-refl-congruence) OR (PxDu1 &syn-pers-refl-congruence) OR (PxDu2 &syn-pers-refl-congruence) OR (PxDu3 &syn-pers-refl-congruence) OR (PxPl2 &syn-pers-refl-congruence) OR (PxPl3 &syn-pers-refl-congruence) TARGET ("ieإ،" Refl &syn-pers-refl-congruence) IF (-1 (Pron Pers Pl1));

COPY:syn-pers-refl-congruence (PxPl2 SUGGEST) EXCEPT (PxSg1 &syn-pers-refl-congruence) OR (PxSg2 &syn-pers-refl-congruence) OR (PxSg3 &syn-pers-refl-congruence) OR (PxDu1 &syn-pers-refl-congruence) OR (PxDu2 &syn-pers-refl-congruence) OR (PxDu3 &syn-pers-refl-congruence) OR (PxPl1 &syn-pers-refl-congruence) OR (PxPl3 &syn-pers-refl-congruence) TARGET ("ieإ،" Refl &syn-pers-refl-congruence) IF (-1 (Pron Pers Pl2)); 

COPY:syn-pers-refl-congruence (PxPl3 SUGGEST) EXCEPT (PxSg1 &syn-pers-refl-congruence) OR (PxSg2 &syn-pers-refl-congruence) OR (PxSg3 &syn-pers-refl-congruence) OR (PxDu1 &syn-pers-refl-congruence) OR (PxDu2 &syn-pers-refl-congruence) OR (PxDu3 &syn-pers-refl-congruence) OR (PxPl1 &syn-pers-refl-congruence) OR (PxPl2 &syn-pers-refl-congruence) TARGET ("ieإ،" Refl &syn-pers-refl-congruence) IF (-1 (Pron Pers Pl3));



ADD:syn-pers-refl-congruence (&syn-pers-refl-congruence) TARGET (Pron Pers) IF (1 &syn-pers-refl-congruence);

ADDRELATION ($2 LEFT) (Pron Refl &syn-pers-refl-congruence) TO (-1 (Pron Pers &syn-pers-refl-congruence));


    # gen + jahkأ،saإ، + vahkkusasj, tjiluk, jahkأ،sasj
    # - - - - - - - - - - - - - - - - - - - - - - - -
    
LIST JAHKASAS = "minuhttasaإ،" "sekundasaإ،" "diibmosaإ،" "tiibmosaإ،" "beaivأ،saإ،" "vahkkosaإ،" "mأ،nnosaإ،" "jahkkأ،saإ،" "ruvdnosaإ،" "kruvdnosaإ،"  "jahkأ،saإ،" "tonnasaإ،" "kilosaإ،" "gilosaإ،" "grأ،mmasأ،إ،" "dأ،ssأ،saإ،" "miellahttosaإ،" "siidosaإ،"  "idjasaإ،";

ADD:msyn-gen-numeral-jahkasaإ، (&msyn-gen-numeral-jahkasaإ،) TARGET (Num Sg Nom) IF (NEGATE 0 Arab)(1 JAHKASAS + A) ;

COPY:msyn-gen-numeral-jahkasaإ، (Num Sg Gen SUGGEST) EXCEPT (Num Sg Nom &msyn-gen-numeral-jahkasaإ،) OR (Num Sg Acc &msyn-gen-numeral-jahkasaإ،) OR (Num Sg Nom) TARGET (&msyn-gen-numeral-jahkasaإ،) (NEGATE 0 Arab) ; 

COPY:msyn-gen-numeral-jahkasaإ، (Num Arab Sg Gen SUGGEST) EXCEPT (Num Arab Sg Nom &msyn-gen-numeral-jahkasaإ،) TARGET (Arab &msyn-gen-numeral-jahkasaإ،) ; 


ADDRELATION ($2 RIGHT) (Num &msyn-gen-numeral-jahkasaإ،) TO (1 A - &msyn-gen-numeral-jahkasaإ،) ;

SUBSTITUTE (&msyn-gen-numeral-jahkasaإ،) (co&msyn-gen-numeral-jahkasaإ،) TARGET (SUGGEST);
    ## Politihkalaإ، dأ،sis leat leamaإ، {guokte}آ£{guovtti} jahkأ،saإ، ovttasbargoؤچoahkkima.
    ## Politihkalaإ، dأ،sis leat leamaإ، guokte jahkأ،saإ، ovttasbargoؤچoahkkima.


# Nominative numeral phrase

LIST NUM-INDEF = "galle" "mأ،إ‹ga" "moadde" ;

# Noun


ADD:msyn-numphrase-sgnom (&msyn-numphrase-sgnom) TARGET (N Sg Nom) OR (N Pl Nom) IF (*-1 (Num Sg Nom) - OKTA OR (Num Sg Acc) + NOM-ACC-NUM OR NUM-INDEF + (Sg Nom) OR NUM-INDEF + (Sg Acc) BARRIER NOT-Attr - PrfPrc - GRADE-ADV  - (A <AttrPred> Sg Nom) - (A <AttrPred> Sg Gen) - (A <AttrPred> Sg Acc) - (Pcle Foc/Neg-ge) - (Pcle Foc/Pos-ge) OR JAHKASAS LINK NEGATE -1 KLASS) 
(NEGATE *-1 ("okta") OR ("1") BARRIER NOT-Attr - PrfPrc)
(NEGATE *-1 (Num Sem/Year) BARRIER NOT-Attr - PrfPrc)
(NEGATE *-1 (Num Rom) BARRIER NOT-Attr - PrfPrc)
(NEGATE *-1 Num BARRIER NOT-Attr - PrfPrc LINK -1 KLASS OR NUMMAR OR COUNTABLE)
#(NEGATE *-1 Der/akti BARRIER NPNHA) 
(NEGATE *-1 (Arab Ord) BARRIER NPNHA OR Num)
(NEGATE *-1 (Num Sem/ID) BARRIER NPNHA OR Num)
(NEGATE *-1 Num BARRIER NPNHA LINK 0 ("aktan" Adv))
(NEGATE *-1 Num BARRIER NPNHA LINK 1 Dem)
(NEGATE *-1 (Num "<[آ§].*>"r) OR (Num "<.*%>"r) OR ("%") BARRIER NPNHA - Num)
(NEGATE *-1 (Num "<.*[0123456789]-.*>"r) BARRIER NPNHA OR Num)
(NEGATE *-1 (Num Sg Nom) BARRIER NPNHA LINK -1 BE + Sg3 OR BE + Du3 OR BE + Pl3 LINK -1 (Dem Pl Loc) OR (Pers Pl3 Loc) OR (Pers Pl2 Loc) OR (Pers Pl1 Loc)) 
(NEGATE -1 JAHKASAS LINK -1 (Num)) 
(NEGATE -1 NUMUNIT LINK -1 PLURAL-QUANTIFIERS OR Num)
(NEGATE -1 NUMUNIT LINK -1 Num OR ("moadde"))
(NEGATE -1 Sem/Time)
(NEGATE -1 COMMA OR CC)
(NEGATE -1 CLB)
(NEGATE -1 (PUNCT RIGHT) LINK -1 Num) 
(NEGATE 0 ABBR OR Prop)
(NEGATE 0 ("lohku"))
##(NEGATE 0 ("<[A-Z].*>"r) OR ("<أ….*>"r) OR ("<أ†.*>"r) OR ("<أک.*>"r) LINK -1 (Arab Nom))
##(NEGATE 0 (Der/NomAct Sg Nom) LINK 0 PrfPrc LINK *1 (N Pl Nom)  BARRIER NOT-Attr) 
(NEGATE 0 <spelled> OR &real)
(NEGATE 0 (Sg Nom) LINK 0 GRAMCHK-NOM-GEN-N)
(NEGATE 0 Symbol)
(NEGATE 0 Gram/NomAg OR Der/NomAg)
(NEGATE 0 (Sg Gen) OR Acc);
##(NEGATE 0 Px LINK NOT 0 (Sg Acc PxSg3) OR (Sg Nom PxSg3) OR (Sg Gen PxSg3)) 
	## Sأ،megielas gأ،vdnojit mأ،إ‹ga erenoamأ،إ، ؤچأ،llinmearkkat.
    ## Ja dunji le dأ،rbbo â€“ danen gأ¥ dat le muv garra miella vaj tuvsأ،n {tjalmme} dahki mijأ،v tuvsأ،n gأ¤rddأ،j gievrabu
	#$ HUOM: Dأ،n mأ،nu dأ،iddأ،rat Sأ،mi Dأ،iddaguovddأ،إ¾a ؤچأ،jأ،husas leaba guokte nisson dأ،iddأ،ra.
	#$ Eat mii ovtta mأ،nus nagodan 80. 000 ruvnno golahit, dan dihte إ،attai dat buorrin, ja mis lei vel 20.000 {ruvdno} maid leimmet seasttaإ،eamen jahkeؤچoahkkimii.
	#$ Mii أ،igut dأ،n أ،igodaga bargat dainna ahte Sأ،mi vuoigatvuoؤ‘alأ،vdegotti 2 (SRU2) {ؤچuovvuleapmi} farggamusat jotkojuvvo, dأ،s maid bivdit ahte dat Konsultaإ،uvdnalأ،hka maid ovddit sأ،mediggerأ،ؤ‘ؤ‘i hilggui 2017 giؤ‘a, vأ،ldojuvvo fas أ،rvvoإ،tallamii. 
	## Viidأ،set atnu EO lea meroإ،tallan ahte EO ja Norgga almmolaإ، dieؤ‘uid mأ،rkanأ،rvu lea sullii 200 miljأ،rdda {ruvdno}.
	#$ Guovllu ruonasguohtumat lea duإ،إ،efal 15,0 {km}.
	#$ Nilut Cupa duopmأ،rأ،إ،إ،i : â€“ Lea lohpi oaivvi ATNIT Nils Johan Vars on 27 November, 2010 01:54:00 Anne Marie Therese {Eira} ii ballan moaitit Nilut Cup lأ،gideddjiid media bokte, go su mielas ii lean dohkأ،laإ، duopmأ،r sin ؤچiekؤچamis nissoniid bronsafinأ،las dأ،n jagأ،إ، Nilut Cupa ؤچiekؤچamiin.
	#$ POT balai juo 1950 logus ahte sأ،pmelaؤچؤچain ja Ruoإ،إ،a ovddasteddjiin davvi-kalohtas sأ،httet leat lagas oktavuoؤ‘at. 
	#$ Dأ،n leat stأ،hta alimus orgأ،nat dadjan ieإ¾aset eanemus geatnegahtti vugiin go 1988:as leat dohkkehan Vuoؤ‘ؤ‘olأ،ga paragrأ،fa 110 {a}.آ آ آ¶
	## JUSTA FأپRREN : Isabel ii leat orrun go moadde vأ،hku Leavnnjas, muhto liiko jo Leavnnja hui bures.
	## okta mأ،nnأ،	
	## Vأ،lljet vihtta (5) stivralahttu ja golbma (3) vأ،rrelahttu.
	## Gأ،ivuona suohkana hأ،lddahusa logut ؤچأ،jehit ahte ovddidanossodagas ii leat go guokte proseantta jأ،vkأ،n, ja doavttirbalvalusas duإ،إ،e beannot proseanta.
	#$ Das leat unnimustأ، guokte vearbba: biehttalanvearba ja vأ،ldovearba.
	#$ Ijأ¤s (2011) dutkkus 
	#$ Biehttaleami ol. 1. persovnna grammأ،htalaإ، rivttes hأ،pmi in, dahje jovssoshأ،pmi, ihtأ، mأ،nأ، gillii vuosttaإ، gearddi guovtti jagi ahkأ،saإ¾إ¾an (2;0.0), mas ؤچuovvu njeallje mأ،nu gaskasaإ، boddu, goas eai leat registrerejuvvon biehttalanhأ،mit, ovdalgo biehttaleapmi fas registrerejuvvo 2;2.24-25 (Ijأ¤s 2011: 170).
	# this is kind of a real-word error, but easier to generalize as a syntactic error
	# in errors.xml
	
	# Arab Numphrase
	
ADD:msyn-numphrase-sgnom (&msyn-numphrase-sgnom) TARGET (N Pl Nom) IF (*-1 (Num Arab Sg Nom) OR (Num Arab Sg Acc) BARRIER NOT-Attr - PrfPrc - GRADE-ADV - (A <AttrPred> Sg Nom) - (A <AttrPred> Sg Gen) - (A <AttrPred> Sg Acc) - (Pcle Foc/Neg-ge) - (Pcle Foc/Pos-ge) OR JAHKASAS LINK NEGATE -1 KLASS OR NUMMAR OR COUNTABLE) 
(NEGATE *-1 ("okta") OR ("1") BARRIER NOT-Attr - PrfPrc)
(NEGATE *-1 (Num Sem/Year) BARRIER NOT-Attr - PrfPrc)
(NEGATE *-1 (Num Rom) BARRIER NOT-Attr - PrfPrc)
#(NEGATE *-1 Der/akti BARRIER NPNHA) 
(NEGATE *-1 (Arab Ord) BARRIER NPNHA OR Num)
#(NEGATE *-1 Num BARRIER NPNHA LINK 0 ("aktan" Adv))
(NEGATE *-1 Num BARRIER NPNHA LINK 1 Dem)
(NEGATE *-1 (Num "<[آ§].*>"r) OR (Num "<.*%>"r) OR ("%") BARRIER NPNHA - Num) 
(NEGATE *-1 (Num Sg Nom) BARRIER NPNHA LINK -1 BE + Sg3 OR BE + Du3 OR BE + Pl3 LINK -1 (Dem Pl Ela) OR (Pers Pl3 Ela) OR (Pers Pl2 Ela) OR (Pers Pl1 Ela)) 
(NEGATE -1 JAHKASAS LINK -1 (Num)) 
(NEGATE -1 NUMUNIT LINK -1 PLURAL-QUANTIFIERS OR Num)
(NEGATE -1 NUMUNIT LINK -1 Num OR ("moadde"))
(NEGATE -1 Sem/Time) 
(NEGATE -1 COMMA OR CC OR CLB)
(NEGATE -1 (PUNCT RIGHT) LINK -1 Num) 
(NEGATE 0 ABBR OR Prop)
(NEGATE 0 ("lohku"))
##(NEGATE 0 ("<[A-Z].*>"r) OR ("<أ….*>"r) OR ("<أ†.*>"r) OR ("<أک.*>"r) LINK -1 (Arab Nom))
##(NEGATE 0 (Der/NomAct Sg Nom) LINK 0 PrfPrc LINK *1 (N Pl Nom)  BARRIER NOT-Attr) 
(NEGATE 0 <spelled> OR &real)
#(NEGATE 0 GRAMCHK-NOM-GEN-N)
#(NEGATE 0 Symbol)
#(NEGATE 0 Gram/NomAg OR Der/NomAg)
(NEGATE 0 (Sg Gen) OR Acc);
##(NEGATE 0 Px LINK NOT 0 (Sg Acc PxSg3) OR (Sg Nom PxSg3) OR (Sg Gen PxSg3)) 


COPY:msyn-numphrase-sgnom (Sg Gen SUGGEST) EXCEPT (Sg Nom) OR (Pl Nom) TARGET (N &msyn-numphrase-sgnom) ;

# Num

ADD:msyn-numphrase-sgnom (&msyn-numphrase-sgnom) TARGET (Num Sg Nom) - OKTA OR (Num Sg Acc) OR NUM-INDEF + (Sg Nom) OR NUM-INDEF + (Sg Acc) IF (*1 (N Sg Nom &msyn-numphrase-sgnom) OR (N Pl Nom &msyn-numphrase-sgnom) BARRIER NOT-Attr - PrfPrc - GRADE-ADV - (A <AttrPred> Sg Nom) - (A <AttrPred> Sg Gen) - (A <AttrPred> Sg Acc)  - (Pcle Foc/Neg-ge) - (Pcle Foc/Pos-ge)) # ("okta" Sg Nom) OR ("1" Sg Nom) 
(NEGATE 0 ("<.*%>"r)) 
(NEGATE 0 (Num "<[0123456789]-.*>"r))
(NEGATE 0 (Num "<biel.*>"r))
(NEGATE 0 Sem/Date OR (N Coll Nom) OR ("tuvsأ،n" Num Pl Nom) OR Sem/Year) 
(NEGATE 0 (Arab Nom) LINK 1 ("<[A-Z].*>"r) OR ("<أ….*>"r) OR ("<أ†.*>"r) OR ("<أک.*>"r))
(NEGATE 0 (Num Rom)) 
(NEGATE 0 &msyn-gen-numeral-jahkasaإ،)
(NEGATE 1 Prop)
(NEGATE 0 Arab LINK 1 ABBR )
(NEGATE 1 Num LINK NOT 0 NUMUNIT)
(NEGATE 1 Dem) 
(NEGATE 1 COMMA) 
(NEGATE 1 (PUNCT RIGHT))
(NEGATE 1 ("ja"))
(NEGATE 1 ("lأ¥hko"))
(NEGATE 1 JAHKASAS)
(NEGATE *1 (N <spelled>) BARRIER NPNHA) ;


# coordinated adjectives
# to the right
ADD:msyn-numphrase-sgnom (&msyn-numphrase-sgnom) TARGET ("akta" Sg Nom) OR ("1" Sg Nom) IF (*1 PRE-NP-HEAD BARRIER NOT-ADV LINK 1 CC LINK 1 PRE-NP-HEAD LINK *1 (N Sg Nom) + &msyn-numphrase-sgnom BARRIER NOT-Attr - PrfPrc - GRADE-ADV  - (A <AttrPred> Sg Nom) - (A <AttrPred> Sg Gen) - (A <AttrPred> Sg Acc) - (Pcle Foc/Neg-ge) - (Pcle Foc/Pos-ge) OR JAHKASAS LINK NOT 0 (N Coll Nom) OR ("tuvsأ،n" Num Pl Nom)) # OR PL-PAIR-N) 
(NEGATE -1 NUMMAR)
(NEGATE -1 (Dem Acc))
(NEGATE 0 NUMUNIT LINK -1 Num OR NUM-INDEF) 
(NEGATE 0 (N Coll Nom) OR ("tuvsأ،n" Num Pl Nom) OR Sem/Year OR Sem/Date OR Sem/Time-clock) 
(NEGATE 0 ONE + (Sg Gen) LINK 1 ("vuoras")) 
(NEGATE 0 (Num "<biel.*>"r))
(NEGATE 0 &msyn-gen-numeral-jahkasaإ،)
(NEGATE 0 (Num "<[0123456789]-.*>"r))
(NEGATE *1 (N <spelled>) BARRIER NPNHA) ;
	## 


ADDRELATION ($2 LEFT) (N &msyn-numphrase-sgnom) OR NUMUNIT + &msyn-numphrase-sgnom TO (*-1 (Num &msyn-numphrase-sgnom) OR NUM-INDEF + (Sg &msyn-numphrase-sgnom));


COPY:msyn-numphrase-nom (SUGGEST) EXCEPT (&msyn-numphrase-sgnom) TARGET (Num &msyn-numphrase-sgnom) IF (0 (Sg Nom)) ;


# Dem

ADD:msyn-numphrase-sgnom (&msyn-numphrase-sgnom) TARGET (Pron Dem Pl) IF (*1 (Num Sg) OR NUM-INDEF + Sg OR (Nom SUGGEST) OR (A Arab) BARRIER (*) - ("maإ‹emus") - ("maإ‹ep" Der/Superl <AttrPred>) - ("maإ‹إ‹e" Der/Superl <AttrPred>) LINK *1 (N &msyn-numphrase-sgnom) OR NUMUNIT + &msyn-numphrase-sgnom BARRIER NPNHA - CC OR JAHKASAS) 
(NEGATE 1 (Pron Dem)) ;


COPY:msyn-numphrase-nom (SUGGEST) EXCEPT (&msyn-numphrase-sgnom) TARGET (Dem &msyn-numphrase-sgnom) ;

ADDRELATION ($3 LEFT) (N &msyn-numphrase-sgnom) OR NUMUNIT + &msyn-numphrase-sgnom TO (*-1 (Dem &msyn-numphrase-sgnom));

SUBSTITUTE (&msyn-numphrase-sgnom) (co&msyn-numphrase-sgnom) TARGET (SUGGEST);


# Genitive numeral phrase

# Noun

