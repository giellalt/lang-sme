	# -ccii vs. -zzi
	# --------------
LIST ZZ-VERBS = (".*zzit"r V) ;

#DELETE SECOND ROUND

ADD:xreal-vأ،zzi-vأ،ccii (&real-vأ،zzi-vأ،ccii) TARGET ZZ-VERBS IF (0 (Ex/V Ex/IV Der/NomAg N Sg Acc) OR (Ex/V Ex/IV Der/NomAg N Sg Gen) OR (Ex/V Ex/IV Der/NomAg N Sg Nom))(NEGATE *0 VFIN BARRIER GRAMCHK-S-BOUNDARY) ;
COPY:syn-ccii-not-zzi (V IV Ind Prt Sg3 SUGGEST) EXCEPT (Ex/V Ex/IV Der/NomAg N Sg Acc &real-vأ،zzi-vأ،ccii) OR (Ex/V Ex/IV Der/NomAg N Sg Gen &real-vأ،zzi-vأ،ccii) OR (Ex/V Ex/IV Der/NomAg N Sg Nom &real-vأ،zzi-vأ،ccii) TARGET (&real-vأ،zzi-vأ،ccii) ;
	## ???leago seammأ، go vأ،ccii?

ADD:xreal-vأ،zzi-vأ،ccii (&real-vأ،zzi-vأ،ccii) TARGET ("vأ،zzi" A Sg Nom) OR ("vأ،zzi" A Sg Gen) OR ("vأ،zzi" A Sg Acc) OR ("vأ،zzi" N NomAg Sg Nom) OR ("vأ،zzi" N NomAg Sg Acc) OR ("vأ،zzi" N NomAg Sg Gen) IF (NEGATE *0 VFIN BARRIER GRAMCHK-S-BOUNDARY) ;
ADD:xreal-vأ،zzi-vأ،ccii (&real-vأ،zzi-vأ،ccii) TARGET ("vأ،zzi" A Sg Nom) OR ("vأ،zzi" A Sg Gen) OR ("vأ،zzi" A Sg Acc) OR ("vأ،zzi" N NomAg Sg Nom) OR ("vأ،zzi" N NomAg Sg Acc) OR ("vأ،zzi" N NomAg Sg Gen) IF (*-1 Nom + Sem/Hum OR Nom + Sem/Org OR Sem/Sur OR Sem/Fem OR Sem/Mal BARRIER GRAMCHK-S-BOUNDARY) ;
COPY:real-vأ،zzi-vأ،ccii ("vأ،zzit" V IV Ind Prt Sg3 SUGGEST) EXCEPT ("vأ،zzi" A Sg Nom &real-vأ،zzi-vأ،ccii) OR ("vأ،zzi" A Sg Gen &real-vأ،zzi-vأ،ccii) OR ("vأ،zzi" A Sg Acc &real-vأ،zzi-vأ،ccii) OR ("vأ،zzi" N NomAg Sg Nom &real-vأ،zzi-vأ،ccii) OR ("vأ،zzi" N NomAg Sg Acc &real-vأ،zzi-vأ،ccii) OR ("vأ،zzi" N NomAg Sg Gen &real-vأ،zzi-vأ،ccii) TARGET (&real-vأ،zzi-vأ،ccii) ;
	## Gaup vأ،zzi  neavttأ،rskuvlla Stأ،da Teأ،hterallaskuvllas, ja eksأ،mena vأ،lddii 1978:is.
	# in errors.xml
	
	# ga (Prt Du3) vs. ba (Foc/ba)
    # ----------------------------

ADD:xmsyn-ba-ga (&msyn-ba-ga) TARGET (Ind Prt Du3 Err/Orth) IF (*0 (Pron Du3 Nom) OR (N Nom) BARRIER GRAMCHK-S-BOUNDARY)(0 Foc/ba) ;

COPY:msyn-ba-ga (SUGGEST) EXCEPT (Err/Orth &msyn-ba-ga) TARGET (V &msyn-ba-ga) ;
	## Joؤ‘iheaddji guovttosges oaؤچؤچuiba jo أ،nsoruossa, mii lea ؤچuovvovaإ، أ،nsu maإ‹إ‹أ، gollemedأ،lja.
