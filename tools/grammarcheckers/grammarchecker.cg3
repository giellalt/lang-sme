LIST VARRA-SUBJ-V = "addit" "bisأ،nit" "boahtit" "bulljarastit" "cirgut" "ؤچoagganit" "ؤچoahkkanit" "doahkkut" "duldet" "duoldat" "earأ،huvvat" "giellut" "goaikut" "goaikkihit" "goikat" "golgat" "golggadit" "golggahit" "golggiidit" "guoؤ‘ؤ‘it" "iskat" "iskkadit" "jأ،pmasit" "jأ،pmit" "johtit" "lihkadit" "luoitit" "ruohtadit" "ruohtastit" "ruohttat" "seaguhit" "seahkanit" "seahkأ،nit" "spulإ¾ut" "suohkut" "suvrut" "vardit" "vأ،ilut" "vأ،ldot"; # suohku	giellu=stirdu=garrأ، doahku gأ،vdnot sisttisdoallأ، ؤچأ،hpoda dohpأ، darvأ،na lassأ،na;

LIST VARRA-OBJ-V = "vأ،ldit" ;
LIST VARRA-COMP-N = "bumpa" "dielku" "johtin" "johtu" "pumpa" "ruoksat"  ; 

LIST NON-VARRA-SUBJ-V = "almmuhit" "أ،ssat" "أ،sahit" "bohciidahttit" "borgat" "ؤچأ،llit" "ؤچuohcat"  "gollat" "jurddaإ،it" "juohkit" "dadjat" "heivet" "hirpmأ،stuhttit" "goahcat" "ovdأ،nit" "ballat" <EX-Nom-Ani> "dagahit" "geahؤچؤچat" "geavahit" "gأ،ibidit" "gأ،vdnat" "gustot" "jأ،hkkit" "maإ‹idit" "govvidit" "vuordit" "vuovdit";  
													 
	## Vأ،rra heive bures go nieiddain orrot jo liegga geahؤچastagat min gأ،nddaide, nأ،rridastأ، ja lohkأ، ieإ¾aset bures nأ،vddaإ،an mأ،tkkis. 


LIST NON-VARRA-SPRED-A = "أ،rtet" "somأ،" "suohtas" "vuoigatmeahttun" ; #A Sem/Hum Sg Nom
LIST VARRA-SPRED-A = "galmmas" "hأ،rvvis" "ruoksat" "suohkat" "varas" ;
LIST VARRA-ATTR-A = ("أ،del" Der/lasj A) ("giellut" V IV PrfPrc) ("goikat" V IV PrfPrc) (goikkis A Cmp/Attr) ("liekkas" A Attr) ("nanus" A Attr) ("njuoskkas" A Attr) ("oؤ‘as" A Attr) ("ruoksat" A Attr) ("sitkat" A Attr) ("varas" A Attr) (".*-#sorta"r N Pl Nom);
    


ADD:xreal-vأ،rra (&real-vأ،rra) TARGET ("varra" Sg Nom) OR ("vأ،rra" Adv Err/Spellrelax) IF (*0 GRAMCHK-VFIN - Sg3 BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess - Po - @>P)(NEGATE -1 (Gen @>N) + Sem/Hum OR (Gen @>N) + Sem/Mal OR (Gen @>N) + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Prop Sem/Plc Sg Gen @>N) OR Sem/Amount + Gen OR (Attr @>N))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH)(NEGATE *-1 Sg3 BARRIER NPNHA LINK NOT *-1 SUBJ OR (Pron Sem/Hum Sg3 Nom) BARRIER NPNHA)(NEGATE *0 (Ind Sg3) + VARRA-SUBJ-V OR (Ind Pl3) + VARRA-SUBJ-V BARRIER NOT-ADV-PCLE) ;   
    ## Ja ii dat leat vel duvdon, muhto varrage lean oahppan dainna eallit. Ja ii dat leat vel dovdon, muhto vأ،rrage lean oahppan dainna eallit.
    #$ Ja dat galgأ، jorgalit velأ، guovtti guvlui, vai cuvke eambbo, ja vai boaؤ‘أ،le juobe golbma goaikkanasage varra
    #$ Dأ،s han cirgot varra, cuozza ja siskkiluإ،at
    #$ Meksiko presideanta, Zedillo, ja su guatemalalaإ، bargoskibir, Arzu, leaba dأ،l loahpaheamen barggu mأ،hcahit dan 45 duhأ،t olbmo, geat Guatemala varra, siskkأ،ldas riiddus bأ،htaredje Meksiko presideanta, Zedillo, ja su guatemalalaإ، bargoskibir, Arzu, leaba dأ،l loahpaheamen barggu mأ،hcahit dan 45 duhأ،t olbmo, geat Guatemala {varra}, siskkأ،ldas riiddus bأ،htaredje

 
ADD:xreal-vأ،rra (&real-vأ،rra) TARGET ("varra" Sg Nom) OR ("vأ،rra" Adv Err/Spellrelax) IF (*1 (V Ind Sg3) BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN)(*-1 @SUBJ> + Sg OR (Pron Sem/Hum Sg3 Nom) BARRIER NPNHAPcle - @ADVL> - @>P - @P<)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;
	## De gal lohkأ، okta dain jiehtanasain ahte bussأ، gal varra geassأ، fatnasa, go sidjiide earأ،ide lea nu lossat. 
	## Sundi Paus, gii veahأ، maإ‹إ‹el 1700-logu gaskkamutto varra lei Finnmأ،rkku ja ؤچearddalaإ، ealأ،husvuoؤ‘u heivehemiid oahppأ،seamos olmmoإ،, ؤچilgii sأ،pmelaؤچؤچaid ja dأ،ؤچؤچaid erohusa guovddأ،إ، borramuإ،riggodagaid geavaheami oktavuoؤ‘as. 
    
ADD:xreal-vأ،rra (&real-vأ،rra) TARGET ("varra" Sg Nom) OR ("vأ،rra" Adv Err/Spellrelax) IF (*1 (V Ind Sg3) OR (V Cond Sg3) BARRIER NOT-ADV-PCLE LINK *1 @<SUBJ + Sg BARRIER NPNHAPcle - @ADVL> - @>P - @P< - ? - @>N)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	## Muhto 1600-logu mielde varra rievddai boazodoallu dan guvlui ahte إ،adde sierra doalut ja stuorit ealut, ja dأ،t ovdأ،nii ain maإ‹it jahkeؤچuoؤ‘is.
	## آ Varra boahtأ، dأ،lأ، presideanta Egil Olli oidnot dأ،n lأ،hkkأ،i.
	## Varra   biddjojuvvoإ،ii dأ،t proإ،eaktavirgi Finnmأ،rkku fylkkagildii.
    
ADD:xreal-vأ،rra (&real-vأ،rra) TARGET ("varra" Sg Nom) OR ("vأ،rra" Adv Err/Spellrelax) IF (*1 SUBJ + Sg OR (Pron Sem/Hum Sg3 Nom) BARRIER NPNHAPcle - @ADVL> - @>P - @P< - ? LINK 1 Rel LINK *1 VFIN BARRIER NOT-ADV-PCLE LINK *1 (V Ind Sg3) BARRIER GRAMCHK-S-BOUNDARY OR COMMA OR VFIN)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	## Danin varra dat olmmoإ، gii lea أ،lgأ،n girjeؤچأ،llin lea hأ،lidan govvet ؤچأ،lalaؤچؤچat daid dovdduid
	
ADD:xreal-vأ،rra (&real-vأ،rra) TARGET ("varra" Sg Nom) OR ("vأ،rra" Adv Err/Spellrelax) IF (*-1 (V Ind Sg3) BARRIER NOT-ADV-PCLE)(*1 @<SUBJ + Sg OR @<SPRED + Sg OR (Pron Sem/Hum Sg3 Nom) OR Ess + @<SPRED BARRIER NPNHAPcle - @ADVL> - @>P - @P< - ? -  PrfPrc)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;
	## Son dovddaha dأ،l ahte lea dan maؤ‘e agis politihkkalaإ، vuogadagas ahte lea varra أ،igi loapahisgoahtit doaimmaid
	## Maiddأ،i أ،ibmu lea nuoskiduvvon, ja leage varra sivvan manne nu olu olbmot jأ،bmet borasdأ،vdii.
	## Dolin lei maiddأ،i olles pyramiida mأ،lejuvon ruoksadin olggobeal ja lea varra leamaإ، oalle oainnأ،hus mii oidnui mأ،إ‹gga miilla duohken.
	
ADD:xreal-vأ،rra (&real-vأ،rra) TARGET ("varra" Sg Nom) OR ("vأ،rra" Adv Err/Spellrelax) IF (-1 ("dat" Pron Dem Sg Nom @>N) OR ("dأ،t" Pron Dem Sg Nom @>N))(*1 (V Ind Sg3) BARRIER NOT-ADV-PCLE LINK *1 @<SPRED + Sg BARRIER NPNHAPcle - ConNeg)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
