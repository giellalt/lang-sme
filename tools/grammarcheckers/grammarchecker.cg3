ADD:xreal-ĂĄllet-allet (&real-ĂĄllet-allet) TARGET ("ĂĄllet" V TV Inf) OR ("ĂĄllet" V TV Ind Prs Sg2) OR ("ĂĄllet" V TV Ind Prs Pl1) OR ("ĂĄllet" V TV Der/d V Imprt ConNeg) OR ("ĂĄllet" V TV Der/d V Imprt Sg2) OR ("ĂĄllet" V TV Der/d V Ind Prs ConNeg) OR ("ĂĄllet" V TV Der/h V Imprt ConNeg) OR ("ĂĄllet" V TV Der/h V Imprt Sg2) OR ("ĂĄllet" V TV Der/h V Ind Prs ConNeg) IF (*1 ConNeg OR VGen + CONNEG-VGEN-V OR (TV Imprt Sg2) BARRIER NOT-ADV-PCLE) ;
    ## Jus vĂĄssĂĄnĂĄigi livÄÄe earĂĄlĂĄgan, de livÄÄe maid min dĂĄlĂĄĂĄigi ja boahtteĂĄigi earĂĄlĂĄgan âŠ Muhto ĂĄllet fal divtte ovttage dadjat didjiide ahte lea menddo maĆĆit! 
    
COPY:real-ĂĄllet-allet ("ii" V IV Neg Imprt Pl2 SUGGEST) EXCEPT ("ĂĄllet" Ex/V TV Der/d Inf) OR ("ĂĄllet" Ex/V TV Der/d Ind Prs Sg2 &real-ĂĄllet-allet) OR ("ĂĄllet" Ex/V TV Der/d Ind Prs Pl1 &real-ĂĄllet-allet) OR ("ĂĄllet" V TV Der/d V Imprt ConNeg &real-ĂĄllet-allet) OR ("ĂĄllet" V TV Der/d V Imprt Sg2 &real-ĂĄllet-allet) OR ("ĂĄllet" V TV Der/d V Ind Prs ConNeg &real-ĂĄllet-allet) OR ("ĂĄllet" V TV Der/h V Imprt ConNeg &real-ĂĄllet-allet) OR ("ĂĄllet" V TV Der/h V Imprt Sg2 &real-ĂĄllet-allet) OR ("ĂĄllet" V TV Der/h V Ind Prs ConNeg &real-ĂĄllet-allet) TARGET (&real-ĂĄllet-allet) ;		
	## â Ăllet bala vĂĄldit oktavuoÄa munnoin gal.	
	
	# ĂĄllut (Adv pĂ„ skrĂ„) vs. allut (V)
	# ----------------------------------

	
ADD:xreal-allut-ĂĄllut (&real-allut-ĂĄllut) TARGET ("ĂĄllut" Err/Orth-a-ĂĄ Adv) OR ("allut" V IV Inf) OR ("alludit" V TV Ind Prs ConNeg) OR ("alludit" V TV Imprt ConNeg) OR ("allut" V IV Ind Prs Pl1) OR ("allut" V IV Imprt Pl1) OR ("alludit" V TV VGen) OR ("allut" V IV Imprt Pl2) OR ("alludit" V TV Imprt Sg2) OR ("allut" Ex/V Ex/IV Der/NomAg N Pl Nom) IF (NEGATE *0 ("!"))(NEGATE *-1 NOT-V LINK NOT *1 ConNeg) ;
COPY:real-allut-ĂĄllut ("ĂĄllut" Adv SUGGEST) EXCEPT ("ĂĄllut" Err/Orth-a-ĂĄ Adv &real-allut-ĂĄllut) OR ("allut" V IV Inf &real-allut-ĂĄllut) OR ("alludit" V TV Ind Prs ConNeg &real-allut-ĂĄllut) OR ("alludit" V TV Imprt ConNeg &real-allut-ĂĄllut) OR ("allut" V IV Ind Prs Pl1 &real-allut-ĂĄllut) OR ("allut" V IV Imprt Pl1 &real-allut-ĂĄllut) OR ("alludit" V TV VGen &real-allut-ĂĄllut) OR ("allut" V IV Imprt Pl2 &real-allut-ĂĄllut) OR ("alludit" V TV Imprt Sg2 &real-allut-ĂĄllut) OR ("allut" Ex/V Ex/IV Der/NomAg N Pl Nom &real-allut-ĂĄllut) TARGET (&real-allut-ĂĄllut) ;		
	## Buoidun boahtĂĄ das ahte biebmooppalaĆĄvuohta lea allut gosa nu guvlui.
	#$ Eaige goahteseainnit leat ĂĄllut.
	#$ Muhto Ingalill Olsena sĂĄtnevuorru SĂĄgat aviissas 12/8-2009/12 Äujuha geainnu boahttevaĆĄ guolĂĄstanresurssaid hĂĄlddaĆĄeapmĂĄi:âMis FinnmĂĄrkkus lea daÄi bahĂĄbut ovttastuvvon lĂĄhtas ĂĄllut.
	#$ â Juo, mii han beare sĂĄddet Egil Olli lĂĄvdde ala, gĂĄrvĂĄsit lobotomerejuvvon ja de son dahkĂĄ buot maid NSR dĂĄhttu, dadjala muhtun ja ÄĂĄjehastĂĄ mo Egil Olli sĂĄhtĂĄĆĄii ilbmat, oaivi ĂĄllut ja njuovÄÄa vel heaĆgut.
	#$ Hukse ĂĄrkii dĂĄhki ja daga dan ĂĄllanveardde ĂĄllut, bija uvssa ĂĄrkka gilgii ja hukse ĂĄrkii golbma gearddi.
	#$ Dasalassin geaidnu lea mohkis ĂĄllut, danin dĂĄvjĂĄ ÄiÄista gĂĄljan boasttobeallĂĄi luotta, Äilge Pieski.
	#$ Dat seammĂĄ luvra lea juo dahkan olu ĂĄllut ĂĄĆĄĆĄiid sĂĄmiid vuostĂĄ. 


    # "ihttin" Adv Sem/Time/  "ihtit" Ex/V Ex/IV Der/NomAg Sem/Hum N Ess vs. ihtit V IV Actio Gen /Nom
    # ---------------------------------------------------
    # condition: possessive suffix only when there is a possible referent
    
#DELETE uncommon
ADD:xreal-ihtit (&real-ihtit) TARGET ("ihttin" Adv) OR ("ihtit" Ex/V Ex/IV Der/NomAg Sem/Hum N Ess) OR ("ihtit" V IV Actio Gen) OR  ("ihtit" V IV Actio Nom) IF (*0 ("eanet") OR ("eambbo") BARRIER GRAMCHK-S-BOUNDARY)(*-1 AUX BARRIER Inf OR GRAMCHK-S-BOUNDARY);  
COPY:real-ihtit ("ihttit" V IV Inf SUGGEST) EXCEPT ("ihtit" Ex/V Ex/IV Der/NomAg Sem/Hum N Ess &real-ihtit) OR ("ihtit" V IV Actio Gen &real-ihtit) OR ("ihtit" V IV Actio Nom &real-ihtit) OR ("ihttin" Adv Sem/Time &real-ihtit) TARGET (&real-ihtit) ;  
  ## 1900-logus ĂĄlge dat liberĂĄlakonservatiiva ĂĄĆĄĆĄit ihttin eanet.
  # in errors.xml
  # LH???


	# jearrĂĄ (jearrat Prs Sg3) vs. jeara N (gjĂŠr)
	# -------------------------------------------
	
LIST NEG-PRONS = "oktage" "goassege" "giige" ;
#DELETE uncommon
ADD:xreal-jeara-jearrĂĄ (&real-jeara-jearrĂĄ) TARGET ("jeara" N Sg) IF (0 Gen OR Nom OR Acc)(NEGATE 0 (TV Imprt Sg2))(0* Sg + Nom OR Sg3 BARRIER GRAMCHK-S-BOUNDARY)(NEGATE *-1 NOT-V BARRIER GRAMCHK-S-BOUNDARY OR NEG-PRONS)(NEGATE *1 EOS + ("^excl"))(NEGATE 1 Sem/Human + Acc)(NEGATE *-1 CC BARRIER NPNH LINK -1 Sem/Food OR Sem/Drink OR Sem/Substnc)(NEGATE 0 @<OBJ LINK 1 @CNP LINK 1 @<OBJ);
	#$ FĂĄgamĂĄhttu, rievttes biergasat, rĂĄinnas ÄĂĄhci, gordni ja jeara dĂĄrbbaĆĄuvvo vuoi ĆĄaddĂĄ buorre vuolla, lohkĂĄ Terje Johansen.
	#$ VĂĄldĂĄ eret jeara ja proteinbĂĄzahusaid vai vuolla ĆĄaddĂĄ Äielggas.
	#$ â Macka vuollabijahaga nanu bealli lea ahte ÄĂĄhci ja jeara ĂĄlo leat seammalĂĄganat.
	#$ Jus geavaha duĆĄĆĄe sohkara, ÄĂĄzi ja jeara, de ii leat juhkosis earĂĄgo alkohola mĂĄistu.
ADD:xreal-jeara-jearrĂĄ (&real-jeara-jearrĂĄ) TARGET ("jearrat" V TV) IF (0 (Imprt ConNeg) OR (Imprt Sg2) OR (Ind Prs ConNeg) OR (VGen))(NEGATE *-1 NOT-V BARRIER GRAMCHK-S-BOUNDARY OR NEG-PRONS)(NEGATE *1 EOS + ("^excl")) ;
COPY:real-jeara-jearrĂĄ ("jearrat" V TV Ind Prs Sg3 SUGGEST) EXCEPT ("jeara" N Sg Gen &real-jeara-jearrĂĄ) OR ("jeara" N Sg Nom &real-jeara-jearrĂĄ) OR ("jeara" N Sg Acc &real-jeara-jearrĂĄ) OR ("jearrat" V TV Imprt ConNeg &real-jeara-jearrĂĄ) OR ("jearrat" V TV Imprt Sg2 &real-jeara-jearrĂĄ) OR ("jearrat" V TV Ind Prs ConNeg &real-jeara-jearrĂĄ) OR ("jearrat" V TV VGen &real-jeara-jearrĂĄ) TARGET (&real-jeara-jearrĂĄ) ;
	## Man lahkai  kvalitehtasihkkarastĂĄ SĂĄmediggi ahte lea sĂĄmi buvtta man SĂĄmediggi doarju, jeara  NSR.
	#$ Muhto jeara datte spiriin, ja dat galget du mĂĄhttĂĄhit, ja almmi lottiin, ja dat galget addit dutnje dieÄu.
	#$ Jus du fitnodat hĂĄlida ovttasbarggu muhtin namuhuvvon osiin, de ii leat go vĂĄldit oktavuoÄa Finnmark BedriftsrĂ„dgiving as, tlf. 78 42 95 50 ja jeara Arthura dahje tlf.78 48 62 45 ja jeara Ăntte.
	#$ Jus leat vĂĄttis, de jeara veahki muhtin olles olbmos.
	#$ Muhto jeara mus nuppe hĂĄve, de galggan mĂĄhttit vĂĄstidit.
	## Buohkat dihtet ahte Jeppe juhkĂĄ, muhto ii oktage jeara mĂĄnin son juhkĂĄ, lea dovddus jearaldat.
	
	
	# jearran (jearrat PrfPrc) vs. jearan N (gjĂŠr)
	# -------------------------------------------
	

#DELETE uncommon	
ADD:xreal-jearan-jearran (&real-jearan-jearran) TARGET ("jeara" N Ess) OR ("jeara" N Sg Loc South Err/Orth) OR ("jeara" N Sg Acc PxSg1) OR ("jeara" N Sg Nom PxSg1) OR ("jeara" N Sg Gen PxSg1) OR ("jearrat" V TV Ind Prs Sg1) IF (NEGATE 0* Sg1 + Nom BARRIER GRAMCHK-S-BOUNDARY)(*-1 NOT-V OR BE BARRIER GRAMCHK-S-BOUNDARY);

COPY:real-jearan-jearran ("jearrat" V TV PrfPrc SUGGEST) EXCEPT ("jeara" N Ess &real-jearan-jearran) OR ("jeara" N Sg Loc South Err/Orth &real-jearan-jearran) OR ("jeara" N Sg Acc PxSg1 &real-jearan-jearran) OR ("jeara" N Sg Nom PxSg1 &real-jearan-jearran) OR ("jeara" N Sg Gen PxSg1 &real-jearan-jearran) OR ("jearrat" V TV Ind Prs Sg1 &real-jearan-jearran) TARGET (&real-jearan-jearran);
