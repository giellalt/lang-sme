# Nominative numeral phrase

LIST NUM-INDEF = "galle" "mÃĄÅga" "moadde" ;

# Noun


ADD:msyn-numphrase-sgnom (&msyn-numphrase-sgnom) TARGET (N Sg Nom) OR (N Pl Nom) IF (*-1 (Num Sg Nom) OR (Num Sg Acc) + NOM-ACC-NUM OR NUM-INDEF + (Sg Nom) OR NUM-INDEF + (Sg Acc) BARRIER NOT-Attr - PrfPrc - GRADE-ADV  - (A <AttrPred> Sg Nom) - (A <AttrPred> Sg Gen) - (A <AttrPred> Sg Acc) - (Pcle Foc/Neg-ge) - (Pcle Foc/Pos-ge) OR JAHKASAS LINK NEGATE -1 KLASS) 
(NEGATE *-1 ("okta") OR ("1") BARRIER NOT-Attr - PrfPrc)
(NEGATE *-1 (Num Sem/Year) BARRIER NOT-Attr - PrfPrc)
(NEGATE *-1 (Num Rom) BARRIER NOT-Attr - PrfPrc)
(NEGATE *-1 Num BARRIER NOT-Attr - PrfPrc LINK -1 KLASS OR NUMMAR OR COUNTABLE)
#(NEGATE *-1 Der/akti BARRIER NPNHA) 
(NEGATE *-1 (Arab Ord) BARRIER NPNHA OR Num)
(NEGATE *-1 (Num Sem/ID) BARRIER NPNHA OR Num)
(NEGATE *-1 Num BARRIER NPNHA LINK 0 ("aktan" Adv))
(NEGATE *-1 Num BARRIER NPNHA LINK 1 Dem)
(NEGATE *-1 (Num "<[Â§].*>"r) OR (Num "<.*%>"r) OR ("%") BARRIER NPNHA - Num)
(NEGATE *-1 (Num "<.*[0123456789]-.*>"r) BARRIER NPNHA OR Num)
(NEGATE *-1 (Num Sg Nom) BARRIER NPNHA LINK -1 BE + Sg3 OR BE + Du3 OR BE + Pl3 LINK -1 (Dem Pl Loc) OR (Pers Pl3 Loc) OR (Pers Pl2 Loc) OR (Pers Pl1 Loc)) 
(NEGATE -1 JAHKASAS LINK -1 (Num)) 
(NEGATE -1 NUMUNIT LINK -1 PLURAL-QUANTIFIERS OR Num)
(NEGATE -1 NUMUNIT LINK -1 Num OR ("moadde"))
(NEGATE -1 Sem/Time)
(NEGATE -1 COMMA OR CC)
(NEGATE -1 CLB)
(NEGATE -1 (PUNCT RIGHT) LINK -1 Num) 
(NEGATE 0 ABBR OR Prop)
(NEGATE 0 ("lohku"))
##(NEGATE 0 ("<[A-Z].*>"r) OR ("<Ã.*>"r) OR ("<Ã.*>"r) OR ("<Ã.*>"r) LINK -1 (Arab Nom))
##(NEGATE 0 (Der/NomAct Sg Nom) LINK 0 PrfPrc LINK *1 (N Pl Nom)  BARRIER NOT-Attr) 
(NEGATE 0 <spelled> OR &real)
(NEGATE 0 (Sg Nom) LINK 0 GRAMCHK-NOM-GEN-N)
(NEGATE 0 Symbol)
(NEGATE 0 Gram/NomAg OR Der/NomAg)
(NEGATE 0 (Sg Gen) OR Acc);
##(NEGATE 0 Px LINK NOT 0 (Sg Acc PxSg3) OR (Sg Nom PxSg3) OR (Sg Gen PxSg3)) 
