	# Pred not Attr (adjectives)
	# --------------------------
	#DELETEآ SECONDآ ROUND	

ADD:xsyn-attr-sgnom (&syn-attr-sgnom) TARGET (A Attr) IF (*-1 COPULAS BARRIER V OR GRAMCHK-S-BOUNDARY LINK *-1 Nom) (NEGATE *1 N BARRIER NOT-Attr - PrfPrc)(NEGATE 1 CC OR COMMA LINK 1 A LINK 1 N)(NEGATE 1 (A Attr) OR ? LINK *1 N BARRIER NPNH)(NEGATE 1 (A Sg Nom) OR (Pron Pers))(NEGATE 0 ("visot") OR ("buot") LINK 1 Pron LINK *1 N)(NEGATE 0 PRED-ATTR-ADJ OR (A Arab Ord Attr))(NEGATE 1 COMMA OR CC LINK 1 (A Attr) OR PRED-ATTR-ADJ)(NOT 0 (A Sg Nom) OR <AttrPred>)(NEGATE 1 COMMA OR ("-") LINK 1 BUT-CC LINK *1 (A Attr) BARRIER NPNHA)(NEGATE 0 Superl LINK 1 CC LINK 1 ("eanet" Superl) OR ("eanemus") LINK 1 A LINK 1 N)(NEGATE 1 (Num Attr) LINK 1 N)(NEGATE 0 ("eanet") LINK 1 PrfPrc);
	#$ Mأ،إ‹ga duhأ،t nuora, geain ledje skuvlauniforpmat ja Norgga ja Myanmar leavggat, ؤچuإ¾إ¾o dego ؤچikإ‹an geaidnorأ،vddain girdihأ،mmanis gitta Nay Pyi Taw gأ،vpogii â€“ mii lea Myanmar {oؤ‘ؤ‘a} huksejuvvon oaivegأ،vpot.
	#$ 1992 rأ،jes lea datte olgunastinlأ،vdegoddi {eanet} adnon gulaskuddanأ،sahussan moanaid oktavuoؤ‘ain, ee. mohtorfievrojohtolaga j.s. oؤ‘ؤ‘ lأ،hkaأ،sahusaid gأ،rvvisteamis.
	#$ Nepأ،las leat badjel 60 etnalaإ، joavkku, ja doppe hubmojuvvojit unnimusat 69 giela, ja nappo lea ge okta dain eanemus {mأ،إ‹ggakultuvrralaإ،}, mأ،إ‹ggagielat ja mأ،إ‹ggaoskkot servodagain mأ،ilmmis.
	#$ Dat lea maiddأ،i dat {vأ،ddأ،seamos} ja eanemus eahperealisttalaإ، lohpأ،dus.
	#$ Gro Harlem Brundtland leage okta Norgga buot eanemus dovddus politihkkأ،riin {maإ‹imuإ،} moaddelot jagi.
    #$ Dat mii lea buot {eanemus} {dأ،rbbaإ،laإ،} min servvodagas, lea bargosajiid hأ،hkat ja nuoraid oaإ¾إ¾ut vأ،ldit oahpu.
	#$ أپhku biejus leat mii dأ،l guldaleame mot dalle doloإ، أ،iggi geavai go أ،hkku ja earأ، sأ،hpannieiddat ledje meahccأ،i lأ،hppon, ja go buoidda ؤŒere ja guokte vilgesأ،hpanbأ،rtni sin doppe gأ،vdne ja hأ،ste sin ieإ¾aset bieju lusa vuolgit.
    #$ Su musihkka lea poehtalaإ، ja das lea roavis ja ihأ،na ؤچأ،ppa ja {fiinna}, alit ja dassأ، lassin oalle vealtameahttun bأ،ruhأ،mat harmoniija.
	## Su musihkka lea poehtalaإ، ja das lea roavis ja ihأ،na {ؤچأ،ppa} ja {fiinna}.
	#$ Sأ،mi mأ،ilmmiartista Sofia Jannok lea duostilis, ؤچeahpes nuorra nieida gii ii bala mأ،tkkoإ،tit.
    ## Spأ،bba ii leat geahppa nu go lأ،ve.
    #$ Dikإ،ui gullet gأ،rrenmirkovأ،ttut, geahppa psykalaإ، vأ،ttut, nugo depreإ،uvnnat ja ballu.
    #$ Lea go duohta ahte leat visot dأ،id govaid ieإ، rأ،hkadan?
    #$ Danne أ،vإ¾إ¾uhan buohkaid dan geavahit, go dat leat boares, geahppa ja oanehis sأ،tni, lohkأ، Sأ،medikki giellastivrra joؤ‘iheaddji Rolf Olsen.
    #$ Lأ،rin lei stuorأ،mus buot 10. luohkأ، bأ،rtniin. --- is stuorأ،mos wrong here Ritva?
    #$ De lei muhtin skuvla-beaivi go son lei earenoamأ،إ، vأ،ibbas. - Ritva is earenoamأ،إ، ok here?
    ## Su namma lea Emma Elliane, lea beare 16 jagi boares ja lea ge jo almmuhan vuosttaإ، CD-skearru.
    #$ Dat rieban maid mii lأ،vet hأ،rdit, lea boares, {ؤچalmmehis} - muhto hui belljes rieban mii orru duos Riebanvأ،ris, ؤچilgii Vilge.
	    
ADD:xsyn-attr-sgnom (&syn-attr-sgnom) TARGET (A Attr) IF (1 CC OR COMMA LINK 1 &syn-attr-sgnom)(NEGATE 0 <AttrPred>);
	## Su musihkka lea poehtalaإ، ja das lea roavis ja ihأ،na {ؤچأ،ppa} ja fiinna.
COPY:syn-attr-sgnom (A Sg Nom SUGGEST) EXCEPT (A Attr &syn-attr-sgnom) TARGET (A &syn-attr-sgnom) ;
	#$ Dat rieban maid mii lأ،vet hأ،rdit, lea {boares}, ؤچalmmehis - muhto hui belljes rieban mii orru duos Riebanvأ،ris, ؤچilgii Vilge.
		
