    #$ Dأ،l vigget vuoiإ‹إ‹at sus {oaإ¾إ¾ut} veahkki beassat rأ،fi vuoiإ‹إ‹adeapmأ،i.

COPY:real-Inf-PrsPl3 (Ind Prs Pl3 SUGGEST) EXCEPT (Inf &real-Inf-PrsPl3) OR (Imprt Pl1 &real-Inf-PrsPl3) OR (Imprt Pl2 &real-Inf-PrsPl3) OR (Ind Prs Pl1 &real-Inf-PrsPl3) OR (Der/NomAg N Pl Nom &real-Inf-PrsPl3) TARGET (&real-Inf-PrsPl3) ;
	## Dat أ،igut visot gأ،rإ¾إ¾idit.
	# in errors.xml


	# PrfPrc vs. Actio Nom, HUOM! just for words with monophthong in infinitive, others are very uncommon
	# --------------------

ADD:xreal-ActioNom-PrfPrc (&real-ActioNom-PrfPrc) TARGET UT-VERBS IF (0 (Actio Gen) OR (Actio Nom) OR (Der/NomAct N Sg Gen Allegro) OR (Der/NomAct N Sg Nom) OR (Der/NomAg N Ess))(NEGATE 0 Ess - Der/NomAg OR DIPHTONG-ROOT)(*-1 BE + VFIN OR BE + Inf BARRIER GRAMCHK-S-BOUNDARY OR PrfPrc)(NEGATE 0 (Actio Gen) LINK 1 Po)(NEGATE 0 Der/Pass)(NEGATE 0 (Prt ConNeg))(NEGATE 0 (N Sg Nom) - Der/NomAg LINK *-1 BE + Sg3 BARRIER GRAMCHK-S-BOUNDARY OR PrfPrc);

	# for cases with immediate objects where it's more evident that it is a PrfPrc

ADD:xreal-ActioNom-PrfPrc (&real-ActioNom-PrfPrc) TARGET UT-VERBS + TV IF (0 (Actio Gen) OR (Actio Nom) OR (Der/NomAct N Sg Gen Allegro) OR (Der/NomAct N Sg Nom) OR (Der/NomAg N Ess))(NEGATE 0 DIPHTONG-ROOT)(*-1 BE + VFIN OR BE + Inf BARRIER GRAMCHK-S-BOUNDARY OR PrfPrc LINK *-1 @OBJ> BARRIER S-BOUNDARY)(NEGATE 0 (Actio Gen) LINK 1 Po)(NEGATE 0 Der/Pass)(NEGATE 0 (Prt ConNeg));
	## Maid lei Keaisأ،r Augustus gohؤچؤچun?
	
ADD:xreal-ActioNom-PrfPrc (&real-ActioNom-PrfPrc) TARGET UT-VERBS + TV IF (0 (Actio Gen) OR (Actio Nom) OR (Der/NomAct N Sg Gen Allegro) OR (Der/NomAct N Sg Nom) OR (Der/NomAg N Ess))(NEGATE 0 DIPHTONG-ROOT)(*-1 BE + VFIN OR BE + Inf BARRIER GRAMCHK-S-BOUNDARY OR PrfPrc)(*1 @OBJ> OR @<OBJ BARRIER NPNHA)(NEGATE 0 (Actio Gen) LINK 1 Po)(NEGATE 0 Der/Pass)(NEGATE 0 (Prt ConNeg));
	## Ikte eahkedis ؤچoahkkinasttii Sأ،B stivrra ja lei gohؤچؤچun olles stivrra oktan vأ،rrelahtuiguin boahtit, vأ،lgga أ،rvvoإ،tallamii ja divaإ،tallan dihtii maid sii sأ،httet Bb gأ،ibidit jus sii galget Bb doarjut dأ،n أ،igodaga.


COPY:real-ActioNom-PrfPrc (IV PrfPrc SUGGEST) EXCEPT (IV Actio Gen &real-ActioNom-PrfPrc) OR (IV Actio Nom &real-ActioNom-PrfPrc) OR (Ex/V IV Der/NomAct N Sg Gen &real-ActioNom-PrfPrc) OR (Ex/V IV Der/NomAct N Sg Nom &real-ActioNom-PrfPrc) OR (Ex/V IV Der/NomAg N Ess &real-ActioNom-PrfPrc) TARGET (IV &real-ActioNom-PrfPrc) ;

COPY:real-ActioNom-PrfPrc (TV PrfPrc SUGGEST) EXCEPT (TV Actio Gen &real-ActioNom-PrfPrc) OR (TV Actio Nom &real-ActioNom-PrfPrc) OR (Ex/V TV Der/NomAct N Sg Gen &real-ActioNom-PrfPrc) OR (Ex/V TV Der/NomAct N Sg Nom &real-ActioNom-PrfPrc) OR (Ex/V TV Der/NomAg N Ess &real-ActioNom-PrfPrc) TARGET (TV &real-ActioNom-PrfPrc) ;
	#$ Ii son leat olmmoإ، gean don livؤچؤچet {doivun} leat mielde Norgga muhtin lأ،hkai eanemus ekstremalaإ، bellodagas.
	## Dأ،t smأ،vva ؤچuvllat, leat maid gorrojuvvon biktasiin mat ledje nie baskun.
	#$ Konfereanssa ulbmil lea  ؤچohket  buot fylkka nuoraid {oaإ¾إ¾un} dihtii أ،rvalusaid mo Finnmأ،rku sأ،httأ، إ،addat ain buoret orrunbأ،ikin.
	#$ Go hأ،llojuvvo sأ،megielddaid ja sأ،medikkiid أ،إ،إ،ebأ،hpأ،riid jorgaleamis sأ،megillii, de hأ،liidan muittuhit dakkأ،r beali أ،إ،إ،is, ahte dأ،s lea sأ،hka sأ،megiela ovddideamis virgegiellan ja politihkalaإ، {bargoneavvun}. 

	# Nom - Gen/Acc
	# -------------

ADD:real-GenSg-NomSg (&real-GenSg-NomSg) TARGET أپ-A-E-O-U-NOUNS + CONC-2-3-4ABC - <spelled> - Prop - Err/Orth IF (0 (N Sg Acc) - PxSg2 OR (N Sg Gen) - PxSg2)(-1 GRADE-ADV - ("oba") - ("vel") LINK -1 COPULAS)(NEGATE 0 Der/vuota)(NEGATE 0 (A Sg Nom) OR (A Attr) OR Ess)(NEGATE 1 N OR Po OR Actio)(NEGATE *1 TV BARRIER NOT-ADV-PCLE);
	#$ Mis lea gal juo mأ،tki diإ‹gojuvvon ja mأ،kson, muhto jus mannأ، bures ekonomalaؤچؤچat dأ،ppe, de besset mأ،nأ،t oassأ،lastit doaimmaide gos soitet vel {oahpu} ge gazzat, nu go historjjأ،laإ، bأ،ikkiid oaidnit, ja nu ain.
	#$ ja mariidna bioteknologiija olis, de lea dأ،rbu ahte stأ،hta searvأ، ovddidan- ja أ،lggahandأ،sis nana ruhtademiin DjO-doaimmaide ja earأ، doaimmaide, main Davvi-Norggas leat erenoamأ،إ، {luonddu} addin lihkostuvvanovdamunit.
	#$ Ja sii إ،addet orrut beare {أ،immu} siste.
	#$ â€“ Mun lean mأ،ilmmi duhtavaإ،, ledje duإ،إ،e riikajoavkku bأ،hؤچؤچit geat ؤچaskkiiga mu, soai han leaba Davvi-Norgga buoremus bأ،hؤچؤچit, lohkأ، Nils Rune Eira.
    ## Mannan vahkkoloahpa dأ،hpأ،husas orro ealgabivdis leamaإ،an beare hoahpu bأ،hؤچit. #case error: hoahpu>hoahppu
    #$ NSR oaivvilda ahte nissonolbmuin ja dievdduin galget leat seamma ieإ،ovdأ،nahttin vejolaإ،vuoؤ‘at, oahpu gazzamis ja fidnodoaimma vأ،lljemis, ja galget lea seamma vejolaإ،vuoؤ‘at vأ،ikkuhit servodatovdأ،neami.
    #$ Dأ،l go beaivvit leat guhkkon dأ،idأ، leat earenoamأ،إ، {suohtas} olgun stoagadit.

COPY:real-GenSg-NomSg (Nom SUGGEST) EXCEPT (Gen &real-GenSg-NomSg) OR (Acc &real-GenSg-NomSg) TARGET (&real-GenSg-NomSg);

	# DerNomAgPlNom-Inf
	# -----------------
	# adnit > atnit

ADD:real-DerNomAgPlNom-Inf (&real-DerNomAgPlNom-Inf) TARGET IT-EVEN-VERBS + CONC-2-3C-DDJ OR IT-EVEN-VERBS + CONC-3A-GRADE-II IF (0 (Ex/V Ex/IV Der/NomAg N Pl Nom) OR (Ex/V TV Der/NomAg N Pl Nom) OR (Ex/V IV Der/NomAg N Pl Nom))(*-1 AUX - BE)(NEGATE 0 Inf)(NEGATE -1 CC OR COMMA LINK -1 N)(NEGATE 0 Inf OR Pl1) ;
	#$ Dasa masa sأ،httأ، guorrasit, lea ahte geassevuodjin njealjejuvllagiiguin lea hأ،stalus, muhto mii {jأ،hkkit} ahte gielddat ieإ¾a buoremusat sأ،httet ja mأ،httet dan hأ،lddaإ،it.
	## Sأ،vvamis mun vuoitأ،n dأ،n gilvvu, lea nu lأ،ittas vuoddjit biilla musihka haga.
	## Sأ،medikki dievasؤچoahkkima meannudeami ii sأ،hte adnit siskkأ،ldas proseassan ja danne ii أ،dde Sأ،mediggerأ،ؤ‘ؤ‘i NؤŒE أ،kkasteami.
	#$ Bargolأ،vdegottis galge leat kommiإ،uvnna joؤ‘iheaddji, delegaإ،uvdnajoؤ‘iheaddjit (dأ،rbbu mielde), goappأ،ge riikka ؤچoahkkinؤچأ،llit ja vأ،ldo ؤچأ،lli.
	# same as ImprtPl2-Inf?
	#$ Jus ehpet أ،ddejuvvo, de geahؤچؤچalehket geardduhit dan maid dadjabehtet, muhto adnit dalle earأ، sأ،niid!
	
ADD:real-DerNomAgPlNom-Inf (&real-DerNomAgPlNom-Inf) TARGET IT-EVEN-VERBS + CONC-2-3C-DDJ OR IT-EVEN-VERBS + CONC-3A-GRADE-II IF (0 (Ex/V Ex/IV Der/NomAg N Pl Nom) OR (Ex/V TV Der/NomAg N Pl Nom) OR (Ex/V IV Der/NomAg N Pl Nom))(-1 (A <TH-Inf>) LINK *-1 BE + Sg3 BARRIER NOT-ADV-PCLE)(NEGATE 0 Inf)(NEGATE -1 CC OR COMMA LINK -1 N)(NEGATE *1 (V Pl3) BARRIER NOT-ADV-PCLE) ;
	## Sأ،vvamis mun vuoitأ،n dأ،n gilvvu, lea nu lأ،ittas vuoddjit biilla musihka haga.
	
ADD:real-DerNomAgPlNom-Inf (&real-DerNomAgPlNom-Inf) TARGET IT-EVEN-VERBS + CONC-2-3C-DDJ OR IT-EVEN-VERBS + CONC-3A-GRADE-II OR IT-EVEN-VERBS + CONC-2-GRADE-II IF (0 (Ex/V Ex/IV Der/NomAg N Pl Nom) OR (Ex/V TV Der/NomAg N Pl Nom) OR (Ex/V IV Der/NomAg N Pl Nom))(-1 PrfPrc LINK -1 BE)(NEGATE 0 Inf OR Pl1)(NEGATE -1 CC OR COMMA LINK -1 N) ;
	## Lean giitevaإ، go lean beassan {johttit} mأ،ilmmes ja miehtأ، sأ،mi ja dakko bokte oإ¾إ¾on inspisraإ،uvnna ieإ¾an ؤچأ،llin dأ،idagiid ja duodjأ،i, lohkأ، Thomas.

COPY:real-DerNomAgPlNom-Inf (Inf SUGGEST) EXCEPT (Ex/V Ex/IV Der/NomAg N Pl Nom &real-DerNomAgPlNom-Inf) TARGET (Ex/V Ex/IV &real-DerNomAgPlNom-Inf) ;

COPY:real-DerNomAgPlNom-Inf (V TV Inf SUGGEST) EXCEPT (Ex/V TV Der/NomAg N Sem/Hum Pl Nom &real-DerNomAgPlNom-Inf) TARGET (TV &real-DerNomAgPlNom-Inf) ;

COPY:real-DerNomAgPlNom-Inf (V IV Inf SUGGEST) EXCEPT (Ex/V IV Der/NomAg N Sem/Hum Pl Nom &real-DerNomAgPlNom-Inf) TARGET (IV &real-DerNomAgPlNom-Inf) ;

