	# oainnat iige oainnĂĄt
	# --------------------

ADD:real-oainnĂĄt-oainnat (&real-oainnĂĄt-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 (Pron Sem/Hum Pers Nom) LINK NOT 0 Sg2);
	## Mun oainnĂĄt ÄohkkĂĄn ieĆĄ searvegotterĂĄÄis, muitala Johanne Gaup.
	## Mun oainnĂĄt maid ledjen gĂĄrtan duon mĂĄinnaĆĄuvvon geaidnobargui RuoĆĄĆĄa beallĂĄi.
	## Mun oainnĂĄt ballen dan ĂĄhkus, dat lĂĄvii ovtto

ADD:real-oainnĂĄt-oainnat (&real-oainnĂĄt-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 Nom - Sg2 OR (N Sg Gen Err/Orth-nom-gen) OR ( N Sg Gen Err/Orth-nom-acc) OR (N Sg Loc) OR (N Prop Sem/Fem Sg Gen) OR (N Prop Sem/Fem Sg Acc) OR (N Prop Sem/Mal Sg Gen) OR (N Prop Sem/Mal Sg Acc) OR (N Prop Sem/Sur Sg Gen) OR (N Prop Sem/Sur Sg Acc) OR (N Prop Sem/Org ACR Sg Acc) OR COMMA)(*1 (V Ind) + VFIN - Neg OR COMMA BARRIER (*) - (N Nom) - (Pron Nom));
	#D? Nom-Gen Prop Sem/Fem Sem/Mal Sem/Sur ???
	#$ Dasto lea perseptuĂĄlalaĆĄ latnja, dovdanlatnja, gos oainnĂĄt, gulat, havssĂĄt, gamus dovddat jna..
	#$ Norggas gĂĄibiduvvo ahte oainnĂĄt ja nagodat lohkat biilagalbba mii lea 20 mehtera dus eret.
	## LĂĄhka oainnĂĄt gĂĄibida buohkaid boazologuid, dietnasiid ja vahĂĄgiid fievrredit âčâč ĂĄhÄiid âșâș boazodoallodieÄĂĄhussii ja sutnje dat mĂĄksojit nĂĄvdevahĂĄt buhtadusat ja boazodoalloĆĄiehtadusa doarjagat.
	## Liisa oainnĂĄt lea leamaĆĄ ĂĄlggu rĂĄjes mielde juo lĂĄgideamin filbmafestivĂĄla AnĂĄris, mii vuosttas geardde dollui 1997:s.
	## Mii leimmet, oainnĂĄt, ÄĂĄllĂĄn ahte mii doarjut oljo- ja gĂĄssabohkama BarentsĂĄbis.

ADD:real-oainnĂĄt-oainnat (&real-oainnĂĄt-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 Nom - Sg2 OR (N Sg Gen Err/Orth-nom-gen) OR (N Sg Gen Err/Orth-nom-acc) OR (N Sg Loc) OR (N Prop Sem/Fem Sg Gen) OR (N Prop Sem/Fem Sg Acc) OR (N Prop Sem/Mal Sg Gen) OR (N Prop Sem/Mal Sg Acc) OR (N Prop Sem/Sur Sg Gen) OR (N Prop Sem/Sur Sg Acc) OR (N Prop Sem/Org ACR Sg Acc) OR COMMA)(*1 VFIN + Neg BARRIER (*) - (N Nom) - (Pron Nom) LINK 1 ConNeg OR ("go" Pcle Qst));
	## - Gielda oainnĂĄt ii sĂĄhte ĂĄlgit olbmuin gĂĄibidit mĂĄvssu jus kloĂĄhkat eai leat gurrejuvvon.
	## Dainna lĂĄgin oainnĂĄt ii leat boazodoallalĂĄhka, oaivvilda BĂŠhr.
	## JahkeÄoahkkin oainnĂĄt ĂĄvĆŸĆŸuhii stivra bargat dainna ĂĄĆĄĆĄiin.
	## Soai oainnĂĄt eaba lean vuordĂĄn vuoitit, go eaba lean ĆĄaddan hĂĄrjehallat ovttas bearehaga.
	## ILO oainnĂĄt ĂĄlgĂĄ oÄÄasit vieĆŸĆŸat dieÄuid RĂĄÄÄehusas, ĂĄkkasta Nystad.
	## - SoaÄi ĂĄigge lĂĄvejin ieĆŸan oappĂĄiguin ja vieljaguin doalvut suoli borramuĆĄa tuiska fĂĄĆggaide duos tuiskaguolbanis, oainnĂĄt sii gillĂĄjedje, muitala son.
	## Vuojahagas oainnĂĄt ferte ĂĄlo okta gii fĂĄkte.
	## - Mun in ĂĄdde mainna son smiehttĂĄ, oainnĂĄt ii go son galgĂĄ leat viehka guhkĂĄ juo ÄohkkĂĄn SĂĄmedikkis.

ADD:real-oainnĂĄt-oainnat (&real-oainnĂĄt-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 @OBJ> OR @ADVL> LINK -1 BOS)(*1 (V Ind) + Neg BARRIER (*) - (N Nom) - (Pron Nom) LINK 1 ConNeg OR ("go" Pcle Qst));
	## Dan oainnĂĄt ii dieÄe okta ge, go FinnmĂĄrkku KomiĆĄuvdna, mii galgĂĄ kĂĄrtet finnmĂĄrkkulaÄÄaid vuoigatvuoÄaid, ii leat boahtĂĄn vel johtui.

ADD:real-oainnĂĄt-oainnat (&real-oainnĂĄt-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (*-1 @OBJ> OR @ADVL> BARRIER NOT-PCLE LINK NOT 0 CS LINK -1 BOS)(*1 (V Ind) + VFIN - Neg - <spelled> OR COMMA BARRIER (*) - (N Nom) - (Pron Nom));
	## Ihttin oainnĂĄt nohkĂĄ dĂĄn ĂĄĆĄĆĄi gulaskuddanĂĄigemearri.
	## Ollu han oainnĂĄt dĂĄhpĂĄhuvvĂĄ gitta Äoahkkimiin ja joatkkaÄoahkkimiin.
	## Nugo oainnĂĄt, de dien govas lea du ĂĄhkku ja govvaÄeahppi lea fĂĄhten hui bures daid dehĂĄleamos beliid ĂĄhkustat. 

ADD:real-oainnĂĄt-oainnat (&real-oainnĂĄt-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (*-1 (V Ind) + VFIN - Err/Any OR BE + Inf BARRIER NOT-ADV-PCLE - ConNeg);
    ## Dat lea ovdal oainnĂĄt dĂĄhpĂĄhuvvan, go Sis-FinnmĂĄrkku suohkaniid vĂĄlljejeaddjit mobiliserejedje ja jienastedje 1993:s GuovddĂĄĆĄbellodaga Johanne Gaup StuorradiggĂĄi..
    #$ ÄalbmegeahÄestagain oidno, don modjestat sutnje, duoÄas oainnĂĄt su, doalahat ieĆŸat su lahka dahje manat su lahka, bovdet su olggos omd. kiinoi, du ustibat muitalit sutnje ahte don leat rĂĄhkĂĄsnuvvan, jus ieĆĄ it duostta muitalit.

ADD:real-oainnĂĄt-oainnat (&real-oainnĂĄt-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (1 Neg LINK 1 ConNeg) ;
    ## Dan geasi oainnĂĄt eat ĆĄatta borrat maidege earĂĄ go luonddu njĂĄlgĂĄid.

ADD:real-oainnĂĄt-oainnat (&real-oainnĂĄt-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 BUT-CC OR THEN-CS-ADV OR BOS)(*1 (N Nom) BARRIER NPNHAPcle LINK *1 (V Ind) + VFIN BARRIER NOT-ADV-PCLE);
	## Dat leamaĆĄ olbmot ÄigĆĂĄi dalle, muhto oainnĂĄt dat soaÄi ĂĄigi hui ollu goaridii...
	
ADD:real-oainnĂĄt-oainnat (&real-oainnĂĄt-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 COMMA LINK NEGATE *-1 (Ind Prs Sg2) OR (Pron Pers Sg2))(1 IF-CS LINK 1 Nom - Sg2);
	## Munnje lea mĂĄilmme dehĂĄlaĆĄ beassat Riddu RiÄÄui, oainnĂĄt jus mun dĂĄppe gulahalan riikkaidgaskasaĆĄ gehÄÄiiguin, de dalle mun gal gulahalan vaikko olles mĂĄilmmi gehÄÄiiguin, dadjala vel loahpas.
	
ADD:real-oainnĂĄt-oainnat (&real-oainnĂĄt-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 COMMA LINK NEGATE *-1 (Ind Prs Sg2) OR (Pron Pers Sg2))(1 (N Nom) OR (<NomGenSg> Sg Acc) + Sem/Hum OR (<NomGenSg> Sg Gen) + Sem/Hum LINK 1 COMMA);
	## Muhto de eahpĂĄdus ÄĂĄĆai mu jurdagiidda, {oainnĂĄt} guldaleaddji, bĂĄlkĂĄ lea hirbmat somĂĄ.
	
SET OAINNAT-SEM = Sem/Measr OR Sem/Time OR Sem/Plc ;

ADD:real-oainnĂĄt-oainnat (&real-oainnĂĄt-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 COMMA LINK *-1 $$OAINNAT-SEM BARRIER NOT-ADV-PCLE  - Po - N LINK NEGATE *-1 (Ind Prs Sg2) OR (Pron Pers Sg2))(*1 $$OAINNAT-SEM BARRIER NPNHA);	
	## FĂĄhkkatlaĆĄ p-pillara sĂĄhttĂĄ vĂĄldit 72 diimmu siste, {oainnĂĄt} golmma jĂĄndoris anaĆĄeamis jus dat galgĂĄ doaibmat.
	## MĂĄnodĂĄvddaid ĂĄigge dĂĄbĂĄlaÄÄat vardĂĄ 20-30 millilittara varra, {oainnĂĄt} illĂĄ desilihtar eanemustĂĄ.

COPY:real-oainnĂĄt-oainnat ("oainnat" Adv SUGGEST) EXCEPT ("oaidnit" V TV Ind Prs Sg2) TARGET (&real-oainnĂĄt-oainnat) ;
	#$ GeahÄa vuorbĂĄdan- ja vuoÄÄudusbearrĂĄigeahÄu neahttasiidduin gos oainnĂĄt bajilgova ohcciin ja 2012 juolluduvvon supmiid.
	## NSR oaivvilda oainnĂĄt dĂĄn ĂĄĆĄĆĄi nu stuorisin ahte dat berre vuojehuvvot buot SĂĄmedikki presideanttaid rĂĄdjĂĄi ja gitta ieĆĄguÄet riikkaid ministariid dĂĄssĂĄi.
	## Beaivvi ovdal leigga oainnĂĄt Guovdageainnus fidnen beaskkaid.
	## Dat lea oainnĂĄt dainnalĂĄgiin ahte Ruhtadandepartemeanta ĆĄiehtadallĂĄ fondii reanttu Norgga BĂĄĆkkuin stĂĄhtaobligaĆĄuvnna hĂĄmis ain logi jahkĂĄi.
	## Lea oainnĂĄt oalle ĂĄrtet go vearroeisevĂĄlddit gal dohkkehit ahte buot boazodoallit devdet sierra ealĂĄhusskoviid mas leat mielde sihke dietnasat ja golut.
	## Lea oainnĂĄt ĂĄibbas Äielggas ahte dĂĄt huksemat ollu bilidit sĂĄmi eatnamiid, erenoamĂĄĆŸit dagahit stuora vahĂĄgiid sĂĄmi ealĂĄhussii, boazodollui.
	## DĂĄl lea oainnĂĄt dainnalĂĄgiin ahte sĂĄmedĂĄlu searvi lĂĄigoha Akersgatas dĂĄl nuppi gearddis gos ii leat vejolaĆĄ doallat sĂĄmedoaluid.
	## Mus leat oainnĂĄt gĂĄvpotmĂĄnĂĄt, sii eai beroĆĄ oaggumis.
	#$ Don oainnĂĄt lea go guovĆŸĆŸa okto vai ii.
	## Lea oainnĂĄt dainna lĂĄgiin ahte mearrĂĄdusa sĂĄhttĂĄ guoddalit Meahcceduopmostullui ja das fas viidĂĄsat gitta AlimusriektĂĄi.
	## Leat oainnĂĄt plĂĄnat stuorra cruisefatnasiid turisttaid finahit bussiiguin MĂĄzes.
	## Son ja earĂĄ oassevĂĄldit eai leat oainnĂĄt oaidnĂĄn progrĂĄmmaid.
	## FinnmĂĄrkku fiehttagat leat dĂĄlvet oainnĂĄt Lulli- Skandinavias ja giÄÄat bohtet monnet eandalii Sis-FinnmĂĄrkui.

    # oasttit (oasttihit) vs. oastit (Inf)
