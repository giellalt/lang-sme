#IF (2 ("Â»") OR ("â") OR ("\"") OR ("'") OR ("âș") OR ("â") OR ("â") OR ("â") OR ("âŻ") OR ("ă") OR ("ïŒ")) ; #NOT THIS ONE! ("â")
