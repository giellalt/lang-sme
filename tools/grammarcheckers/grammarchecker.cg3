# ADD (&keep-your-voice-down) ("^[A-ZĂĂĂĂĆ ĆœÄĆ]+$"r) (NOT (0 (<firstCohortOfParagraph>)));

ADD (&punct-end) TARGET Nom (-1 (\n));

	## Â«Äohkken ĂĄiggiid ÄaÄa buoremus sĂĄmi artisttaidÂ»



    # Spacing errors
    # --------------

# Note that some of these rules some times have to span windows â but
# still go exactly one word â which is a little complicated in
# CG. Therefore, we define some templates for going exactly one word
# to the left/right:
TEMPLATE prevWordCrossSent = (-1 (*)) OR (-1 (>>>) LINK *-2< (<<<) BARRIER (<<<)) ;
TEMPLATE nextWordCrossSent = (1 (*))  OR (0  (<<<) LINK *1>  (>>>) BARRIER (>>>) LINK 1 (*)) ;
# In the above template, the first test is the regular, non-spanning
# case â it just goes exactly one word to the right and matches
# anything.
#
# The second test, if the first one didn't match, will only run from
# the last cohort of a window, and will link to the first word of the
# following window. The "0 (<<<)" means "we're the last word", while
# the (>>>) matches the invisible first cohort of the following window
# (and the BARRIER ensures we only cross exactly one window
# boundary). Then we match anything on the following cohort, which is
# the first real cohort of the window.
#
# See http://beta.visl.sdu.dk/cg3/single/#test-spanning for some
# documentation on the < and > modifiers, and
# http://beta.visl.sdu.dk/cg3/single/#templates on templates. The
# below rules use these templates like
# (T:nextWordCrossSent LINK 0 (<someTag>))

## ( ĂĄddejumi

	# Clean up potential punctuation error tagging before making real errors of them
	# ------------------------------------------------------------------------------

	# Remove the <NoSpaceAfterPunctMark> tag if followed by a quote sign:
SUBSTITUTE:RemopveNoSpaceAfterPunctMark (<NoSpaceAfterPunctMark>) (*) TARGET CLB IF (T:nextWordCrossSent LINK 0 QMARK );
#SUBSTITUTE:RemopveNoSpaceAfterPunctMark (<NoSpaceAfterPunctMark>) (*) TARGET ABBR IF (1 PUNCT-RIGHT );

SUBSTITUTE:RemoveNoSpaceAfterPunctMark (<NoSpaceAfterPunctMark>) (*) TARGET ("!") IF (T:nextWordCrossSent LINK 0 ("!"));
	## RĂĄhkat seaguhusa bohttalii, ja biddju de viesu lusa ja de!!!

SUBSTITUTE:RemoveNoSpaceAfterPunctMark (<NoSpaceAfterPunctMark>) (*) TARGET ("?") IF (T:nextWordCrossSent LINK 0 ("?"));

	# Error tags on bad punctuation or missing/extra spaces
	# -----------------------------------------------------

ADD:space-after-paren-beg      (&space-after-paren-beg)       TARGET (<spaceAfterParenBeg>) ;
ADD:space-after-paren-beg-link (&space-after-paren-beg COERROR) TARGET (*) IF (-1 (<spaceAfterParenBeg>) ) ;
ADDRELATION:space-after-paren-beg-rel (RIGHT) (&space-after-paren-beg) TO (1 (COERROR) LINK 0 (&space-after-paren-beg)) ;
COPY:space-after-paren-beg-sugg (VSTR:"$1$2"S SUGGESTWF) TARGET ("<(.*)>"r &space-after-paren-beg) IF
        (1 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;
	## ĂĄddejumi )

ADD:space-before-paren-end      (&space-before-paren-end)       TARGET (<spaceBeforeParenEnd>);
ADD:space-before-paren-end-link (&space-before-paren-end COERROR) TARGET (*) IF (1 (<spaceBeforeParenEnd>) );
ADDRELATION:space-before-paren-end-rel (LEFT) (&space-before-paren-end) TO (-1 (COERROR) LINK 0 (&space-before-paren-end) );
COPY:space-before-paren-end-sugg (VSTR:"$2$1"S SUGGESTWF) TARGET ("<(.*)>"r &space-before-paren-end) IF
        (-1 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;
	## Son gii njeaidĂĄ skĂĄluid ĆĄaddĂĄ eret vuolgit. De galgĂĄ fas cegget skĂĄluid ja ĂĄlgit gaikut.

ADD:space-before-punct-mark (&space-before-punct-mark) TARGET (<SpaceBeforePunctMark>)(NEGATE -1 <SpaceOnRightSide>);
	#$ Paltto (s. 37) Â«mĂĄnĂĄt sturrot/mun ieĆĄ boarĂĄsmuvanÂ» {?}?
ADD:space-before-punct-mark-link (&space-before-punct-mark COERROR) TARGET (*) IF (1 (<SpaceBeforePunctMark>) );
ADDRELATION:space-before-punct-mark-rel (LEFT) (&space-before-punct-mark) TO (-1 (COERROR) LINK 0 (&space-before-punct-mark) );
COPY:space-before-punct-mark-sugg (VSTR:"$2$1"S SUGGESTWF) TARGET ("<(.*)>"r &space-before-punct-mark) IF
        (-1 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;
	## vuosttu  ceggejit
	## ĂĄlgit gaikut.  Stoagus joatkĂĄ
	## maid lea bargu.  â Mun barggan

ADD:double-space-before (&double-space-before)     (<doubleSpaceBefore>);
ADD:double-space-before-link (&double-space-before COERROR) TARGET (*) IF (T:nextWordCrossSent LINK 0 (<doubleSpaceBefore>)) ;
ADDRELATION:double-space-before-rel ($2) (*) FROM (T:nextWordCrossSent LINK 0 (<doubleSpaceBefore>)) ; #SJUR WHY NOT LEFT OR RIGHT?
ADDRELATION:double-space-before-rel (LEFT) (COERROR) FROM (T:nextWordCrossSent LINK 0 (<doubleSpaceBefore>)) ;
COPY:double-space-before (VSTR:"$2\ $1"S SUGGESTWF) TARGET ("<(.*)>"r &double-space-before) IF
        (T:prevWordCrossSent LINK 0 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;
	# Test sentence: 'Sanner,gii rĂĄÄÄehusas.gii lĂĄvvardaga?Bonju dĂĄn!Lassin.'
	## Sanner,gii                       - works
	## rĂĄÄÄehusas.Europride-festivĂĄla   - does not work
	## lĂĄvvardaga?Bonju                 - does not work
	## rĂĄidovĂĄzzimis!Lassin             - does not work

	# 1. Add error tag on punctuation
LIST no-space-after-punct-OK-before = (")") ("/") ("!") ("?") (","); # Â«jna.)Â» is OK

#ADD:no-space-after-punct (&no-space-after-punct-mark) TARGET (<NoSpaceAfterPunctMark>) IF (T:nextWordCrossSent) (NOT 1 no-space-after-punct-OK-before)(NEGATE 0 (A Arab));

ADD:no-space-after-punct (&no-space-after-punct-mark) TARGET (<NoSpaceAfterPunctMark>) IF (T:nextWordCrossSent LINK NOT 0 no-space-after-punct-OK-before)(NEGATE 0 (A Arab))(NEGATE 0 Sem/Sign LINK 1 Sem/Sign LINK 1 Sem/Sur)(NEGATE 1 (Num Arab Sg) OR (Num Sem/ID) LINK -1 (";") LINK -1 (Num Arab Sg) LINK *-1 ("ahki") BARRIER (*) - (Num Arab Sg) - (Num Sem/ID) - (";"))(NEGATE 0 (ABBR Gram/IAbbr) LINK 1 COMMA OR CITATION)(NEGATE 0 ("!") LINK 1 ("!"))(NEGATE 0 Sem/Date OR ABBR LINK 1 COMMA OR (";") OR (":"))(NEGATE 0 ("..."))(NEGATE 0 COMMA LINK 1 ("." CLB))(NEGATE 0 ( "." CLB) OR ( "?" CLB) OR ( "!" CLB) OR ( "," CLB) LINK *1> ("Â»") OR (""") OR ("'")) (NEGATE 0 ( "?" CLB) OR ( "!" CLB) LINK *1> ( "?" CLB) OR ( "!" CLB))(NEGATE 0 (")") LINK -1 ABBR)(NEGATE 0 ABBR LINK 1 (")")) ;
	#$ ErenoamĂĄĆŸit ruoĆ§a gĂĄldut ÄuoÄÄuhit ahte sĂĄmiin ii leat leamaĆĄ ieĆŸaset metĂĄlladiĆggaid buvttadus. Muhtin girjjis sĂĄmi kultuvrra birra ÄuoÄÄuhuvvo ahte Â«Datni lea ĂĄidna metĂĄlla maid sĂĄmit leat ieĆŸa gieÄahallan....Â» ja Vaapsteguovllus muitala nuppi girji: Â«MetĂĄllas eai rĂĄhkadan sĂĄmit makkĂĄrge ruovttodoallobiergasa. Visot maid dĂĄrbbaĆĄii, son osttii, ja dat ii lean ollu ge.Â»
	#$ RĂĄhkat seaguhusa bohttalii, ja biddju de viesu lusa ja de!!!
    #$ ILS ĂĄrvvoĆĄtalai buot geahÄÄalemiid mannan giÄa maid {4.}, 7. ja 10. luohkĂĄid ja vuoÄÄokurssa oahppit ÄaÄahedje.
    #$ DĂĄs buvttĂĄn dĂĄl ieĆŸan ÄĂĄllosiid; jearahallamiid Â«mearrasĂĄmehoavddainÂ» {H.}J. Leonardsen, ja Nordkapp SĂĄmiid Searvvi joÄiheddjiin, Ivar Utsi.
    #$ BeaivegirjenotĂĄhtat agis {1;1â3;6.4} leat oktiibuot logi ieĆĄguÄege sturrosaĆĄ ÄĂĄllingirjji, muhto guorahallanĂĄigodaga rĂĄddjema dihte {gÄ. s. 54} geavahan dĂĄs ovcci vuosttaĆĄ girjji agi 3;0.6 rĂĄdjĂĄi, seamma ahkĂĄi goas maĆimus videobĂĄtti materiĂĄla lea bĂĄddejuvvon.
    #$ DĂĄt dovdomearkkat leat maid boazodoalu muohtakarakteriseremis, mas omd. geavahit dajaldagaid assĂĄs geardni dan sadjĂĄi go dĂĄrkilis mihtidemiin, ahte lea omd. 10 cm geardni (Eira {et al.}, 2011, sisa sĂĄddejuvvon).

	# 2. Add error tag + COERROR on the following word (part 1 of extending the blue underline to the following word):

ADD:no-space-after-punct-link (&no-space-after-punct-mark COERROR) TARGET (*) IF (T:prevWordCrossSent LINK 0 (&no-space-after-punct-mark) LINK NOT 0 (COERROR))(NEGATE 1 (Num Arab Sg) OR (Num Sem/ID) LINK -1 (";") LINK -1 (Num Arab Sg) LINK *-1 ("ahki") BARRIER (*) - (Num Arab Sg) - (Num Sem/ID) - (";"))(NEGATE 0 (Num Arab Sg) OR (Num Sem/ID) LINK -1 (";") LINK -1 (Num Arab Sg) OR (Num Sem/ID) LINK -1 ("ahki"))(NEGATE 0 COMMA LINK -1 (ABBR Gram/IAbbr))(NEGATE 0 ("!") LINK 1 ("!"))(NEGATE 0 COMMA LINK 1 ("." CLB))(NEGATE 0 ( "." CLB) OR ( "?" CLB) OR ( "!" CLB) LINK *1> ("Â»"))(NEGATE 0 ( "?" CLB) OR ( "!" CLB) LINK *1> ( "?" CLB) OR ( "!" CLB))(NEGATE 0 (")") LINK -1 ABBR)(NEGATE 0 ABBR LINK 1 (")"))  ;
	#$ Agi 2;0 rĂĄjes guorahallanĂĄigodaga loahpageahÄai, ahkkĂĄi 2;10, mĂĄnnĂĄ geavaha 3. persovnna hĂĄmis muhtumin geahnohisdĂĄsat mĂĄddaga.
	#$ Don oainnĂĄt vuolimusas galle sĂĄni galggat ivdnet juohke cealkagis,.

	# 3. Add RIGHT relation on the punctuation (part 2 of extending the blue underline to the following word,
	#    also ensures that the correction will replace the word, not be appended to it):
ADDRELATION:no-space-after-punct-rel (RIGHT) (COERROR) FROM (T:prevWordCrossSent LINK 0 (<NoSpaceAfterPunctMark>)) ;
	# 4. Add suggestions
COPY:no-space-after-punct-sugg (VSTR:"$1\ $2"S SUGGESTWF) TARGET ("<(.*)>"r &no-space-after-punct-mark) IF
        (T:nextWordCrossSent LINK 0 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;

	# No space before parentheses - 1: add error tag on the target cohort:
ADD:no-space-before-parenthesis (&no-space-before-parent-start) TARGET (<NoSpaceBeforeParenBeg>) ;
	## VuoigatvuoÄa LĂĄvdegotti(SVL).
	#$ VuoigatvuoÄa LĂĄvdegotti (SVL).

	# No space before parentheses - 2: add error tag + link on the preceding cohort:
ADD:no-space-before-parenthesis (&no-space-before-parent-start COERROR) TARGET (*) IF ( 1 (&no-space-before-parent-start))(NEGATE 0 <NoSpaceBeforeParenBeg> ) ; # the preceding cohort

	# No space before parentheses - 3: add LEFT relation:
ADDRELATION:no-before-after-parenthesis (LEFT) (COERROR) FROM ( 1 (<NoSpaceBeforeParenBeg>)) ;

	# No space before parentheses - 4: Add suggestions
COPY:no-space-before-parenthesis (VSTR:"$2\ $1"S SUGGESTWF) TARGET ("<(.*)>"r &no-space-before-parent-start) IF
        (-1 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;


	# No space after parentheses - 1: add error tag on the target cohort:
ADD:no-space-after-parenthesis (&no-space-after-parent-end) TARGET (<NoSpaceAfterParenEnd>)(NEGATE 1 CLB OR PUNCT)(NEGATE 0 <LastCohortOfParagraph>) ;
	## VuoigatvuoÄa LĂĄvdegotti(SVL)Äilgehus.
	#$ VuoigatvuoÄa LĂĄvdegotti(SVL).

	# No space after parentheses - 2: add error tag + link on the following cohort:
ADD:no-space-after-parenthesis (&no-space-after-parent-end COERROR) TARGET (*) IF (-1 (&no-space-after-parent-end))(NEGATE 0 <NoSpaceAfterParenEnd> ) ; # the folloowing cohort

	# No space after parentheses - 3: add RIGHT relation:
ADDRELATION:no-space-after-parenthesis (RIGHT) (COERROR) FROM (-1 (<NoSpaceAfterParenEnd>)) ;

	# No space after parentheses - 4: Add suggestions
COPY:no-space-after-parenthesis (VSTR:"$1\ $2"S SUGGESTWF) TARGET ("<(.*)>"r &no-space-after-parent-end) IF
        (1 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;


	# comma errors
	# ------------
	#ÄĂĄllinrĂĄvagirji komma: muhto-konjunkĆĄuvnna ovddabeallai biddjo rihkku. Son livcÌcÌii gal viĆĄĆĄal, muhto sus ii leat goassege dilli bargat. Olgoriikkas ii oahpa duĆĄĆĄe giela, muhto ollu eanetge.
	#1.2 Goas eat ane rihkku
	#Oanehis cealkagiin mat gullet oktii:
	#Son oaivvildii ahte lea buoret joÄi go oru. Dihten ahte vuolggĂĄt odne.
	#Oanehis cealkagiin, main objeaktan lea cealkkaoassi, eat bija rihku konjunkĆĄuvnna ahte ovddabeallĂĄi:
	#Mun dihten ahte dat ii mana bures.
	#Rihkku galgĂĄ biddjot oalgecealkaga maĆĆĂĄi.
	#Ahte nu galggai geavvat, dan ii lean gal oktage ĂĄrvidan.
	#Go ĂĄhcÌcÌi boahtĂĄ, de mii herskkostallat.
	#Jos mii dalle eat livcÌcÌe vuolgĂĄn ruoktot, de gal leimmet gĂĄrtat vuordit mĂĄĆga beaivvi. Vaikke ledjege vĂĄiban, de dat dattetge ain jotke.

#DELETE SECOND ROUND
		
ADD:xpunct-rihkku (&punct-rihkku) TARGET BUT-CC + CC IF (NEGATE -1 COMMA OR BOS OR QMARK OR (";") OR ("âŠ") OR (":") OR ("-") OR ("â") OR PUNCT);	
	#$ Undertittel: {Muhto} Heaika ii bala dien âsĂĄnisâ.
    #$ Jus vĂĄssĂĄnĂĄigi livÄÄe earĂĄlĂĄgan, de livÄÄe maid min dĂĄlĂĄĂĄigi ja boahtteĂĄigi earĂĄlĂĄgan âŠ Muhto ĂĄllet fal divtte ovttage dadjat didjiide ahte lea menddo maĆĆit!	
	#$ Â» {M}uhto sii eai adden dĂĄn eai ge duostan jearrat sus.
	## Son livcÌcÌii gal viĆĄĆĄal muhto sus ii leat goassege dilli bargat.
	## Olgoriikkas ii oahpa duĆĄĆĄe giela muhto ollu eanetge.
# comma error: Dan vuoÄul maid ovdelis lean namuhan balan{,} ahte KĂĄrĂĄĆĄjoga nuoraidruovttus ii leat sihkkaris boahtteĂĄigi.
     ## Sii muitaledje maid doppe ledje gullan muhto Ănde gal ii orron jĂĄhkkimin dasa.
     
ADD:xpunct-rihkku (&punct-rihkku) TARGET THEN-CS-ADV IF (*-1 BOS LINK 1 THAT-CS OR IF-CS OR ("jos") OR BECAUSE-WHEN OR ("vaikke") OR ("vaikko") OR ("ovdal go") OR ("maĆĆel go") OR ("dassĂĄ go") OR ("dan botta go") OR ("dalle go"))(NEGATE -1 COMMA OR BOS OR ("-") OR ("â") OR ("/") OR (":"))(NEGATE -1 CC OR CS LINK -1 BOS)(NEGATE *-1 ("ja") BARRIER NPNHA - Po)(NEGATE -1 BECAUSE-WHEN LINK -1 NOT-V LINK -1 COMMA)(NEGATE -1 ("ii" Qst) LINK -1 COMMA);
	#$ Go de dadjĂĄ ahte dĂĄt gapmu lea historjjĂĄlaÄÄat, kultuvrralaÄÄat ja sosiĂĄlalaÄÄat Äadnon, de adden ahte vĂĄsĂĄhusat justa leat Äoagganan rupmaĆĄii, ja daid vuoÄul {de} sĂĄhttit gamus dovdat ovdal go mĂĄhttit dan Äilget.
	#$ Go de ÄuÄit bohtet sudno vissui, ferteba soai ÄiehkĂĄdit.
	## Jos mii dalle eat livcÌcÌe vuolgĂĄn ruoktot de gal leimmet gĂĄrtat vuordit mĂĄĆga beaivvi.
	## Vaikke ledjege vĂĄiban de dat dattetge ain jotke.
	## Ovdal go mun bohten de vulggii ĂĄhÄÄi.
	
	# subclause first, main clause with subject first
	# - - - - - - - - - - - - - - - - - - - - - - - -
ADD:xpunct-rihkku (&punct-rihkku) TARGET V IF (0 VFIN)(NEGATE 0 <aux> LINK NOT *1 Inf OR PrfPrc)(NEGATE 0 (Inf SUGGEST) OR (PrfPrc SUGGEST) OR (Adv SUGGEST))(*-1 (Pron Pers Nom) OR (Pron Dem Nom) - @>N OR (N Nom) OR ("dat" Pcle) BARRIER Rel OR CS OR THEN-CS-ADV LINK NOT 0 Rel OR <firstCohortOfParagraph> LINK *-1 VFIN BARRIER CS OR Rel OR COMMA LINK  NOT 0 <vdic> LINK *-1 THAT-CS OR IF-CS OR ("jos") OR BECAUSE-WHEN OR ("vaikke") OR ("vaikko") OR ("ovdal go") OR ("maĆĆel go") OR ("dassĂĄ go") OR ("dan botta go") OR ("dalle go") BARRIER COMMA OR (":") OR (";") OR CS LINK -1 BOS)(NEGATE *-1 (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) LINK *-1 COMMA OR BOS BARRIER NPNHAPcle - THEN-CS-ADV)(NEGATE *-1 COMMA OR (";") OR (":") OR ("-") BARRIER (*) - THEN-CS-ADV - Pcle - CS - @SUBJ> - Adv - CC)(NEGATE *1 THEN-CS-ADV LINK -1 COMMA)(NEGATE -1 Adv LINK -1 CC);
	#$ Go dĂĄn digaĆĄtallama loktejit guovllulaĆĄ dĂĄssĂĄi de das lea buoret vuoÄÄu gĂĄvdnat vel eanet  buori ĂĄkkaid  ja buorebut {} sĂĄhttet oktiiÄatnat fierpmĂĄdagaid Norggas ja Suomas.
	#$ Vaikko nĂĄ buorit ovdamunit leat; eahpelihkostuvvat mii atnit vejolaĆĄvuoÄaideamet ja {} leat vuoittahallit ruovttuguovllus.
	#$ Jus livÄÄe ÄaÄahuvvon albma dutkamat, ja eai livÄÄe duĆĄĆĄe Äaskan oivviid eret vĂĄldoolbmuin, de sihkkarit ÄĂĄllojuvvon historja maĆĆil 1852 {livÄÄii} ĆĄaddan ĂĄibbas earĂĄ.
	#$ Jus leaĆĄ dieÄut govvii - {sĂĄhttibehtet} riĆget dahje fitnat min luhtte.
	#$	SĂĄmediggi atnĂĄ dĂĄrbun deattuhit dĂĄn ja muittuhit ahte seammĂĄs go boazodoalu guohtongeavaheapmi guhkĂĄ lea mearriduvvon lĂĄgas, de leat lĂĄgat ja hĂĄlddaĆĄeapmi uhccĂĄn beroĆĄtan ja gozihan earĂĄ sĂĄmi resursageavaheami.
    #$ Jus dat leat duoÄat sĂĄhttĂĄ dat mielddisbuktit eahpĂĄdusa ja balu nuorra sĂĄpmelaÄÄaid gaskkas {joatkit} / ĂĄlgit oahpu vĂĄldit HĂĄpmira joatkkaskuvllas.
    #$ Ahte earĂĄt eai ĆĄat galgga stivret vel dan ge maid {mii} jurddaĆĄit ieĆŸamet oaivvisteamet.
    #$ Go geahÄÄĂĄ mo ovddeĆĄ ĂĄigge ĂĄrbevirolaĆĄ mĂĄhtut fievrriduvvojedje boazodoalus ja buohtastahttĂĄ dan otnĂĄ diliin, de sĂĄhttĂĄ buorebut addet mii odne gĂĄibiduvvo mĂĄhtuid seailluheapmĂĄi.
    #$ Jos dii livÄÄiidet adden maid dĂĄt sĂĄtni mearkkaĆĄa : VĂĄibmolĂĄÄisvuoÄa mun dĂĄhtun, in ge oaffara, de ehpet livÄÄe dubmen sivahemiid.
   #$ Go maĆĆĂĄ fas lean oaidnĂĄn dan seamma lĂĄttĂĄna, gurĆŸo dahje turista, go son {leat} bivddus lihkostuvvan, de lea son aiddo loktaneamen ĂĄvvudeamis.
	#$ Vaikke vel KĂĄrĂĄĆĄjogas ja Guovdageainnus leat matematihkalaÄÄat menddo unnĂĄn ĂĄirasat, de dat {leat} liikkĂĄ ĂĄidna ovttaskas gielddat mat sĂĄddejit ieĆŸaset ĂĄirasiid SĂĄmediggĂĄi, almmĂĄ gilvaleami haga earĂĄ gielddaiguin.	
	#$ Jos eadni dahje ĂĄhÄÄi lea ĂĄidna olmmoĆĄ {gii} hĂĄllĂĄ sĂĄmegiela mĂĄnnĂĄi, de ĆĄaddĂĄ lossat oahpahit giela.
	## MaĆĆil go ĂĄhÄÄi boÄii mun vulgen.
	## DassĂĄ go Niillas boahtĂĄ mun vuorddĂĄn.
	## Dalle go mii leimmet mu ĂĄhÄiin ovtta siiddas mun galgen ieĆĄ vuolgit merrii.

ADD:xpunct-rihkku (&punct-rihkku) TARGET V IF (0 VFIN)(NEGATE 0 <aux> LINK NOT *1 Inf OR PrfPrc)(*-1 (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) OR ("dat" Pcle) BARRIER Rel LINK NOT 0 Rel OR <firstCohortOfParagraph> LINK *-1 VFIN LINK *-1 ("rĂĄjes") LINK -1 ("dat" Pron Dem Sg Acc) OR ("dat" Pron Dem Sg Gen) LINK -1 BOS)(NEGATE *-1 (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) LINK *-1 COMMA OR BOS BARRIER NPNHAPcle - THEN-CS-ADV)(NEGATE *-1 COMMA OR (";") BARRIER (*) - THEN-CS-ADV - Pcle);
	## Dan rĂĄjes go nĂĄitaleigga dat juo leaba juo huksen dĂĄlu.
	
ADD:xpunct-rihkku (&punct-rihkku) TARGET V IF (0 VFIN LINK 0 NOT-V + Ind LINK *1 ConNeg BARRIER NOT-ADV-PCLE LINK *1 ONE + (Pron Indef Sg Nom Foc/Neg-ge) BARRIER GRAMCHK-S-BOUNDARY)(*-1 VFIN BARRIER <firstCohortOfParagraph> LINK *-1 THAT-CS OR IF-CS OR ("jos") OR BECAUSE-WHEN OR ("vaikke") OR ("vaikko") OR ("ovdal go") OR ("maĆĆel go") OR ("dassĂĄ go") OR ("dan botta go") OR ("dalle go") LINK -1 BOS)(NEGATE *-1 (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) LINK *-1 COMMA OR BOS BARRIER NPNHAPcle - THEN-CS-ADV)(NEGATE *-1 COMMA OR (";") BARRIER (*) - THEN-CS-ADV - Pcle);	
	## Ahte nu galggai geavvat dan ii lean gal oktage ĂĄrvidan.

	# subclause first, main clause without subject first
	# - - - - - - - - - - - - - - - - - - - - - - - - - -
ADD:xpunct-rihkku (&punct-rihkku) TARGET V IF (0 VFIN LINK NOT 0 Inf OR (Gram/3syll Ind Prs Pl3))(NEGATE 0 (PrfPrc SUGGEST) OR (Inf SUGGEST) OR (Adv SUGGEST))(*-1 VFIN BARRIER NOT-ADV-PCLE LINK *-1 THAT-CS OR IF-CS OR ("jos") OR BECAUSE-WHEN OR ("vaikke") OR ("vaikko") OR ("ovdal go") OR ("maĆĆel go") OR ("dassĂĄ go") OR ("dan botta go") OR ("dalle go") BARRIER (";") LINK -1 BOS)(NEGATE *-1 (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) LINK -1 COMMA OR BOS)(NEGATE -1 THEN-CS-ADV LINK -1 BECAUSE-WHEN LINK -1 NOT-V LINK -1 COMMA)(NEGATE -1 ("ii" Qst) LINK -1 THEN-CS-ADV LINK -1 COMMA)(NEGATE 0 &syn-double-negation)(NEGATE -1 (V Neg));
	#$ Vaikko luohti lea muhtun guovlluin ealli ĂĄrbevierru, muhtun sajiin dat fas lea ĂĄibbaĆĄ jĂĄvkan.
	#$ Go mĂĄnĂĄid ĂĄlo galgĂĄ Äalmmis doallat, amaset {eai} ĆĄatta biilla vuollai, vĂĄidala Gerd ja Biret-ĂĄhkku lea ovtta oaivilis.		
	## Dan botta go mĂĄnnĂĄ oaÄÄĂĄ ĂĄiggun gohpuid bassat.
    #$ Go geahÄÄat leavttu ja dan guÄe guvlui leat manname, ii go {de} livÄÄe kapteainnas buot eanemus jierpmĂĄlaĆĄ jurdda stivregoahtit nuppe guvlui ja dĂĄhttut buot olbmuid mannat gĂĄdjunfatnasiidda?
    #$ Go oahppit leat {adden} dahje ipmirdan ieĆĄ dan sisdoalu dĂĄhpĂĄhusas, sĂĄhttĂĄ oahpaheaddji jearrat ahte leat go sii ovttaoaivilis dĂĄinna sisdoaluin.

ADD:xpunct-rihkku (&punct-rihkku) TARGET ("daÄe") IF (*-1 BOS LINK 1 ("maÄe"))(NEGATE -1 COMMA OR BOS);
	## MaÄe losit siivu daÄe njoazebut mannĂĄ mĂĄtki.

ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE ("ja" CC) IF  (1 ("de" &punct-rihkku))(NEGATE 0 ADDED-BEFORE-BLANK);
	## Jus mii dal joatkit vuovdimiin, de ii njuolgga mĂĄrkan goassege ja de bĂĄllejit kilohatti njeaidit daÄi eanet jagis jahkĂĄi ja loahpas ÄohkkĂĄt mii 5 kr. kilohattiin, ballĂĄ Eira.
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE ("muhto" &punct-rihkku) OR ("de" &punct-rihkku) OR ("daÄe" &punct-rihkku) IF (NEGATE -1 CC LINK -1 (","))(NEGATE -1 ("<,>"))(NEGATE 0 ADDED-BEFORE-BLANK);
	#$ Jus mii dal joatkit vuovdimiin, de ii njuolgga mĂĄrkan goassege ja de bĂĄllejit kilohatti njeaidit daÄi eanet jagis jahkĂĄi ja loahpas ÄohkkĂĄt mii 5 kr. kilohattiin, ballĂĄ Eira.
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) OR ("dat" Pcle) IF (*1 VFIN + (V &punct-rihkku) BARRIER NOT-ADV-PCLE)(NEGATE -1 ("<,>"))(NEGATE 0 ADDED-BEFORE-BLANK) ;
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE VFIN IF (0 (V &punct-rihkku))(*-1 VFIN BARRIER NOT-ADV-PCLE)(NEGATE -1 ("<,>"))(NEGATE 0 ADDED-BEFORE-BLANK) ;

	# this one takes into account the position of the parent of a preceeding accusative
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE Acc IF (rp V) (1 (V &punct-rihkku))(NEGATE -1 ("<,>"))(NEGATE 0 ADDED-BEFORE-BLANK) ;


	# goallosĂĄhcu sĂĄni ovdal
	# - - - - - - - - - - - -
	
##ADD:punct-sahcu (&punct-sĂĄhcu) TARGET ("-" PUNCT) IF (NEGATE -1 CC);	
	## Muitalusat -girji
	
LIST CS-RIHKKU = "ovdal" "ovdalgo" "maĆĆelgo" "dassĂĄĆŸii" ;
	

	# Comma between two main clauses with subject
	# - - - - - - - - - - - - - - - - - - - - - -
	# Rihkku biddjo dievaslaĆĄ vĂĄldocealkagiid gaskii.

ADD:xpunct-rihkku (&punct-rihkku) TARGET ("ja") IF (NOT 0C @CNP)(*1 SUBJ BARRIER CC OR CS OR VFIN OR <firstCohortOfParagraph> LINK *1 VFIN BARRIER @CVP)(*-1 VFIN BARRIER CC OR COMMA LINK NOT 0 N + CASE)(NEGATE -1 COMMA OR (";") OR Cmp/SplitR)(NEGATE 1 THAT-CS)(NEGATE -1 Attr OR @>N)(NEGATE -1 (N Sg Nom) LINK 2 (N Sg Nom))(NEGATE 1 (A Sg Nom) OR PrsPrc OR (Der/NomAg N Sg Nom) LINK -2 (Der/NomAg N Sg Nom) OR (A Sg Nom) OR PrsPrc)(NEGATE 1 Interr OR ("makkĂĄraĆĄ"))(NEGATE 1 MO-MANge)(NEGATE -1 VFIN LINK -1 CS-RIHKKU)(NEGATE 1 Inf LINK -2 Inf LINK *-1 AUX)(NEGATE -1 PrfPrc + Der/Pass LINK NEGATE *-1 BE) ;
	#$ Fiinna virge namahuvvon {ja} fiinna namat olbmot leat moanat mĂĄllĂĄsiid oktavuoÄas hupmat viĆĄuvnna birra "SĂĄpmi rĂĄjiid haga"
    #$ De mun gal vuot fertejin duoÄalaÄÄat sutnje geahÄastit ja jearralit mot moai sĂĄhtĂĄĆĄeimmet dĂĄn guovllu bullehit - go lagamus bievla lea ÄuoÄi miilla duohken - muÄui lea duĆĄĆĄe muohta nu guhkĂĄs go Äalbmi guoddĂĄ.
	#$ Ăhku biejus leat mii dĂĄl guldaleame mot dalle doloĆĄ ĂĄiggi geavai go ĂĄhkku ja earĂĄ sĂĄhpannieiddat ledje meahccĂĄi lĂĄhppon, ja go buoidda Äere {ja} guokte vilgesĂĄhpanbĂĄrtni sin doppe gĂĄvdne ja hĂĄste sin ieĆŸaset bieju lusa vuolgit.
	 #$ DĂĄl ii leat ge ĆĄat guhkĂĄ ovdal {bivalda} ja muohta suddĂĄ, ja de ĆĄaddĂĄ fas buoret guohtun.
     #$ DĂĄs oahpaheaddji sĂĄhttĂĄ fuomĂĄĆĄit geat ĂĄddejit rolla-sĂĄni sisdoalu {ja} mo earĂĄt leat ÄoavdĂĄn / adden dan.
	 #$ Dat earru lea dat ahte makkĂĄraĆĄ vuolggasajis dutkan dahkko, gean dĂĄrbbuide dat dahkko {ja} makkĂĄraĆĄ ĂĄddejumi dieÄu birra lea go dutkamuĆĄ dahkko.
	 #$ MĂĄnĂĄidgĂĄrdefĂĄlaldat galgĂĄ fuolahit mĂĄnĂĄid giela ja kultuvrra {ja} vuoÄÄuduvvot dakkĂĄr sĂĄmi ĂĄrvvuide go âgal dat oahppĂĄâ ja mihttomearrĂĄi ahte sihkkarastit mĂĄnĂĄ vejolaĆĄvuoÄa ovdĂĄnit iehÄanas individan.
	 #$ Danne buktĂĄ proĆĄeavtta â Buoret ĂĄrvvoĆĄtallangeavahus â doibmiibidjan oahppoplĂĄnageavahusa plĂĄnadĂĄsiide, ja sĂĄvvamis vuogĂĄiduhttĂĄ guÄelĂĄhkĂĄi oahpaheaddjit {ja} skuvlajoÄiheaddjit barget ĂĄrvvoĆĄtallaneavttuiguin ulbmilrelaĆĄuvnnas, ja viidĂĄseappot veahkehit oahpaheddjiid maiddĂĄi konkretiseret gelbbolaĆĄvuoÄaulbmiliid ieĆĄguhtetge oahppi oahppoulbmilin.
	 #$ SkĂĄiddeduoddara badjeolbmot ballet oÄÄa EO- njuolggadusat ja gĂĄibadusat sĂĄhttet dagahit ahte	MĂĄÄĂĄrjĂĄvrri	boazunjuovahat PorsĂĄnggus ii dohkkehuvvo.
	 #$ SĂMI KULTUVRA SĂĄmediggi oaidnĂĄ ahte lea deaĆ§alaĆĄ ja {riggudahtti} Norgii bisuhit sĂĄmi giela, kultuvrra ja ĂĄrbevieruid dain guovlluin gos sĂĄmit ĂĄrbevirolaÄÄat leat ĂĄssan, ja gos dii doibmet . 
	 ## Dat lea oalle galmmas ja vuoddjit leat bidjan rĂĄjĂĄ 25 buolaĆĄgrĂĄdii, Äilge HĂŠtta.
	 ## Dasa lassin lea RuoĆ§a SĂĄmediggi lohpidan doarjut riikkajoavkku 90 000.-, dieÄiha presideanta â RuoĆ§a SĂĄmediggi lea hĂĄrve dorjon riikkajoavkku {ja} mii leat ilolaĆĄ go dĂĄl ĂĄddet doarjaga.
	 #$ DĂĄn buĆĄeahttapoastta badjel ruhtaduvvo sĂĄmi aviissaid buvttadeapmi ja doarjja buvttadit aviisasiidduid julev- ja mĂĄttasĂĄmegillii.
	 #$ Geasi ĂĄigge dĂĄn guovllus vĂĄnddardettiin olbmui ĆĄaddĂĄ dego niegulĂĄgan dovdu, dasgo go beaivi bĂĄitĂĄ {ja} ligge jĂĄndoriid mielde ovtta manu, de ĂĄigeĂĄddejupmi jĂĄvkĂĄ dego bihÄosa ahkidis huikkaĆĄeapmi duottarvieltti jeakkĂĄdagas.
	 #$ RĂĄÄÄi ĂĄdde ahte dĂĄt buktĂĄ eahpesihkkarvuoÄa sihke bargiide {ja} erenoamĂĄĆŸit geavaheaddjiide, go dĂĄt lea ĂĄidna mĂĄnĂĄidsuodjalanfĂĄlaldat sĂĄmegielat nuoraide geat leat gaskal 12-18 jagi. 
     ## Elle boÄii mĂĄnĂĄinis jo juovlamĂĄnus ja earĂĄt fas gĂĄrte vuordit gitta guovvamĂĄnnui. 
     ## Mun liikon cÌuoigat ja MĂĄret fas liiko viehkat.
     #$ SĂĄmediggi lea finnmĂĄrkkulĂĄhkaproseassa rĂĄjes juohke ĂĄidna lĂĄhkabarggus oaivvildan ahte ILO-konvenĆĄuvdna nr. 169 ferte siskkĂĄldahttojuvvot {ja} ahte dasa ferte addojuvvot ovdasadji Norgga lĂĄga ovddabeallĂĄi seamma lĂĄhkai go konvenĆĄuvnnat Siviila ja PolitihkalaĆĄ vuoigarvuoÄaid birra ja maiddĂĄi EkonomalaĆĄ SosiĂĄla ja KultuvrralaĆĄ vuoigatvuoÄat birra leat oĆŸĆŸon.
     #$ DĂĄt bargu lea dehĂĄlaĆĄ vai juohke ĂĄidna sĂĄpmelaĆĄ galgĂĄ sĂĄhttit ĂĄvkkĂĄstallat vuoigatvuoÄa- {ja} politihkkaovdĂĄneami mii lea dĂĄhpĂĄhuvvan maĆimus moaddelot jagi ja boahtĂĄn ĂĄvkin sĂĄpmelaÄÄaide Norggas.
     
     
ADD:xpunct-rihkku (&punct-rihkku) TARGET (Nom) IF (0 Sem/Animate - Num - ("ieĆĄ") LINK *1 VFIN BARRIER Rel OR GRAMCHK-S-BOUNDARY OR COMMA OR CC OR ("iige") LINK NOT 0 Inf OR N + CASE)(NEGATE 0 Rel OR (A Sem/Hum Comp))(*-1 VFIN - Imprt BARRIER @CVP OR FS-QPRON-ADV OR CS-RIHKKU OR ("galle") OR COMMA OR (";") OR (":") LINK NOT 0 COPULAS OR Neg OR <aux> OR (SUGGEST Adv))(NONE lp VFIN)(NEGATE -1 CS OR CC OR CP)(NEGATE 0 @<SPRED)(NEGATE -1 COMMA OR (";") OR (":") OR ("âč") OR ("â") OR ("-") OR Attr OR @>N)(NEGATE 1 CP)(NEGATE 0 Prop LINK -1 Prop LINK 0 Gen OR Acc)(NEGATE 0 Sem/Human LINK *-1 <vdic> BARRIER NOT-ADV-PCLE)(NEGATE 0 $$PERS-NUM LINK -1 AUX + $$PERS-NUM)(NEGATE 0 N LINK -1 (Pron Sem/Hum Pers Acc) OR (Pron Sem/Hum Pers Gen))(NEGATE 0 $$NUMBER + (Pron Nom) LINK *-1 $$NUMBER + V)(NEGATE -1 ("mannat" V IV Ind Prt Pl3) OR ("mannet" V IV Ind Prs Sg3) OR ("mannat" V IV Ind Prs Du1) LINK -1 BOS)(NEGATE 1 Po)(NEGATE 0 ("[A-Z].*"r) - Prop)(NEGATE -1 ("<[A-Z].*>"r))(NEGATE -1 ("dĂĄssĂĄ") OR <TH-ahte> + VFIN); # LINK *2 VFIN BARRIER Rel OR GRAMCHK-S-BOUNDARY LINK 0 Inf);
	#$ Maid dahke dasto IeĆĄjĂĄrluntta - {geat} ledje gilvvu lĂĄgideaddjit?
	#$ Easka de ÄĂĄjeha galle suorpma {boaris} son lea.
	#$ Muhto kantorolbmĂĄi jorggihii ÄĂĄllinmĂĄĆĄiidnii go ipmirdii mii leimme mĂĄrĆĄkku bĂĄrtnit.
    #$ Das lohkĂĄ biebman ealu dĂĄssĂĄ Boazodoallostivra meannudii ohcama mas lei bivdĂĄn gaskaboddosaĆĄ lobi luoitit ealu Jillen-Njaarkei dĂĄssĂĄi oÄÄa doallu rahppo.	
	#$ Oassi mis hĂĄllĂĄ muhtun sĂĄmegiela, oasis bearraĆĄiin {mĂĄnĂĄt} eai leat oahppan sĂĄmegiela ovtta dahje mĂĄĆggaid sohkabuolvvaid ĂĄigge.
	#$âDĂĄs girddii garjĂĄ badjel dĂĄhkki ja gahÄahii varas dĂĄvtti muvrarĂĄiggi bodnĂĄi.
	#$ DuvvĂĄt borret riissaid, maid olbmot bĂĄlkot nĂĄittosbĂĄrra ala -ja dat bohtanit Äoavjjis ja duvvĂĄt jĂĄpmet.
	#$ Ć livgii duĆĄĆĄe rĂĄnu {mun} ala, ii lean ge dĂĄrbu eanet go lei juo geassebĂĄhkka.
	#$ Manne {mii} eai daid sĂĄhte geavahit dan sadjĂĄi go Äuovvut ameriikkalaĆĄ vieruid, loahpaha Johnsen ja muitala vuosttaĆĄ Soigosat doalut dollojuvvojedje 2003 njukÄamĂĄnus.
	#$ DĂĄbĂĄlaĆĄ spiehkastat lei maid atnit goalmmĂĄt persovnna hĂĄmiid earĂĄ sojahanhĂĄmiid sajis, ovdamearkka dihte nĂĄ : âč {Mun boahtĂĄ} âș, âč moai lohkĂĄ âș, âč don gomihii âș ja âč mĂĄnĂĄt ĂĄlggii âș, Äilge IjĂ€s.
	##Â Dalle dolvon {ieĆĄ} ohcamuĆĄa ja ĂĄdden dan ruovttubĂĄlvalusa joÄiheaddjĂĄi, muitala Guovdageainnu nisu Aili Skum Norvang.
	 #$ Kirste Paltto romĂĄnii Guhtoset dearvan min {bohccot} Äujuhuvvo ovdamearkan oanĂĄdusain ( GDMB 9 ), dasgo lea ĂĄlkit geavahit dan go guhkit Äujuhusa ( Paltto 1987 : 9 ).
	 #$ RuÄain galget sii oasttit sĂĄmi stohkosiid HĂĄmmerfeasta buohccivissui - mĂĄnĂĄidossodahkii
	 #$ JurddaĆĄ duĆĄĆĄe ieĆĄ, stuora lossa skuterin girdit 10 mehtera ĂĄimmus, dadjĂĄ {Siri}, ja muitala ahte su eadni gal meastta cissai buvssaide go oinnii su njuikume.
	 #$ Hui ollusat leat duĆĄĆĄe geavahan luohte oasi ja Sverre Kjelsberg oasi leat guoÄÄĂĄn, dadjĂĄ Simona {MĂĄhtte} ja lohkĂĄ son ii dieÄe manne Sverre Kjelsberg ii lean mielde Gylne Tider joavkkus.
	 #$ In hĂĄlit geange diktaÄĂĄlli stiilla geavahit, muhto, numo ĂillohaĆĄ, de liikon {munge} modearna stiilla, mii ii leat Äatnon masage. 
	 #$ Norggas liikojit ovccis logi olbmos bohccobierggu ja fas gĂĄvccis logi olbmos dadjet bohccobiergu lea dearvvaĆĄlaĆĄ borramuĆĄ, ÄĂĄjeha varas oaiviliskkus maid Synovate lea dahkan.
	 #$ Leat mii geat stivrejit, ja leat mii geat diehtit man Äeahpit mii leat.  
	 #$ MaĆĆĂĄ Äoahkkima mii lei ĂĄmmĂĄtvirgeolbmĂĄid dĂĄsis njukÄamĂĄnus 2006, de galge RuoĆ§a departemeantta ĂĄirasat guorahalat dien ĂĄĆĄĆĄi {dĂĄrkileappot}, earet earĂĄ gĂĄvnnahit sierra lĂĄhkavuoÄu geahÄÄaladdandoaimmaide
	 #$ FinnmĂĄrkku fylkkamĂĄnni cuiggoda fylkkagieldda go eai dĂĄrkkis oĆŸĆŸotgo mĂĄnĂĄt {geat} orrot mĂĄnĂĄidsuodjalusinstituĆĄuvnnaid dan oahpu maid sis lea riekti oaĆŸĆŸut.
	 #$ Danin orro leamen nu go mii jĂĄhkiimet, ahte biehttaleapmi mielddisbuktĂĄ heajot ĂĄrvvoĆĄtallama go doarjun, muhto eat {mii} almmatge ÄuoÄÄut ahte dat lea ĂĄidna sivva dan govvii maid mii dĂĄs oaidnit, mii ÄĂĄjeha makkĂĄr oaidnu guÄesge lea fondii.
	 #$ Son jearrala dan guovtti njuvÄÄas ahte diehtiba soai gos {Soria-Moria} sloahtta lea.
	 #$ DĂĄt lea vuosttaĆĄ, {ja} dĂĄssĂĄĆŸii ĂĄidna, suohkan lullisĂĄmeguovllus mii boÄii mielde hĂĄlddaĆĄanguvlui.	 
	 #$ GirkonjĂĄrgga joatkkaskuvla lea fylkka ĂĄidna {joatkkaskuvla} geas lea ieĆŸas neahttasiidu sĂĄmegillii.
	 ## MĂĄhtte cÌĂĄlii teavstta Elle fas heivehii dan nuhttii. 
	 # needs testing
     ## MĂĄhtte mĂĄrfu, Elle bassĂĄ ja Biera Äorge ovdal go mii vuolgit.
     ## Muhtumat lohket earĂĄt ÄĂĄllet.
     #$ ArktalaĆĄ RĂĄÄÄi lea ĂĄidna guovlluguovdasaĆĄ ovttasbargoorgĂĄna mii siskkilda gĂĄvcci ĂĄrktalaĆĄ riikka ; vihtta davviriikka, USA.
     #$ LĂĄvdegoddi cealkĂĄ ahte sĂĄmi jienastuslohku lea ĂĄidna lohku maid sii leat sĂĄhttĂĄn atnit vuoÄÄun barggusteaset.
     #$ LoabĂĄga gielda lea ĂĄidna gielda regiovnnas mii guovvamĂĄnus 2008 lea mearridan ahte gielda dĂĄhttu ohcat beassat mielde sĂĄmegiela hĂĄlddaĆĄanguvlui.
     
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE ("ja" &punct-rihkku) IF (NEGATE -1 (","))(NEGATE 0 ADDED-BEFORE-BLANK);
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE (Nom &punct-rihkku) IF (NEGATE -1 (","))(NEGATE 0 ADDED-BEFORE-BLANK);
	 ## Soai muitaleaba soai hĂĄliideaba olbmuid beroĆĄtiĆĄgoahtit eambbo ieĆŸaset ĂĄssanbĂĄikkiid birra.
     ## Cealkagiid gaskkas main lea oktasaĆĄ cealkkaoassi
     ## Elle finai vuos buvddas ja de manai ruoktot. (OktasaĆĄ subjeakta)
     ## Johan ĂĄiggui vĂĄldit eksĂĄmena ja mun maid. (OktasaĆĄ verbĂĄla ja objeakta) MĂĄhtte manai oarjjabeallai ja Biera nuorttabeallai. (OktasaĆĄ verbĂĄla)
     ## GaĆŸaldatmearkka ja cÌuorvvasmearkka maĆis
     ## âManne lea mĂĄilbmi jorbbas?â jearai mĂĄnnĂĄ. âVuoi daid cÌĂĄppa lĂĄbbĂĄid!â cÌurvii ĂĄhkku.
     ## BeaivĂĄdemiid oktavuoÄas
     ## BuolbmĂĄgis juovlamĂĄnu 3. beaivvi 1995 BuolbmĂĄgis juovlamĂĄnu 3 beaivvi 1995 BuolbmĂĄgis 2015-03-15
     
ADDRELATION ($2 LEFT) (CC &punct-rihkku) TO (-1 (ADDED-BEFORE-BLANK &punct-rihkku)) ;

    # vĂĄilu "ja" dahje rihkku listtus
    # -------------------------------
    
LIST 3-STAVVAL-IT-V = (".*dit"r V) (".*git"r V) (".*hit"r V) (".*kit"r V) (".*lit"r V) (".*mit"r V) (".*rit"r V) (".*ĆĄit"r V) (".*tit"r V) ;

ADD:xpunct-rihkku (&punct-rihkku) TARGET (Inf) OR (Ind Prs Pl1) OR 3-STAVVAL-IT-V + (Ind Prs Pl3) OR 3-STAVVAL-IT-V + (Ind Prt Sg2) IF (-1 Inf LINK NOT 0 <TH-Inf> OR <Inf> LINK -1 COMMA LINK -1 Inf); 
	## GuovddĂĄĆĄ galgĂĄ Äohkket, ovddidit, vuogĂĄdahttit, ĂĄigĂĄdit, gieÄahallat,     heivehallat     gaskkustit ĂĄĆĄĆĄĂĄisoahppevaĆĄ dieÄuid ja duoÄaĆĄtusaid ĂĄlgoĂĄlbmotvuoigatvuoÄaid birra riikkalaĆĄ ja riikkaidgaskasaĆĄ dĂĄsis. 
	
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE (V &punct-rihkku) IF (0 Inf OR (Ind Prs Pl1) OR 3-STAVVAL-IT-V + (Ind Prs Pl3) OR 3-STAVVAL-IT-V + (Ind Prt Sg2))(NEGATE -1 (","))(NEGATE 0 ADDED-BEFORE-BLANK);

ADDRELATION (LEFT) (&punct-rihkku) TO (-1 (ADDED-BEFORE-BLANK)) ;



	# Before fallback some specific rule
	# ----------------------------------

SELECT:PcleCompounds Adv IF (1 ("ge")) (0 (Adv Err/Orth-a-ĂĄ));
	## Go suohkan dĂĄl viimmĂĄtge lea boahtĂĄn nehtii, addĂĄ dat midjiide vejolaĆĄvuoÄaid njuolggo oktavuoÄaide suohkana ĂĄssiiguin.

	SECTION

	# Fallback error disambiguation
	# -----------------------------

# Remove Err/Orth and other Err/ readings if there are alternative, non-Err readings.
# Should block a number of false positives.
# NB! SUB:* rewritten as SUB:1, SUB:2, etc to work around a serious memory leak in vislcg3.
# Please leave as is until the leak has been fixed by Tino.
# NOT COERROR so we don't remove readings meant to stretch the squiggly underline of other cohort errors

#REMOVE:SuperfluousErrTags SUB:0 AllErrorTags IF (0/* AllErrorTags) (0/* NoErrorTags) (NOT 0 (COERROR)) (NOT 0 (typo)) ;
REMOVE:SuperfluousErrTags SUB:1 AllErrorTags IF (0/* AllErrorTags) (0/* NoErrorTags) (NOT 0 (COERROR)) (NOT 0 (typo)) ;
REMOVE:SuperfluousErrTags SUB:2 AllErrorTags IF (0/* AllErrorTags) (0/* NoErrorTags) (NOT 0 (COERROR)) (NOT 0 (typo)) ;
REMOVE:SuperfluousErrTags SUB:3 AllErrorTags IF (0/* AllErrorTags) (0/* NoErrorTags) (NOT 0 (COERROR)) (NOT 0 (typo)) ;

    # Fallback rules for the remaining errors
    # ---------------------------------------
    #
    # 1. speller output
    # 2. Err/Orth cases not dealt with in other rules
    # 3. Other Err/ type errors (Err/Lex, Err/DerSub, etc)
    # 4. Unrecognised words

# Fallback for Err/Orth â want to underline these too, and preferably generate
# TODO: Different error tag for these? Currently the same as dynamically <spelled> errors.

# Speller suggestions rule - make sure the suggestions survive the cg mangling:
ADD:spelled (typo SUGGESTWF) (<spelled>) IF (NEGATE -1 ("â") OR (""") OR ("â") OR ("â") OR ("â") OR ("â") LINK 2 ("â") OR (""")) ;

	#### Err/Orth rules - make sure all Err/Orth analyses are generated as the normative counterpart of itself:
	# 1. Add a typo error tag if there is an Err/Orth tag __anywhere__ - including in subreadings:


SET NonErr/Orth = (*) - Err/Orth-any ;

ADD:Err/Orth-any (typo) TARGET (*) IF (NEGATE 0/* NonErr/Orth - Err/Lex - Err/Spellrelax)(0/* Err/Orth-any OR Err/Spellrelax)(NEGATE -1 ("â") LINK 2 ("â")) ;
	#$ DĂĄvjĂĄ dĂĄt sĂĄtni unnut geavahuvvo dalle go galggaĆĄii hĂĄllat geahppĂĄneami birra ( mii dieÄusge fas lea ĂĄibbas earĂĄ go {geahppun} ).
	## Dan sadjĂĄi bealalaÄÄat leat diktan mĂĄrkĂĄnsĂĄgaid leavvat, ja dainna lĂĄgiin rĂĄĆggaĆĄtan dĂĄrbbaĆĄmeahttumiid.
	## GirkovĂĄlggain  ÄakÄamĂĄnu  18.  b.  don  vĂĄlljet  gosa  RuoĆ§a  girku  galgĂĄ  bidjat  fĂĄmu  lagamuĆĄ  njeallje  jagi.  Geasa  attĂĄt luohttamuĆĄa?
	#disregarding simple citations for now
	## Jus dakkĂĄr dieÄĂĄhus deaddiluvvo jienastanlihpuid {maĆĂĄbeallĂĄi}, de galgĂĄ dan almmuhit ovddabealde.

	# 2. Copy to a new reading minus Err/Orth, to generate suggestions - main reading:

COPY:Err/Orth-any (SUGGEST) EXCEPT Err/Orth-any_OR_TV_IV TARGET (typo) IF (NOT 0/* (SUGGESTWF) OR (SUGGEST));

COPY:Err/Orth-any SUB:0 (SUGGEST) EXCEPT Err/Orth-any_OR_TV_IV TARGET (typo) IF (NOT 0/* (SUGGESTWF) OR (SUGGEST));

COPY:Err/Orth-any SUB:1 (SUGGEST) EXCEPT Err/Orth-any_OR_TV_IV TARGET (typo) IF (NOT 0/* (SUGGESTWF) OR (SUGGEST));
COPY:Err/Orth-any SUB:2 (SUGGEST) EXCEPT Err/Orth-any_OR_TV_IV TARGET (typo) IF (NOT 0/* (SUGGESTWF));
COPY:Err/Orth-any SUB:3 (SUGGEST) EXCEPT Err/Orth-any_OR_TV_IV TARGET (typo) IF (NOT 0/* (SUGGESTWF));
COPY:Err/Orth-any SUB:4 (SUGGEST) EXCEPT Err/Orth-any_OR_TV_IV TARGET (typo) IF (NOT 0/* (SUGGESTWF));
	#THIS does not work at the moment, but hopefully Tino can help

# 3. Substitute Err/Orth in subreadings to get something for generation.
# Cf: http://giellatekno.uit.no/bugzilla/show_bug.cgi?id=2317

#SUBSTITUTE:Err/Orth-any SUB:0 Err/Orth-any (*) TARGET (SUGGEST) ;
#SUBSTITUTE:Err/Orth-any SUB:1 Err/Orth-any (*) TARGET (SUGGEST) ;
#SUBSTITUTE:Err/Orth-any SUB:2 Err/Orth-any (*) TARGET (SUGGEST) ;
#SUBSTITUTE:Err/Orth-any SUB:3 Err/Orth-any (*) TARGET (SUGGEST) ;

	# Some regression tests:
	# 'sĂĄtnejodiheaddji' â 'sĂĄtnejoÄiheaddji' # Simple Err/Orth
	# 'vuoddoskuvlla' â 'vuoÄÄoskuvlla'       # Err/Orth in subreading, not main reading
	# 'olgoriikadepartementtas' â 'olgoriikkadepartemeanttas' # Err/Orth in subreading
	# 'stnejodiheaddji' â 'sĂĄtnejoÄiheaddji'  # simple <speller>
	# 'Finnmarku' â 'FinnmĂĄrku'               # Err/orth-a-ĂĄ
	# 'johttigohte' â 'johtigohte'            # disambiguator sometimes removes this
	# 'buorrre' â 'buorre'                    # <speller>
	# 'husket' â 'hukset'                     # <speller>

COPY:no-double-dot (VSTR:"$1"S SUGGESTWF) EXCEPT  ("<(.*)[.]>"r) TARGET ("<(.*)[.]>"r <spelled>) IF
        (1 ("<[.].*>"r))
        (NOT 0 ("<$1>"v))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;
REMOVE:no-double-dot (<spelled> "<.*[.]>"r) IF (1 ("<[.].*>"r));
# Avoid suggestions getting two periods in a row (if there's a following period)
	#$ 6-7 (maĆĆel rĂĄĆggaĆĄtusÄ.)

	#$ Dat beare guhkkĂĄ doppe, iige {daga} maidege ieĆŸĂĄ.

## Remove the prederivation transitivity tags Ex/TV and Ex/IV to allow generation. The generator takes input of the following forms:
#
# mearridit+Ex/V+Ex/TV+Der/PassL+V+IV+Ind+Prs+ConNeg
# mearridit+Ex/V+Ex/TV+Der/PassL+V+IV+Ind+Prs+Sg3
#
# mearridit+Ex/V+TV+Der/PassL+V+Ind+Prs+ConNeg
# mearridit+Ex/V+TV+Der/PassL+V+Ind+Prs+Sg3
#
# mearridit+Ex/V+Der/PassL+V+IV+Ind+Prs+ConNeg
# mearridit+Ex/V+Der/PassL+V+IV+Ind+Prs+Sg3
#
# mearridit+Ex/V+Der/PassL+V+Ind+Prs+ConNeg
# mearridit+Ex/V+Der/PassL+V+Ind+Prs+Sg3
#
# whereas we used to give it input like:
#
# mearridit+Ex/V+Ex/TV+Der/PassL+V+Ind+Prs+Sg3
#
# That didn't match up. Now it does.

SUBSTITUTE:Ex/tags SUB:0 (Ex/IV) (*) TARGET (SUGGEST) ;
SUBSTITUTE:Ex/tags SUB:1 (Ex/IV) (*) TARGET (SUGGEST) ;
SUBSTITUTE:Ex/tags SUB:2 (Ex/IV) (*) TARGET (SUGGEST) ;
SUBSTITUTE:Ex/tags SUB:3 (Ex/IV) (*) TARGET (SUGGEST) ;

SUBSTITUTE:Ex/tags SUB:0 (Ex/TV) (*) TARGET (SUGGEST) ;
SUBSTITUTE:Ex/tags SUB:1 (Ex/TV) (*) TARGET (SUGGEST) ;
SUBSTITUTE:Ex/tags SUB:2 (Ex/TV) (*) TARGET (SUGGEST) ;
SUBSTITUTE:Ex/tags SUB:3 (Ex/TV) (*) TARGET (SUGGEST) ;

# TODO: Examples where the below rule works, while the above COPY:Err/Orth-any does not:
COPY:Err/Orth (SUGGEST) EXCEPT (Ex/N Ex/V Ex/A Ex/IV Ex/TV Err/Orth)
                             OR (South Err/Orth)
                             OR (Err/Orth Err/SpaceCmp)
                             OR (Err/Orth)
                             OR (Err/Orth-a-ĂĄ)
                             OR (Err/Orth-nom-acc)
                             OR (Err/Orth-nom-gen)
                         TARGET (Err/Orth typo)
                             OR (Err/Orth-a-ĂĄ typo)
                             OR (Err/Orth-nom-acc typo)
                             OR (Err/Orth-nom-gen typo)
                         IF (NOT 0 (SUGGEST) ) ;
	#$ Muhto dalle gĂĄrtĂĄ maiddĂĄi {Äielgaseappon} man_lĂĄhkĂĄi mearrideaddjit stuorĂĄt servvodagas, go sin fĂĄpmu lea gĂĄrtan dego semeantan, dagahit lĂĄhttenvuoÄu muhtinlĂĄgan eahpealbma bivdui ja gilvui, gos vel diehta ge gĂĄrtĂĄ hiĆgĂĄlastojuvvot dego ÄĂĄjĂĄhussan meassuin ja eisevĂĄlddiid buĆĄeahtain.
	#$ Ii buot dĂĄfus gal, muhto juste das {mainna lĂĄgiin} olmmoĆĄ lĂĄhtte ja makkĂĄr gova ÄĂĄjeha earĂĄide lei sutnje hui deaĆ§alaĆĄ.

# Fallback: Add typo tag to any other Err tag not covered above,
# to ensure that they are at least underlined - important to make the
# grammar checker catch the same errors as the speller:
# presently defined as:
#  Err/Not-Orth = Err/Lex Err/DerSub Err/CmpSub Err/HyphSub Err/Hyph Err/MissingHyph Err/Spellrelax ;
ADD:other-errors (typo) Err/Not-Orth (NEGATE 0t (*) - Err/Any);

# Add typo error tag to unkown words that are not corrected by the speller, so that they at least get a blue underline and a message
ADD:uncorrected-typos (typo) (?) ;

# Local Variables:
# cg-pre-pipe: "bash -o pipefail modes/smegram-dev9-cg.mode"
# cg-post-pipe: "divvun-suggest -g generator-gramcheck-gt-norm.hfstol -m errors.xml -l sme"
# End:

	# ====================== #
		AFTER-SECTIONS
	# ====================== #

	# Tag removal rules to prepare for generation

SUBSTITUTE (MWE) (*) TARGET MWE ;
	## GuollefestivĂĄla geassemĂĄnus ja Riddu RiÄÄu suoidnemĂĄnus.


#SUBSTITUTE (Gram/3syll) (*) TARGET Gram/3syll ;

# Only add the &typo tag if no other error tags:
SUBSTITUTE (typo) (&typo) TARGET (typo) IF (NEGATE 0 (/^&.*/r));
# Else drop it so it generates correctly:
SUBSTITUTE (typo) (*) TARGET SUGGEST OR SUGGESTWF;
