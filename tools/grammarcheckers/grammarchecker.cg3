	## Mon leamaإ، mielde jagi 2001 rأ،jes ja lea alu somأ،.	
	## Anders Nordsletta muittuhii biraseisevأ،lddiid ahte olbmot sأ،mis leat alu أ،vkkأ،stallan ja vieإ¾إ¾an أ،igأ،i boaؤ‘u luonddus.
	## Lean alu hأ،lidan sأ،httit njuket fierpmi badjil maإ‹إ‹أ، go lean vuoitأ،n seahta.	
	
	# alu vs. alo
	# -----------

	
ADD:xreal-alo-alu (&real-alo-alu) TARGET ("أ،lo" Err/Orth-a-أ، Adv) OR ("allut" V IV Imprt ConNeg) OR ("allut" V IV Imprt Sg2) OR ("allut" V IV Ind Prs ConNeg) IF (-1 Sem/Measr) ;
COPY:real-alo-alu ("alu" Po SUGGEST) EXCEPT ("allut" V IV Imprt ConNeg &real-alo-alu) OR ("allut" V IV Imprt Sg2 &real-alo-alu) OR ("allut" V IV Ind Prs ConNeg &real-alo-alu) TARGET (&real-alo-alu) ;
