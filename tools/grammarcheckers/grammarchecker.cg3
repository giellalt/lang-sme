	# -------------------------

	
ADD:xsyn-sgnom-sgacc (&syn-sgnom-sgacc) TARGET (N Sg Nom) OR (N Err/Orth Sg Acc) IF (*-1 <TH-Acc-Any> OR <PA-Acc-Any> OR <PR-Acc-Any> BARRIER NPNHA OR Num LINK NONE c آ§TH)(0 DOUBLE-CONSONANT-NOUNS)(NEGATE 0 آ§ANYROLE - آ§AG OR (V SUGGEST))(NEGATE 0 Sem/Hum LINK *-1 <vdic> BARRIER NPNHA)(NEGATE *-1 <TH-ahte> LINK -1 COMMA LINK *-1 VFIN)(NEGATE 0 Acc - Err/Orth)(NEGATE 0 (N Sg Nom) LINK *-1 CC OR COMMA BARRIER NOT-Attr LINK -1 (N Sg Nom))(NEGATE 1 COMMA OR CC LINK 1 N LINK 1 CC LINK *1 N BARRIER NOT-Attr) ; #2nd
	## Nissonolbmot dahket  otne stuorأ،mus {oassi} barggu mأ،ilmmis, muhto sii eai oamas eanet go 1 proseantta mأ،ilmmi riggodagaid. 
	#$ Dasa lassin lea Ruoإ§a Sأ،mediggi lohpidan doarjut riikkajoavkku 90 000.-, dieؤ‘iha presideanta â€“ Ruoإ§a Sأ،mediggi lea hأ،rve dorjon riikkajoavkku ja mii leat ilolaإ، go dأ،l أ،ddet doarjaga.
	#$ Dat dagahedje ahte earit galge juhkkojuvvot nuvttأ، guolأ،steddjiide, muhto jus galggai sأ،httit oaإ¾إ¾ut eari de biddjui mearri man olu dorski fertii unnimusat bivdأ،n ovtta jagis, jagiin 1987:s 1989 rأ،djأ،i.
	## Jagi 2004:is  rأ،hkadii Gaup goansta mii lea ain dأ،l okta dan goansttain FMX:s.
	## Jienasteddjiide sأ،httأ، إ،addat vأ،ttis أ،ddet, mo olgeإ،- ja ovddأ،dusbellodat sأ،htiba ovddidit oktasaإ، sأ،mepolitihkka  jus dأ،t bellodagat fidnejit rأ،ؤ‘ؤ‘ehus vأ،lddi boahtte ؤچavؤچؤچa Stuorradikke vأ،lggain.
	
ADD:xsyn-sgnom-sgacc (&syn-sgnom-sgacc) TARGET (N Sg Nom) OR (N Err/Orth Sg Acc) IF (1 CC LINK 1 آ§TH LINK p <TH-Acc-Any> OR <PA-Acc-Any> OR <PR-Acc-Any>)(0 DOUBLE-CONSONANT-NOUNS)(NEGATE 0 آ§ANYROLE - آ§AG OR (V SUGGEST))(NEGATE 0 Sem/Hum LINK *-1 <vdic> BARRIER NPNHA)(NEGATE *-1 <TH-ahte> LINK -1 COMMA LINK *-1 VFIN)(NEGATE 0 Acc - Err/Orth) ; #2nd
	## Jus mii nannet mأ،httu  ja diؤ‘olaإ،vuoؤ‘a dأ،id birra dutkamuإ،aid bokte, de lea أ،lgoأ،lbmogiidda أ،lkit أ،kkastallat أ،igumuإ،aid ja politihka, muitala Retter.
	## NRK filbmii olles su mأ،tki ja ؤچأ،jehedje dan TV's.
	#$ Muؤ‘ui mun gal liikon buot, muhto buoremusaid searvvis leat Eagles, Metallica, Iron Maiden, Jan Garbarek, ja Mari Boine, oaivvilda musihkka أ،إ‹giris almmأ،i. DUOMMأپ: ok
		
	# subject inbetween
	
ADD:xsyn-sgnom-sgacc (&syn-sgnom-sgacc) TARGET (N Sg Nom) OR (N Err/Orth Sg Acc) IF (-1 (N Nom) + Sem/Human LINK *-1 <TH-Acc-Any> OR <PA-Acc-Any> OR <PR-Acc-Any> BARRIER NPNHA OR Num)(0 DOUBLE-CONSONANT-NOUNS)(NEGATE 0 آ§ANYROLE - آ§AG OR (V SUGGEST))(NEGATE 0 Sem/Hum LINK *-1 <vdic> BARRIER NPNHA)(NEGATE *-1 <TH-ahte> LINK -1 COMMA LINK *-1 VFIN)(NEGATE 0 Acc - Err/Orth) ;	#2nd
	## Jagi 2004:is rأ،hkadii Gaup goansta mii lea ain dأ،l okta dan goansttain FMX:s.  

ADD:xsyn-sgnom-sgacc (&syn-sgnom-sgacc) TARGET (N Err/Orth Sg Acc) IF (lp <TH-Acc-Any>)(NEGATE 0 Sem/Hum OR Sem/Mal OR Sem/Fem OR Sem/Sur LINK *-1 <vdic> BARRIER NPNHA)(NEGATE *-1 <TH-ahte> LINK -1 COMMA LINK *-1 VFIN)(NEGATE 0 (Sg Nom) OR (Sg Acc) - Err/Orth OR (A Attr)) ; #2nd
	#$ Nأ، mii oaإ¾إ¾ut sأ،mi ja أ،lgoأ،lbmot perspektiivva buot oahpahusas.
	## Sأ،mediggi berre dأ،s doallat vuollegis profiila.
	#$ Manne mii eai daid sأ،hte geavahit dan sadjأ،i go ؤچuovvut ameriikkalaإ، vieruid, loahpaha Johnsen ja muitala vuosttaإ، Soigosat doalut dollojuvvojedje 2003 njukؤچamأ،nus.
			
COPY:acc-not-nom (SUGGEST) EXCEPT (Err/Orth Err/Orth-nom-acc &syn-sgnom-sgacc) OR (Err/Orth &syn-sgnom-sgacc) TARGET (Err/Orth N &syn-sgnom-sgacc) ; #2nd
COPY:acc-not-nom (Acc SUGGEST) EXCEPT (Nom &syn-sgnom-sgacc) TARGET (N &syn-sgnom-sgacc)(NOT 0 Err/Orth) ; #2nd
	

