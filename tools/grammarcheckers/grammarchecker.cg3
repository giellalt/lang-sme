	# Sg3 should be ConNeg
	# --------------------
	
	
ADD:msyn-Sg3-ConNeg (&msyn-Sg3-ConNeg) TARGET (V Cond Prs Sg3) - Err/Any OR BE + Sg3 - Err/Any IF (*-1 Neg BARRIER NOT-NP-HEAD-COMMA-CC-Adv-Neg OR (Sg Nom) LINK NEGATE 1 COMMA OR (".*ge"r)) (NEGATE *-1C (Pron Sg3 Nom) OR Rel BARRIER (*) - Adv - Pcle  LINK *-1 Neg BARRIER NOT-NP-HEAD-COMMA-CC-Adv-Neg)(NEGATE 0 ConNeg - Err/Orth)(NEGATE -1 COMMA OR Rel);
	##  Nأ،hkkedikإ،un ja - goarrun lea nu أ،rbevirolaإ، bargu ahte earأ،lأ،gan oahpahus go dat man lأ،hkai lea ohppojuvvon boares أ،iggi rأ،jes, ii {buoridivؤچؤچii} sأ،miid ruhtadili iige dat heiveإ،ii kultuvrralaإ، progrأ،mmii nu mo skuvla dan lea jurddaإ،an.
	## Ale, son lea hui nuoskkis odne, nissonأ،إ،إ،i,آ» أپne beasahallأ،.

ADD:msyn-Sg3-ConNeg (&msyn-Sg3-ConNeg) TARGET (V Neg) IF (1 &msyn-Sg3-ConNeg);

COPY:msyn-Sg3-ConNeg (ConNeg SUGGEST) EXCEPT Sg3 OR (Err/Orth Sg3) TARGET (V &msyn-Sg3-ConNeg) IF (NOT 0 Neg) ;

ADDRELATION:msyn-Sg3-ConNeg (LEFT $2) (ConNeg &msyn-Sg3-ConNeg) TO (-1 (Neg &msyn-Sg3-ConNeg)) ;

    ## Juos in mأ،htأ،إ،ii ؤچأ،llit ja lأ،vlut, livؤچؤچen eahpelihkostuvvan olmmoإ،. Juos in mأ،htأ،إ،e ؤچأ،llit ja lأ،vlut, livؤچؤچen eahpelihkostuvvan olmmoإ،.
    ## In mun nu bures ja inge nu ؤچأ،bbأ،t mأ،htأ،إ،ii ؤچأ،llit ja lأ،vlut, jos livؤچؤچen eahpelihkostuvvan olmmoإ،.
