	# Ess not dego
	# ------------
	
LIST DEGO-ESS-ADV = "ruovttoluotta" ;


LIST DEGO-ESS-V = "galgat" "ĆĄaddat" "gĂĄrtat" "dahkat" "orrut" ;

LIST DEGO-ESS-V2 = "lohkat" "jurddaĆĄit" "jurddahit" "guovllastit" "gullostit"  ;

LIST ESSIVE-TIME-N = "skĂĄbma" "bassi" "veaigi" "ĂĄrga" "ruĆĄki" (".*skĂĄpmu"r) "joavdu" "vistta" ;

LIST DEGO-V = "muitit" ;

ADD:xsyn-not-dego (&syn-not-dego COERROR) TARGET SUCH-AS IF (*1 Ess OR ("danin") BARRIER GRAMCHK-NPNH LINK NOT 0 (N Sg Nom) OR Sem/Wthr OR ESSIVE-TIME-N LINK NEGATE -1 QMARK) (NEGATE *1 (Actio Ess) BARRIER GRAMCHK-NPNH)(NEGATE *1 (".*niehku"r Ess) OR (".*gearpmaĆĄ"r Ess) OR (".*lĂĄga"r Ess) OR (".*ĆĄlĂĄga"r PxSg1) OR ("lĂĄvvomuorra" Ess) OR Comp BARRIER GRAMCHK-NPNH) (NEGATE 1 ("ovdamearka" Ess) LINK NOT 1 ("dat" Pron Dem Sg Ill)) (NEGATE 1 ("ovdamearka" Ess) LINK NOT 1 (".") OR ("!") OR ("?")) (NEGATE 1 ("ovdamearka" Ess) LINK NOT 1 THAT-CS) (NEGATE -1 ("hĂĄpmi"))(NEGATE *-1 DEGO-ESS-V BARRIER V OR GRAMCHK-S-BOUNDARY) (NEGATE *0 DEGO-ESS-V2 BARRIER V LINK NOT -2 Po) (NEGATE *-1 BE - Cond BARRIER V OR GRAMCHK-S-BOUNDARY LINK NOT *1 ("mielde") OR ("vuostĂĄ" Adv) OR ("sĂĄhka") OR DEGO-ESS-ADV BARRIER NPNH) (NEGATE -1 BE LINK 0 (IV Actio Ess) LINK NOT -1 ("orrut")) (NEGATE *-1 Ess BARRIER GRAMCHK-NPNH LINK 1 BE)
(NEGATE 1 Ess LINK *1 COPULAS + Sg3 BARRIER NOT-ADV-PCLE)
(NEGATE 1 Ess LINK lp DEGO-V); #parent of the essive should not be a DEGO-V
	#$ Muhto eai leat dĂĄn rĂĄdjai gĂĄvdnan oÄÄa birgenlĂĄgi {dego} ulbmilin lei, ja measta buohkat ĂĄigot jorggihit boazodollui.
	#$ MĂĄĆgasat muitet su buoremusat {dego} advokĂĄhtan ja sĂĄmiid ovddasteaddjin historjjĂĄlaĆĄ ĂlttĂĄ stuimmiid oktavuoÄas 1970- ja 80 logus, dasa lassin su guovddĂĄĆĄ barggu ĂĄlgoĂĄlbmotjuristan ja maĆĆĂĄ fas rĂĄÄÄeaddin departemeanttain main lei ovddasvĂĄstĂĄdus sĂĄmi ĂĄĆĄĆĄiin.
	
	
ADD:xsyn-not-dego (&syn-not-dego) TARGET Ess - <spelled> IF (*-1 ("dego" &syn-not-dego) BARRIER Ess)(NEGATE 1 Ess);
ADD:xsyn-not-dego (&syn-not-dego) TARGET Ess - <spelled> IF (-1C Ess)(NEGATE 0 (Sem/Act Sg Nom));
