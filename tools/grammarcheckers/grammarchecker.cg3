# Syntactic tags
# --------------

LIST @+FAUXV = @+FAUXV ;
LIST @+FMAINV = @+FMAINV ;
LIST @-FAUXV = @-FAUXV ;

LIST @-FMAINV = @-FMAINV ;
LIST @-FSUBJ> = @-FSUBJ> ;
LIST @-F<OBJ = @-F<OBJ ;
LIST @-FOBJ> = @-FOBJ> ;
LIST @SPRED<OBJ = @SPRED<OBJ ;
LIST @-F<ADVL = @-F<ADVL ;
LIST @-FADVL> = @-FADVL> ;
LIST @-F<SPRED = @-F<SPRED ;
LIST @-F<OPRED = @-F<OPRED ;
LIST @-FSPRED> = @-FSPRED> ;
LIST @-FOPRED> = @-FOPRED> ;

SET FOBJ = @-F<OBJ OR @-FOBJ> ;
SET FMAINV = @-FMAINV OR @+FMAINV ;
SET FAUXV = @-FAUXV OR @+FAUXV ;

LIST @ADVL = @ADVL @ADVL> @ADVL< @<ADVL @>ADVL @-F<ADVL @-FADVL> ;
LIST @>ADVL = @>ADVL ;
LIST @ADVL< = @ADVL< ;
LIST @<ADVL = @<ADVL ;
LIST @ADVL> = @ADVL> ;

LIST @HAB = @HAB ;

LIST @>N = @>N ;

LIST @N< = @N< ;


LIST @>A = @>A ;

LIST @P< = @P< ;

LIST @>P = @>P ;

LIST @HNOUN = @HNOUN ;
LIST @INTERJ = @INTERJ ;

LIST @>Num = @>Num;

LIST @Pron< = @Pron< ;
LIST @>Pron = @>Pron ;

LIST @Num< = @Num< ;

LIST @OBJ = @OBJ ;
LIST @<OBJ = @<OBJ ;
LIST @OBJ> = @OBJ> ;
LIST @OPRED = @OPRED ;
LIST @<OPRED = @<OPRED ;
LIST @OPRED> = @OPRED> ;
LIST @PCLE = @PCLE ;
LIST @COMP-CS< = @COMP-CS< ;

LIST @SPRED = @SPRED ;
LIST @<SPRED = @<SPRED ;
LIST @SPRED> = @SPRED> ;
LIST @<PPRED = @<PPRED ;
LIST @SUBJ = @SUBJ ;
LIST @<SUBJ = @<SUBJ ;
LIST @SUBJ> = @SUBJ> ;
SET SUBJ = @<SUBJ OR @SUBJ> OR @SUBJ ;
SET SPRED = @<SPRED OR @SPRED> OR @SPRED ;
SET OPRED = @<OPRED OR @OPRED> OR @OPRED ;

LIST @PPRED = @PPRED ;

LIST @APP = @APP ;
LIST @APP-N< = @APP-N< ;
LIST @APP-Pron< = @APP-Pron< ;
LIST @APP>Pron = @APP>Pron ;
LIST @APP-Num< = @APP-Num< ;
LIST @APP-ADVL< = @APP-ADVL< ;
LIST @VOC = @VOC ;

LIST @CVP = @CVP ;
LIST @CNP = @CNP ;

SET OBJ = (@<OBJ) OR (@OBJ>) OR (@OBJ) OR (@-F<OBJ) OR (@-FOBJ>) ;
LIST <OBJ = @IOBJ @<OBJ ;
LIST OBJ> = @OBJ> @IOBJ> ;

SET <OBJ-OTHERS = <OBJ OR (Gen) OR (Nom) OR (Ess) OR (Loc) OR (Adv) ;
SET OBJ>-OTHERS = OBJ> OR (Gen) OR (Nom) OR (Ess) OR (Loc) OR (Adv) ;


LIST @X = @X ;

LIST Guess				= Guess ;
LIST Err/Confused		= Err/Confused ;
LIST Err/Confused-Ess	= Err/Confused-Ess ;
LIST Err/Confused-DerPassPrsSg3 = Err/Confused-DerPassPrsSg3 ;
LIST Err/Confused-DerPassPrtSg3 = Err/Confused-DerPassPrtSg3 ;
LIST Err/Confused-NSgPxSg1 = Err/Confused-NSgPxSg1 ;
LIST Err/Confused-ASgNom = Err/Confused-ASgNom ;
LIST Err/Confused-ImprtDu1 = Err/Confused-ImprtDu1 ;
LIST Err/Confused-NomAgIll = Err/Confused-NomAgIll ;
LIST Err/Confused-ImprtSg2 = Err/Confused-ImprtSg2 ;
LIST Err/Confused-Any	= Err/Confused Err/Confused-Ess Err/Confused-ASgNom Err/Confused-ImprtDu1 Err/Confused-NomAgIll Err/Confused-ImprtSg2;
LIST Err/Orth           = Err/Orth ;
LIST Err/Orth-a-ÃĄ       = Err/Orth-a-ÃĄ ;
LIST Err/Orth-nom-acc   = Err/Orth-nom-acc ;
LIST Err/Orth-nom-gen   = Err/Orth-nom-gen ;
LIST Err/Lex            = Err/Lex ;
LIST Err/Spellrelax = Err/Spellrelax ;
LIST Err/DerSub         = Err/DerSub ;
LIST Err/CmpSub         = Err/CmpSub ;
LIST Err/HyphSub        = Err/HyphSub ;
LIST Err/Hyph           = Err/Hyph ;        # There is hyphen, but there shouldn't be
LIST Err/MissingHyph    = Err/MissingHyph ; # On compounds that SHOULD have had a hyphen, but don't
LIST Err/SpaceCmp       = Err/SpaceCmp ;
LIST Err/MissingSpace   = Err/MissingSpace ;

LIST Err/Orth-any       = Err/Orth Err/Orth-a-ÃĄ Err/Orth-nom-gen Err/Orth-nom-acc ;
# Has to be LIST, so ensure this contains all the Err/Orth-any tags:
LIST Err/Orth-any_OR_Ex = Err/Orth Err/Orth-a-ÃĄ Err/Orth-nom-gen Err/Orth-nom-acc Ex/N Ex/V Ex/A Ex/IV Ex/TV ;
# Any Err/Orth + transitivity tags:
LIST Err/Orth-any_OR_TV_IV = Err/Orth Err/Orth-a-ÃĄ Err/Orth-nom-gen Err/Orth-nom-acc Err/Spellrelax TV IV ;
# Any Err that is NOT Err/Orth:
LIST Err/Not-Orth = Err/Lex Err/DerSub Err/CmpSub Err/HyphSub Err/Hyph Err/MissingHyph Err/Spellrelax ;
LIST Err/Any			= Err/Orth Err/Orth-a-ÃĄ Err/Orth-nom-gen Err/Orth-nom-acc Err/Confused Err/Confused-Ess Err/Confused-ASgNom Err/Confused-NomAgIll Err/Confused-DerPassPrsSg3 Err/Lex Err/DerSub Err/CmpSub Err/HyphSub Err/SpaceCmp Err/Spellrelax Err/MissingHyph Err/MissingSpace ;

# All Error tags
SET AllErrorTags = Err/Orth-any OR Err/Not-Orth ;
SET NoErrorTags = (*) - AllErrorTags ;

# Dialect tags
# -------------

LIST Dial/-KJ  = Dial/-KJ ; # forms not in use in KJ (KÃĄrÃĄsjohka)
LIST Dial/-GG  = Dial/-GG ; # forms not in use in GG (Guovdageaidnu)
LIST Dial/-GS  = Dial/-GS ; # forms not in use in GS (GÃĄrasavvon)
LIST South     = South ; # forelÃļpig lagt til Sg Loc -n, som er en sub-form

