LIST LAHKA-NOUN = "Â§" "almmolaĆĄvuohta" "eanagirji" "eanangirji" "eatnangirji" "ÄaÄaheapmi" "fĂĄpmudus" "fĂĄpmuiboahtin" "gĂĄibĂĄdus" "geatnegasvuohta" "geavaheapmi" "gonagas" "hĂĄlddaĆĄangeavat" "juksanmearri" "kap" "kapihtal" "kapihttal" "konvenĆĄuvdna" "lĂĄhkaĂĄsahus" "lĂĄhkaovdabargu" "lĂĄigohanvuoigatvuohta" "mearrĂĄdus" "njuolggadus" "nr" "paragrĂĄfa" "riekteĂĄddejupmi" "riektegĂĄldu" "riektegeavat" "riektesubjeakta" "sĂĄmekonvenĆĄuvdna" "vuoigatvuoÄabargu" "vuoigatvuohta" ;

