#Err/Confused-DerPassPrsSg3
    # N Sg Nom subject

ADD:real-ImprtDu1-DerPassPrsSg3 (&real-ImprtDu1-DerPassPrsSg3) TARGET (N Sg Nom Err/Confused-DerPassPrsSg3) OR (V TV Imprt Du1) OR (Der/PassS Ind Prs Sg3 Err/Confused) IF (NEGATE *1 ("!"))(NEGATE -1 (A Attr) OR (A Sg Nom) OR (N Gen) - Sem/Time - Sem/Plc OR VFIN OR Inf OR (Pron Gen))(-1 (Pers Nom Sg3) OR (N Sg Nom) LINK NEGATE *-1 VFIN BARRIER NOT-ADV-PCLE - PrfPrc)(NEGATE *1 VFIN BARRIER NOT-ADV-PCLE - PrfPrc)(NEGATE 0 Der/Pass - Err/Confused-Any)(NEGATE 0 (Prs Sg3) - Err/Confused-Any)(NEGATE -1 Gen OR <NomGenSg> LINK -1 Actio OR PrfPrc LINK *-1 VFIN BARRIER NOT-ADV-PCLE);
    ## Heaikkas vĂĄilot dĂĄt dĂĄiddut, son biddju jurddaĆĄeaddji, filosofa posiĆĄuvdnii, dakkĂĄr gii smiehtada dĂĄlĂĄ â doloĆĄ â ja boahtteĂĄiggi, dakkĂĄr gii jurddaĆĄaddĂĄ eallima mohkas gaĆŸaldagaid. #biddju ----> biddjo
	#$ ĂlbmotgirjerĂĄdju lĂĄhka nanne ahte fylkkagirjerĂĄjus galgĂĄ leat ĆĄiehtadussii Äadnon ovttasbargat fylkkasuohkana skuvlanjunnuĆŸiin ja fylkkagirjerĂĄjuin fĂĄgalaĆĄ gealbbu biddju geavahussii dĂĄrbbu mielde skuvlaeisevĂĄldiide.
	#OR (Dem Sg Nom) can be subject but also prenominal :(

ADD:real-ImprtDu1-DerPassPrsSg3 (&real-ImprtDu1-DerPassPrsSg3) TARGET (N Sg Nom Err/Confused-DerPassPrsSg3) OR (V TV Imprt Du1) OR (Der/PassS Ind Prs Sg3 Err/Confused) IF (NEGATE *1 ("!"))(-1 ("nugo") LINK NEGATE *2 VFIN BARRIER GRAMCHK-S-BOUNDARY OR CS)(NEGATE 0 Der/Pass - Err/Confused-Any)(NEGATE 0 (Prs Sg3));
    ## DĂĄidagat govvejit dĂĄlĂĄ ĂĄigĂĄsaĆĄ sĂĄmi dĂĄidaga, nugo dahkku Gjert Rognli, AsbjĂžrn ForsĂžget, Annelise Josefsen, Ulrika Tapio Blind ja Aage Gaup bokte. # #dahkku ----> dahkko pass -- doesn't work yet

    # N Sg Nom subject

ADD:real-ImprtDu1-DerPassPrsSg3 (&real-ImprtDu1-DerPassPrsSg3) TARGET (N Sg Nom Err/Confused-DerPassPrsSg3) OR (V TV Imprt Du1) OR (Der/PassS Ind Prs Sg3 Err/Confused) IF (NEGATE *1 ("!"))(NEGATE -1 (A Attr) OR (A Sg Nom) OR (N Gen) - Sem/Time - Sem/Plc OR VFIN OR Inf OR Dem)(-1 (Pers Nom Sg3) OR (N Sg Nom))(NEGATE 0 Der/Pass - Err/Confused-Any)(NEGATE 0 (Prs Sg3));
	## ĂrvĂĄlus biddju fylkkadiggĂĄi meannudeapmai.
	#$ Skum fas lohkĂĄ, ahte sis ii leat ĆĄat ovttasbargu ĆĄiehttadus, go dat nohkka jahkĂĄi 2013, ja danne lea dĂĄt su mielas heittot {dahkku}.
	#$

ADD:real-ImprtDu1-DerPassPrsSg3 (&real-ImprtDu1-DerPassPrsSg3) TARGET (N Sg Nom Err/Confused-DerPassPrsSg3) OR (V TV Imprt Du1) OR (Ind Prs Sg3 Err/Confused) IF (NEGATE *1 ("!"))(-1 Ess LINK -1 BOS)(NEGATE -1 (A Attr) OR (A Sg Nom)  OR (N Gen) - Sem/Time - Sem/Place OR VFIN OR Inf OR Dem)(*1 THAT-CS BARRIER NOT-ADV-PCLE)(NEGATE 0 Der/Pass - Err/Confused-Any)(NEGATE 0 (Prs Sg3));

	# Ill valency

LIST <*-Ill> = <.*-?Ill-.*>r;

ADD:real-ImprtDu1-DerPassPrsSg3 (&real-ImprtDu1-DerPassPrsSg3) TARGET (N Sg Nom Err/Confused-DerPassPrsSg3) OR (V TV Imprt Du1) - DIPHTONG-ROOT OR (Ind Prs Sg3 Err/Confused) - DIPHTONG-ROOT IF (NEGATE *1 ("!"))(0 <*-Ill>)(*1 (N Ill) OR (Pron Ill) BARRIER NPNHAPcle - Acc)(NEGATE -1 (A Attr) OR (N Gen) - Sem/Time - Sem/Place OR VFIN OR Inf OR Dem)(NEGATE 0 N + <TH-Ill-Any>)(NEGATE 0 Der/Pass - Err/Confused-Any)(NEGATE 0 (N Gen) LINK 1 N LINK *1 VFIN)(NEGATE 0 (Prs Sg3));
    ## â Mii oaivvildat leat dehĂĄlaĆŸĆŸan ahte ovddasvĂĄstĂĄdus dĂĄsseĂĄrvvu- ja vealahanĂĄĆĄĆĄiin {biddju} sĂĄmi ĂĄsahussii, ja de lea GĂĄldu lunddolaĆĄ ĂĄsahus.
    #$ {Guovlu} girdigietti lagasbirrasii, masa maid gullet rĂĄdjesuohkanat Norggabealde, dagahit oktasaĆĄ mĂĄtkeguovllu masa gullet viiddis, doaresbeal ĂĄvdin guovllut, meahcce ja duottarguovllut ja sĂĄmi kultuvra.

	# ConNeg after Neg

ADD:real-ImprtDu1-DerPassPrsSg3 (&real-ImprtDu1-DerPassPrsSg3) TARGET (N Sg Nom Err/Confused-DerPassPrsSg3) OR (V TV Imprt Du1) OR (Ind Prs Sg3 Err/Confused) IF (NEGATE *1 ("!"))(*-1 (V Neg) BARRIER NOT-ADV-PCLE)(NEGATE *1 ConNeg)(NEGATE 0 Der/Pass - Err/Confused-Any)(NEGATE 0 (Prs Sg3));

	# explicit Adv inbetween in case of ambiguity
ADD:real-ImprtDu1-DerPassPrsSg3 (&real-ImprtDu1-DerPassPrsSg3) TARGET (N Sg Nom Err/Confused-DerPassPrsSg3) OR (V TV Imprt Du1) OR (Ind Prs Sg3 Err/Confused) IF (-1 Adv OR Pcle LINK -1 (V Neg))(NEGATE *1 ConNeg)(NEGATE 0 Der/Pass - Err/Confused-Any)(NEGATE 0 (Prs Sg3));
    ## Mii leat ĂĄlo vikkahan ahte eissevĂĄldit galget guldalit orohagaid vai njuovĆŸilit manaĆĄii boazulogu heivehanĂĄĆĄĆĄi, nu daÄi bahĂĄbut ii ĂĄlo dahkku.


COPY:real-ImprtDu1-DerPassPrsSg3 (Ex/V Ex/TV Der/PassS V IV Ind Prs Sg3 SUGGEST) EXCEPT (V TV Imprt Du1 &real-ImprtDu1-DerPassPrsSg3) OR (Err/Confused-DerPassPrsSg3 &real-ImprtDu1-DerPassPrsSg3) TARGET (V TV Imprt Du1 &real-ImprtDu1-DerPassPrsSg3) ;

COPY:real-ImprtDu1-DerPassPrsSg3 (Ex/TV Der/PassS V SUGGEST) EXCEPT (V Der/PassS Err/Confused &real-ImprtDu1-DerPassPrsSg3) BEFORE IV OR TV TARGET (Ind Prs Sg3 Err/Confused &real-ImprtDu1-DerPassPrsSg3) ;


	# Imprt+Du1 vs noun nomsg   u-stam; alla konsonantgrupper utom 1 och  4D, grad III-II
	# GRUPP 2, 3C + ddj-dj-j   -  nomsg GRAD III eller II
	# GRUPP 3A, 3B och 4      -   nomsg GRAD III
	# --------------------------------------------------------------------------------
	# diehttuÂą(noun,conc|diehtu), adnu-atnu  Imprt+Du1 EVEN-stem vs noun nomsg   u-stam; konsonantgrupper 2 och 3C och ddj-dj-j, grad III-II ---- problem: not the same lemma
	#adnu --- atnu+N+Sg+Nom Confused
	#should be: Err/Confused-ImprtDu1

	# important, the noun has to be in the target, not the verb

LIST SPECIAL-ATTR = ("okta" Num Sg Nom) ("seammĂĄ" Adv) ("buorre" A Sg Nom) (Der/lasj A Sg Nom) ;

ADD:real-ImprtDu1-NSgNom (&real-ImprtDu1-NSgNom) TARGET (N Sg Nom Err/Confused-ImprtDu1) IF (NEGATE *1 ("!"))(-1 (A Attr) OR (Indef Attr) OR (Pron Pers Gen) OR SPECIAL-ATTR OR (N Gen) - Sem/Time OR VFIN OR Inf OR Dem OR GRADE-ADV OR (Pron Gen))(NEGATE 0 &real-ImprtDu1-DerPassPrsSg3)(*0 VFIN BARRIER GRAMCHK-S-BOUNDARY - BECAUSE-WHEN)(NEGATE *0 (N Sg Nom) OR (Pron Sg Nom) OR (Pron Sg3) BARRIER NOT-ADV)(NEGATE 1 PRE-NP-HEAD LINK 1 (N Sg Nom))(NEGATE -1 (V Neg))(NEGATE 0/1 N)(NEGATE 0 (Ind Prs Sg3) - Err/Any);
	#(0 EVEN-VERBS + CONC-2-3C-DDJ)
	## UNOHAS DAHKU: - Unohas dahkku go Magnhild Mathisena eai dohkkehan, lohket Magnhilda bellodatolbmot.

ADD:real-ImprtDu1-NSgNom (&real-ImprtDu1-NSgNom) TARGET EVEN-VERBS + CONC-2-3C-DDJ IF (0 (Der/PassS Ind Prs Sg3 Err/Confused) OR (Imprt Du1) OR Err/Confused-ImprtDu1) (NEGATE *1 ("!"))(-1 (A Attr) OR (Indef Attr) OR (Pron Pers Gen) OR SPECIAL-ATTR OR (Dem Sg Nom) OR (N Gen) - Sem/Time OR VFIN OR Inf OR GRADE-ADV OR (Pron Gen))(0* VFIN BARRIER CC OR CS)(NEGATE 0 &real-ImprtDu1-DerPassPrsSg3)(*0 VFIN)(NEGATE *0 (N Sg Nom) OR (Pron Sg Nom) OR (Pron Sg3) BARRIER NOT-ADV)(NEGATE 1 PRE-NP-HEAD LINK 1 (N Sg Nom))(NEGATE -1 (V Neg))(NEGATE 0/1 N)(NEGATE 0 (Ind Prs Sg3) - Err/Any);
    ## Vaikko lea guhkit ĂĄigge leamaĆĄ ollu hubmu medias FĂžrstera vĂĄttisvuoÄaid birra, de vĂĄrresĂĄtnejoÄiheaddji ja opmodatfitnodaga stivralĂĄhttu Isak Mathis O. HĂŠtta ii vĂĄldde makkĂĄrge ovttasvĂĄstĂĄdusa ĂĄĆĄĆĄis. #hubmu
    ## Reinprodukteris lea leamaĆĄ ollu hubmu effektivitehta ja seastima birra. #hubmu
    ## Lea leamaĆĄ ollu hubmu dan oktasaĆĄ ovdĂĄnahttinfitnodaga birra, mii galggai leat nanu neavvu oÄÄa ealĂĄhusproĆĄeavttaid finansieremiid oktavuoÄas. #hubmu
	#$ 1935 lei lohkku lassĂĄnan 230 000:i ja 1980-logu loahpageahÄen lei {olmmoĆĄlohkku} 1,2 miljovnna. #not compounds

    # A Attr without VFIN

ADD:real-ImprtDu1-NSgNom (&real-ImprtDu1-NSgNom) TARGET (N Sg Nom Err/Confused-ImprtDu1) IF (NEGATE *1 ("!"))(-1 (A Attr)  OR (Indef Attr) OR SPECIAL-ATTR LINK *-1 BOS BARRIER NOT-ADV-PCLE - ("-"))(*1 CS OR EOS BARRIER S-BOUNDARY)(NEGATE 0 &real-ImprtDu1-DerPassPrsSg3)(NEGATE *0 (N Sg Nom) OR (Pron Sg Nom) OR (Pron Sg3) BARRIER NOT-ADV)(NEGATE -1 (V Neg))(NEGATE 0 (Ind Prs Sg3) - Err/Any);
	#(0 EVEN-VERBS + CONC-2-3C-DDJ)
    #$ - Hui ĂĄrtegis dahkku, go stuorra oassi SĂĄmi Radio doaimmas lea gaskkustit ĂĄigeguovdilis ĂĄĆĄĆĄiid sĂĄmegillii, ja erenoamĂĄĆŸit neahtas.

    # ellipsis

ADD:real-ImprtDu1-NSgNom (&real-ImprtDu1-NSgNom) TARGET (N Sg Nom Err/Confused-ImprtDu1) IF (NEGATE *1 ("!"))(-1 (A Attr) OR (Indef Attr) OR SPECIAL-ATTR OR (N Gen) - Sem/Time - Sem/Plc OR VFIN OR Inf OR Dem OR GRADE-ADV LINK *-1 BOS OR ("=") BARRIER NOT-ADV-PCLE - ADVLCASE - Gen)(*1 EOS BARRIER NOT-ADV-PCLE - ADVLCASE - Sem/Year)(NEGATE 0 &real-ImprtDu1-DerPassPrsSg3)(NEGATE -1 (V Neg))(NEGATE 0/1 N)(NEGATE 0 (Ind Prs Sg3) - Err/Any);
	## Fasttes dahkku.
    ## SĂĄmi mĂĄnĂĄidgĂĄrddiid lohkku 2011.
    ## n = olbmuid lohkku.

    # coordination

ADD:real-ImprtDu1-NSgNom (&real-ImprtDu1-NSgNom) TARGET (N Sg Nom Err/Confused-ImprtDu1) IF (NEGATE *1 ("!"))(-1 COMMA OR CC LINK -1 (N Nom Sg))(0* VFIN BARRIER CC OR CS)(NEGATE 0 &real-ImprtDu1-DerPassPrsSg3)(NEGATE 0/1 N)(NEGATE 0 (Ind Prs Sg3) - Err/Any);
	#(0 EVEN-VERBS + CONC-2-3C-DDJ)
ADD:real-ImprtDu1-NSgNom (&real-ImprtDu1-NSgNom) TARGET EVEN-VERBS + CONC-2-3C-DDJ IF (0 (Der/PassS Ind Prs Sg3 Err/Confused) OR (Imprt Du1)) (NEGATE *1 ("!"))(-1 COMMA OR CC LINK -1 (N Nom Sg))(0* VFIN BARRIER CC OR CS)(NEGATE 0 &real-ImprtDu1-DerPassPrsSg3)(NEGATE 0/1 N)(NEGATE 0 (Ind Prs Sg3) - Err/Any);

ADD:real-ImprtDu1-NSgNom (&real-ImprtDu1-NSgNom) TARGET (N Sg Nom Err/Confused-ImprtDu1) IF (NEGATE *1 ("!"))(1 COMMA OR CC LINK 1 (N Nom Sg))(0* VFIN BARRIER CC OR CS)(NEGATE 0 &real-ImprtDu1-DerPassPrsSg3)(NEGATE -1 (V Neg))(NEGATE 0/1 N)(NEGATE 0 (Ind Prs Sg3) - Err/Any);
    ## Doahpagis duodji lea leamaĆĄ viiddis mearkkaĆĄupmi: {dahkku}, buvtta, doaibma.

ADD:real-ImprtDu1-NSgNom (&real-ImprtDu1-NSgNom) TARGET (N Sg Nom N Sg Nom Err/Confused-ImprtDu1) IF (0 EVEN-VERBS + CONC-2-3C-DDJ) (NEGATE *1 ("!"))(-1 (A Attr) OR SPECIAL-ATTR OR (N Gen) - Sem/Time - Sem/Plc OR VFIN OR Inf OR Dem)(0* VFIN BARRIER CC OR CS)(NEGATE 0 &real-ImprtDu1-DerPassPrsSg3)(NEGATE *0 (N Sg Nom) OR (Pron Sg Nom) OR (Pron Sg3) BARRIER NOT-ADV)(NEGATE 1 PRE-NP-HEAD LINK 1 (N Sg Nom))(NEGATE -1 (V Neg))(NEGATE 0/1 N)(NEGATE 0 (Ind Prs Sg3) - Err/Any);
    ## DĂĄn dĂĄlvvi lea leamaĆĄ hubmu dan birra ahte bohccot nelgot ja danin fertejit biebmat daid vai eai jĂĄme nelggiin. #hubmu

	## Guovdageainnu servodat oaĆŸĆŸu unnĂĄn ĂĄvkki SĂĄmedikkis, ja jus dat ii rievdat politihka guovddĂĄĆĄ sĂĄmi guovlluid olgguĆĄteamis, de ii leat adnu dasa, lohkĂĄ son dan birra go okte lea lohkan medias ahte SĂĄmedikki oÄÄoĆĄii heaittihit. -  adnu
	## Mii vĂĄldit sĂĄmegiela duoÄas, lea Rettera Äielga diehttu.  -   diehttu
	## Njulges sĂĄhccu Äujuha man olu berre njuovvat go ealu varihiid gaskamearĂĄlaĆĄ njuovvandeaddu lea nuo ja nuo stuoris..  -   sĂĄhccu
	## KĂĄrttaid lassin girjjis lea tabealla iehÄanas stĂĄhtain ovttas ieĆŸaset leavggaiguin ja sĂĄmegielat ohccu. -- ohccu
	## â Girjjis lea maiddĂĄi vuogas ohccu mas sĂĄtnevĂĄdjasiid gĂĄvnnat fĂĄttĂĄid mielde, daddjo preassadieÄĂĄhusas. -- ohccu
	## Son navdĂĄ liikkĂĄ, ahte lea Ipmila gohÄÄu ahte son dĂĄl galgĂĄ fĂĄrret Guovdageidnui. --- gohÄÄu
	## DĂĄkkĂĄr gohÄÄu lea EspĂĄnja justisministtar sĂĄdden riikka ĂĄĆĄĆĄĂĄskuhtti eisevĂĄlddiide. ---- gohÄÄu
	## FinnmĂĄrkkus lea lohkku rievddadan veahĂĄ, muhto manai garrasit maĆĂĄs maĆĆil 1990 ( 25_% ). ---- lohkku
	## Olbmuid lohkku, geat gullet boazodollui, lassĂĄnii goappaĆĄ riikkain 1975/80/1975 rĂĄjes, ja Norggas ledje boazodoalus eanemus olbmot jagis 1990. --- lohkku
	## Okta miellahttu goappĂĄge riikkas galgĂĄ leat boazodoalli geas lea nana diehttu boazodoalus. - diehttu
    #$ RĂĄssin dat lieÄÄu ja veajehaĆŸĆŸan ÄĂĄzis silban deaddju. #deaddju ---> deadju	deadjut+V+IV+Ind+Prs+Sg3

	# lea + N Sg Nom

ADD:real-ImprtDu1-NSgNom (&real-ImprtDu1-NSgNom) TARGET (N Sg Nom Err/Confused-ImprtDu1) IF (NEGATE *1 ("!"))(*-1 (Neg Sg3) OR COPULAS + Sg3 BARRIER NOT-ADV-PCLE - @>P - Po - BE + (PrfPrc) - BE + (ConNeg))(NEGATE 0 &real-ImprtDu1-DerPassPrsSg3)(NEGATE -1 (V Neg))(NEGATE 0/1 N)(NEGATE 0 (Ind Prs Sg3) - Err/Any);
    ## DĂĄn dĂĄlvvi lea leamaĆĄ hubmu dan birra ahte bohccot nelgot ja danin fertejit biebmat daid vai eai jĂĄme nelggiin.
    # (0 EVEN-VERBS + CONC-2-3C-DDJ)
    ## MaiddĂĄi earĂĄ sajiin riikkas lea seammalĂĄdje; jus lea jazza birra hubmu, de oaĆŸĆŸu eambbo ruÄa.
ADD:real-ImprtDu1-NSgNom (&real-ImprtDu1-NSgNom) TARGET (N Sg Nom Err/Confused-DerPassPrsSg3) IF (NEGATE *1 ("!"))(*-1 COPULAS + Sg3 BARRIER NOT-ADV-PCLE - @>P - Po - BE + (PrfPrc))(NEGATE 0 &real-ImprtDu1-DerPassPrsSg3)(NEGATE 0/1 N)(NEGATE 0 (Ind Prs Sg3) - Err/Any);
    #$ â Dan birra ii leat leamaĆĄ hubmu, eatge leat dan ĂĄrvvoĆĄtallan, lohkĂĄ Krumsvik.

    # Sg3

ADD:real-ImprtDu1-NSgNom (&real-ImprtDu1-NSgNom) TARGET (N Sg Nom Err/Confused-ImprtDu1) IF (NEGATE *1 ("!"))(1 (V Sg3))(*-1 BOS OR CS OR BUT-CC OR Rel BARRIER NOT-ADV-PCLE - ADVLCASE)(NEGATE 0 &real-ImprtDu1-DerPassPrsSg3)(NEGATE -1 (V Neg))(NEGATE 0/1 N)(NEGATE 0 (Ind Prs Sg3) - Err/Any);
    ## Manin lohkku njiedjĂĄ?
    ## Vaikko leat heajos dĂĄlkkit leamaĆĄ ovdalaĆĄ jagiid, de muitala Berit Marie Eira ahte dat ii leat bissehan mĂĄnĂĄid boahtimis ÄiekÄamiidda ja lohkĂĄ ahte lohkku lea lassĂĄnan jagis jahkĂĄi.
    ## 60-70 000 ainolaÄÄa orrut JapĂĄnas, muhto lohkku lea gĂĄddimis mealgat stuorĂĄt, go ollu ainolaÄÄa Äiegadit ieĆŸaset identitehta.

    # spred

ADD:real-ImprtDu1-NSgNom (&real-ImprtDu1-NSgNom) TARGET (N Sg Nom Err/Confused-ImprtDu1) IF (NEGATE *1 ("!"))(NEGATE *-1 (Pron Sg3) OR (N Nom Sg) BARRIER NOT-ADV-PCLE)(1 (V Sg3) + COPULAS LINK *1 @<SPRED BARRIER NPNHA)(NEGATE 0 &real-ImprtDu1-DerPassPrsSg3)(NEGATE -1 (V Neg))(NEGATE 0/1 N);
	## KonfirmĂĄntaĂĄiggi lĂĄhÄÄu lea ieĆĄguÄetlĂĄgĂĄn ieĆĄguÄet bĂĄikkis.

	# post relative sentence

ADD:real-ImprtDu1-NSgNom (&real-ImprtDu1-NSgNom) TARGET (N Sg Nom Err/Confused-ImprtDu1) IF (NEGATE *1 ("!"))(1 (Rel Sg) OR (Interr Sg) LINK NEGATE 0 ("<maid>"))(NEGATE 0 &real-ImprtDu1-DerPassPrsSg3)(NEGATE -1 (V Neg))(NEGATE 0/1 N)(NEGATE 0 (Ind Prs Sg3) - Err/Any);
    ## DaÄibahĂĄbut lea vieris ĆĄlĂĄjaid gilvin jĂĄvrriide {dahkku} man ii sĂĄhttĂĄ mĂĄhcahit dahje njulget.




COPY:real-ImprtDu1-NSgNom (SUGGEST) EXCEPT (Err/Confused-ImprtDu1 &real-ImprtDu1-NSgNom) TARGET (N Sg Nom Err/Confused-ImprtDu1 &real-ImprtDu1-NSgNom) ;

	# NomAg Ill vs Prt Sg3
	# --------------------

ADD:real-NomAgIll-PrtSg3 (&real-NomAgIll-PrtSg3) TARGET (Ex/V Der/NomAg N Sg Ill) IF (0 UT-VERBS + CONC-3A-3B-4 - DIPHTONG-ROOT)(NEGATE *0 VFIN BARRIER GRAMCHK-S-BOUNDARY OR CC)(NEGATE -1 (<.*-Ill-.*>r))(NEGATE -1 (Dem Sg Gen) OR Attr OR ADJ_ATTR/NOM OR Num)(NEGATE 0 Err/Spellrelax OR (Ind Prt Sg3) - Err/Any OR Der/h OR (Prop Sg Ill))(NEGATE -1 CC LINK -1 (N Sg Ill))(NEGATE **1 Sem/Sur OR Sem/Mal OR Sem/Fem BARRIER (*) - Attr LINK 0 (Sg Ill) OR (Sg Nom))(NEGATE 1 ("ges"));
	## BĂĄlddis beare bijai njĂĄlmmi botnjut ja biĆĄkui.
	## MĂĄhtes ĂĄbbui bĂĄhti.
	## Ja nugo gullet, de son ieĆĄ riggui dieinna vugiin. - riggui
	## OlmmĂĄi oaÄÄui ruÄaid, nu dĂĄvjĂĄ go geange sis gĂĄvnnai, ja riggui hirbmosit. - riggui
	## Son rĂĄgĂĄdii ja ÄievÄÄai ja gazzui seainni. -- gazzui
	## Son gal sihkkarit doaivu ahte lei albma guovĆŸa mii rĂĄgui ja gazzui seainni. --- gazzui
	#$ {MĂĄhkarĂĄvjui} ja VuorjenjĂĄrgii ĆĄattaĆĄii nu divrras rusttet ahte ferteĆĄii geahÄalit unnit rusttegiid rĂĄhkadit maiguin HonnesvĂĄhkĂĄi maid sĂĄhtii addit elrĂĄvnnji.
	#$ Davvi-Norgga universitehta ĆĄĂĄlloĆĄa sĂĄkka go muhtin pasieanttat leat ĆĄaddan badjelmeare guhkĂĄ vuordit ovdal go besset iskkadeapmĂĄi dahje {dikĆĄui}. 

COPY:real-NomAgIll-PrtSg3 (V IV Ind Prt Sg3 SUGGEST) EXCEPT (Ex/V IV Der/NomAg N Sg Ill &real-NomAgIll-PrtSg3) TARGET (IV &real-NomAgIll-PrtSg3) ;

	# (verb-3-stav/)PxSg2  vs nompl, a-stam, ĂĄ-stam, o-stam, e-stam; alla konsonantgrupper utom 1 og 4D
	# nomsg GRAD III
