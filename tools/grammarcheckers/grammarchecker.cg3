    #$ Konferأ،nssa ulbmil dأ،n hأ،ve lea ؤچohkket nissoniid geain leat ieإ،guؤ‘etlأ،gan duogأ،إ¾at ja ahki, oainnusin dahkan dihte nissoniid vأ،sihusaid luonddu ja ressurssaid birra {davvi} bأ،ikkأ،laإ، servodagain.


    # BEGINNING Dependency rules and semantic role rules
    # ####################################################
    # I want to put them here to identify valid verb-argument constructions (for example for avoiding nominal readings of verbs)

	# dependency
	# ==========

	# SET objects
	# -----------

LIST <ctjHead> = <ctjHead> ;

LIST OBJ-COMP = ("ahte" CS) ("makkأ،r" Pron) ("movt" CS) ;
LIST MCL-CONJ = ("de" CC) ("dellie" CC)("dillie" CC)("dle" CC) ("die" Adv) ("muhto" CC) ("mohte" CC) ("men" CC) ("valla" CC) ; # these typically introduce a main clause, not coordination of subclauses
SET ADVL-COMP = MO-MANge - ("man" Foc/ge) ;

LIST @FV = @+FMAINV @+FAUXV ;
LIST @AUX = @-FAUXV @+FAUXV ;
LIST @MV = @-FMAINV @+FMAINV @FMVdic @IMVdic ;
LIST @V = @+FMAINV @-FMAINV @+FAUXV @-FAUX @FS-VFIN< @FS-ADVL @FS-<ADVL @FS-ADVL> ; #@FS-OBJ @FS-OBJ> @FS-<OBJ @FS-SUBJ @FS-SUBJ> @FS-<SUBJ @FS-IMV @FS-N<IMV @FS-N< @FS-P< @FS-P<IMV @FS-IAUX @ICL-P< @ICL-P<IMV @FS-N<IAUX @ICL-OBJ @ICL-SUBJ @PRED @PRED2;
#LIST ADVL = @<ADVL @ADVL> @ADVL @-FADVL> @-F<ADVL @APP-ADVL< @CL-<ADVL @CL-ADVL> ; # @i-<ADVL @i-ADVL> ; 		         # adverbial
#LIST @ICL-OBJ = @ICL-OBJ ; 	         # non-finite subclause ...
#LIST @ICL-SUBJ = @ICL-SUBJ ; 	         # non-finite subclause ...
#
#LIST SUBJ = @<SUBJ @SUBJ> @SUBJ @-FSUBJ> ;
#LIST SUBJ> = @SUBJ> @tSUBJ> ;
#LIST <SUBJ = @<SUBJ @<tSUBJ ;
LIST IOBJ = @<IOBJ @IOBJ> ;
LIST FOBJ> = @-FOBJ> @-FIOBJ> ;
LIST F<OBJ = @-F<OBJ @-F<IOBJ ;
#LIST APP = @APP>Pron @APP-ADVL< @APP-N< @APP-Num< @APP-Pron< ;
SET @ARG = SUBJ OR OBJ OR SPRED OR OPRED ; #OR ADVL OR @ICL-OBJ OR @<PPRED OR IOBJ OR @POSS> OR @APP-N< OR @P< ;
#

LIST @FS-VFIN< = @FS-VFIN< ;
LIST @FS-ADVL 	= @FS-ADVL ;
LIST @FS-<ADVL 	= @FS-<ADVL ;
LIST @FS-ADVL> 	= @FS-ADVL> ;
LIST @FS-OBJ 	= @FS-OBJ ;
LIST @FS-OBJ> 	= @FS-OBJ> ;
LIST @FS-<OBJ 	= @FS-<OBJ ;
LIST @FS-SUBJ 	= @FS-SUBJ ;
LIST @FS-SUBJ> 	= @FS-SUBJ> ;
LIST @FS-<SUBJ 	= @FS-<SUBJ ;
LIST @FS-IMV 	= @FS-IMV ;
LIST @FS-N<IMV 	= @FS-N<IMV ;
LIST @FS-N< 	= @FS-N< ;
LIST @FS-P< 	= @FS-P< ;
LIST @FS-P<IMV 	= @FS-P<IMV ;
LIST @FS-IAUX 	= @FS-IAUX ;
LIST @ICL-P< 	= @ICL-P< ;
LIST @ICL-P<IMV = @ICL-P<IMV ;
LIST @FS-N<IAUX = @FS-N<IAUX ;
LIST @ICL-OBJ 	= @ICL-OBJ ;
LIST @ICL-SUBJ 	= @ICL-SUBJ ;

LIST @FMVdic = @FMVdic ;
LIST @IMVdic = @IMVdic ;

LIST MUITALIT = "أ،rvalit" "bivdit" "boagustit" "cealkit" "cuoigut" "ؤچilget" "ؤچurvet" "ؤچuorvut" "dadjat" "geardduhit" "gielistit" "gilljut" "hأ،llat" "hoallat" "huikit" "huikkأ،dit" "imaإ،tallat" "jearrat" "jievإ¾at"  "juoigat" "jurdilit" "jurddaإ،it" "kommenteret" "lأ،vlut" "lasihit" "loahpahit" "lohkat" "lohpidit" "mأ،idnut" "mأ،innaإ،it" "muitalit" "muittuhit" "nأ،gget" "njأ،vggأ،dit" "oaivvildit" "rأ،vvet" "savkalit" "sأ،rdnidit" "إ،uohkihit" "vأ،idalit" "vأ،ruhit" "vأ،stidit" ;
    ## Njأ،v, vأ،idalii Busi ja gأ،vastalai.
    ## Njأ،v, njأ،vggأ،dii Busi fas ja fanahalai.

LIST ILL-LOC-PRON-ADV = "buot" "visot" ;

	# multilingual sets
	# -----------------

LIST THEN-sme = "de" ;
LIST THEN-smn = "te" ;
LIST THEN-smj = "de" ;
#LIST THEN-sma = "de" ;
SET THEN-CS-ADV = THEN-sme OR THEN-smn OR THEN-smj ; # conjunction and adverb


LIST BECAUSE-WHEN-sme = "go" ;
LIST BECAUSE-WHEN-smn = "ko" ;
LIST BECAUSE-WHEN-smj = "gأ¥" ;
LIST BECAUSE-WHEN-sma = "goh" ;
SET BECAUSE-WHEN = BECAUSE-WHEN-sme OR BECAUSE-WHEN-smn OR BECAUSE-WHEN-smj OR BECAUSE-WHEN-sma ;

LIST IF-CS-sme = "jus" ;
LIST IF-CS-smn = "jis" "jos" ;
LIST IF-CS-smj = "jus" ;
LIST IF-CS-sma = "jis" ;
SET IF-CS = IF-CS-sme OR IF-CS-smn OR IF-CS-smj OR IF-CS-sma ;

LIST THAT-CS-sma = "ahte" ;
LIST THAT-CS-smj = "ahte" ;
LIST THAT-CS-sme = "ahte" ;
LIST THAT-CS-smn = "et" ;
SET THAT-CS = THAT-CS-sma OR THAT-CS-smj OR THAT-CS-sme OR THAT-CS-smn ;

LIST BUT-CC-sme = "muhto" ;
LIST BUT-CC-smn = "mut" "mutأ¢" ;
LIST BUT-CC-smj = "valla" ;
LIST BUT-CC-sma = "men" ;
SET BUT-CC = BUT-CC-sme OR BUT-CC-smn OR BUT-CC-smj OR BUT-CC-sma ;

LIST WHAT-smj = "mij" ;
LIST WHAT-sme = "mii" ;
LIST WHAT-sma = "guktie" ;
LIST WHAT-smn = "mii" ;
SET WHAT = WHAT-smj OR WHAT-sma OR WHAT-sme OR WHAT-smn ;

LIST WHO-smj = "guhti" ;
LIST WHO-sme = "gii" ;
LIST WHO-sma = "gie" ;
LIST WHO-smn = "kii" ;
SET WHO = WHO-smj OR WHO-sma OR WHO-sme OR WHO-smn ;

LIST SUCH-AS-sma = "gumhtie" "jemhtie";
LIST SUCH-AS-smj = "degu" "dagu" ;
LIST SUCH-AS-sme = "dego" ;
LIST SUCH-AS-smn = "tego" ;
SET SUCH-AS = SUCH-AS-sma OR SUCH-AS-smj OR SUCH-AS-sme OR SUCH-AS-smn ;


LIST ONE-smn = "ohtأ¢" ;
LIST ONE-sme = "okta" ;
LIST ONE-smj = "akta" ;
LIST ONE-sma = "akte" ;
SET ONE = ONE-smn OR ONE-sme OR ONE-smj OR ONE-sma ;

LIST BE-smj = "liehket" ;
LIST BE-sma = "leah" ;
LIST BE-sme = "leat" ;
LIST BE-smn = "leؤ‘e" ;
SET BE = BE-smj OR BE-sma OR BE-sme OR BE-smn ;

LIST BECOME-sma = "sjأ¯dtedh" ;
LIST BECOME-sme = "إ،addat" ;
LIST BECOME-smj = "sjaddat" ;
LIST BECOME-smn = "إ،oddأ¢ؤ‘" ;
SET BECOME = BECOME-sma OR BECOME-sme OR BECOME-smj OR BECOME-smn ;


LIST CAN-sma = "maehtedh" ;
LIST CAN-sme = "sأ،httit" ;
LIST CAN-smj = "mأ،httet" ;
LIST CAN-smn = "sأ¤ttiؤ‘" ;
SET CAN = CAN-sma OR CAN-sme OR CAN-smj OR CAN-smn ;

LIST BEGIN-sme = "أ،lgit" ;
LIST BEGIN-smn = "أ¤lgiؤ‘" ;
LIST BEGIN-sma = "aelkedh" ;
LIST BEGIN-smj = "أ،lgget" ;
SET BEGIN = BEGIN-smn OR BEGIN-sme OR BEGIN-sma OR BEGIN-smj ;	

LIST NOT-V-sma = "ij" ;
LIST NOT-V-smj = "ij" ;
LIST NOT-V-sme = "ii" ;
LIST NOT-V-smn = "ij" ;
SET NOT-V = NOT-V-sma OR NOT-V-smj OR NOT-V-sme OR NOT-V-smn ;

LIST I-smn = "mun" ;
LIST I-sme = "mun" ;
LIST I-sma = "manne" ;
LIST I-smj = "mأ¥n" ;
SET I = I-smn OR I-sme OR I-sma OR I-smj ;

LIST WE-2-smn = "muoi" ;
LIST WE-2-sme = "moai" ;
LIST WE-2-sma = "mأ¥nnoeh" ;
LIST WE-2-smj = "maجٹj" ;
SET WE-2 = WE-2-smn OR WE-2-sme OR WE-2-sma OR WE-2-smj ;

LIST YOU-smn = "tun" ;
LIST YOU-sme = "don" ;
LIST YOU-sma = "datne" ;
LIST YOU-smj = "dأ¥n" ;
SET YOU = YOU-smn OR YOU-sme OR YOU-sma OR YOU-smj ;


LIST YOU-2-smn = "toai" ;
LIST YOU-2-sme = "doai" ;
LIST YOU-2-sma = "dأ¥tnoeh" ;
LIST YOU-2-smj = "daجٹj" ;
SET YOU-2 = YOU-2-smn OR YOU-2-sme OR YOU-2-sma OR YOU-2-smj ;

LIST SHE-smn = "sun" ;
LIST SHE-sme = "son" ;
LIST SHE-sma = "dأ¯hte" ;
LIST SHE-smj = "juohkka" ;
SET SHE = SHE-smn OR SHE-sme OR SHE-sma OR SHE-smj ;

	# grammatical sets

LIST CONGRUENCE-A-sma = (Der/Comp A) (Der/Superl A) "faavroes" "jaahkoelassje" "vأ¦jkeles";
LIST CONGRUENCE-A-smj = "buorre" ;
LIST CONGRUENCE-A-sme = "buorre" ;
LIST CONGRUENCE-A-smn = "pyeri" (Der/Comp A) (Der/Superl A) (".*vأ¢إ،"r) (".*lأ¢إ،"r) (".*sأ¢إ،"r) (".*gأ¢إ،"r) (".*bأ¢إ،"r) ;
SET CONGRUENCE-A = CONGRUENCE-A-sma OR CONGRUENCE-A-smj OR CONGRUENCE-A-sme OR CONGRUENCE-A-smn ;


# Only verbs in the predicate gets <mv> and <aux>
# -----------------------------------------------
SUBSTITUTE:SubV=mv (V) (<mv> V) TARGET @MV (NEGATE 0 (<mv>));
SUBSTITUTE:SubV=aux (V) (<aux> V) TARGET @AUX (NEGATE 0 (<aux>));


# citations - the verb is marked so it will be handled differently from other verbs if it is in the end of the sentence
SUBSTITUTE:utt (@+FMAINV)(@FMVdic) TARGET (<vdic>) (-1 COMMA LINK 1 VFIN LINK *1 @<SUBJ BARRIER @V) ;
	## Mii fertet maiddأ،i geahؤچadit makkأ،r lassi guoimmuhemiid galgat fأ،llat vai bohtet vel eanet olbmot boahtte jagi, loahpaha duhtavaإ، beaivvأ،laإ، joؤ‘iheaddji Eriksen.

SUBSTITUTE:utt (@+FMAINV)(@FMVdic) TARGET (<vdic>) (*1 (":") BARRIER @V LINK 1 CITATION) ;
	## Ja go stأ،llu أ،lggii nohkkat, de son fas ؤچuorvvui moarsis: "Boaؤ‘e nohkkat!"
SUBSTITUTE:utt (@+FMAINV)(@FMVdic) TARGET (<vdic>) (0 VFIN LINK -1 @SUBJ> LINK *-1 COMMA BARRIER @V) ;
SUBSTITUTE:utt (@+FMAINV)(@IMVdic) TARGET (<vdic>) (*1 (":") BARRIER @V LINK 1 CITATION) ;
	## Ja lea dadjan: "Ale nohka mu nalde!"

# the finite verb of object-subclauses gets @FS-SUBJ:
SUBSTITUTE:SubV=FS-SUBJmv (@+FMAINV)(@FS-<SUBJ) TARGET V (-1 SPRED)(0 Qst);
SUBSTITUTE:SubV=FS-SUBJmv (@+FMAINV)(@FS-<SUBJ) TARGET V (-1 THAT-CS LINK -1 SPRED)(0 Qst);
	## Dأ،s leat juohkelأ،gأ،إ، muitalusat, muhto ii leat vissis leatgo jur njuolga, go eai leat ؤچأ،llojuvvon.
	## Muhto vissis ii leat leatgo jur njuolga.
SUBSTITUTE:SubV=FS-SUBJmv (@+FMAINV)(@FS-<SUBJ) TARGET V (*-1 BOS BARRIER S-BOUNDARY LINK 1 THAT-CS)(*-1 SPRED BARRIER S-BOUNDARY);
	## Dehأ،laإ، lea ahte don maid boaؤ‘أ،t.
	## Lea dehأ،laإ، ahte don maid boaؤ‘أ،t.
SUBSTITUTE:SubV=FS-SUBJmv (@+FMAINV)(@FS-SUBJ>) TARGET V (*-1 BOS BARRIER S-BOUNDARY LINK 1 THAT-CS)(*1 COPULAS LINK *1 (@<SPRED) BARRIER S-BOUNDARY);
	## Ahte don maid boaؤ‘أ،t lea dehأ،laإ،.

# the finite verb of object-subclauses gets @FS-OBJ:
SUBSTITUTE:SubV=FS-OBJmv (@+FMAINV)(@FS-OBJ) TARGET V (*-1 OBJ-COMP BARRIER @V OR @CVP OR CS OR Rel LINK NOT *-1 Com BARRIER @ARG LINK *-1 TV + VFIN)(NEGATE *-1 Interr BARRIER @V OR @CVP OR CS OR Rel LINK *-1 BOS BARRIER @V)(NEGATE *1 (?));
	#$ Sأ،pmelaؤچؤچas leai dakkأ،r luondu, ahte son hأ،liidiإ،goؤ‘ii gottiid.
SUBSTITUTE:SubV=FS-OBJmv (@+FMAINV)(@FS-OBJ) TARGET V (*-1 OBJ-COMP BARRIER @V OR @CVP OR CS OR Rel LINK NOT *-1 Com BARRIER @ARG)(NEGATE *-1 Interr BARRIER @V OR @CVP OR CS OR Rel LINK *-1 BOS BARRIER @V)(NEGATE *1 (?))(*1 VFIN LINK *1 TV + VFIN);
SUBSTITUTE:SubV=FS-OBJmv (@+FMAINV)(@FS-OBJ) TARGET V (*-1 CC OR COMMA BARRIER @V OR @CVP OR CS OR Rel OR @SUBJ> LINK NOT 0 MCL-CONJ LINK *-1 (@FS-OBJ) BARRIER @V)(NEGATE *1 (@<SUBJ)) ; # coordination
SUBSTITUTE:SubVmain=FS-OBJaux (@+FAUX) (@FS-OBJ) TARGET V (*-1 OBJ-COMP BARRIER @V OR @CVP OR CS OR Rel LINK NOT *-1 Com BARRIER @ARG)(NEGATE *1 (?)) ;
SUBSTITUTE:SubVmain=FS-OBJaux (@+FAUX) (@FS-OBJ) TARGET V (*-1 CC BARRIER @V OR @CVP OR CS OR Rel OR @SUBJ> LINK NOT 0 MCL-CONJ LINK *-1 (@FS-OBJ) BARRIER VFIN) ;  # coordination
SUBSTITUTE:SubVmain=FS-OBJaux (@+FAUX) (@FS-OBJ) TARGET V (**-1 Indef OR A BARRIER VFIN OR @CVP OR CS OR Rel LINK -1 ("man" Adv) LINK NOT *-1 Com BARRIER @ARG) ; # object-subclause starts with "man stuoris/galle"
SUBSTITUTE (@+FAUX) (@FS-OBJ) TARGET V (0 (Neg Ind) LINK *-1 @FS-OBJ BARRIER VFIN) ; # coordination with Neg

# the finite verb of advl-subclauses gets @FS-ADVL> or @FS-<ADVL:
SUBSTITUTE:SubV=FS-<ADVLmv (@+FMAINV)(@FS-<ADVL) TARGET VFIN (-1 @SUBJ> OR Nom LINK *-1 VFIN BARRIER NPNHA) ;

SUBSTITUTE:SubV=FS-<ADVLmv (@+FMAINV)(@FS-<ADVL) TARGET V (*-1 ADVL-COMP OR CS OR Rel BARRIER @V OR Rel OR @CVP OR @COMP-CS<)(*-1 @FV BARRIER (":"))(NEGATE *-1 BECAUSE-WHEN BARRIER @V OR Rel OR @CVP OR @COMP-CS< LINK -1 ("nu"))(NEGATE *-1 ADVL-COMP + Sem/Plc LINK -1 Adv + Sem/Plc) ;
    # the last condition makes sure there is a potential finite verb of the main clause to the left that can be modified
    #$GRAMval Jus eai leat أ،lgأ،n divodemiin ovdal geassemأ،nu, de sأ،httet manahit visot daid tippenruؤ‘aid, lohkأ، Johansen, gii ii loga liikot dili nu go dأ،l lea.
    ##GRAMval â€“ Mأ،nأ،t ja olbmot gean govven eai liiko man lأ،hkأ،i media govve sin.

SUBSTITUTE:SubV=FS-<ADVLmv (@+FMAINV)(@FS-<ADVL) TARGET V (*-1 ADVL-COMP OR CS BARRIER @V OR Rel OR @CVP OR @COMP-CS<)(*-1 @FV BARRIER (":"))(NEGATE *-1 BECAUSE-WHEN BARRIER @V OR Rel OR @CVP OR @COMP-CS< LINK -1 ("nu"))(NEGATE *-1 ADVL-COMP + Sem/Plc BARRIER NPNHAPcle LINK -1 Adv + Sem/Plc) ;
    #GRAMval
    #$ Ii leat liikkأ، makkأ،rge أ،gga ballat ahte foandda doarjagat eai vأ،ikkut buori ovdأ،neami dohko gos dat geavahuvvojit .
    #last condition

SUBSTITUTE:SubV=FS-OBJ (@+FMAINV)(@FS-OBJ) TARGET V (*-1 ADVL-COMP OR CS BARRIER @V OR Rel OR @CVP OR @COMP-CS<)(*-1 @FMVdic OR @IMVdic)(NOT *1 @FV BARRIER S-BOUNDARY) ;
    # The variant for the ones where the part following ":" is a subclause of the clause before ":" like in direct speech
	## Muhto dan gottأ،hallan olbmo bأ،rdni, go son gulai ahte su أ،hؤچؤچi lea goddojuvvon, de son dajai vaإ،iidisguin ahte: "Mon vuolggأ،n ja bأ،إ¾أ،n visot vaikko livؤچؤچo man olu dأ،إ¾at".
SUBSTITUTE:SubV=FS-OBJ (@+FMAINV)(@FS-OBJ) TARGET V (*-1 CITATION BARRIER @V OR Rel OR @CVP OR @COMP-CS< LINK -1 (":") LINK *-1 @FMVdic OR @IMVdic);
	## Ja go stأ،llu أ،lggii nohkkat, de son fas ؤچuorvvui moarsis: "Boaؤ‘e nohkkat!"
	## Ja go boؤ‘ii dat bأ،iki, de son gohؤچui ؤچanadit dal gittalaga ؤچeabehiidda, ja son dajai: "Vurdet vehأ،إ،, mon manan geahؤچؤچame geainnuid."
SUBSTITUTE:SubV=FS-OBJ (@+FAUX)(@FS-OBJ) TARGET V (*-1 CITATION BARRIER @V OR Rel OR @CVP OR @COMP-CS< LINK -1 (":") LINK *-1 @FMVdic OR @IMVdic);
	## Ja lea dadjan: "Ale nohka mu nalde!"
SUBSTITUTE:SubV=FS-ADVL>mv (@+FMAINV)(@FS-ADVL>) TARGET V (*-1 ADVL-COMP OR CS BARRIER @V OR Rel OR @CVP OR @COMP-CS<)(*1 @FV BARRIER S-BOUNDARY) ;
    # the last condition makes sure there is a potential finite verb of the main clause to the left that can be modified
	## Ja vaikko presideanta logai daid dأ،rbbaإ،laإ¾إ¾an oؤ‘ؤ‘asit guorahallat, ii mieؤ‘ihan son Sأ،medikki boastut bargan.
SUBSTITUTE:SubV=FS-<ADVLmv (@+FMAINV)(@FS-<ADVL) TARGET V (*-1 CC OR COMMA BARRIER @V OR Rel OR @CVP OR MCL-CONJ LINK NOT 0 MCL-CONJ LINK *-1 (@FS-<ADVL) BARRIER @V OR MCL-CONJ)(NEGATE *1 (@<SUBJ)) ;  # coordination, if there is no subject in the new clause
SUBSTITUTE:SubV=FS-ADVL>mv (@+FMAINV)(@FS-ADVL>) TARGET V (*-1 CC OR COMMA BARRIER @V OR Rel OR @CVP OR MCL-CONJ LINK NOT 0 MCL-CONJ LINK *-1 (@FS-ADVL>) BARRIER @V OR MCL-CONJ)(NEGATE *1 (@<SUBJ)) ;  # coordination, if there is no subject in the new clause
# some relative clauses introduced by adverbs
SUBSTITUTE:SubV=FS-Naux (@+FAUX) (@FS-N<) TARGET V (*-1 ("gos") OR ("gosa") BARRIER VFIN OR COMMA LINK *-1 N OR Po or DOPPE OR DOHKO BARRIER NOT-COMMA) ;
	## Muitalus sأ،pmelaؤچؤچaid birra, gos sii leat vuohؤچؤچan orron, ja got sin dilli lea leamaإ،, ja mainna sii leat eallأ،n ja gos sii leat boahtأ،n.
SUBSTITUTE:SubV=FS-Naux (@+FAUX) (@FS-N<) TARGET V (*-1 ("got") BARRIER VFIN OR COMMA LINK -1 COMMA LINK -1 N) ;
	## Ja dأ،t lea duإ،إ،e ovdamearkan, got lea Sأ،mis geavvan.
SUBSTITUTE:SubV=FS-Naux (@+FMAINV) (@FS-N<) TARGET V (*-1 ("gos") OR ("gosa") BARRIER VFIN OR COMMA LINK *-1 N OR Po or DOPPE OR DOHKO BARRIER NOT-COMMA) ;

SUBSTITUTE:SubVmain=FS-<ADVLaux (@+FAUX)(@FS-<ADVL) TARGET V (*-1 ADVL-COMP OR CS BARRIER @V OR Rel OR @CVP OR (";")) (*-2 @FV BARRIER (":"));
	## Sus إ،attai أ،lo oaivvebأ،vؤچؤچas go galggai bargat rehkenastimiin.
SUBSTITUTE:SubVmain=FS-<ADVLaux (@+FAUX)(@FS-<ADVL) TARGET V (*-1 ADVL-COMP OR CS BARRIER @V OR Rel OR @CVP OR (";")) (*-2 @FMVdic)(NOT *1 @FV BARRIER S-BOUNDARY) ;
SUBSTITUTE:SubVmain=FS-ADVL>aux (@+FAUX)(@FS-ADVL>) TARGET V (*-1 ADVL-COMP OR CS BARRIER @V OR Rel OR @CVP OR (";"))(*1 @FV) ;
	## Go galggai bargat rehkenastimiin sus إ،attai أ،lo oaivvebأ،vؤچؤچas.
SUBSTITUTE:SubVmain=FS-ADVLaux (@+FAUX) (@FS-<ADVL) TARGET V (*-1 CC BARRIER @V OR Rel OR @CVP OR @SUBJ> LINK NOT 0 MCL-CONJ LINK *-1 (@FS-<ADVL) BARRIER VFIN OR COMMA)(NEGATE *1 (@<SUBJ)) ;  # coordination
SUBSTITUTE:SubVmain=FS-ADVLaux (@+FAUX) (@FS-ADVL>) TARGET V (*-1 CC BARRIER @V OR Rel OR @CVP OR @SUBJ> LINK NOT 0 MCL-CONJ LINK *-1 (@FS-ADVL>) BARRIER VFIN OR COMMA)(NEGATE *1 (@<SUBJ)) ;  # coordination
SUBSTITUTE (@+FAUX) (@FS-<ADVL) TARGET V (0 (Neg Ind) LINK *-1 @FS-<ADVL BARRIER VFIN)(*1 @+FMAINV OR @+FAUXV OR @FMVdic) ;
    # The last condition makes sure there is finite verb candidate for the main clause
    # coordination with Neg
	## ... juktie faamojne أ¸أ¸hpehti, idtji guktie dah tjaalege-أ¥أ¥hpetjh.
SUBSTITUTE (@+FAUX) (@FS-ADVL>) TARGET V (0 (Neg Ind) LINK *-1 @FS-ADVL> BARRIER VFIN)(*1 @+FMAINV OR @+FAUXV OR @FMVdic BARRIER S-BOUNDARY) ;
    # The last condition makes sure there is finite verb candidate for the main clause
	#$ Ja dasa lea dأ،t sivva: go sأ،pmelaإ، boahtأ، moskkus gأ،mmirii, de son ii ipmir ii bأ،ljo maidege, go ii biegga beasa bossut njuni vuostأ،.

SUBSTITUTE:ctjHead (@<OBJ) (<ctjHead> @<OBJ) TARGET @<OBJ (NEGATE *-1 @CNP OR COMMA BARRIER @ARG OR (<mv>) LINK -1 @<OBJ)(1 COMMA OR @CNP LINK *1 @<OBJ BARRIER @V OR @ARG OR S-BOUNDARY) ;
SUBSTITUTE:ctjHead (@<OBJ) (<ctjHead> @<OBJ) TARGET @<OBJ (NEGATE *-1 @CNP OR COMMA BARRIER @ARG OR (<mv>) OR S-BOUNDARY LINK *-1 @<OBJ BARRIER @V OR @ARG)(0 Num LINK *1 (N Gen) BARRIER NOT-ADJ LINK 1 COMMA OR @CNP LINK *1 @<OBJ BARRIER @V OR @ARG) ;
SUBSTITUTE:ctjHead (@OBJ>) (<ctjHead> @OBJ>) TARGET @OBJ> (NEGATE *-1 @CNP OR COMMA BARRIER @ARG OR (<mv>) OR S-BOUNDARY LINK -1 @OBJ>)(1 COMMA OR @CNP LINK *1 @OBJ> BARRIER @ARG OR @V) ;
SUBSTITUTE:ctjHead (@-F<OBJ) (<ctjHead> @-F<OBJ) TARGET @-F<OBJ (NEGATE *-1 @CNP OR COMMA BARRIER @ARG OR @V LINK -1 @-F<OBJ)(1 COMMA OR @CNP LINK *1 @-F<OBJ BARRIER @ARG OR @V OR S-BOUNDARY) ;
SUBSTITUTE:ctjHead (@<ADVL) (<ctjHead> @<ADVL) TARGET @<ADVL (NEGATE *-1 @CNP OR COMMA BARRIER @ARG OR S-BOUNDARY LINK -1 @<ADVL)(1 @CNP LINK *1 @<ADVL BARRIER @ARG OR @V OR S-BOUNDARY OR CC) ;
SUBSTITUTE:ctjHead (@ADVL>) (<ctjHead> @ADVL>) TARGET @ADVL> (NEGATE *-1 @CNP OR COMMA BARRIER @ARG OR S-BOUNDARY LINK -1 @ADVL>)(1 @CNP LINK *1 @ADVL> BARRIER  @ARG OR @V OR S-BOUNDARY OR CC) ;
SUBSTITUTE:ctjHead (@-F<ADVL) (<ctjHead> @-F<ADVL) TARGET @-F<ADVL (NEGATE *-1 @CNP OR COMMA BARRIER @ARG OR @V LINK -1 @-F<ADVL)(1 COMMA OR @CNP LINK *1 @-F<ADVL BARRIER @ARG OR @V OR S-BOUNDARY) ;
	## Muhto lei nu vأ،ttis rehkenastit tأ،lain ja bustأ،vain.

SETCHILD @FMVdic TO (-1 COMMA LINK *-1 @+FMAINV BARRIER VFIN OR GRAMCHK-S-BOUNDARY);
	## Sأ،medikki ja Finnmأ،rkku fylkadikki ovttasbargu lea sأ،kka buorrأ،nan dan maإ‹emus jagi, lohkأ،ba Sأ،mediggerأ،ؤ‘i lahttu Jأ¸rn Are Gaski ja Finnmأ،rku fylkasأ،tnejoؤ‘iheaddji Runar Sjأ¥stad.
## obj-subclause to the nearest mv to the left
SETPARENT:ADVLsentenceToSentence @FS-ADVL TO (*-1 ADVL-COMP OR CS LINK NOT 0 MCL-CONJ LINK **-1 (<mv>) BARRIER @SUBJ> OR @V OR (":") LINK NOT 0 @FS-N< OR @FS-N<IMV) ;
	## Guktie vienhth jis dohte baenie-saehpie sأ¥أ¥jhtoe bأ¥etedh! # no mainclause

# advl-subclause to mainclause' mainverb
SETPARENT:ADVLsentenceToSentence @FS-ADVL (NONE p (*)) TO (*-1 @+FMAINV OR @-FMAINV BARRIER (":"));
	## Gأ،vpot ii dأ،rbbaإ، ؤچuovgga beaivvأ،إ¾is ii ge mأ،nus, dasgo Ipmila hearvأ،svuohta ؤچuvge dan, ja Lأ،ppis lea dan ؤچuovga.

	# subclause to mainclause to the right
SETPARENT:ADVLsentenceToSentence @FS-ADVL (NONE p (*)) TO (*1 @+FMAINV OR @-FMAINV);
	## Goh Jeesuse أ¥nnetji guhkiebasse bأ¥ata, dellie Seebedevusen elkide, Jaahke gonnoeh Jأ¥أ¥hannesem vuajnije.

SETPARENT:OBJsentenceToSentence @FS-OBJ> TO (*1 (<mv>) LINK NOT 0 IV);

SETPARENT:ADVLsentenceToSentence @FS-ADVL> TO (*1 (<mv>) BARRIER COMMA OR GRAMCHK-S-BOUNDARY);
	# we do not want to link non-arguments...
	#$ Muhto nu guhkأ، go nأ، {lea} dilli, de olbmot أ،lget unnit ahte unnit beroإ،tit dأ،idaga.
    # the finite verb of a subclause should go to the main verb of the main clause to its right
	## Go Linأ، lea boahtأ،n ruoktot maإ‹إ‹el skuvlla, manai son njuolga Busi lusa.
SETPARENT:SetCNPToInf ($$CASE @<ADVL) TO (*-1 @CNP OR COMMA BARRIER <mv> LINK *-1 ($$CASE @<ADVL) LINK *-1 (<mv>)) ;
	## Lأ،vdegotti lahtut, geat gullet Ovddأ،dusbellodahkii, Olgeإ¾ii ja Kristtalaإ، أ،lbmotbellodahkii, eai liiko importasuodjأ،i, mii livؤچؤچii hatti vuoؤ‘ؤ‘un.
	#$ Oahpahus galgأ، veahkehit ohppiid liikot leat luonddus ja addit sidjiide vejolaإ،vuoؤ‘a ovdأ،nahttit fantasiija, hأ،bmengأ،lgga ja beroإ،tumi diؤ‘oإ،tit {birrasa}.

	# EARLY ADPOSITION RULES
	# ----------------------

SETPARENT Gen (1C Po LINK 1 EOS) TO (1 Po);


	# "map" ADJUNCTS
	# --------------

LIST TIME-ADJUNCT-N = ("loahpaloahppa" Loc Sg) ;

SUBSTITUTE N (آ§TIME-ADJUNCT N) TARGET N IF (0 TIME-ADJUNCT-N)(NEGATE 0 آ§TIME-ADJUNCT) ;
	## Berit Anja Skoglund lohkأ، vأ،hnemiid duoؤ‘aid إ،addan heahtأ،i go eai إ،at diehtأ،n mot galget nأ،kcet bissehit dأ،n أ،igumuإ،a, ja sii balle {loahpaloahpas} sأ،memأ،nأ،id Oslo gأ،vpogis gillأ،t dأ،n geaإ¾il.

SUBSTITUTE N (آ§TIME-ADJUNCT N) TARGET N IF (0 ("أ،igi" Sg Loc) LINK -1 ("dأ،lأ،" A Attr))(NEGATE 0 آ§TIME-ADJUNCT) ;
	## Dأ،lأ، أ،iggis mii eai oainne su lunddolaإ، ؤچalmmiiguin, muhto ovtta beaivvi son galgأ، fastain boahtit eatnamii ja buohkat galget su oaidnit.

SUBSTITUTE N (آ§TIME-ADJUNCT N) TARGET N IF (0 ("hأ،vvi" Gen) LINK -1 (Pron Dem Gen) OR TIME-A)(NEGATE 0 آ§TIME-ADJUNCT) ;
	## â€“ Buohkat eai dأ،rbbaإ، liikot Dأ،n hأ،ve go lei Amerihkأ،s de son gearggehii skearru Los Angelesis.

SUBSTITUTE Adv (آ§TIME-ADJUNCT Adv) TARGET Adv IF (0 ("ovtta gaskka" Adv))(NEGATE 0 آ§TIME-ADJUNCT); #(0 ("gaska" N Sg Acc) OR ("gaska" N Sg Gen) LINK -1 ONE + (Num Sg Acc) OR ONE + (Num Sg Gen))(NEGATE 0 آ§TIME-ADJUNCT) ;
	## Eisevأ،lddit balle {ovtta gaskka} badjel 1400 norgalaؤچؤچa jأ،pmأ،n.

SUBSTITUTE N (آ§PLACE-ADJUNCT N) TARGET N IF (0 ("oktavuohta" Sg Loc))(-1 (Pron Dem Sg Gen))(NEGATE 0 آ§PLACE-ADJUNCT);
	## Dأ،n oktavuoؤ‘as maid ballأ، Wilhelmsen ahte أ،idna guollevuostأ،ivأ،ldin rustet Smiervuonas إ،addأ، giddet

SUBSTITUTE N (آ§TIME-ADJUNCT N) TARGET N IF (0 Sem/Time + Gen LINK -1 Num LINK *-1 <LO-Loc-Any> BARRIER NPNHA)(NEGATE 0 آ§TIME-ADJUNCT) ;
	## Muhtumin sأ،htأ،n ؤچohkkat Facebook:s duإ،إ،e vihtta minuhta, muhto olles diimmu maid muhtun beivviid, muitala Inger Johanne.
	## Dakkaraإ، vearredagu dihte sahtta إ،addat ؤچohkkat mأ،إ‹ga jagi, muitala Henriksen.


SUBSTITUTE Adv (آ§TIME-ADJUNCT Adv) TARGET	("duoؤ‘aid" Adv)(NEGATE 0 آ§TIME-ADJUNCT) ;

SUBSTITUTE N (آ§TIME-ADJUNCT N) TARGET N IF (0 Sem/Time + Gen LINK -1 (Pron Dem Gen) OR TIME-A OR ("ollis" A))(NEGATE *-1 IV BARRIER NPNHA LINK *-1 <TH-Acc-Any><TH-Inf> BARRIER NOT-ADV-PCLE)(NEGATE 0 آ§TIME-ADJUNCT) ;
	## Norgalaؤچؤچat liikojit pestoi, maإ‹emus jagiid lea pesto johtu loktanan 29 proseanttain Norggas.
	## Son ballأ، arvit olles beaivve.
	#$ Guovdageainnu Meahcأ،steddjiid Searvvi joؤ‘iheaddji Johan Henrik Buljo ballأ، dأ،l leat maإ‹imuإ، giؤ‘a go lobأ،laؤچؤچat besset loddet : â€“ Jus dأ،l rivvejit mis vel giؤ‘ؤ‘aloddama, mii de bأ،hcأ، doalahit dأ،loniid أ،rbevirolaإ، kultuvrra dأ،ppe, jearrأ، Johan Henrik Buljo.

SUBSTITUTE N (آ§TIME-ADJUNCT N) TARGET N IF (0 ("loahppa" Sg Loc) LINK -1 ("loahppa" N Sg Gen) OR ("loahppa" N Sg Acc))(NEGATE 0 آ§TIME-ADJUNCT) ;
	## loahpa loahpas

SUBSTITUTE N (آ§MANNER-ADJUNCT N) TARGET N IF (0 ("lأ،hki" N Sg Com))(-1 ("dأ،t" Pron Dem Sg Com))(NEGATE 0 آ§MANNER-ADJUNCT) ;
	## â€“ Go ruhtahivvodaga lasihit, de beassat mii dasto lasihit virggiid miehtأ، Sأ،mi guovlluide, ja dainna {lأ،giin} nannet ahte sأ،mi beroإ،tumit ovddiduvvojit, ja dan maid diehtit ahte stuora oassi sأ،miin eai hأ،lddaإ، sأ،megiela, ii ؤچأ،lalaؤچؤچat iige njأ،lmmأ،laؤچؤچat, dasto in bala ahte mii eat oaؤچؤچo ieإ¾amet oasi, oaivvilda Wulff.

SUBSTITUTE N (آ§MANNER-ADJUNCT N) TARGET N IF (0 ("leaktu" N Sg Com))(-1 ("ollis" A Attr))(NEGATE 0 آ§MANNER-ADJUNCT) ;

SUBSTITUTE N (آ§MANNER-ADJUNCT N) TARGET N IF (0 ("lassi" N Ess))(-1 ("dat" Pron Dem Sg Ill))(NEGATE 0 آ§MANNER-ADJUNCT) ;

SUBSTITUTE N (آ§MANNER-ADJUNCT N) TARGET N IF (0 ("heahti" N Sg) LINK 0 Loc OR (Gen PxSg3) OR (Acc PxSg3))(1 ("ge"))(*-1 ("ii") BARRIER GRAMCHK-S-BOUNDARY)(NEGATE 0 آ§MANNER-ADJUNCT) ;
	##

SUBSTITUTE N (آ§MANNER-ADJUNCT N) TARGET N IF (0 ("dأ،ssi" N Sg Loc))(NEGATE *-1 Dem BARRIER NOT-A)(NEGATE 0 آ§ANYADJUNCT OR آ§ANYROLE);
	## Bargobأ،jit dieؤ‘usge galget geavatlaإ، {dأ،sis} vأ،ikkuhit ja bidjat proseassaid johtui.

LIST COMMUNICATION-TV = "ؤچأ،llit" "kommenteret" "raporteret" ;

SUBSTITUTE N (آ§MANNER-ADJUNCT N) TARGET N IF (0 ("dأ،ssi" N Sg Loc))(*-1 MUITALIT OR COMMUNICATION-TV BARRIER NPNHA)(NEGATE 0 آ§ANYADJUNCT OR آ§ANYROLE) ;
	## Strأ¸m Bull deattuha ahte son kommenteret obbalaإ، dأ،sis, go ii dovdda dأ،n konkrehta أ،إ،إ،i.
	## Norggas lea geatnegasvuohta raporteret riikkaidgaskasaإ، dأ،sis Dأ،lkkأ،datkonvenإ،uvnna ja Kyotoprotokolla vuoؤ‘ul.

	# VALENCY DEPENDENCIES
	# --------------------


SETCHILD (V <mielde>) TO (2 EOS LINK -1 ("mielde"))  ;
	## Mأ،nأ،t liikojedje bures ؤچأ،jأ،lmasii ja juige mielde.

SETCHILD (V <TH-Ill-Any>) TO (*-1 Ill OR ILL-LOC-PRON-ADV BARRIER NOT-ADV) ;
	## Nissubirgui liikojedje sihke sأ،pmelaؤچؤچat ja dأ،ؤچؤچat.
	## Dasa gal mأ،nأ،t liikoje ja ledje hirbmat أ،إ‹girat.

SETCHILD (V <TH-Ill-Any>) TO (-1 @ADVL> LINK *-1 Ill OR ILL-LOC-PRON-ADV BARRIER NOT-ADV) ;

SETCHILD (V <TH-Ill-Any>) TO (-1 ConNeg LINK -1 Neg LINK -1 Ill OR ILL-LOC-PRON-ADV) ;
	## Dasa eai leat buot skuvlamأ،nأ،t liikon.
SETCHILD (V <TH-Ill-Any>) TO (2 PUNCT-LEFT-RIGHT OR EOS OR COMMA LINK -1 Ill OR ILL-LOC-PRON-ADV) ;
	## Dan dihte sii eai diehtأ،n buorebu, ja sii liikojedje vأ،hneneatnamii ( ) ja eallinvuohkأ،i nu bures, ahte seammأ، vuostemielain sii dan guoؤ‘أ،إ،e go bahأ،dahkki jأ،pminduopmobأ،ikأ،i manaإ،ii ( Leem 1767 : 172 ).
	## Guollebivdit eai liikon ruovdeإ،أ،kإ،ii.
	## Muhtumat maid eai liikon hأ،vgii, juogo dainna go dat lea ropmi dahje mأ،gu geaإ¾il, muhto eatnasat borre hأ،vgga.

SETCHILD (V <TH-Ill-Any>)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (1 Adv OR Pcle OR @>N OR PrfPrc LINK 1 Ill OR ILL-LOC-PRON-ADV) ;

SETCHILD (V <TH-Ill-Any>)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (*1 @>N BARRIER NOT-ADV-PCLE LINK 1 Ill) ;
	## EU vuosttildeddjiid joؤ‘iheaddji Sigbjأ¸rn Gjelsvik liikui hui bures daidda bohtosiidda, vaikko dat ii atte makkأ،rge ؤچielga vuoitukandidahta.

SETCHILD (V <TH-Ill-Any>)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (1 Adv OR Pcle LINK 1 @>N OR PrfPrc LINK 1 Ill OR ILL-LOC-PRON-ADV) ;
	## Dat kvenat mat ovddemus bohte 1700-logus, gal orro أ،lkibut seahkaneame bأ،ikkأ،laؤچؤچat heivehuvvon riggodatgeavaheapmأ،i go sii أ،saiduvve eanas sأ،mi guovlluide.
	#unsure about PrfPrc


SETCHILD (V <TH-Ill-Any>)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (*1 Ill - Attr OR ILL-LOC-PRON-ADV - @>N BARRIER NPNHA - @<ADVL) ;
	#$ Don dahje liikkot dahje ii liiko dأ،n filmma.

SETCHILD (V <TH-Ill-Any>)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (1 Adv OR ("mii" Sg Acc) LINK 1 @>N OR @>A OR Adv LINK 1 @>N LINK 1 CC LINK 1 @>N LINK 1 Ill) ;
	## Girjeؤچأ،lli Karin Anema gأ،ibida girjeأ،rvvoإ،talli Karin Swart-Dondersa jأ،vkadit أ،rvvoإ،tallamis أ،إ،إ،iid maid Anema ii liiko, go dأ،t girjeأ،rvvoإ،tallan sأ،httأ، vأ،ikkuhit unohasat su journalisttalaإ، ja girjeؤچأ،lli luohttevaإ،vuhtii.

SETCHILD (V <TH-Ill-Any>)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (1 Adv OR ("mii" Sg Acc) LINK *1 @SUBJ> BARRIER NPNHA LINK 1 Ill OR ILL-LOC-PRON-ADV) ;
	##

SETCHILD (V <TH-Ill-Any>)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (1 EOS OR COMMA OR @CVP LINK *-1 Ill OR ILL-LOC-PRON-ADV BARRIER GRAMCHK-S-BOUNDARY LINK NOT 0 @>N) ;
	## Muhtin mأ،nأ،ide lea أ،lki liikot, daidda geat leat â€œ siivutâ€‌, leat gierdavaؤچؤچat vuordit, jegolaؤچؤچat, ja hأ،rve dadjet vuostأ،.
	## Norggas leat luoitimat viehka bures muddejuvvon, muhto dasa eai leat liikon buot riikkat.
	#$ Muhto lea go dainna lأ،giin ahte jus oaإ¾إ¾ut buori vejolaإ،vuoؤ‘a dasa, de mii givssidit dan gean eat liiko?
SETCHILD (V <TH-Ill-Any>)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (1 Ill - @>N - @>A - Attr OR DOHKO OR ILL-LOC-PRON-ADV - @>N) ;
	## Nissubirgui liikojedje sihke sأ،pmelaؤچؤچat ja dأ،ؤچؤچat.
	## Dأ،n geaإ¾il lea hui vأ،ttis nuorra niidii dahje bأ،rdnأ،i fuomأ،إ،it ahte sii gusto liikojit olbmuide geat leat seamma sohkabealis go ieإ¾a.

	## Ill in COMP-CS
SETCHILD (V <TH-Ill-Any>)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (*1 ("earأ،") OR ("ieإ¾أ،") OR Comp BARRIER NOT-ADV-PCLE LINK 1 BECAUSE-WHEN LINK *1 Ill - @>N - @>A - Attr OR ILL-LOC-PRON-ADV - @>N BARRIER NPNHA) ;
	## Son ii luohttأ،n earأ، go Heikii, أ،innas dأ،kkأ،r hearkkes أ،إ،إ،is.


SETCHILD (V <TH-Ill-Any>)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (-3 BOS OR PUNCT LINK 1 @>N LINK 1 Ill) ;
	## Makkأ،r bargovugiide liikot ?
SETCHILD (V <TH-Ill-Any>)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (-4 BOS OR PUNCT LINK 1 SUBJ LINK 1 Neg LINK 1 Ill OR ILL-LOC-PRON-ADV) ;
	## Muhtimat eai dasa liiko, muhto dat lea vuoiggalaإ،, ja buorida min barggu.
SETCHILD (V <TH-Ill-Any>)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (0 ConNeg LINK -1 Neg LINK *-1 Ill OR ILL-LOC-PRON-ADV BARRIER NPNHA) ;
	## Muhto dأ،sa eai liikon أ،mmأ،tolbmot ja eanandoallobargit.
	## Dasa oainnat eai liiko dakkأ،rat geat ieإ¾a eai mأ،hte sأ،megiela.
SETCHILD (V <TH-Ill-Any>) TO (*-1 @SUBJ> - Rel - Indef BARRIER NPNHAPcle LINK *-1 Ill OR ILL-LOC-PRON-ADV BARRIER GRAMCHK-S-BOUNDARY LINK NOT 0 @>N) ;
	#$ â€“ Sأ،htaإ،in sأ،ddet geasseliؤ‘iid vaikko ieإ¾an ustibii ؤŒehkii, go son sihkkarit liiko suopmelaإ، rأ،siin.
	## â€œ Eallinâ€‌ lea dat CD masa ieإ، nai liikon buoremusat, lohkأ، Mari Boine.
	#$ Luonddus leat hأ،stalusat buohkaide, sihke sidjiide geat vأ،ivvahit alla rأ،siid siste gأ،llit, ja sidjiide geat liikojit giccodit muorain.
	#$ Progrأ،mma lea oaivvilduvvon ii duإ،إ،e Gأ،ba Ohcejoga Nissoniidda, muhto maid Searalaإ، Sirpmأ، Nissoniidda ja ؤŒeahpes Avvila Nissoniidda, muhto maid buot almmأ،iolbmuide, geat liikojit nissoniin.
SETCHILD (V <TH-Ill-Any>)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (*-1 @SUBJ> BARRIER (*) - Adv - @ADVL LINK -1 Rel + Ill) ;
	## Diibmأ، gis ledje kinnalaؤچؤچat geat إ،addet dat turistat geaidda olbmot oaba mأ،ilmmis liikojit heajumusat.

SETCHILD (V <TH-Ill-Any>) (0 ConNeg)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (-1 Neg LINK *-1 @SUBJ> BARRIER (*) - Adv - @ADVL LINK -1 Rel + Ill) ;

SETCHILD (V <TH-Ill-Any>)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (1 @>N OR @<SUBJ LINK 1 Ill OR DOHKO) ;
	## Novgoroda beales eai liikon dأ،ؤچؤچa sisabأ،hkkemii, dan dihte go sii atne dأ،n ieإ¾aset vearro- ja vuollأ،saإ،guovlun.

SETCHILD (V <TH-Ill-Any>)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (*1 @>N - @>A BARRIER NPNHA - Acc LINK 1 Ill) ;
		## Leat go dakkأ،r gii liikot aivve seamma sohkabealأ،t olbmuide, vai liikot go maiddأ،i nuppi sohkabealأ،t olbmuide.
		## Atle liiko hui bures dأ،nset ja teأ،hteriin bargat.

SETCHILD (V <TH-Ill-Any>)(NONE c Ill OR ILL-LOC-PRON-ADV) TO (*1 @>N - @>A BARRIER NPNHA - Acc LINK 1 CC LINK 1 @>N LINK 1 Ill) ;
	## أپrtet, mii han liikot vuovttaid ja skuovaid eaiggأ،dii.

SETCHILD (V <TH-lusa-Any>)(NONE c N OR Pron) TO (*1 @>P BARRIER NPNHA LINK 1 ("lusa")) ;
	## Lei nu buolaإ، ja soai أ،ibbaإ،eigga nu issorasat dan rukses cizأ،إ¾a lusa mii galggai oahpistit sudno Geassegieddأ،i.

SETCHILD (V <TH-birra-Any>)(NONE c N OR Pron) TO (*1 @>P BARRIER NPNHA LINK 1 ("birra")) ;
	## â€“ Mii oaidnit movt mأ،nأ،t beroإ،tit buollinvأ،ras, earret earأ، dan dihte go ohppet dan birra mأ،nأ،idgأ،rddiin ja skuvllain.

SETCHILD (V <TH-birra-Any>)(-2 @>P)(NONE c N OR Pron) TO (-1 @>P) ;
	##

SETCHILD (V <TH-ala-*Plc>)(NONE c N - Sem/Place OR Pron) TO (*1 @>P BARRIER NPNHA - ? LINK 1 ("ala") OR ("nala")) ;
	## Gaup ja Minde luohttiba dal Dearvvasvuoda ja sosidaldepartementta nala.


SETCHILD (V <TH-Nom-Any><PO-Ill-Any>)(*1 SUBJ OR @<SPRED OR Inf BARRIER GRAMCHK-S-BOUNDARY) TO (-1 Ill);
