ADD:xreal-sأ،htأ،إ، (&real-sأ،htأ،إ،) TARGET ("sأ،htaإ،it") OR CAN + (IV Ind Cond Prs Err/Orth-a-أ،) IF (NEGATE *-1 (@OBJ>) + Sem/Hum OR (@OBJ>) + Sem/Fem  OR (@OBJ>) + Sem/Mal OR (@OBJ>) + Sem/Sur OR (@OBJ>) + (Pron Pers) OR (@OBJ>) + ("dat") OR (@OBJ>) + SأپHTAإ IT-OBJ BARRIER V OR GRAMCHK-S-BOUNDARY)(NEGATE *1 OBJ + Sem/Human OR Acc + Sem/Human OR OBJ + (Pron Pers) OR OBJ + ("dat") BARRIER V OR GRAMCHK-S-BOUNDARY)(NEGATE -1 DE-ILL-ADV LINK 2 EOS)(NOT 0 Der/Pass)(NEGATE *-1 Rel BARRIER GRAMCHK-S-BOUNDARY LINK -1 COMMA LINK -1 SأپHTAإ IT-OBJ);
