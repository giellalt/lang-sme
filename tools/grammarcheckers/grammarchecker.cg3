	# "map" MANNER role
	# --------------------

SUBSTITUTE Adv (Â§MA Adv) TARGET Adv IF (p (V <MA-Adv-Manner>))(0 MANNER-ADV)(NOT 0 Â§ANYROLE) ;
	##
SUBSTITUTE CS (Â§MA CS) TARGET CS IF (p (V <MA-Adv-Manner>))(0 MANNER-ADV OR ("nugo"))(NOT 0 Â§ANYROLE) ;
	#NOT SURE..

	# "map" EXTENT role
