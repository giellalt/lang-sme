SET PLURAL-QUANTIFIERS-sma = ("mĂ„edtie" Nom)Â OR ("mĂ„edtie" Indef Sg Acc) ORÂ ("moattes" Nom) OR (Num Sg Nom) - ("akte") ;
SET PLURAL-QUANTIFIERS-smn = ("moadda" Nom)Â OR ("moadda" Indef Sg Acc) ORÂ ("moattes" Nom) OR (Num Sg Nom) - ("akta") ;
