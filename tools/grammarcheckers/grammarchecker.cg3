LIST BFORM = ".*"r ;


# Word or not
# -----------
LIST WORD = N A Adv V Pron CS CC Po Pr Interj Pcle Num ABBR ACR  \? ;
 # any word

LIST ? = ? ;

SET REALWORD = WORD - Num - Ord ;

SET REALWORD-NOTABBR = WORD - Num - Ord - ABBR ;

SET WORD-NOTDE = WORD - ("de") ;

# Derivational affixes
# --------------------

LIST V-DER = Der/adda Der/alla Der/asti Der/d Der/g Der/h Der/halla Der/hudda Der/huhtti Der/huvva Der/j Der/l Der/ahtti Der/st Der/stuvva Der/InchL ;

LIST N-DER = Der/eaddji Der/Dimin Der/eamoإ، Der/NomAct Der/heapmi Der/NomAct Der/إ، Der/muإ، Der/upmi Der/us Der/vuota (Der2 Der/NomAg) ;
 # Actio ;

LIST A-DER = Der/diibmosaإ، Der/eaddji Der/geahtes Der/keahtes Der/heapmi Der/lأ،gan Der/lasj Der/meahttun Der/lأ،gأ،n (Ex/V A);

LIST A-V = (Ex/V A) ;

SET A-NOT-V = A - A-V ;

LIST Der1 = Der1 ;
LIST Der2 = Der2 ;
LIST Der3 = Der3 ;

SET V-ACT = V - Der/Pass ;

# Case sets
# ---------

LIST ADVLCASE = Ill Loc Com Ess ;

# Sg Nom - Sg Nom | Pl Nom - Pl Nom
# Sg Acc - Sg Acc | Pl Acc - Pl Acc
# Sg Gen - Sg Gen | Pl Gen - Pl Gen
# Sg Gen - Sg Ill | Pl Gen/Ill - Pl Ill
# Sg Gen - Sg Loc | Pl Loc - Pl Loc
# Sg Com - Sg Com | Pl Gen/Com - Pl Com
# Ess - Ess

LIST CASE-HALFAGREEMENT = Ill (Sg Loc) (Pl Com) Ess ;
LIST CASE-AGREEMENT = Nom Acc Gen (Pl Ill) Loc Com Ess ;
LIST CASE = Nom Acc Gen Ill Loc Com Ess ;

SET NOT-NOM = CASE - Nom ;
SET NOT-GEN = CASE - Gen ;
SET NOT-ACC = CASE - Acc ;
SET NOT-ACC-GEN = CASE - Acc - Gen ;

# Verb sets
# ---------

# Verbs and their complements
# - - - - - - - - - - - - - -

SET NOT-VERB = WORD - V ;

# Finiteness and mood
# - - - - - - - - - -

SET V-IND-FIN = Prs OR Prt ;
 # Problem: "In boahtأ،n" is an invisible indicative

SET V-MOOD = Ind OR Pot OR Imprt OR ImprtII OR Cond OR (Neg Sup) ;

LIST GC = ("gؤچ") ;

SET VFIN = GC OR V-MOOD - ConNeg ;

LIST PUNCT-LEFT = (PUNCT LEFT) ;
LIST PUNCT-RIGHT = (PUNCT RIGHT) ;

SET PUNCT-LEFT-RIGHT = PUNCT-LEFT OR PUNCT-RIGHT ;


SET GRAMCHK-VFIN = GC OR V-MOOD - ConNeg - PUNCT-LEFT-RIGHT;


SET VFIN-POS = V-MOOD - ConNeg - Neg ;

SET VFIN-NOT-IMP = VFIN - Imprt ;

SET VFIN-NOT-NEG = VFIN - Neg ;
  # this might be to strict, besides, "iige" can be written "ii ge"

SET NOT-PRFPRC = WORD - PrfPrc ;

# Person
# - - - -

LIST V-SG1 = (V Ind Prs Sg1)  (V Ind Prt Sg1) (V Cond Prs Sg1)
             (V Cond Prt Sg1) (V Pot Prs Sg1) (V Neg Ind Sg1);

LIST V-SG2 = (V Ind Prs Sg2)  (V Ind Prt Sg2) (V Cond Prs Sg2)
             (V Cond Prt Sg2) (V Pot Prs Sg2) (V Neg Ind Sg2);

LIST V-SG3 = (V Ind Prs Sg3)  (V Ind Prt Sg3) (V Cond Prs Sg3)
             (V Cond Prt Sg3) (V Pot Prs Sg3) (V Neg Ind Sg3);

LIST V-DU1 = (V Ind Prs Du1)  (V Ind Prt Du1) (V Cond Prs Du1)
          (V Cond Prt Du1) (V Pot Prs Du1) (V Neg Ind Du1);

LIST V-DU2 = (V Ind Prs Du2)  (V Ind Prt Du2) (V Cond Prs Du2)
	         (V Cond Prt Du2) (V Pot Prs Du2) (V Neg Ind Du2);

LIST V-DU3 = (V Ind Prs Du3)  (V Ind Prt Du3) (V Cond Prs Du3)
	         (V Cond Prt Du3) (V Pot Prs Du3) (V Neg Ind Du3);

LIST V-PL1 = (V Ind Prs Pl1)  (V Ind Prt Pl1) (V Cond Prs Pl1)
             (V Cond Prt Pl1) (V Pot Prs Pl1) (V Neg Ind Pl1);

LIST V-PL2 = (V Ind Prs Pl2)  (V Ind Prt Pl2) (V Cond Prs Pl2)
             (V Cond Prt Pl2) (V Pot Prs Pl2) (V Neg Ind Pl2);

LIST V-PL3 = (V Ind Prs Pl3)  (V Ind Prt Pl3) (V Cond Prs Pl3)
             (V Cond Prt Pl3) (V Pot Prs Pl3) (V Neg Ind Pl3);


 # Note that imperative verbs are not included in these sets!

# Some subsets of the VFIN sets
# - - - - - - - - - - - - - - -
SET V-SG = V-SG1 OR V-SG2 OR V-SG3 ;
SET V-DU = V-DU1 OR V-DU2 OR V-DU3 ;
SET V-PL = V-PL1 OR V-PL2 OR V-PL3 ;

SET V-DU-PL = V-DU1 OR V-DU2 OR V-DU3 OR V-PL1 OR V-PL2 OR V-PL3 ;

SET V-NOT-SG1 = VFIN-NOT-IMP - V-SG1 ;
SET V-NOT-SG2 = VFIN-NOT-IMP - V-SG2 ;
SET V-NOT-SG3 = VFIN-NOT-IMP - V-SG3 ;
SET V-NOT-DU1 = VFIN-NOT-IMP - V-DU1 ;
SET V-NOT-DU2 = VFIN-NOT-IMP - V-DU2 ;
SET V-NOT-DU3 = VFIN-NOT-IMP - V-DU3 ;
SET V-NOT-PL1 = VFIN-NOT-IMP - V-PL1 ;
SET V-NOT-PL2 = VFIN-NOT-IMP - V-PL2 ;
SET V-NOT-PL3 = VFIN-NOT-IMP - V-PL3 ;


SET V-1-2 = V-SG1 OR V-SG2 OR V-DU1 OR V-DU2 OR V-PL1 OR V-PL2 ;
SET V-3  = V-SG3 OR V-DU3 OR V-PL3 ;

# Sets consisting of forms of "leat" (these ones need to be rewritten)
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
LIST LEAN = ("leat" V Ind Prs Sg1) ("leat" V PrfPrc);
LIST LEAT = ("leat" V Ind Prs Pl1) ("leat" V Ind Prs Pl3)
      ("leat" V Ind Prs Sg2) ("leat" V Inf) ("leat" V Ind Prs ConNeg);

LIST LEAT-FIN-NOT-IMP = ("leat" V Ind) ("leat" V Cond) ("leat" V Pot);

LIST VPRFPRC = (V PrfPrc) ;
LIST LEATPRFPRC = ("leat" PrfPrc) ;
SET PRC-NOT-LEAT = VPRFPRC - LEATPRFPRC ;
    # In order to distinguish between real leat-constructions and participles of other verbs
LIST HABEO-SG3 = ("leat" Sg3) (V Neg Sg3) ("إ،addat" Sg3) ;

LIST HABEO-PL3 = ("leat" Pl3) (V Neg Pl3) ("إ،addat" Pl3) ;

SET HABEO-3 = HABEO-SG3 OR HABEO-PL3 ;

# Pronoun sets
# ------------

LIST MUN = (Pron Pers Sg1 Nom);
LIST DON = (Pron Pers Sg2 Nom);
LIST SON = ("son" Pron Pers Sg3 Nom);
LIST MOAI = (Pron Pers Du1 Nom);
LIST DOAI = (Pron Pers Du2 Nom);
LIST SOAI = (Pron Pers Du3 Nom);
LIST MII-PERS = (Pron Pers Pl1 Nom);
LIST DII = (Pron Pers Pl2 Nom);
LIST SII = ("son" Pron Pers Pl3 Nom);

LIST PERS = Sg1 Sg2 Sg3 Du1 Du2 Du3 Pl1 Pl2 Pl3 ;

SET PPRON-NOM-NOT-DAT = MUN OR DON OR SON OR MOAI OR DOAI OR SOAI OR MII-PERS OR DII OR SII ;

SET PPRON-NOT-DAT = (Pron Pers) - ("dat") ;

SET PPRON-DU-PL = MOAI OR DOAI OR SOAI OR MII-PERS OR DII OR SII ;
SET PPRON-PL = MII-PERS OR DII OR SII ;

SET PRON-DU = MOAI OR DOAI OR SOAI ;

SET PPRON-NOT-SII = MUN OR DON OR SON OR MOAI OR DOAI OR SOAI OR MII-PERS OR DII ;

LIST PPRON-GEN = (Sg1 Gen) (Sg2 Gen) (Sg3 Gen) (Du1 Gen) (Du2 Gen) (Du3 Gen)
	(Pl1 Gen) (Pl2 Gen) (Pl3 Gen);

SET PPRON-NOT-GEN = (Pron Pers) - PPRON-GEN ;

LIST DEM-SG = (Pron Dem Sg Nom);
LIST DEM-PL = (Pron Dem Pl Nom);
SET NOT-DEM = WORD - Dem ;

LIST SGPRON = (Pron Sg1) (Pron Sg2) (Pron Sg3) (Pron Sg) (Pron PxSg1) (Pron PxSg2) (Pron PxSg3);
LIST DUPRON = (Pron Du1) (Pron Du2) (Pron Du3)  (Pron PxDu1) (Pron PxDu2) (Pron PxDu3);
LIST PLPRON = (Pron Pl1) (Pron Pl2) (Pron Pl3) (Pron Pl) (Pron PxPl1) (Pron PxPl2) (Pron PxPl3);
LIST DUPRON-NOTPX = (Pron Du1) (Pron Du2) (Pron Du3) ;

SET PRON-NOT-SG = DUPRON OR PLPRON ;

LIST DAT-PRON = ("dat") ("dأ،t") ("diet") ("duot") ("dot") ;

LIST QUANT-PRON = "ollu" "olu" "unnأ،n" "vأ،hأ،إ،" "veahأ،إ،" "vehأ،إ،" ;
# This set is for choosing between Adv and Pron Indef.

# Adjectival sets and their complements
# -------------------------------------
SET LEX-A = A - A-DER ;

SET A-CASE = A - Attr - Adv ;

LIST A-CC = A CC ;

SET NOT-ADJ = WORD - A ;
SET NOT-NUM = WORD - Num ;
SET NOT-ADJ-COMMA = WORD - A - COMMA ;
SET NOT-Attr = WORD - Attr ;
SET NOT-ADJ-PCLE = WORD - A - Pcle ;
SET NOT-ADJ-CC = WORD - A-CC ;

SET NOT-AA = WORD - A - Adv OR ("maid") ;

LIST NOMINAL-ADJ = "guoktilaإ،" "lأ،mis" "oasأ،laإ،" ("suddu" Der/lasj) "viissis";

 # and many others

# Adverbial sets and their complements
# ------------------------------------
SET LEX-ADV = Adv - (Ex/A) ;

SET NOT-ADV            = (*) - Adv OR (Adv Subqst) OR ("de") ;
SET NOT-ADV-N          = (*) - Adv - N OR (Adv Subqst);
SET NOT-ADV-PCLE       = (*) - Adv - Pcle OR (Adv Subqst) OR ("de") OR (";") OR ("â€‌") ;
SET NOT-ADV-INDEF      = WORD - Adv - Indef OR (Adv Subqst);
SET NOT-ADV-PCLE-ILL   = WORD - Adv - Pcle - Ill OR (Adv Subqst);
SET NOT-ADV-PCLE-Refl  = WORD - Adv - Pcle - Refl OR (Adv Subqst);
SET NOT-ADV-PCLE-INDEF = WORD - Adv - Pcle - Indef OR (Adv Subqst);
SET NOT-ADV-PCLE-NEG   = WORD - Adv - Pcle - Neg OR (Adv Subqst);
SET NOT-ADVL-PCLE-NEG  = WORD - @ADVL - @P< - Pcle - Neg OR (Adv Subqst);
SET NOT-ADVL-PCLE      = (*) - @ADVL - @P< - Pcle OR (Adv Subqst);


LIST MO-MANge = "goas" "gokko" "gos" "gosa" "govt" ("got" Adv) ("guؤ‘e lأ،dje" Adv) "makkأ،r" "man" ("man lأ،dje" Adv) ("man lأ،hkأ،i" Pron Rel) "manne" "mo" "mot" "mov" "movt" ("nugo" @CVP) (V Qst);

SET MO = MO-MANge - ("man" Foc/ge) ;

 # Introduce finite clauses.

LIST PLACE-ADV =  "davأ،bealde" "mأ،ttabealde" "nuorttabealde" "oarjebealde" "olggobeale" ;
# There will usually be a Gen in front.

LIST DOPPE = "badjin" "bajil" "dakko" "dأ،" "dأ،kko" "dأ،ppe" "dأ،s" "diekko" "dieppe" "do" "dokko" "doppe" "duo" "duokko" "duoppe" "olgun" ;
# Adverbs with a locativic form, but donآ´t get Loc as a tag.

LIST DOHKO = "bajأ،s" "davأ،s" "deike" "diehke" "diehko" "dohko" "duohko" "luksa" "lulأ،s" "nuorttas" "oarjjأ،s" "olggos" "ruoktot" "ruovttoluotta" "sisa" "vulos" "vuolأ،s" "vuovdimassii"     ;
# Adverbs with a illativic form, but they donآ´t get Ill as a tag.


# Coordinators
# ------------
SET Foc = Foc/Neg-ge OR Foc/Pos-ge  OR Foc/gen  OR Foc/ges  OR Foc/gis  OR Foc/naj OR Foc/ba  OR Foc/be  OR Foc/hal  OR Foc/han  OR Foc/bat OR Foc/son ;

LIST NEGFOC = (Neg Foc/ge) ;

LIST XGO = "dego" "dugo" "nugo" "seammalأ،djego" "seammalأ،hkaigo" ;
  # Compounds
LIST SEAMMAX = "seammalأ،dje" "seammalأ،hkai" "seammalأ،hkأ،i" ;
  # Those combine with go
  
LIST COMPGO = "nu" "seamma" "seammأ،" "liikkأ،" "lihkkأ،" ;

LIST MADE = "maؤ‘e" "maؤ‘i" ;
LIST DADE = "daؤ‘e" "daؤ‘i" ;

SET CRD = COMMA OR CC OR NEGFOC OR XGO OR ("/") OR ("-") OR DADE ;

	# coordinators

LIST LCRD = @CNP ;
    # local coordinator
LIST GCRD = @CVP ;
    # global coordinator

SET CRD2 = (@CNP) OR COMMA OR NEGFOC OR XGO OR ("/") OR ("-") OR DADE ;
    # AFTER LCRD vs. GCRD disambiguation

# Sets for adverbs that have lookalikes
# -------------------------------------
 # Here come some adverbs that have identical twins in other POS.
 # If these are found in Adv contexts, we treat them as adverbs.

LIST ADV-LACCAT = "absoluhtalaإ،" "agأ،laؤچؤچat" "aitosaؤچؤچat" ("aktiiva" Der/lasj) ("aktiivva" Der/lasj) "almmolaإ،" "analogalaإ،" "automأ،htalaإ،" "أ،lgoأ،lgosaإ،" "أ،lgovuolggalaإ،" "أ،rbevirolaإ،" "beaivvأ،laؤچؤچat" "biologalaإ،" ("buhttenriekti" Der/lasj) ("bustأ،vva" Der/lasj) "ؤچأ،lalaؤچؤچat" "ؤچearddalaإ،" "dأ،bأ،laإ،"  "duoؤ‘alaؤچؤچat" ("dutkanpolitihkka" Der/lasj) "eahpedأ،bأ،laإ،" "eahpeformأ،lalaإ،" "eahpekritihkalaإ،" "eahpevirggأ،laإ،" "eaktodأ،htolaؤچؤچat" "ekologalaإ،" "ekologأ،laإ،" "ekonomأ،laإ،" "eksplisihtalaإ،" ("elektrovdna" Der/lasj) "eahpitkeahttأ،" ("etihkka" Der/lasj) "etymologalaإ،" "fأ،galaإ،" "fonehtalaإ،" "fonologalaإ،" "fonotأ،vttalaإ،" "formأ،lalaإ،" ("fysiologa" Der/lasj) "gaskamearأ،laإ،" "geavatlaؤچؤچat" ("gealbu" Der/lasj) ("geografa" Der/lasj) ("geogrأ،fa" Der/lasj) ("giella" Der/lasj) ("girkoriekti" Der/lasj) "globأ،lalaؤچؤچat" ("gorri" Der/lasj) "govttolaإ،" "hأ،lddahuslaإ،" "historjjأ،laإ،" "ideologalaإ،" "ieإ،heanأ،laإ،" "implisihtalaؤچؤچat" "jahkأ،saؤچؤچat" "jeavddalaؤچؤچat" ("jietnadatoahppa" Der/lasj) ("juridihkka" Der/lasj) "konkrehtalaإ،" ("kritihkka" Der/lasj) "kronologalaإ،" ("kulturhistorjأ،" Der/lasj) ("kulturpolitihkka" Der/lasj) ("kultuvra" Der/lasj) "logihkalaإ،" ("luohtu" Der/lasj) ("mأ،إ‹ggafأ،ga" Der/lasj) "mekأ،nalaإ،" ("metoda" Der/lasj) "moralalaإ،" "morأ،lalaإ،" "morfologalaإ،" "naإ،uvnnalaإ،" "negatiivalaإ،" "negatiivvalaإ،" "njأ،lmmأ،laؤچؤچat" "njuolgguslaؤچؤچat" ("oaiveأ،إ،إ،i" Der/lasj) "obbalaإ،" "obbalohkأ،i" "oktasaؤچؤچat" "oktilaإ،" "ollislaؤچؤچat" "oppalaؤچؤچat" "optimalalaؤچؤچat" "ovttabealأ،laإ،" "ovttajienalaإ،" "ovttamielalaإ،" "pedagogalaإ،" ("politihkka" Der/lasj) ("praktihkka" Der/lasj) ("prinsihppa" Der/lasj) ("privأ،htariekti" Der/lasj) "profehtalaإ،" "psykologalaإ،" "rأ،fأ،laؤچؤچat" ("reأ،lapolitihkka" Der/lasj) ("riektehistorjأ،" Der/lasj) ("riekti" Der/lasj) "riikkaidgaskasaإ،" "sأ،megielalaإ،" ("riikkagoddi" Der/lasj) ("ruhta" Der/lasj) "rumaإ،laإ،" "sأ،mepolitihkalaإ،" "sekundأ،ralaؤچؤچat" "semantihkalaإ،" ("servodatأ،vki" Der/lasj) ("siviilariekti" Der/lasj) "sosiأ،lalaإ،" ("stأ،htapolitihkka" Der/lasj) "strategalaإ،" ("suorgepolitihkka" Der/lasj) ("teknihkka" Der/lasj) "teorehtalaإ،" ("topografa" Der/lasj) ("vأ،ldoأ،إ،إ،i" Der/lasj) ("virgi" Der/lasj) ("vierru" Der/lasj) ;

LIST ADV-AFTER-NUM = "geardde" "hأ،vvi"  ;

LIST DUSSE = "أ،ibbas" "duإ،إ،e" "erenoamأ،إ¾it" "goitge" "man" "measta" "meastui" "oalle" "oba" "oktiibuot" "oppa" "sullii" ;

LIST EASKKA = "easkka" "easka" ;

LIST ADV-NOT-ARG = "aiddo" "ain" "aivve" "albma" "aإ‹kke" "أ،lggos" "bأ،ifأ،hkka" "beanta" "beare" ;

#LIST ADV-NOT-ARG2 = "aiddo" "ain" "aivve" "albma" "aإ‹kke" "أ،lggos" "أ،lgobأ،liid" "أ،lo" "bأ،ifأ،hkka" "beanta" "beare" "dakkaviؤ‘e" "dal" "dan_dihte" "danne" "dasto" "dattetge" ("dأ،bأ،laإ،" Adv) "dأ،vjأ،" "de" "dieؤ‘inge" "dieؤ‘usge" "duoؤ‘aid" "easkka" "fal" "fargga" "fas" "fأ،rrolaga" "gal" "goas" "goasse" "gos" "gosa" "gostege" "govt" "gusto" "hedi" "juo" "justa" "loahpas" "maiddأ،i"  "manin" "manne" "nuppes" "suige" "إ،at" "vel" "viimmat" "vuos" ;


LIST ADV-NOT-VERB = "duإ،إ،e" "viimmat" ;

LIST ADV-NOT-NOUN = "easka" "vأ،rra" ;

LIST ADV-NOT-ADJ = "luovos" ;


LIST ADV-NOT-NAMES = "Ain" "Anne" "Diego" "Dieppe" "Enge" "Galle" "Haga"
           "Joba" "Johan" "Liikka" "Mai" "Mannes" "Mo" "Mot" "Naba"
           "Nan" "Oktan" "Sierra" "Sokka" "Villa" ;

SET ADV-NOT-OTHER-POS = ADV-NOT-VERB OR ADV-NOT-NOUN OR ADV-NOT-NAMES ;


# Sets of elements with common syntactic behaviour
# ================================================

SETS

# Verbs
# -----
# Hmm V*?
SET VERB = V - (V N);
  # V is all readings with a V tag in them, VERB should
            # be the ones without an N tag following the V
SET VERB-NOT-ACTIO = V - (V N) - Actio ;

SET LEX-V = VERB - V-DER;
       # VERB but not V-DER

 # The set REALCOPULAS is smaller than COPULAS, made for verbs with PrfPrc complements: Seammأ،s REALCOPULAS son dovdan ieإ¾as...
LIST REALCOPULAS = "dأ،idit" "leahkit" "leat" "orrut" "soaitit" "veadjit" ;
	#added orrut because of the following example:
	# Rissiid, dakإ‹asa ja lasttaid gal orrot eambbo soaitimis ؤچohkken, ja dأ،rbu rievddadii jagis jahkأ،i .

# The set COPULAS is for predicative constructions
LIST COPULAS = "dأ،idit" "gأ،rtat" "leahkit" "leat" "orrut" "soaitit" "إ،addat" "veadjit" ;
 #  "bissut" ?
 # 'Dأ،idit' can appear without 'leat'.

SET V-NOT-COP = V - COPULAS ;

LIST MOD-ASP = "bأ،llet" "berret" "dأ،idit" "fertet" "galgat" "gillet" "lأ،vet"  "sأ،httit" "seahtit" "soaitit" "viggat" ;

 # Verbs that never have arguments of their own - so we leave out "أ،igut", for ex.

LIST AUX-OR-MAIN = "أ،igut" "أ،lgit" "beassat" "galgat" "hأ،lidit" "hأ،liidit" "mأ،httit" "nagodit" "ollit" "orrut" "sihtat" "veadjit";

 # These verbs can take arguments, so they do not belong in the AUX group,
 # but they are nevertheless mapped to (@+FAUXV).
 # Added "أ،lgit" to the group (Lene) - Made rules for "boahtit" which  sometimes can be AUX
 # Magga (1982: 120): أ،igut, dأ،idit, deaivat, fertet, galgat, lأ،vet, mأ،httit, oaإ¾إ¾ut, sأ،httit, soaitit, veadjit - in some of the meanings
 # Halvhjelpeverb: أ،lgit, berret, dohkket, gأ،rtat, heivet, liigut, إ،addat - in some of the meanings

SET AUX = COPULAS OR Neg OR MOD-ASP OR AUX-OR-MAIN ;


SET V-NOT-AUX = V - AUX ;
 # The set of verbs that cannot be auxiliaries.
			  # Does not include AUX-OR-MAIN.
SET VFIN-NOT-AUX = VFIN - AUX ;
SET GRAMCHK-VFIN-NOT-AUX = VFIN - <aux> ;

SET V-MAIN = V - COPULAS - Neg - MOD-ASP OR ("orrut") ;

# The set of verbs that can be main verbs. Includes AUX-OR-MAIN.
SET V-DER-PASS = V OR V-DER OR Der/Pass;
  # OR is union, this should work
				   # The set is used in one rule with no hits.
LIST V-TRANS = TV (IV Der/ahtti) (IV Der/h) ;
# This is only a tool for making the following sets, bacause of that the symbols (|) and (-) in the set donآ´t function as one had expected.
SET V-TRANS-ACT = V-TRANS - (TV Der/PassS) - (TV Der/PassL);
 #XXX Never acc-obj for a.l. or actor?
 # All active verbs with a TV tag, including AUX-OR-MAIN.

SET V-TRANS-ACT-NOT-AUX = V-TRANS - Der/Pass - AUX ;

SET V-TRANS-ACT-NOT-ACT = V-TRANS - Der/Pass - Der/NomAct - Actio - NOMAG - PrsPrc - Attr OR (TV Actio Ess) ;

SET V-TRANS-ACT-NOT-ACT-NOT-AUX = V-TRANS - Der/Pass - Der/NomAct - Actio - NOMAG - AUX OR (Actio Ess) ;


# Sets for verbs choosing oblique objects or adverbials
# - - - - - - - - - - - - - - - - - - - - - - - - - - -

# This is the list of strictly transitive verbs. In the rules, refer not to STVLIST, but to the set STV defined below.
LIST STVLIST = (IV Der/ahtti) (IV Der/h) "addit" "amaإ،it" "atnit" "أ،nssأ،إ،it" "أ،rvalit" "أ،rvidit" "أ،rvvoإ،tallat" "أ،sahit" "أ،vإ¾إ¾uhit" "bajidit" "bearrat" "biebmat" "bidjat" "bilidit" "billistit" "bissehit" "bisuhit" "boaldit" "boktit" "borahit" "buhtadit" "buktit" "buoridit" "caggat" "coggalit" "cealkit" "cegget" "ؤچaؤ‘ahit" "ؤچielggadit" "ؤچoaggit" "ؤچoavdit" "ؤچohkket" "ؤچuoؤچؤچuhit" "ؤچuohppat" "ؤچuovvulit" "ؤچuovvut" "dadjat" "dagahit" "dahkat" "dأ،hkidit" "dأ،httut" "dأ،rbbahit" "dأ،rbbaإ،it" "dأ،rkkistit" "dأ،vistit" "deaivat" "deattuhit" "deavdit" "diehtit" "diktit" "doahttalit" "doaimmahit" "doalahit" "doallat" "doarjut" "dohkkehit" "dovdat" "dovddahit" "duoؤ‘aإ،tit" "eahpidit" "eaiggأ،duإ،إ،at" "eaktudit" "ealأ،skahttit" "eavttuhit" "evttohit" "fأ،llat" "fidnet" "fievrridit" "fuolahit" "fuomأ،إ،it" "garvit" "gaskkustit" "gأ،djut" "gأ،httet" "gأ،ibidit" "gأ،rإ¾إ¾idit" "gأ،vdnat" ("gأ،vnnadit" Sg1) ("gأ،vnnadit" Sg2) ("gأ،vnnadit" Sg3) "geahؤچadit" "geahؤچؤچat" "geassit" "geatnegahttit" "geavahit" "gieؤ‘ahallat" "giddet" "goddit" "gohؤچؤچut" "gohؤچodit" "gokؤچat" "gozihit" "guoddalit" "guoؤ‘ؤ‘it" "guoؤ‘ohit" "guorahallat" "guorrat" "guoskkahit" "hأ،bmet" "hأ،hkat" "hأ،lddaإ،it" "heaittihit" "heivehit" "hilgut" "ipmirdit" "joؤ‘ihit" "juksat" "juohkit" "juolludit" "kأ،rtet" "lأ،gidit" "lأ،hؤچit" "lأ،igohit" "loahpahit" "lohpidit" "loktet" "luoikat" "luoikkahit" "luoitit" "massit" "mearkkaإ،it" "mielddisbuktit" "movttiidahttit" "muddet" "muitalit" "muittuhit" "namahit" "nammadit" "namuhit" "nannet" "nanosmahttit" "nuppأ،stuhttit" "oaidnit" "oastit" "oaivvildit" "oamastit" "oaإ¾إ¾ut" "oؤ‘asmahttit" "oؤ‘astit" "ollaإ،uhttit" "organiseret" "ovdanbuktit" "ovdأ،nahttit" "ovddastit" "ovddidit" "prioriteret" "rأ،ddjet" "rأ،ؤ‘ؤ‘et" "rأ،fأ،idahttit" "rأ،fأ،iduhttit" "rأ،hkadit" "rأ،vvet" "rievdadit" "rihkkut" "sأ،ddet" "seaguhit" "seailluhit" "sihkkarastit" "sihtat" "siskkildit" "sisttisdoallat" "suodjalit" "suovvat" "unnidit" "vahأ،gahttit" "vأ،illahit" "vأ،ldit" "vأ،lljet" "vأ،rret" "vأ،sihit" "vأ،ttأ،smahttit" "viiddidit" "vuhtiivأ،ldit" "vuoؤ‘ؤ‘udit" "vuohttit" "vuoitit" "vuojuhit" "vuoruhit" "vuosttaldit" "vuovdit" ;

	# Strictly transitiv-verbs - a start. This set is ment as a help choosing Acc or Gen. Example: "Mun borren eatni kafeأ،s." - there is Gen, no Acc, even if the verb is transitive. Thatآ´s why "borrat" is not in this set.
	# These verbs: "addit", "fidnet" and "oaإ¾إ¾ut" can, when itآ´s about sex, be without object: "Son oaؤچؤچui gonagasa bأ،rtnis."

SET STV = STVLIST - Der/Pass ;


SET STV-NOT-ACT = STV - (Actio Nom) - (Actio Gen) - (Actio Acc) - (Actio Loc) - (Actio Ill) - (Actio  Com) - NOMAG ;


LIST LOCV = "أ،vkkأ،stallat" "ballat" "beassat" "beroإ،tit" "biehttalit" "bihtit" "ceavzit" "dinet" "dolkat" "eastadallat" "eastadit" "fuolahit" "fuollat" "geargat" "heaitit" "ilbmat" "jearrat" "luohpat" "mأ،innaإ،it" "nohkkot" "oassأ،lastit" "spiehkastit" "vأ،ruhit" "vأ،stidit" ;

		#Note that "fuolahit" obviously has two homonymous variants:
		#fuolahit1+Acc, fuolahit2+Loc

LIST COMV = "أ،rvalit" "أ،rvvohuإ،إ،at" "أ،vkaإ،uvvat" "bأ،lddalastit" "bأ،rtaإ،uvvat" "birgehallat" "birget" "buohtastahttit" "deaivvadit" "gulahallat" "gulaskuddat" "hilboإ،it" "joatkit" "leaikkastallat" "lohpأ،daddat" "lohpأ،dallat" "lonuhit" "meannudit" "malssidit" "molssodit" "ovttasbargat" "ovttastahttit" "riidalit" "servvoإ،tallat" "servvoإ،taddat" "soabadit" "soahpat" "إ،iehtadallat" "إ،iehtadit" ;

		#Note that "leaikkأ،stallat" has two homonymous variants:
		#leaikkأ،stallat1 (IV), leaikkأ،stallat2+Com

LIST ILLV = "أ،ibbaإ،it" "أ،lgit" "أ،saiduvvat" "bأ،itit" "beassat" "ؤچohkkedit" "ؤچujuhit" "ؤچuohcit" "deaivat" "doaإ،kut" "dorvvastit" "doإ،ket" "duhtat" "geahؤچؤچat" "gullat" "guoskat" "gustot" "hأ،rjأ،nit" "heivet" "irggأ،stallat" "jأ،hkkit" "liikot" "luohttit" "mannat" "mأ،hccat" "mieؤ‘ihit" "oahpأ،smuvvat" "oahpأ،snuvvat" "ollet" "oskut" "riepmat" "rأ،hkkanit" "soahpat" "searvat" "suhttat" "vأ،stidit" "vuolgit";


LIST TRANSLV = "jأ،pmit" "duإ،إ،at" "hأ،vkat" "nأ،italit" "gaskkalduvvat" "nohkat" "goarrأ،nit" "heahpanit" "boakؤچأ،nit" "إ،lundut" "rأ،igأ،nit" "vuollأ،nit" "gopmأ،nit" "fuotnأ،nit" "roahppأ،nit" "reakؤچanit" "bieؤ‘ganit" "luoddanit" "guvggodit" "liegganit" "suorganit" "bأ،hkkanit" "cuovkanit" "hedjonit" "lohppet" "goikat" "galbmot" "goallut" "ruostut" "buoidut" "guvggodit" "suvrut" "suddat" ;

  # Taken from Helander (2001) p. 89, might be useful in the future as those verbs typically take humans and places in illative case.

LIST REKSV = "أ،ibbaإ،it" "deaivat" "dorvvastit" "duhtat" "gustot" "hأ،rjأ،nit" "jأ،hkkit" "liikot" "mieؤ‘ihit" "ollet" "rأ،hkkanit" "soahpat" "searvat" "vuolgit" "beroإ،tit" "biehttalit" "bihtit" "ceavzit" "dinet" "dolkat" "eastadallat" "eastadit" "fuolahit" "fuollat" "geargat" "heaitit" "luohpat" "oassأ،lastit" "vأ،ruhit" ;
# This set is for giving infitives @ADVL after the verb.

LIST ACC-LOCV = "biehttalit" "earuhit" "gieldit" "jearrat" ;

LIST ACC-ILLV = "addit" "bidjat" "mearkkaإ،it";
    # Two-place predicates that take a direct object and an illative adverbial.

LIST MIELDE-V = "addit" "bidjat" "dأ،idit" "leat" "oastit" "oaإ¾إ¾ut" "vأ،ldit" ;
    # Phrasal verbs that take mielde as their complement.

# Son attii girjji mielde.

LIST TIMEADVERBIAL-V = "أ،djأ،nit" "أ،ssat" "bargat" "bistit" "bivdit" "eallit" "fievrridit" "guohtut" "joatkit" "lأ،ddet" "oahpahit" "oؤ‘asmahttit" ;

    # Do not take members of the time set as an object

LIST TIMEOBJECT-V = "addit" "atnit" "أ،rvalit" "bأ،lvalit"  "ؤچuovvut" "deavdit" "diإ‹got" "evttohit" "fأ،tmmastit" "gأ،ibidit" "gأ،vdnat" "geavahit" "gierdat" "guhkidit" "hأ،bmet" "jorgalit" "juolludit" "lasihit" "liigudit" "loahpahit" "loaktit" "markeret" "mearridit" "molsut" "oanidit" "oaإ¾إ¾ut" "soahpat" "إ،iehttat" "vأ،rret" "viiddidit" ;

    # might take time as an object - verbs which are not members of PLACE-V:

LIST DURATION-V = "أ،djأ،nit" "bargat" "bistit" "eallit" "leat" ;

LIST POINT-IN-TIME-V = "أ،rrit" "bissehit" "caggat" "cakkadit" "cakkastallat" "doalahit" "doallat" "duostut" "dustet" "eastadit" "gieldit" "goahcat" "heaؤ‘uإ،tit" "hehttet" ;

LIST ROUTEADVERBIAL-V = "boahtit" "ؤچuoigat" ;

    # bevegelse langsmed noe, innafor et bestemt omrأ¥de
LIST ROUTEOBJECT-V = "أ،sahit" "bidjat" "botnjat" "basuhit" "buoridit" "ؤچielggadit" "ؤچuovvulit" "ؤچilget" "ؤچuorvut" "ؤچurvet" "dieؤ‘ihit" "duoؤ‘aإ،tit" "duorggastit" "geavahit" "geahpedit" "geahpidit" "gudnejahttit" "guorahallat" "gieؤ‘ahallat" "guoؤ‘ؤ‘it" "gilljut" "heahtit" "huikit" "huikkأ،dit" "juoigat" "lأ،vlut" "lohkat" "loahpahit" "mearridit" "mأ،idnut" "nannet" "njulget" "oahpahit" "rأ،hkadit" "sivdnidit" "suokkardit" "unnidit" "vأ،lmmaإ،tit" "vurket" ;

LIST HAB-VERB = "boahtit" "leat" "goallut" "heaإ‹gأ،t" "jأ،pmit" "إ،addat" ;
	# To be used in habitative-sentences.

# Valency sets
# - - - - - - -

LIST INFV = "astat" "أ،djأ،nit" "أ،igut" "أ،lgit" "أ،sahit" "bأ،gget" "bأ،vؤچؤچagit" "beassat" "berret" "bivdit" "bivvat" "bistit" "boahtit" "bovdet" "ؤچohkkأ،t" "ؤچohkkedit" "ؤچohkkأ،nit" "ؤچuoؤچؤچahit" "ؤچuoؤچؤچastit" "ؤچuorvut" "ؤچurggodit" ("dadjat" Der/PassL) ("dadjat" Der/PassS) "dagahit" "dأ،httut" "dأ،idit" "dأ،rbbaإ،it" "defineret" "diktit" "doaivut" "doapmat" "duostat" "fertet" "fuobmأ،t" "fuolahit" "galgat" "gأ،ibidit" "gأ،rrut" "gأ،rtat" "geahؤچؤچalit" "geargat" "geatnegahttit" "gierdat" "gillet" "gohؤچؤچut" "hأ،hppehit" "hأ،lidit" "hأ،liidit" "hأ،rjأ،nit" "heivet" "lأ،vet" "mannat" "mأ،httit" "mأ،إ،إ،at" "movttiidahttit" "muitit" "nagodit" "navdit" "oahpahit" "oahpأ،stuvvat" "oahppat" "oaإ¾إ¾ut" "ollet" "ribahit" "riepmat" "sأ،httit" "seahtit" "sihtat" "soaitit" "suovvat" "إ،addat" "staؤ‘ؤ‘at" "veadjit" "viggat" "viإ،إ،at" "vuogأ،iduvvat" "vuolgit" "vuollأ،nit" "vuordit";


LIST ACC-INFV = "bivdit" "ؤچuorvut" "dagahit" "diktit" "gohؤچؤچut" "movttiidahttit" "sihtat" "suovvat" ;

 # These are verbs taking accusative objects and infinitives at the same time;

 # a subset of INFV.
	## Ii suova nieiddas nأ،italit.

LIST OPREDV = "alidit" "atnit" "dadjat" "dahkat" "dulkot" "geavahit" "geahؤچؤچat" "gohؤچodit" "gohؤچؤچut" "meroإ،tallat" "navdit" "vأ،ldit" "vأ،lljet";

 # Verbs that occur with objects that have secondary predicates.

LIST OKTII-V = ("boallu" Der/huvva) "goallostuvvot" "beaإ،kkehat" "bidjat" "ؤچatnat" "suddat" "heivet" "bidjat" "ؤچaskit" "geassit" "gullat" "rehkenastit" "ordnet" "soahpat" "gأ،vnnadit" "heivehit" "doaibmat" "iskat" "laktit" "seaguhit";

 # Danger: This list could be too long, in certain respects.
