# Coordinators
# ------------
SET Foc = Foc/Neg-ge OR Foc/Pos-ge  OR Foc/gen  OR Foc/ges  OR Foc/gis  OR Foc/naj OR Foc/ba  OR Foc/be  OR Foc/hal  OR Foc/han  OR Foc/bat OR Foc/son ;

LIST NEGFOC = (Neg Foc/ge) ;

LIST XGO = "dego" "dugo" "nugo" "seammalÃĄdjego" "seammalÃĄhkaigo" ;
  # Compounds
LIST SEAMMAX = "seammalÃĄdje" "seammalÃĄhkai" "seammalÃĄhkÃĄi" ;
  # Those combine with go
  
LIST COMPGO = "nu" "seamma" "seammÃĄ" "liikkÃĄ" "lihkkÃĄ" ;

LIST MADE = "maÄe" "maÄi" ;
LIST DADE = "daÄe" "daÄi" ;

SET CRD = COMMA OR CC OR NEGFOC OR XGO OR ("/") OR ("-") OR DADE ;

	# coordinators

LIST LCRD = @CNP ;
    # local coordinator
LIST GCRD = @CVP ;
    # global coordinator

SET CRD2 = (@CNP) OR COMMA OR NEGFOC OR XGO OR ("/") OR ("-") OR DADE ;
    # AFTER LCRD vs. GCRD disambiguation

# Sets for adverbs that have lookalikes
# -------------------------------------
