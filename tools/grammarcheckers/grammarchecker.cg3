	#$ Moai fertejetne suomastit, go mun in oalle lأ،hkai adde koltأ،giela iige songe fas mu sأ،megiela. 
    ## Mun vأ،lddأ،n mu girjji.
    #$ Mii hأ،lidit ieإ¾a bearrأ،igeahؤچؤچat min ieإ¾amet luondduriggodagaid.
    #$ Ja dies mun fuobmأ،jin ge oؤ‘ؤ‘a ealأ،husa, deike min guovlluide gos lea nu stuora bargguhisvuohta.XXX
    #$ 
    # problem about "son" is that both "ieإ¾as" and "su" is possible dependent on the referent
    # the COPY rule does not keep the tags in the original order, that might cause problems for the generation
	#$ Moai luhtiime dutnje, Linأ،, ja nأ، munno beahtأ،t!
    #$ Mun vuolggأ،n ja don galggat leat mu fأ،rus.
    # in errors.xml


	# Ess not dego
	# ------------
	
LIST DEGO-ESS-ADV = "ruovttoluotta" ;


LIST DEGO-ESS-V = "galgat" "إ،addat" "gأ،rtat" "dahkat" "orrut" ;

LIST DEGO-ESS-V2 = "lohkat" "jurddaإ،it" "jurddahit" "guovllastit" "gullostit"  ;

LIST ESSIVE-TIME-N = "skأ،bma" "bassi" "veaigi" "أ،rga" "ruإ،ki" (".*skأ،pmu"r) "joavdu" "vistta" ;

LIST DEGO-V = "muitit" ;

ADD:xsyn-not-dego (&syn-not-dego COERROR) TARGET SUCH-AS IF (*1 Ess OR ("danin") BARRIER GRAMCHK-NPNH LINK NOT 0 (N Sg Nom) OR Sem/Wthr OR ESSIVE-TIME-N LINK NEGATE -1 QMARK) (NEGATE *1 (Actio Ess) BARRIER GRAMCHK-NPNH)(NEGATE *1 (".*niehku"r Ess) OR (".*gearpmaإ،"r Ess) OR (".*lأ،ga"r Ess) OR (".*إ،lأ،ga"r PxSg1) OR ("lأ،vvomuorra" Ess) OR Comp BARRIER GRAMCHK-NPNH) (NEGATE 1 ("ovdamearka" Ess) LINK NOT 1 ("dat" Pron Dem Sg Ill)) (NEGATE 1 ("ovdamearka" Ess) LINK NOT 1 (".") OR ("!") OR ("?")) (NEGATE 1 ("ovdamearka" Ess) LINK NOT 1 THAT-CS) (NEGATE -1 ("hأ،pmi"))(NEGATE *-1 DEGO-ESS-V BARRIER V OR GRAMCHK-S-BOUNDARY) (NEGATE *0 DEGO-ESS-V2 BARRIER V LINK NOT -2 Po) (NEGATE *-1 BE - Cond BARRIER V OR GRAMCHK-S-BOUNDARY LINK NOT *1 ("mielde") OR ("vuostأ،" Adv) OR ("sأ،hka") OR DEGO-ESS-ADV BARRIER NPNH) (NEGATE -1 BE LINK 0 (IV Actio Ess) LINK NOT -1 ("orrut")) (NEGATE *-1 Ess BARRIER GRAMCHK-NPNH LINK 1 BE)
(NEGATE 1 Ess LINK *1 COPULAS + Sg3 BARRIER NOT-ADV-PCLE)
(NEGATE 1 Ess LINK lp DEGO-V); #parent of the essive should not be a DEGO-V
	#$ Muhto eai leat dأ،n rأ،djai gأ،vdnan oؤ‘ؤ‘a birgenlأ،gi {dego} ulbmilin lei, ja measta buohkat أ،igot jorggihit boazodollui.
	#$ Mأ،إ‹gasat muitet su buoremusat {dego} advokأ،htan ja sأ،miid ovddasteaddjin historjjأ،laإ، أپlttأ، stuimmiid oktavuoؤ‘as 1970- ja 80 logus, dasa lassin su guovddأ،إ، barggu أ،lgoأ،lbmotjuristan ja maإ‹إ‹أ، fas rأ،ؤ‘ؤ‘eaddin departemeanttain main lei ovddasvأ،stأ،dus sأ،mi أ،إ،إ،iin.
	
	
ADD:xsyn-not-dego (&syn-not-dego) TARGET Ess IF (*-1 ("dego" &syn-not-dego) BARRIER Ess)(NEGATE 1 Ess);
ADD:xsyn-not-dego (&syn-not-dego) TARGET Ess IF (-1C Ess)(NEGATE 0 (Sem/Act Sg Nom));
	# coordination
	#$ Unnأ،n {skuvlavأ،zzin} nuortalaؤچؤچaide.
ADD:xsyn-not-dego (&syn-not-dego) TARGET Ess IF (*-1 CC BARRIER NPNH - (Sem/Sur Nom) - (Sem/Plc Nom) LINK -1 (Ess &syn-not-dego) );
	## Dأ،l 20 jagi lea ruovttoluotta dego majoran ja Banak Girdistaإ،uvnna {hoavdan}.

ADDRELATION:syn-not-dego (DELETE1 $2) (Ess &syn-not-dego) TO (*-1 ("dego" &syn-not-dego)); 

#COPY:syn-dego-ess (Sg Nom SUGGEST &syn-dego-nom) EXCEPT (Ess &syn-not-dego) TARGET (Ess &syn-not-dego) ;
	#$  Reykjavikas davأ،s lea stuorra luoddanan geaؤ‘gi Grأ،steinn dego muittuhussan gufihttariin, mat أ،sse das ovdal go geainnu rأ،hkadedje.
    ## Almma Sأ،melأ،ga giellanjuolggadusaid haga ja mأ،nأ،idgأ،rdelأ،ga آ§_2.3 oasi ja 8.3 oasi ektui lea suohkanis dego bearrأ،igeahؤچؤچoeisevأ،ldin ovddasvأ،stأ،dus addit fأ،laldaga sأ،mi mأ،nأ،ide mأ،nأ،idgأ،rddis.
    #$ Vai vأ،rtnuhisvuohta nogaإ،ii, mii orru leamen dego oassin dieid sis-vuona olbmuid luonddus, de ferteإ،edje sii, erenoamأ،إ¾it nuorrageardi, oaإ¾إ¾ut lagabui oktavuoؤ‘a sivilisaإ،uvnnain.
	#$ Ovtta sajis oidnen go ruإ‹kأ،n lei goddأ،n vaikke man olu goddesأ،hpأ،niid, dat ledje gأ،vvut dego lahttan eatnamis, ruإ‹kأ،n lei ؤچollen daid, vissa borran duإ،إ،e juoidأ،.
	#$ Erenoamأ،إ¾it alla ؤچأ،zi أ،igge, dego giؤ‘ؤ‘adulvin, jogat ja أ،djagat leat hui rأ،vdnjأ،i.
    #$ Skallhalsen plأ،naguovllu siskkobeallأ،i lea evttohuvvon ؤچoavddus mas bieggamillot mannet veahأ،إ، dego dأ،vgin nuortalulأ،bealde oarjjadavأ،beallأ،i gaskal 2300 ja 4000 mehtara guhkkodahkan.
آ آ آ آ #$ Lei nu seavdnjat إ،addan dego skأ،bman lأ،vii leahkit.
آ آ آ آ #$ Spoahkkasat lassأ،nit ja maإ‹أ،إ¾assii ruohؤچa gullo ovtta njuoؤ‘ahassii dego buolaإ،in muhtin livؤچؤچii vuovttaidis ؤچohkumin.
	#$ Nuppe dأ،fus dutkit leat Nielsena rأ،jes buohtastahttأ،n - naga essiivva kأ،susgehؤچosiin - n, ja muhtumin govvidan hأ،miid dego "varran", varrana ja varranaga synonyman.
	#$ Sii dieؤ‘ihit plakأ،htaiguin, maid rأ،hkadit dego govvan maid olmmoإ، sأ،httأ، ؤچikإ‹an heإ‹get seaidnأ،i.
	#$ Duإ،إ،e infinitiivva geavahus predikأ،hta haga ii daga teavstta dego niehkun ja gielddusin ( vs. Dubrovina 1979, 112 ), iige dat leat أ،lo ؤچatnosis affektiiva mearkkaإ،umiin.
    ## SNF doaibmأ، dأ،l juo dego resursaguovddأ،إ¾in. SNF doaibmأ، dأ،l juo resursaguovddأ،إ¾in.
	#$ Dieؤ‘ut dأ،iddaduoji birra orrot dego hأ،vkame buot luoddaguordujiid ja fabrihkkarأ،hkadun dujiid sisa.	
	## Meahceallit leat daid borran nu ahte erttetdأ،vttit duإ،إ،e leat bأ،hcأ،n dego lأ،vvomuorran. -- dego + Nom
آ آ آ آ #$ Muhto dalle gأ،rtأ، maiddأ،i ؤچielgaseappon man_lأ،hkأ،i mearrideaddjit stuorأ،t servvodagas, go sin fأ،pmu lea gأ،rtan dego semeantan, dagahit lأ،httenvuoؤ‘u muhtinlأ،gan eahpealbma bivdui ja gilvui, gos vel diehta ge gأ،rtأ، hiإ‹gأ،lastojuvvot dego ؤچأ،jأ،hussan meassuin ja eisevأ،lddiid buإ،eahtain.  -- dego + Nom
آ آ آ آ #$ Muhto mأ،tketelefovdna lea إ،addan dego rumaإ،oassin mأ،إ‹gasii, dadjأ، dutki. -- dego + Nom
    #$ Geahؤچؤچأ، munnje, dego vuorddaإ،eame boahtte gaإ¾aldaga. Logan son dat lea vissa oahpahan bأ،rdnistas juoigat.
    #$ Muitalus إ،addأ، dego viidأ،bun sidjiide geat guldalit, jus seammأ،s maiddأ،i besset oaidnit juoidأ، â€“ dأ،s livؤچؤچii lunddolaإ، geavahit stأ،lu ja bأ،rtni dohkأ،id ja ieإ،guؤ‘etlأ،gan elliid.
    #$ Muhto eai leat dأ،n rأ،djai gأ،vdnan oؤ‘ؤ‘a birgenlأ،gi dego ulbmilin lei, ja measta buohkat أ،igot jorggihit boazodollui.
    ## Dasa_lassin oaivvilda Sأ،mediggi ahte dأ،t livؤچؤچii hirbmat bajأ،dus Romsii dego أ،lgoأ،lbmotgأ،vpogin jus oaؤچؤچoإ،ii vأ،ldoovddasvأ،stأ،dusa lأ،gidit dأ،kkأ،r doaluid.
    ## Oallugat eai dieؤ‘e maid galget oaivvildit mu birra dego artistan, dan sivas go seaguhan lأ،vluma sأ،mi kultuvrrain, ؤچoavjedأ،nssain ja urban - ja dأ،rogiel musihkain, lohka Kأ¥ven.
    ## â€“ In bilkit guhkkin eret risttalaإ، oskku dainna CD:iin, muhto mun barggan dan mii mu mielas lea miellagiddevaإ، dego komponistan ja musihkkأ،rin, dasa_lassin in hأ،lit ieإ¾an seaguhit maid earأ،t oaivvildit, lohkأ، Fjellheim.
    ## Dأ، gieskat riإ‹gii muhtun Min_أپiggi journalista munnje ja jearai mus makkأ،r oaidnu mus lea Marianne Balto Henriksenii ( AP ) dego politihkarin ja olmmoإ¾in.
    ## - Gielda lea mielde dego movttiidahttimohtorin.
    ## Lei gأ،ddenuohti sullasaإ، rأ،hkkanus - nuohtti lei dego dأ،vgin ؤچavgejuvvon gأ،ttis. #Ess


ADD:xsyn-comp (&syn-comp) TARGET A OR Adv IF (0 ("eanet") - Superl OR ("eambbo") - Superl LINK 1 (A Nom) OR (A Ess) OR Attr + <AttrPred> LINK NOT 0 ("vejolaإ،") OR ("nuorra") OR NO_COMP OR Der/lasj)(NEGATE 2 CS LINK *1 (A Nom) BARRIER NOT-ADV) (NEGATE -1 ("unnit") OR ("uhcit")) (NEGATE *-1 Neg BARRIER GRAMCHK-S-BOUNDARY) ;
#(-1 GRADE-ADV)
ADD:xsyn-comp (&syn-comp) TARGET A  IF (0 Sg + Nom - Comp OR Ess - Comp OR Attr + <AttrPred>) (-1 ("eanet") - Superl OR ("eambbo") - Superl LINK 1 (A Nom) OR (A Ess) OR Adv OR Attr + ADJ_ATTR/NOM LINK NOT 0 ("vejolaإ،") OR ("nuorra") OR NO_COMP OR Der/lasj)(NEGATE 1 CS LINK *1 (A Nom) BARRIER NOT-ADV) (NEGATE -2 ("unnit") OR ("uhcit")) (NEGATE *-1 Neg BARRIER GRAMCHK-S-BOUNDARY);
#(-2 GRADE-ADV)

ADDRELATION (DELETE1) (A &syn-comp) TO (-1 ("eanet" &syn-comp) OR ("eambbo" &syn-comp)) ;

COPY:syn-comp (Der/Comp SUGGEST) EXCEPT (&syn-comp) AFTER A TARGET (A &syn-comp) (NEGATE 0 ("eanet") OR ("eambbo")) ;
COPY:syn-comp (Ex/A Der/Comp SUGGEST) EXCEPT (&syn-comp) BEFORE A TARGET (A &syn-comp) (NEGATE 0 ("eanet") OR ("eambbo")) ;

	## Lea إ،addan eambbo positiiva go lei, ja bohtosat leat buorit.
	## Dat bأ،icco sأ،htأ،إ،ii addit stuorأ،t hأ،sttalusaid ieإ،guؤ‘etge neavtأ،riid, ja dalle soaitأ، maiddأ،i teahter إ،addat eanet miellagiddevaإ¾إ¾an ja ؤچierggosat gehؤچؤچiide.
    #$ Allet bala, dii han lehpet eanet veara go ollu cizأ،إ¾at!
    ## Ramones vأ،ikkuhusas Blackfire musihkii ii leat eahpأ،dus, vaikko Blackfire vuohki leage eanet aggressiiva go ovdagovastis.
    #$ Ramones vأ،ikkuhusas Blackfire musihkii ii leat eahpأ،dus, vaikko Blackfire vuohki leage eanet aggressiiva go lodji.
    #$ Ramones vأ،ikkuhusas Blackfire musihkii ii leat eahpأ،dus, vaikko Blackfire vuohki leage eanet aggressiiva go duoؤ‘ai lodji.
    ## Gأ،ivuona suohkan lea ge eanemus geaؤ‘gأ،i suohkan Romssa fylkkas.
    ## Olbmot leat sajأ،iduvvan sihke ceaggumus vأ،kkiide ja eanemus geaؤ‘gأ،i vuonaide, ja sأ،httأ، juohkit suohkana 3 أ،ssأ،nguvlui. 
    #$ Dأ،t servvodat lea ain odne eambbo bivdoservvodat go eanas earأ، bأ،ikkiin oarjemأ،ilmmis.
    # tag order can create problems for generation
    # in errors.xml

LIST ONLY-MASS-N = Sem/Substnc "rأ،ssi" ; 
	# doppe lea eanemus beakkأ،n/fiskes MASS-N + Sg
	# lea unnأ،n MASS-N + Sg
LIST MASS-OR-COUNT = "ؤچأ،hci" "guolli" "muorra" "olmmoإ،" ;

SET MASS-N = ONLY-MASS-N OR MASS-OR-COUNT ;
SET COUNT-N = N - MASS-N OR MASS-OR-COUNT;

LIST BINARY-A = "beakkأ،n" "dovddus" ; #To be or not to be
    
    #DELETE SECOND ROUND

ADD:xsyn-super (&syn-super) TARGET A OR Adv IF (0 ("eanet") + Superl OR ("eambbo") + Superl OR ("eanemus" Adv Superl) LINK 1 (A Nom) OR (A Ess) OR (A Attr) LINK NOT 0 NO_COMP)(NEGATE 2 CS LINK *1 (A Nom) BARRIER NOT-ADV)(NEGATE 1 A - BINARY-A LINK NOT *1 N BARRIER NPNH LINK *0 VFIN + COPULAS)(NEGATE *1 (N Pl Nom) + COUNT-N BARRIER NPNH LINK *0 COPULAS BARRIER GRAMCHK-S-BOUNDARY OR VFIN OR Inf OR PrfPrc OR (Prs Pl1) LINK 0 Pl3 OR VFIN OR Inf - COPULAS OR PrfPrc - COPULAS)(-1 Dem OR (N Gen) OR (Pron Gen) OR ONE + (Num Sg Nom) LINK NEGATE 0 Refl LINK *-1 TV)(NEGATE -1 (Sg Nom) LINK -1 BE + Sg3 OR BECOME + Sg3)(NEGATE -1 (Sg Nom) LINK -1 (N Gen) OR Attr LINK -1 BE + Sg3 OR BECOME + Sg3) ;
# + ADJ_ATTR/NOM OR Attr LINK NOT 0 ("vejolaإ،") OR ("nuorra") OR NO_COMP OR Der/lasj
	#$  Juste dأ،l lea dat eanemus {kreatiiva} proseassa, go mii leat bidjame maإ‹emus jienaid, ja maإ‹إ‹el dan mii أ،lgit mixet, muitala Guifen Min أپigأ،i.
    #$ Snأ¸hvit-huksen lea dat eanemus {kontroversiealla} petroleumhuksen-proإ،eakta mii lea leamaإ، Norggas.
    
ADD:xsyn-super (&syn-super) TARGET A IF (0 Sg + Nom - Superl OR Ess - Superl OR Attr - Superl)(-1 ("eanet") + Superl OR ("eambbo") + Superl OR ("eanemus") + Superl)(NEGATE 2 CS LINK *1 (A Nom) BARRIER NOT-ADV)(-2 Dem OR (N Gen) OR (Pron Gen) OR ONE + (Num Sg Nom) LINK NEGATE 0 Refl LINK *-1 TV)(NEGATE 0 NO_COMP)(NEGATE -2 (Sg Nom) LINK -1 BE + Sg3 OR BECOME + Sg3)(NEGATE -2 (Sg Nom) LINK -1 (N Gen) OR Attr LINK -1 BE + Sg3 OR BECOME + Sg3);
   #LINK NOT 0 ("vejolaإ،") OR ("nuorra") OR NO_COMP OR Der/lasj
   #$ Dalle إ،attai kubأ،na sigأ،ra eanemus {beakkأ،n} آ«lassibierggasآ» politihkkأ،riin, gأ،vpealbmأ،in ja India badjeseaؤ‘u nuorain.	
	#$ Eai dus إ،atta dأ،n vahku nu ollu sosiأ،la doaimmat ja danne beasat أ،ibbas rأ،fis ؤچiekإ‹udahttit ieإ¾at eanemus somأ،s أ،إ،إ،iide.
	## Dأ،t leat gilvvut mأ،ilmmi eanemus ekstremalaإ، valأ،إ،tallamiin.
	## Meahcأ،stallan lea vأ،rra sأ،mi eanemus bivnnuhis vأ،lljenfأ،ga.	
	## DAT eanemus {jierpmأ،laإ،} maid Rأ،ؤ‘ؤ‘ehus ja Stuoradiggi dأ،l sأ،httأ، dahkat, lea maإ‹idit Finnmأ،rkolأ،hkأ،rvalusa mearrideami. 
	## Ovddأ،dusbellodat lea negatiiva dأ،n ovdأ،neapmأ،i mii duhtada duإ،إ،e DAID eanemus {radikأ،la} sأ،pmelaؤچؤچaid.
	#$ Riddu Riؤ‘ؤ‘u lea eanemus dovddus ????
	#$ lea eanemus dovddus vأ،ldorolla dihte Ofelaإ،-filmmas.
	#$ De soaitأ، olmmoإ، veahأ،إ، balus dahje speantta, muhto dieؤ‘usge {eanemus} movttet.
	#$ muhto dieؤ‘usge oahppit bohtet gal leat eanemus suopmelaؤچؤچat, dadjأ، Lehtola.
	#$ Eanemus bargguheamit leat Lأ،hpis ja Guovdageainnus.
	#$ jأ،vkأ، eanemus liekkas robi ja lovtta bokte.
	#$ mas leat eanemus bأ،ikkأ،laإ، kantuvrrat	
	#$ ahte eanemus beakkأ،n sykkelat ledje juo vuvdon
	#$ goalmmأ،t jagi oahpus leat eanemus guoros sajit
	#$ Finnmأ،rkkus leat eanemus nuorra eatnit olles Norggas
	#$ Guovdageainnu dikإ،o- ja fuollaossodagas leat eanemus oahppameahttun olbmot olles Norggas.
	#$ guؤ‘es sin mielas ledje eanemus etnalaإ، sأ،ddagat
	#$ gos eanemus arkeologalaإ، dieؤ‘ut leat
	#$ ledje dأ،lvet eanemus sosiأ،la oktavuoؤ‘at obanassiige jagis
	#$ Eanemus sأ،megielat 0-9 jahkأ،saؤچؤچat ledje أپlaheajus
	## Nepأ،las leat badjel 60 etnalaإ، joavkku, ja doppe hubmojuvvojit unnimusat 69 giela, ja nappo lea ge okta dain eanemus somأ،s servodagain mأ،ilmmis.
	#$ Olu lea ؤچivgan Sأ،mirأ،ؤ‘is, muitala rأ،ؤ‘i kulturؤچأ،lli Mأ،rjأ، Sofe Aikio ja namuha maiddأ،i Davvi إ uvva, mii lea leamaإ، Davviriikkaid eanemus {lihkostuvvan} أ،lgoأ،lbmotfeastivأ،la.
	
	# okta dain
	
	#DELETE SECOND ROUND

ADD:xsyn-super (&syn-super) TARGET A OR Adv IF (0 ("eanet") + Superl OR ("eambbo") + Superl OR ("eanemus" Adv Superl) LINK 1 (A Nom) OR (A Ess) OR (A Attr) LINK NOT 0 NO_COMP)(NEGATE 2 CS LINK *1 (A Nom) BARRIER NOT-ADV)(NEGATE 1 A - BINARY-A LINK NOT *1 N BARRIER NPNH LINK *0 VFIN + COPULAS)(NEGATE *1 (N Pl Nom) + COUNT-N BARRIER NPNH LINK *0 COPULAS BARRIER GRAMCHK-S-BOUNDARY OR VFIN OR Inf OR PrfPrc OR (Prs Pl1) LINK 0 Pl3 OR VFIN OR Inf - COPULAS OR PrfPrc - COPULAS)(*-1 (Pron Pl Loc) BARRIER NPNH LINK -1 (Num Sg Nom)) ;


