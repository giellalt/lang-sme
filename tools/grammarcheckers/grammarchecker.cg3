# Conceptual Hierarchy
# ====================
# minor caps : structure elements not sets
# caps : sets
#
#                                                verbal content
#                                   /                                        \
#                                 /                                            \
#                         DYNAMIC-V                                          STATIC-V
#                         /                  \                                /               \
#                 human activity              events                  concrete/human         abstract
#             /               \               /           \               /                 /
# concrete activity*   abstract activity    ABSTR-EVENT-V EVENT-V        PLACE-V      ABSTR-PLACE-V
#                     /               \
#             HUMAN-AGENT-V    ABSTR-ENTITY-COM-V
#
# =================================================================================================================================
#
#                                                        concrete activity*
#                                         /                   \                           \
#                        physical activity                     VERBAL-ACTIVITY-V       INTELLECTUAL-ACTIVITY-V
#                     /                       \
# movement (MOVEMENT-V)                       other
#
#                                 /           /           \           \               \
#                     HUMAN-SOURCE-VEHICLE-V  REM-WITH-PARTS ACTIVITY-V BODY-ACTIVITY-V WRITING-ACTIVITY-V ....
#                     /           \
#             VEHICLE-PLACE-V VEHICLE-TOOL-V
#
# others:
# HUNTING-ACTIVITY-V; KITCHEN-ACTIVITY-V; WORKING-ACTIVITY-V; WRITING-ACTIVITY-V; HANDICRAFT-ACTIVITY-V; ONLY-PLACE-LOC-V ; HUMAN-LOC-V
#
# =================================================================================================================================

    #  Verbs according to loc/com preferance
    #  - - - - - - - - - - - - - - - - - - -
# The idea is that the superset DYNAMIC-V does not select (Pl Loc) if the noun is a member of the set TOOL, ABSTR-TOOL or CONCEPT. This is the "minste felles multiplum". The sub-sets are different, e.g. many of them (but not all) are not connected to HUMAN in (Pl Loc), one is not connected to ABSTR-ENTITY and ACTOR in (Pl Loc). We work with negation so the rules donÂŽt destroy analysis because of insufficent sets.

LIST ONLY-INE-MOVEMENT-V = "bĂĄhtarit" "beahkit" "boahtit" "borjjastit" "ciĆkut" "ÄĂĄhppĂĄnit" "ÄĂĄhpihit" "Äierastit" "Äuoigat" "Äuoiggadit" "Äuoigalit" "fierrat" "finadit" "finihit" "fitnat" "gĂĄlaĆĄit" "gĂĄllit" "girdit" "goargĆut" "guokkardit" "goarbmot" "girddaĆĄit" "ihtit" "jĂĄvkkehit" "jĂĄvkkihit" "johtit" "jorgalit" "jorggihit" "lĂĄvket" "lĂĄvkut" "mannat" "mĂĄtkkoĆĄtit" "murdit" "murdilit" "njoammut" "haskat" "haskadit" "njuiket" "njuikut" "riidet" "ruohttat" "ruohtastit" "sihkkelastit" "skierbmut" "suobbulit" "soabbut" "ĆĄloahtat" "steavĆŸut" "vĂĄccaĆĄit" "vĂĄdjolit" "vĂĄjaldit" "vĂĄjuldit" "vĂĄnddardit" "viehkat" "vieĆŸĆŸat" "vuodjalit" "vuodjat" "vuodjit" "vuojadit" "vuojaĆĄit" "vuojistit" "vuolgit" "sirdasit" "viegahit" "viegaldahttit" "viegahallat" ;

LIST MOVEMENT-V = "ĂĄdjit" "beahkit" "beassat" "boahtit" "borjjastit" "ciĆkut" "ÄĂĄhpodit" "ÄĂĄhppĂĄnit" "ÄĂĄhpihit" "Äierastit" "Äuoigat" "Äuoiggadit" "Äuoigalit" "Äuovvut" "fĂĄrret" "fierrat" "finadit" "finihit" "fitnat" "gakcut" "gĂĄlaĆĄit" "gĂĄllit" "gĂĄllilit" "givttahit" "girdit" "gĂĄrrut" "goargĆut" "guokkardit" "goarbmot" "goastat" "girddaĆĄit" "hurgalit" "ihtit" "jĂĄvkkehit" "jĂĄvkkihit" "joavdat" "johtalit" "johttĂĄt" "johtit"  "jorgalit" "jorggihit" "lĂĄvket" "lĂĄvkestit" "lĂĄvkut" "mĂĄhccat" "mannat" "mĂĄtkkoĆĄtit" "murdit" "murdilit" "njoammut" "haskat" "haskadit" "njuiket" "njuikut" "ollet" "ollit" "riidet" "ruohttat" "ruohtastit" "sĂĄhtostit" "sĂĄhttit" "sihkkelastit" "skierbmut" "suhkat" "suobbulit" "soabbut" "suvdit" "ĆĄloahtat" "steavĆŸut" "stĂĄvĆŸut" "vĂĄccaĆĄit" "vĂĄdjolit" "vĂĄjaldit" "vĂĄjuldit" "vĂĄnddardit" "vĂĄzzit" "vĂĄzzilit" "viehkalit" "viehkat" "vieĆŸĆŸat" "vuodjalit" "vuodjat" "vuodjit" "vuojadit" "vuojaĆĄit" "vuojistit" "vuojahit" "vuojihit" "vuodjelit" "vuojehit" "vuolgit" "sirdaĆĄuvvat" "sirdahuvvat" "sirdit" "sirdasit" "viegahit" "viegaldahttit" "viegahallat" "vĂĄccihit" "Äuoiggahit" "fierahit" "fieraldahttit" "girddihit" "girddĂĄldahttit";
