	# 1. Add error tags:
ADD:xpunct-aistton       (&punct-aistton)       TARGET (""") ;  # Delayed til later
MAP:punct-aistton-both  (&punct-aistton-both)  TARGET ("آ«" PUNCT LEFT)  OR ("â€œ" PUNCT LEFT) OR ("\"") OR ("â€‍") OR ("â€ں") OR ("'") OR ("â€¹") OR ("â€ک") OR ("â€ڑ") OR ("`") OR ("â€›") OR ("â‌›") OR ("â‌‌") OR ("â‌®") OR ("م€‌") OR ("م€ں")
IF (2 ("آ»") OR ("â€œ") OR ("\"") OR ("'") OR ("â€؛") OR ("â€™") OR ("â‌œ") OR ("â‌‍") OR ("â‌¯") OR ("م€‍") OR ("ï¼‚")) ; #NOT THIS ONE! ("â€‌")
	## Artihkkal Ii fal EU Finnmأ،rkoaviisa "Mearrit", borgemأ،nnu 1993

# "	آ« آ» â€œ â€‌ â€‍ â€ں ' â€¹ â€؛ â€ک â€™ â€ڑ â€› â‌› â‌œ â‌‌ â‌‍ â‌® â‌¯ م€‌ م€‍ م€ں ï¼‚


ADD:punct-aistton-left  (&punct-aistton-left)  TARGET ("آ«" PUNCT LEFT) - Err/Orth OR ("â€œ" PUNCT LEFT) - Err/Orth OR ("â€‍"  PUNCT LEFT) - Err/Orth OR ("â€ں") - Err/Orth OR ("â€¹") - Err/Orth OR ("â€ک") - Err/Orth OR ("â€ڑ") - Err/Orth OR ("â€›") - Err/Orth OR ("â‌›") - Err/Orth OR ("â‌‌") - Err/Orth OR ("â‌®") - Err/Orth OR ("م€‌") - Err/Orth OR ("م€ں") - Err/Orth IF (NOT 0 <SpaceOnRightSide>);
	#$ lأ،vlo â€œأ،hku sأ،vzzat lأ،vlaga.
ADD:punct-aistton-right (&punct-aistton-right) TARGET ("آ«" PUNCT LEFT <SpaceOnRightSide>) OR ("â€¹" PUNCT LEFT <SpaceOnRightSide>)  OR ("â‌®" <SpaceOnRightSide>) OR ("â€›" <SpaceOnRightSide>) OR ("â‌›" <SpaceOnRightSide>) OR ("â‌‌" <SpaceOnRightSide>) OR 
("آ«" PUNCT LEFT <LastCohortOfParagraph>) OR ("â€¹" PUNCT LEFT <LastCohortOfParagraph>)  OR ("â‌®" <LastCohortOfParagraph>) OR ("â€›" <LastCohortOfParagraph>) OR ("â‌›" <LastCohortOfParagraph>) OR ("â‌‌" <LastCohortOfParagraph>)
IF (*-2 ("آ«") OR ("â€¹") OR ("â‌®") OR ("â€›") OR ("â‌›") OR ("â‌‌") BARRIER PUNCT OR CLB);
	##  Obbalaؤچؤچat lei nu ahte eatnasat geat أ،igo sأ،tnesaji oaivvildedje ahte آ«Fjellfinnhua{آ«} filbma ii dagat ahte buorrأ،na gaskavuohta olbmoؤچearddaid gaskka davviguovllus.
	## Sأ،mi fibmafestivأ،la joؤ‘iheaddji Anne Lajla Utsi duoؤ‘aإ،ta ahte sii أ،igo geassأ،dit آ«Villmarkssenter{آ«} bأ،ikkis orrumis, go eaiggأ،t ja sأ،mepolitihkar Issأ،n (Isak Mathis O. Hأ¦tta) lea ovddidan cealkأ،muإ،aid mأ،id olluhat leat dulkon rasistalaإ¾إ¾an.

	# for undefined if left or right
ADD:punct-aistton-left  (&punct-aistton-left)  TARGET ("'" PUNCT) OR ("\"" PUNCT) (*-1 BOS BARRIER ("'" PUNCT) OR ("\"" PUNCT))(NEGATE -1> ("." CLB) OR ("!") OR ("?") LINK *-1 ("آ«" PUNCT LEFT)  OR ("â€œ" PUNCT LEFT) OR ("\"")  OR ("'")  LINK -1 BOS)(NEGATE 0 <SpaceOnRightSide>)(NEGATE 1 ("." CLB) OR ("!") OR ("?"));
	#$ Jos boaؤ‘أ،t dakko, go boaؤ‘أ،t stأ،lu goahtأ،i, de mon galggan neavvut du.{"} Sأ،pmelaإ، vulggii ruoktot.

ADD:punct-aistton-right (&punct-aistton-right) TARGET ("'" PUNCT) OR ("\"" PUNCT) OR ("ï¼‚") (*-1 (&punct-aistton-left));
	## Don ؤچuoؤچؤچut mu 'ovddas'.
	## Ii lean eambbo go okta vuohki dأ،n eastadit, jus eisevأ،ldit eai hأ،liidan vuotnabivddu oalأ،t nohkat".
	## Muhto earenoamأ،إ¾it lei hأ،vdda birra sأ،hka: 1926:s dagai Davvesiidda suohkanstivra rأ،fأ،iduhttincealkأ،muإ،a, vai lottit mat "dأ،l leat hui unnأ،n, eai galgga oalأ،t nohkat" (FFF 1926: أ،إ،إ،i 88, s. 337).

ADD:punct-aistton-right (&punct-aistton-right) TARGET ("'" PUNCT) OR ("\"" PUNCT) OR ("ï¼‚") OR ("آ»") OR ("â€œ") (0 <SpaceOnRightSide> OR <LastCohortOfParagraph>);

ADD:punct-aistton-right (&punct-aistton-right) TARGET ("'" PUNCT) OR ("\"" PUNCT) OR ("ï¼‚") OR ("آ»") OR ("â€œ") (1 ("." CLB) OR ("!" CLB) OR ("?" CLB) OR COMMA OR (":" CLB) OR (";" CLB) OR ("-" PUNCT));
	## Doppe biddjui ovdan nu ahte sأ،pmelaؤچؤچaide mearkkaإ،a dأ،t: آ«leat dahje ii leat{آ»}.

	# 2. Add COERROR tags to the preceding/following word (depending on LEFT or RIGHT quotation marks), to handle overlapping errors:
MAP:punct-aistton-both-link  (&punct-aistton-both COERROR )  TARGET (*) IF (-2 (&punct-aistton-both) LINK NOT 0 (COERROR)) ;
ADD:punct-aistton-left-link  (&punct-aistton-left COERROR )  TARGET (*) IF (-1 (&punct-aistton-left) LINK NOT 0 (COERROR)) ;
#ADD:punct-aistton-left-link  (&punct-aistton-left COERROR )  TARGET (*) IF (-*<1 (>>>) BARRIER (>>>) (&punct-aistton-left) LINK NOT 0 (COERROR)) ;
	# when it follows the next window

ADD:punct-aistton-right-link (&punct-aistton-right COERROR ) TARGET (*) IF (1 (&punct-aistton-right) LINK NOT 0 (COERROR)) ;

ADD:punct-aistton-right-link (&punct-aistton-right COERROR) TARGET ("." CLB) OR ("!" CLB) OR ("?" CLB) IF (1*> (>>>) BARRIER (>>>) LINK 1 ("'" PUNCT <SpaceOnRightSide>) OR ("\"" PUNCT <SpaceOnRightSide>) OR ("ï¼‚" PUNCT <SpaceOnRightSide>) OR ("آ»" PUNCT <SpaceOnRightSide>) LINK NOT 0 (COERROR)) ;
	# when  jumping  to the next window

	# 3. Add relation RIGHT/LEFT from the sentral cohort to the LINKed cohort for extended underline:
ADDRELATION:punct-aistton-both-rel  (RIGHT) (&punct-aistton-both)  TO (2  COERROR LINK 0 (&punct-aistton-both) );
ADDRELATION:punct-aistton-left-rel  (RIGHT) (&punct-aistton-left)  TO (1  COERROR LINK 0 (&punct-aistton-left) );
ADDRELATION:punct-aistton-left-rel  (RIGHT) (&punct-aistton-left)  TO (1*> (>>>) BARRIER (>>>) LINK 1 COERROR  LINK 0 (&punct-aistton-left) );
	## Jos boaؤ‘أ،t dakko, go boaؤ‘أ،t stأ،lu goahtأ،i, de mon galggan neavvut du.{"} Sأ،pmelaإ، vulggii ruoktot.
ADDRELATION:punct-aistton-right-rel (LEFT)  (&punct-aistton-right) TO (-1 COERROR LINK 0 (&punct-aistton-right));
ADDRELATION:punct-aistton-right-rel (LEFT)  (&punct-aistton-right) TO (-1*< (<<<) BARRIER (<<<) LINK 0 COERROR LINK 0 (&punct-aistton-right));

	# 4. Generate suggestions including the following/preceeding word (ie matching underline):
	# Generer forslag for hermeteikn pأ¥ _begge_ sider viss me har feilen pأ¥ eitt og same ord:
COPY:punct-aistton-both-sugg KEEPORDER (VSTR:"â€‌$1â€‌"S SUGGESTWF) TARGET (&punct-aistton-both) IF
        (NOT 0 (COERROR))
        (2 &punct-aistton-both)
        (2 COERROR)
        (1 ("<(.*)>"r))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;

	# Generer forslag for doble hermeteikn pأ¥ _venstre_ side:
COPY:punct-aistton-left-sugg KEEPORDER (VSTR:"â€‌$1"S SUGGESTWF) TARGET (&punct-aistton-left) IF
        (NOT 0 (COERROR))
        (NOT 0 ("'" PUNCT) OR ("â€ڑ") OR ("â€›") OR ("â‌›") OR ("â€ک"))
        (1 &punct-aistton-left LINK 0 COERROR LINK 0 ("<(.*)>"r))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;

	# Generer forslag for enkle hermeteikn pأ¥ _venstre_ side:
COPY:punct-aistton-left-sugg KEEPORDER (VSTR:"â€™$1"S SUGGESTWF) TARGET (&punct-aistton-left) IF
		(0 ("'" PUNCT) OR ("â€ڑ") OR ("â€›") OR ("â‌›") OR ("â€ک"))
        (NOT 0 (COERROR))
        (1 &punct-aistton-left LINK 0 COERROR LINK 0 ("<(.*)>"r))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;

	# Generer forslag for hermeteikn pأ¥ _hأ¸gre_ side:
COPY:punct-aistton-right-sugg KEEPORDER (VSTR:"$1â€‌"S SUGGESTWF) TARGET (&punct-aistton-right) IF
        (NOT 0 (COERROR))
        (NOT 0 ("'" PUNCT))
        (-1 &punct-aistton-right LINK 0 COERROR LINK 0 ("<(.*)>"r))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;
	# this one is after a clause/window boundary
COPY:punct-aistton-right-sugg KEEPORDER (VSTR:"$1â€‌"S SUGGESTWF) TARGET (&punct-aistton-right) IF
        (NOT 0 (COERROR))
        (NOT 0 ("'" PUNCT))
        (-1*< (<<<) BARRIER (<<<) LINK 0 &punct-aistton-right LINK 0 COERROR LINK 0 ("<(.*)>"r))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;
   ## Jos boaؤ‘أ،t dakko, go boaؤ‘أ،t stأ،lu goahtأ،i, de mon galggan neavvut du{."} Sأ،pmelaإ، vulggii ruoktot.

	# Generer forslag for hermeteikn pأ¥ _hأ¸gre_ side:
COPY:punct-aistton-right KEEPORDER (VSTR:"$1â€™"S SUGGESTWF) TARGET (&punct-aistton-right) IF
        (NOT 0 (COERROR))
        (0 ("'" PUNCT))
        (-1 &punct-aistton-right LINK 0 COERROR LINK 0 ("<(.*)>"r))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;

# ADD (&keep-your-voice-down) ("^[A-Zأ†أکأ…أپإ إ½ؤگإٹ]+$"r) (NOT (0 (<firstCohortOfParagraph>)));

ADD (&punct-end) TARGET Nom (-1 (\n));

	## آ«ؤŒohkken أ،iggiid ؤچaؤ‘a buoremus sأ،mi artisttaidآ»



    # Spacing errors
    # --------------

# Note that some of these rules some times have to span windows â€“ but
# still go exactly one word â€“ which is a little complicated in
# CG. Therefore, we define some templates for going exactly one word
# to the left/right:
TEMPLATE prevWordCrossSent = (-1 (*)) OR (-1 (>>>) LINK *-2< (<<<) BARRIER (<<<)) ;
TEMPLATE nextWordCrossSent = (1 (*))  OR (0  (<<<) LINK *1>  (>>>) BARRIER (>>>) LINK 1 (*)) ;
# In the above template, the first test is the regular, non-spanning
# case â€“ it just goes exactly one word to the right and matches
# anything.
#
# The second test, if the first one didn't match, will only run from
# the last cohort of a window, and will link to the first word of the
# following window. The "0 (<<<)" means "we're the last word", while
# the (>>>) matches the invisible first cohort of the following window
# (and the BARRIER ensures we only cross exactly one window
# boundary). Then we match anything on the following cohort, which is
# the first real cohort of the window.
#
# See http://beta.visl.sdu.dk/cg3/single/#test-spanning for some
# documentation on the < and > modifiers, and
# http://beta.visl.sdu.dk/cg3/single/#templates on templates. The
# below rules use these templates like
# (T:nextWordCrossSent LINK 0 (<someTag>))

## ( أ،ddejumi

	# Clean up potential punctuation error tagging before making real errors of them
	# ------------------------------------------------------------------------------

	# Remove the <NoSpaceAfterPunctMark> tag if followed by a quote sign:
SUBSTITUTE:RemopveNoSpaceAfterPunctMark (<NoSpaceAfterPunctMark>) (*) TARGET CLB IF (T:nextWordCrossSent LINK 0 QMARK );
#SUBSTITUTE:RemopveNoSpaceAfterPunctMark (<NoSpaceAfterPunctMark>) (*) TARGET ABBR IF (1 PUNCT-RIGHT );

SUBSTITUTE:RemoveNoSpaceAfterPunctMark (<NoSpaceAfterPunctMark>) (*) TARGET ("!") IF (T:nextWordCrossSent LINK 0 ("!"));
	## Rأ،hkat seaguhusa bohttalii, ja biddju de viesu lusa ja de!!!

SUBSTITUTE:RemoveNoSpaceAfterPunctMark (<NoSpaceAfterPunctMark>) (*) TARGET ("?") IF (T:nextWordCrossSent LINK 0 ("?"));

	# Error tags on bad punctuation or missing/extra spaces
	# -----------------------------------------------------

ADD:space-after-paren-beg      (&space-after-paren-beg)       TARGET (<spaceAfterParenBeg>) ;
ADD:space-after-paren-beg-link (&space-after-paren-beg COERROR) TARGET (*) IF (-1 (<spaceAfterParenBeg>) ) ;
ADDRELATION:space-after-paren-beg-rel (RIGHT) (&space-after-paren-beg) TO (1 (COERROR) LINK 0 (&space-after-paren-beg)) ;
COPY:space-after-paren-beg-sugg (VSTR:"$1$2"S SUGGESTWF) TARGET ("<(.*)>"r &space-after-paren-beg) IF
        (1 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;
	## أ،ddejumi )

ADD:space-before-paren-end      (&space-before-paren-end)       TARGET (<spaceBeforeParenEnd>);
ADD:space-before-paren-end-link (&space-before-paren-end COERROR) TARGET (*) IF (1 (<spaceBeforeParenEnd>) );
ADDRELATION:space-before-paren-end-rel (LEFT) (&space-before-paren-end) TO (-1 (COERROR) LINK 0 (&space-before-paren-end) );
COPY:space-before-paren-end-sugg (VSTR:"$2$1"S SUGGESTWF) TARGET ("<(.*)>"r &space-before-paren-end) IF
        (-1 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;
	## Son gii njeaidأ، skأ،luid إ،addأ، eret vuolgit. De galgأ، fas cegget skأ،luid ja أ،lgit gaikut.

ADD:space-before-punct-mark (&space-before-punct-mark) TARGET (<SpaceBeforePunctMark>)(NEGATE -1 <SpaceOnRightSide>);
	#$ Paltto (s. 37) آ«mأ،nأ،t sturrot/mun ieإ، boarأ،smuvanآ» {?}?
ADD:space-before-punct-mark-link (&space-before-punct-mark COERROR) TARGET (*) IF (1 (<SpaceBeforePunctMark>) );
ADDRELATION:space-before-punct-mark-rel (LEFT) (&space-before-punct-mark) TO (-1 (COERROR) LINK 0 (&space-before-punct-mark) );
COPY:space-before-punct-mark-sugg (VSTR:"$2$1"S SUGGESTWF) TARGET ("<(.*)>"r &space-before-punct-mark) IF
        (-1 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;
	## vuosttu  ceggejit
	## أ،lgit gaikut.  Stoagus joatkأ،
	## maid lea bargu.  â€“ Mun barggan

ADD:double-space-before (&double-space-before)     (<doubleSpaceBefore>);
ADD:double-space-before-link (&double-space-before COERROR) TARGET (*) IF (T:nextWordCrossSent LINK 0 (<doubleSpaceBefore>)) ;
ADDRELATION:double-space-before-rel ($2) (*) FROM (T:nextWordCrossSent LINK 0 (<doubleSpaceBefore>)) ;
ADDRELATION:double-space-before-rel (LEFT) (COERROR) FROM (T:nextWordCrossSent LINK 0 (<doubleSpaceBefore>)) ;
COPY:double-space-before (VSTR:"$2\ $1"S SUGGESTWF) TARGET ("<(.*)>"r &double-space-before) IF
        (T:prevWordCrossSent LINK 0 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;
	# Test sentence: 'Sanner,gii rأ،ؤ‘ؤ‘ehusas.gii lأ،vvardaga?Bonju dأ،n!Lassin.'
	## Sanner,gii                       - works
	## rأ،ؤ‘ؤ‘ehusas.Europride-festivأ،la   - does not work
	## lأ،vvardaga?Bonju                 - does not work
	## rأ،idovأ،zzimis!Lassin             - does not work

	# 1. Add error tag on punctuation
LIST no-space-after-punct-OK-before = (")") ("/") ("!") ("?") (","); # آ«jna.)آ» is OK

#ADD:no-space-after-punct (&no-space-after-punct-mark) TARGET (<NoSpaceAfterPunctMark>) IF (T:nextWordCrossSent) (NOT 1 no-space-after-punct-OK-before)(NEGATE 0 (A Arab));

ADD:no-space-after-punct (&no-space-after-punct-mark) TARGET (<NoSpaceAfterPunctMark>) IF (T:nextWordCrossSent LINK NOT 0 no-space-after-punct-OK-before)(NEGATE 0 (A Arab))(NEGATE 0 Sem/Sign LINK 1 Sem/Sign LINK 1 Sem/Sur)(NEGATE 1 (Num Arab Sg) OR (Num Sem/ID) LINK -1 (";") LINK -1 (Num Arab Sg) LINK *-1 ("ahki") BARRIER (*) - (Num Arab Sg) - (Num Sem/ID) - (";"))(NEGATE 0 (ABBR Gram/IAbbr) LINK 1 COMMA OR CITATION)(NEGATE 0 ("!") LINK 1 ("!"))(NEGATE 0 Sem/Date OR ABBR LINK 1 COMMA OR (";") OR (":"))(NEGATE 0 ("..."))(NEGATE 0 COMMA LINK 1 ("." CLB))(NEGATE 0 ( "." CLB) OR ( "?" CLB) OR ( "!" CLB) OR ( "," CLB) LINK *1> ("آ»") OR (""") OR ("'")) (NEGATE 0 ( "?" CLB) OR ( "!" CLB) LINK *1> ( "?" CLB) OR ( "!" CLB))(NEGATE 0 (")") LINK -1 ABBR)(NEGATE 0 ABBR LINK 1 (")")) ;
	#$ Erenoamأ،إ¾it ruoإ§a gأ،ldut ؤچuoؤچؤچuhit ahte sأ،miin ii leat leamaإ، ieإ¾aset metأ،lladiإ‹ggaid buvttadus. Muhtin girjjis sأ،mi kultuvrra birra ؤچuoؤچؤچuhuvvo ahte آ«Datni lea أ،idna metأ،lla maid sأ،mit leat ieإ¾a gieؤ‘ahallan....آ» ja Vaapsteguovllus muitala nuppi girji: آ«Metأ،llas eai rأ،hkadan sأ،mit makkأ،rge ruovttodoallobiergasa. Visot maid dأ،rbbaإ،ii, son osttii, ja dat ii lean ollu ge.آ»
	#$ Rأ،hkat seaguhusa bohttalii, ja biddju de viesu lusa ja de!!!
    #$ ILS أ،rvvoإ،talai buot geahؤچؤچalemiid mannan giؤ‘a maid {4.}, 7. ja 10. luohkأ،id ja vuoؤ‘ؤ‘okurssa oahppit ؤچaؤ‘ahedje.
    #$ Dأ،s buvttأ،n dأ،l ieإ¾an ؤچأ،llosiid; jearahallamiid آ«mearrasأ،mehoavddainآ» {H.}J. Leonardsen, ja Nordkapp Sأ،miid Searvvi joؤ‘iheddjiin, Ivar Utsi.
    #$ Beaivegirjenotأ،htat agis {1;1â€“3;6.4} leat oktiibuot logi ieإ،guؤ‘ege sturrosaإ، ؤچأ،llingirjji, muhto guorahallanأ،igodaga rأ،ddjema dihte {gؤچ. s. 54} geavahan dأ،s ovcci vuosttaإ، girjji agi 3;0.6 rأ،djأ،i, seamma ahkأ،i goas maإ‹imus videobأ،tti materiأ،la lea bأ،ddejuvvon.
    #$ Dأ،t dovdomearkkat leat maid boazodoalu muohtakarakteriseremis, mas omd. geavahit dajaldagaid assأ،s geardni dan sadjأ،i go dأ،rkilis mihtidemiin, ahte lea omd. 10 cm geardni (Eira {et al.}, 2011, sisa sأ،ddejuvvon).

	# 2. Add error tag + COERROR on the following word (part 1 of extending the blue underline to the following word):

ADD:no-space-after-punct-link (&no-space-after-punct-mark COERROR) TARGET (*) IF (T:prevWordCrossSent LINK 0 (&no-space-after-punct-mark) LINK NOT 0 (COERROR))(NEGATE 1 (Num Arab Sg) OR (Num Sem/ID) LINK -1 (";") LINK -1 (Num Arab Sg) LINK *-1 ("ahki") BARRIER (*) - (Num Arab Sg) - (Num Sem/ID) - (";"))(NEGATE 0 (Num Arab Sg) OR (Num Sem/ID) LINK -1 (";") LINK -1 (Num Arab Sg) OR (Num Sem/ID) LINK -1 ("ahki"))(NEGATE 0 COMMA LINK -1 (ABBR Gram/IAbbr))(NEGATE 0 ("!") LINK 1 ("!"))(NEGATE 0 COMMA LINK 1 ("." CLB))(NEGATE 0 ( "." CLB) OR ( "?" CLB) OR ( "!" CLB) LINK *1> ("آ»"))(NEGATE 0 ( "?" CLB) OR ( "!" CLB) LINK *1> ( "?" CLB) OR ( "!" CLB))(NEGATE 0 (")") LINK -1 ABBR)(NEGATE 0 ABBR LINK 1 (")"))  ;
	#$ Agi 2;0 rأ،jes guorahallanأ،igodaga loahpageahؤچai, ahkkأ،i 2;10, mأ،nnأ، geavaha 3. persovnna hأ،mis muhtumin geahnohisdأ،sat mأ،ddaga.
	#$ Don oainnأ،t vuolimusas galle sأ،ni galggat ivdnet juohke cealkagis,.

	# 3. Add RIGHT relation on the punctuation (part 2 of extending the blue underline to the following word,
	#    also ensures that the correction will replace the word, not be appended to it):
ADDRELATION:no-space-after-punct-rel (RIGHT) (COERROR) FROM (T:prevWordCrossSent LINK 0 (<NoSpaceAfterPunctMark>)) ;
	# 4. Add suggestions
COPY:no-space-after-punct-sugg (VSTR:"$1\ $2"S SUGGESTWF) TARGET ("<(.*)>"r &no-space-after-punct-mark) IF
        (T:nextWordCrossSent LINK 0 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;

	# No space before parentheses - 1: add error tag on the target cohort:
ADD:no-space-before-parenthesis (&no-space-before-parent-start) TARGET (<NoSpaceBeforeParenBeg>) ;
	## Vuoigatvuoؤ‘a Lأ،vdegotti(SVL).
	#$ Vuoigatvuoؤ‘a Lأ،vdegotti (SVL).

	# No space before parentheses - 2: add error tag + link on the preceding cohort:
ADD:no-space-before-parenthesis (&no-space-before-parent-start COERROR) TARGET (*) IF ( 1 (&no-space-before-parent-start))(NEGATE 0 <NoSpaceBeforeParenBeg> ) ; # the preceding cohort

	# No space before parentheses - 3: add LEFT relation:
ADDRELATION:no-before-after-parenthesis (LEFT) (COERROR) FROM ( 1 (<NoSpaceBeforeParenBeg>)) ;

	# No space before parentheses - 4: Add suggestions
COPY:no-space-before-parenthesis (VSTR:"$2\ $1"S SUGGESTWF) TARGET ("<(.*)>"r &no-space-before-parent-start) IF
        (-1 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;


	# No space after parentheses - 1: add error tag on the target cohort:
ADD:no-space-after-parenthesis (&no-space-after-parent-end) TARGET (<NoSpaceAfterParenEnd>)(NEGATE 1 CLB OR PUNCT)(NEGATE 0 <LastCohortOfParagraph>) ;
	## Vuoigatvuoؤ‘a Lأ،vdegotti(SVL)ؤچilgehus.
	#$ Vuoigatvuoؤ‘a Lأ،vdegotti(SVL).

	# No space after parentheses - 2: add error tag + link on the following cohort:
ADD:no-space-after-parenthesis (&no-space-after-parent-end COERROR) TARGET (*) IF (-1 (&no-space-after-parent-end))(NEGATE 0 <NoSpaceAfterParenEnd> ) ; # the folloowing cohort

	# No space after parentheses - 3: add RIGHT relation:
ADDRELATION:no-space-after-parenthesis (RIGHT) (COERROR) FROM (-1 (<NoSpaceAfterParenEnd>)) ;

	# No space after parentheses - 4: Add suggestions
COPY:no-space-after-parenthesis (VSTR:"$1\ $2"S SUGGESTWF) TARGET ("<(.*)>"r &no-space-after-parent-end) IF
        (1 ("<(.*)>"r))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;


	# comma errors
	# ------------
	#ؤچأ،llinrأ،vagirji komma: muhto-konjunkإ،uvnna ovddabeallai biddjo rihkku. Son livcجŒcجŒii gal viإ،إ،al, muhto sus ii leat goassege dilli bargat. Olgoriikkas ii oahpa duإ،إ،e giela, muhto ollu eanetge.
	#1.2 Goas eat ane rihkku
	#Oanehis cealkagiin mat gullet oktii:
	#Son oaivvildii ahte lea buoret joؤ‘i go oru. Dihten ahte vuolggأ،t odne.
	#Oanehis cealkagiin, main objeaktan lea cealkkaoassi, eat bija rihku konjunkإ،uvnna ahte ovddabeallأ،i:
	#Mun dihten ahte dat ii mana bures.
	#Rihkku galgأ، biddjot oalgecealkaga maإ‹إ‹أ،i.
	#Ahte nu galggai geavvat, dan ii lean gal oktage أ،rvidan.
	#Go أ،hcجŒcجŒi boahtأ،, de mii herskkostallat.
	#Jos mii dalle eat livcجŒcجŒe vuolgأ،n ruoktot, de gal leimmet gأ،rtat vuordit mأ،إ‹ga beaivvi. Vaikke ledjege vأ،iban, de dat dattetge ain jotke.

#DELETE SECOND ROUND
		
ADD:xpunct-rihkku (&punct-rihkku) TARGET BUT-CC + CC IF (NEGATE -1 COMMA OR BOS OR QMARK OR (";") OR ("â€¦") OR (":") OR ("-"));	
	#$ Undertittel: {Muhto} Heaika ii bala dien â€œsأ،nisâ€‌.
    #$ Jus vأ،ssأ،nأ،igi livؤچؤچe earأ،lأ،gan, de livؤچؤچe maid min dأ،lأ،أ،igi ja boahtteأ،igi earأ،lأ،gan â€¦ Muhto أ،llet fal divtte ovttage dadjat didjiide ahte lea menddo maإ‹إ‹it!	
	#$ آ» {M}uhto sii eai adden dأ،n eai ge duostan jearrat sus.
	## Son livcجŒcجŒii gal viإ،إ،al muhto sus ii leat goassege dilli bargat.
	## Olgoriikkas ii oahpa duإ،إ،e giela muhto ollu eanetge.
# comma error: Dan vuoؤ‘ul maid ovdelis lean namuhan balan{,} ahte Kأ،rأ،إ،joga nuoraidruovttus ii leat sihkkaris boahtteأ،igi.
     ## Sii muitaledje maid doppe ledje gullan muhto أپnde gal ii orron jأ،hkkimin dasa.
     
ADD:xpunct-rihkku (&punct-rihkku) TARGET THEN-CS-ADV IF (*-1 BOS LINK 1 THAT-CS OR IF-CS OR ("jos") OR BECAUSE-WHEN OR ("vaikke") OR ("vaikko") OR ("ovdal go") OR ("maإ‹إ‹el go") OR ("dassأ، go") OR ("dan botta go") OR ("dalle go"))(NEGATE -1 COMMA OR BOS OR ("-") OR ("â€“") OR ("/") OR (":"))(NEGATE -1 CC OR CS LINK -1 BOS)(NEGATE *-1 ("ja") BARRIER NPNHA - Po)(NEGATE -1 BECAUSE-WHEN LINK -1 NOT-V LINK -1 COMMA)(NEGATE -1 ("ii" Qst) LINK -1 COMMA);
	#$ Go de dadjأ، ahte dأ،t gapmu lea historjjأ،laؤچؤچat, kultuvrralaؤچؤچat ja sosiأ،lalaؤچؤچat ؤچadnon, de adden ahte vأ،sأ،husat justa leat ؤچoagganan rupmaإ،ii, ja daid vuoؤ‘ul {de} sأ،httit gamus dovdat ovdal go mأ،httit dan ؤچilget.
	#$ Go de ؤچuؤ‘it bohtet sudno vissui, ferteba soai ؤچiehkأ،dit.
	## Jos mii dalle eat livcجŒcجŒe vuolgأ،n ruoktot de gal leimmet gأ،rtat vuordit mأ،إ‹ga beaivvi.
	## Vaikke ledjege vأ،iban de dat dattetge ain jotke.
	## Ovdal go mun bohten de vulggii أ،hؤچؤچi.
	
	# subclause first, main clause with subject first
	# - - - - - - - - - - - - - - - - - - - - - - - -
ADD:xpunct-rihkku (&punct-rihkku) TARGET V IF (0 VFIN)(NEGATE 0 <aux> LINK NOT *1 Inf OR PrfPrc)(NEGATE 0 (Inf SUGGEST) OR (PrfPrc SUGGEST) OR (Adv SUGGEST))(*-1 (Pron Pers Nom) OR (Pron Dem Nom) - @>N OR (N Nom) OR ("dat" Pcle) BARRIER Rel OR CS OR THEN-CS-ADV LINK NOT 0 Rel OR <firstCohortOfParagraph> LINK *-1 VFIN BARRIER CS OR Rel OR COMMA LINK  NOT 0 <vdic> LINK *-1 THAT-CS OR IF-CS OR ("jos") OR BECAUSE-WHEN OR ("vaikke") OR ("vaikko") OR ("ovdal go") OR ("maإ‹إ‹el go") OR ("dassأ، go") OR ("dan botta go") OR ("dalle go") BARRIER COMMA OR (":") OR (";") OR CS LINK -1 BOS)(NEGATE *-1 (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) LINK *-1 COMMA OR BOS BARRIER NPNHAPcle - THEN-CS-ADV)(NEGATE *-1 COMMA OR (";") OR (":") OR ("-") BARRIER (*) - THEN-CS-ADV - Pcle - CS - @SUBJ> - Adv - CC)(NEGATE *1 THEN-CS-ADV LINK -1 COMMA)(NEGATE -1 Adv LINK -1 CC);
	#$ Go dأ،n digaإ،tallama loktejit guovllulaإ، dأ،ssأ،i de das lea buoret vuoؤ‘ؤ‘u gأ،vdnat vel eanet  buori أ،kkaid  ja buorebut {} sأ،httet oktiiؤچatnat fierpmأ،dagaid Norggas ja Suomas.
	#$ Vaikko nأ، buorit ovdamunit leat; eahpelihkostuvvat mii atnit vejolaإ،vuoؤ‘aideamet ja {} leat vuoittahallit ruovttuguovllus.
	#$ Jus livؤچؤچe ؤچaؤ‘ahuvvon albma dutkamat, ja eai livؤچؤچe duإ،إ،e ؤچaskan oivviid eret vأ،ldoolbmuin, de sihkkarit ؤچأ،llojuvvon historja maإ‹إ‹il 1852 {livؤچؤچii} إ،addan أ،ibbas earأ،.
	#$ Jus leaإ، dieؤ‘ut govvii - {sأ،httibehtet} riإ‹get dahje fitnat min luhtte.
	#$	Sأ،mediggi atnأ، dأ،rbun deattuhit dأ،n ja muittuhit ahte seammأ،s go boazodoalu guohtongeavaheapmi guhkأ، lea mearriduvvon lأ،gas, de leat lأ،gat ja hأ،lddaإ،eapmi uhccأ،n beroإ،tan ja gozihan earأ، sأ،mi resursageavaheami.
    #$ Jus dat leat duoؤ‘at sأ،httأ، dat mielddisbuktit eahpأ،dusa ja balu nuorra sأ،pmelaؤچؤچaid gaskkas {joatkit} / أ،lgit oahpu vأ،ldit Hأ،pmira joatkkaskuvllas.
    #$ Ahte earأ،t eai إ،at galgga stivret vel dan ge maid {mii} jurddaإ،it ieإ¾amet oaivvisteamet.
    #$ Go geahؤچؤچأ، mo ovddeإ، أ،igge أ،rbevirolaإ، mأ،htut fievrriduvvojedje boazodoalus ja buohtastahttأ، dan otnأ، diliin, de sأ،httأ، buorebut addet mii odne gأ،ibiduvvo mأ،htuid seailluheapmأ،i.
    #$ Jos dii livؤچؤچiidet adden maid dأ،t sأ،tni mearkkaإ،a : Vأ،ibmolأ،ؤ‘isvuoؤ‘a mun dأ،htun, in ge oaffara, de ehpet livؤچؤچe dubmen sivahemiid.
   #$ Go maإ‹إ‹أ، fas lean oaidnأ،n dan seamma lأ،ttأ،na, gurإ¾o dahje turista, go son {leat} bivddus lihkostuvvan, de lea son aiddo loktaneamen أ،vvudeamis.
	#$ Vaikke vel Kأ،rأ،إ،jogas ja Guovdageainnus leat matematihkalaؤچؤچat menddo unnأ،n أ،irasat, de dat {leat} liikkأ، أ،idna ovttaskas gielddat mat sأ،ddejit ieإ¾aset أ،irasiid Sأ،mediggأ،i, almmأ، gilvaleami haga earأ، gielddaiguin.	
	#$ Jos eadni dahje أ،hؤچؤچi lea أ،idna olmmoإ، {gii} hأ،llأ، sأ،megiela mأ،nnأ،i, de إ،addأ، lossat oahpahit giela.
	## Maإ‹إ‹il go أ،hؤچؤچi boؤ‘ii mun vulgen.
	## Dassأ، go Niillas boahtأ، mun vuorddأ،n.
	## Dalle go mii leimmet mu أ،hؤچiin ovtta siiddas mun galgen ieإ، vuolgit merrii.

ADD:xpunct-rihkku (&punct-rihkku) TARGET V IF (0 VFIN)(NEGATE 0 <aux> LINK NOT *1 Inf OR PrfPrc)(*-1 (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) OR ("dat" Pcle) BARRIER Rel LINK NOT 0 Rel OR <firstCohortOfParagraph> LINK *-1 VFIN LINK *-1 ("rأ،jes") LINK -1 ("dat" Pron Dem Sg Acc) OR ("dat" Pron Dem Sg Gen) LINK -1 BOS)(NEGATE *-1 (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) LINK *-1 COMMA OR BOS BARRIER NPNHAPcle - THEN-CS-ADV)(NEGATE *-1 COMMA OR (";") BARRIER (*) - THEN-CS-ADV - Pcle);
	## Dan rأ،jes go nأ،italeigga dat juo leaba juo huksen dأ،lu.
	
ADD:xpunct-rihkku (&punct-rihkku) TARGET V IF (0 VFIN LINK 0 NOT-V + Ind LINK *1 ConNeg BARRIER NOT-ADV-PCLE LINK *1 ONE + (Pron Indef Sg Nom Foc/Neg-ge) BARRIER GRAMCHK-S-BOUNDARY)(*-1 VFIN BARRIER <firstCohortOfParagraph> LINK *-1 THAT-CS OR IF-CS OR ("jos") OR BECAUSE-WHEN OR ("vaikke") OR ("vaikko") OR ("ovdal go") OR ("maإ‹إ‹el go") OR ("dassأ، go") OR ("dan botta go") OR ("dalle go") LINK -1 BOS)(NEGATE *-1 (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) LINK *-1 COMMA OR BOS BARRIER NPNHAPcle - THEN-CS-ADV)(NEGATE *-1 COMMA OR (";") BARRIER (*) - THEN-CS-ADV - Pcle);	
	## Ahte nu galggai geavvat dan ii lean gal oktage أ،rvidan.

	# subclause first, main clause without subject first
	# - - - - - - - - - - - - - - - - - - - - - - - - - -
ADD:xpunct-rihkku (&punct-rihkku) TARGET V IF (0 VFIN LINK NOT 0 Inf OR (Gram/3syll Ind Prs Pl3))(NEGATE 0 (PrfPrc SUGGEST) OR (Inf SUGGEST) OR (Adv SUGGEST))(*-1 VFIN BARRIER NOT-ADV-PCLE LINK *-1 THAT-CS OR IF-CS OR ("jos") OR BECAUSE-WHEN OR ("vaikke") OR ("vaikko") OR ("ovdal go") OR ("maإ‹إ‹el go") OR ("dassأ، go") OR ("dan botta go") OR ("dalle go") BARRIER (";") LINK -1 BOS)(NEGATE *-1 (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) LINK -1 COMMA OR BOS)(NEGATE -1 THEN-CS-ADV LINK -1 BECAUSE-WHEN LINK -1 NOT-V LINK -1 COMMA)(NEGATE -1 ("ii" Qst) LINK -1 THEN-CS-ADV LINK -1 COMMA)(NEGATE 0 &syn-double-negation)(NEGATE -1 (V Neg));
	#$ Vaikko luohti lea muhtun guovlluin ealli أ،rbevierru, muhtun sajiin dat fas lea أ،ibbaإ، jأ،vkan.
	#$ Go mأ،nأ،id أ،lo galgأ، ؤچalmmis doallat, amaset {eai} إ،atta biilla vuollai, vأ،idala Gerd ja Biret-أ،hkku lea ovtta oaivilis.		
	## Dan botta go mأ،nnأ، oaؤ‘ؤ‘أ، أ،iggun gohpuid bassat.
    #$ Go geahؤچؤچat leavttu ja dan guؤ‘e guvlui leat manname, ii go {de} livؤچؤچe kapteainnas buot eanemus jierpmأ،laإ، jurdda stivregoahtit nuppe guvlui ja dأ،httut buot olbmuid mannat gأ،djunfatnasiidda?
    #$ Go oahppit leat {adden} dahje ipmirdan ieإ، dan sisdoalu dأ،hpأ،husas, sأ،httأ، oahpaheaddji jearrat ahte leat go sii ovttaoaivilis dأ،inna sisdoaluin.

ADD:xpunct-rihkku (&punct-rihkku) TARGET ("daؤ‘e") IF (*-1 BOS LINK 1 ("maؤ‘e"))(NEGATE -1 COMMA OR BOS);
	## Maؤ‘e losit siivu daؤ‘e njoazebut mannأ، mأ،tki.

ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE ("ja" CC) IF  (1 ("de" &punct-rihkku))(NEGATE 0 ADDED-BEFORE-BLANK);
	## Jus mii dal joatkit vuovdimiin, de ii njuolgga mأ،rkan goassege ja de bأ،llejit kilohatti njeaidit daؤ‘i eanet jagis jahkأ،i ja loahpas ؤچohkkأ،t mii 5 kr. kilohattiin, ballأ، Eira.
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE ("muhto" &punct-rihkku) OR ("de" &punct-rihkku) OR ("daؤ‘e" &punct-rihkku) IF (NEGATE -1 CC LINK -1 (","))(NEGATE -1 ("<,>"))(NEGATE 0 ADDED-BEFORE-BLANK);
	#$ Jus mii dal joatkit vuovdimiin, de ii njuolgga mأ،rkan goassege ja de bأ،llejit kilohatti njeaidit daؤ‘i eanet jagis jahkأ،i ja loahpas ؤچohkkأ،t mii 5 kr. kilohattiin, ballأ، Eira.
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) OR ("dat" Pcle) IF (*1 VFIN + (V &punct-rihkku) BARRIER NOT-ADV-PCLE)(NEGATE -1 ("<,>"))(NEGATE 0 ADDED-BEFORE-BLANK) ;
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE VFIN IF (0 (V &punct-rihkku))(*-1 VFIN BARRIER NOT-ADV-PCLE)(NEGATE -1 ("<,>"))(NEGATE 0 ADDED-BEFORE-BLANK) ;

	# this one takes into account the position of the parent of a preceeding accusative
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE Acc IF (rp V) (1 (V &punct-rihkku))(NEGATE -1 ("<,>"))(NEGATE 0 ADDED-BEFORE-BLANK) ;


	# goallosأ،hcu sأ،ni ovdal
	# - - - - - - - - - - - -
	
##ADD:punct-sahcu (&punct-sأ،hcu) TARGET ("-" PUNCT) IF (NEGATE -1 CC);	
	## Muitalusat -girji
	
LIST CS-RIHKKU = "ovdal" "ovdalgo" "maإ‹إ‹elgo" "dassأ،إ¾ii" ;
	

	# Comma between two main clauses with subject
	# - - - - - - - - - - - - - - - - - - - - - -
	# Rihkku biddjo dievaslaإ، vأ،ldocealkagiid gaskii.

ADD:xpunct-rihkku (&punct-rihkku) TARGET ("ja") IF (NOT 0C @CNP)(*1 SUBJ BARRIER CC OR CS OR VFIN OR <firstCohortOfParagraph> LINK *1 VFIN BARRIER @CVP)(*-1 VFIN BARRIER CC OR COMMA)(NEGATE -1 COMMA OR (";") OR Cmp/SplitR)(NEGATE 1 THAT-CS)(NEGATE -1 Attr OR @>N)(NEGATE -1 (N Sg Nom) LINK 2 (N Sg Nom))(NEGATE 1 (A Sg Nom) OR PrsPrc OR (Der/NomAg N Sg Nom) LINK -2 (Der/NomAg N Sg Nom) OR (A Sg Nom) OR PrsPrc)(NEGATE 1 Interr OR ("makkأ،raإ،"))(NEGATE 1 MO-MANge)(NEGATE -1 VFIN LINK -1 CS-RIHKKU)(NEGATE 1 Inf LINK -2 Inf LINK *-1 AUX)(NEGATE -1 PrfPrc + Der/Pass LINK NEGATE *-1 BE) ;
	#$ Fiinna virge namahuvvon {ja} fiinna namat olbmot leat moanat mأ،llأ،siid oktavuoؤ‘as hupmat viإ،uvnna birra "Sأ،pmi rأ،jiid haga"
    #$ De mun gal vuot fertejin duoؤ‘alaؤچؤچat sutnje geahؤچastit ja jearralit mot moai sأ،htأ،إ،eimmet dأ،n guovllu bullehit - go lagamus bievla lea ؤچuoؤ‘i miilla duohken - muؤ‘ui lea duإ،إ،e muohta nu guhkأ،s go ؤچalbmi guoddأ،.
	#$ أپhku biejus leat mii dأ،l guldaleame mot dalle doloإ، أ،iggi geavai go أ،hkku ja earأ، sأ،hpannieiddat ledje meahccأ،i lأ،hppon, ja go buoidda ؤŒere {ja} guokte vilgesأ،hpanbأ،rtni sin doppe gأ،vdne ja hأ،ste sin ieإ¾aset bieju lusa vuolgit.
	 #$ Dأ،l ii leat ge إ،at guhkأ، ovdal {bivalda} ja muohta suddأ،, ja de إ،addأ، fas buoret guohtun.
     #$ Dأ،s oahpaheaddji sأ،httأ، fuomأ،إ،it geat أ،ddejit rolla-sأ،ni sisdoalu {ja} mo earأ،t leat ؤچoavdأ،n // adden dan.
	 #$ Dat earru lea dat ahte makkأ،raإ، vuolggasajis dutkan dahkko, gean dأ،rbbuide dat dahkko {ja} makkأ،raإ، أ،ddejumi dieؤ‘u birra lea go dutkamuإ، dahkko.
	 #$ Mأ،nأ،idgأ،rdefأ،laldat galgأ، fuolahit mأ،nأ،id giela ja kultuvrra {ja} vuoؤ‘ؤ‘uduvvot dakkأ،r sأ،mi أ،rvvuide go â€œgal dat oahppأ،â€‌ ja mihttomearrأ،i ahte sihkkarastit mأ،nأ، vejolaإ،vuoؤ‘a ovdأ،nit iehؤچanas individan.
	 #$ Danne buktأ، proإ،eavtta â€‌ Buoret أ،rvvoإ،tallangeavahus â€‌ doibmiibidjan oahppoplأ،nageavahusa plأ،nadأ،siide, ja sأ،vvamis vuogأ،iduhttأ، guؤ‘elأ،hkأ،i oahpaheaddjit {ja} skuvlajoؤ‘iheaddjit barget أ،rvvoإ،tallaneavttuiguin ulbmilrelaإ،uvnnas, ja viidأ،seappot veahkehit oahpaheddjiid maiddأ،i konkretiseret gelbbolaإ،vuoؤ‘aulbmiliid ieإ،guhtetge oahppi oahppoulbmilin.
	 #$ Skأ،iddeduoddara badjeolbmot ballet oؤ‘ؤ‘a EO- njuolggadusat ja gأ،ibadusat sأ،httet dagahit ahte	Mأ،ؤ‘أ،rjأ،vrri	boazunjuovahat Porsأ،nggus ii dohkkehuvvo.
	 #$ SأپMI KULTUVRA Sأ،mediggi oaidnأ، ahte lea deaإ§alaإ، ja {riggudahtti} Norgii bisuhit sأ،mi giela, kultuvrra ja أ،rbevieruid dain guovlluin gos sأ،mit أ،rbevirolaؤچؤچat leat أ،ssan, ja gos dii doibmet . 
	 ## Dat lea oalle galmmas ja vuoddjit leat bidjan rأ،jأ، 25 buolaإ،grأ،dii, ؤچilge Hأ¦tta.
	 ## Dasa lassin lea Ruoإ§a Sأ،mediggi lohpidan doarjut riikkajoavkku 90 000.-, dieؤ‘iha presideanta â€“ Ruoإ§a Sأ،mediggi lea hأ،rve dorjon riikkajoavkku {ja} mii leat ilolaإ، go dأ،l أ،ddet doarjaga.
	 #$ Dأ،n buإ،eahttapoastta badjel ruhtaduvvo sأ،mi aviissaid buvttadeapmi ja doarjja buvttadit aviisasiidduid julev- ja mأ،ttasأ،megillii.
	 #$ Geasi أ،igge dأ،n guovllus vأ،nddardettiin olbmui إ،addأ، dego niegulأ،gan dovdu, dasgo go beaivi bأ،itأ، {ja} ligge jأ،ndoriid mielde ovtta manu, de أ،igeأ،ddejupmi jأ،vkأ، dego bihؤچosa ahkidis huikkaإ،eapmi duottarvieltti jeakkأ،dagas.
	 #$ Rأ،ؤ‘ؤ‘i أ،dde ahte dأ،t buktأ، eahpesihkkarvuoؤ‘a sihke bargiide {ja} erenoamأ،إ¾it geavaheaddjiide, go dأ،t lea أ،idna mأ،nأ،idsuodjalanfأ،laldat sأ،megielat nuoraide geat leat gaskal 12-18 jagi. 
     ## Elle boؤ‘ii mأ،nأ،inis jo juovlamأ،nus ja earأ،t fas gأ،rte vuordit gitta guovvamأ،nnui. 
     ## Mun liikon cجŒuoigat ja Mأ،ret fas liiko viehkat.
     #$ Sأ،mediggi lea finnmأ،rkkulأ،hkaproseassa rأ،jes juohke أ،idna lأ،hkabarggus oaivvildan ahte ILO-konvenإ،uvdna nr. 169 ferte siskkأ،ldahttojuvvot {ja} ahte dasa ferte addojuvvot ovdasadji Norgga lأ،ga ovddabeallأ،i seamma lأ،hkai go konvenإ،uvnnat Siviila ja Politihkalaإ، vuoigarvuoؤ‘aid birra ja maiddأ،i Ekonomalaإ، Sosiأ،la ja Kultuvrralaإ، vuoigatvuoؤ‘at birra leat oإ¾إ¾on.
     #$ Dأ،t bargu lea dehأ،laإ، vai juohke أ،idna sأ،pmelaإ، galgأ، sأ،httit أ،vkkأ،stallat vuoigatvuoؤ‘a- {ja} politihkkaovdأ،neami mii lea dأ،hpأ،huvvan maإ‹imus moaddelot jagi ja boahtأ،n أ،vkin sأ،pmelaؤچؤچaide Norggas.
     
     
ADD:xpunct-rihkku (&punct-rihkku) TARGET (Nom) IF (0 Sem/Animate - Num - ("ieإ،") LINK *1 VFIN BARRIER Rel OR GRAMCHK-S-BOUNDARY OR COMMA OR CC OR ("iige") LINK NOT 0 Inf)(NEGATE 0 Rel OR (A Sem/Hum Comp))(*-1 VFIN - Imprt BARRIER @CVP OR FS-QPRON-ADV OR CS-RIHKKU OR ("galle") OR COMMA OR (";") OR (":") LINK NOT 0 COPULAS OR Neg OR <aux> OR (SUGGEST Adv))(NONE lp VFIN)(NEGATE -1 CS OR CC OR CP)(NEGATE 0 @<SPRED)(NEGATE -1 COMMA OR (";") OR (":") OR ("â€¹") OR ("â€œ") OR ("-") OR Attr OR @>N)(NEGATE 1 CP)(NEGATE 0 Prop LINK -1 Prop LINK 0 Gen OR Acc)(NEGATE 0 Sem/Human LINK *-1 <vdic> BARRIER NOT-ADV-PCLE)(NEGATE 0 $$PERS-NUM LINK -1 AUX + $$PERS-NUM)(NEGATE 0 N LINK -1 (Pron Sem/Hum Pers Acc) OR (Pron Sem/Hum Pers Gen))(NEGATE 0 $$NUMBER + (Pron Nom) LINK *-1 $$NUMBER + V)(NEGATE -1 ("mannat" V IV Ind Prt Pl3) OR ("mannet" V IV Ind Prs Sg3) OR ("mannat" V IV Ind Prs Du1) LINK -1 BOS)(NEGATE 1 Po)(NEGATE 0 ("[A-Z].*"r) - Prop)(NEGATE -1 ("<[A-Z].*>"r))(NEGATE -1 ("dأ،ssأ،") OR <TH-ahte> + VFIN); # LINK *2 VFIN BARRIER Rel OR GRAMCHK-S-BOUNDARY LINK 0 Inf);
	#$ Maid dahke dasto Ieإ،jأ،rluntta - {geat} ledje gilvvu lأ،gideaddjit?
	#$ Easka de ؤچأ،jeha galle suorpma {boaris} son lea.
	#$ Muhto kantorolbmأ،i jorggihii ؤچأ،llinmأ،إ،iidnii go ipmirdii mii leimme mأ،rإ،kku bأ،rtnit.
    #$ Das lohkأ، biebman ealu dأ،ssأ، Boazodoallostivra meannudii ohcama mas lei bivdأ،n gaskaboddosaإ، lobi luoitit ealu Jillen-Njaarkei dأ،ssأ،i oؤ‘ؤ‘a doallu rahppo.	
	#$ Oassi mis hأ،llأ، muhtun sأ،megiela, oasis bearraإ،iin {mأ،nأ،t} eai leat oahppan sأ،megiela ovtta dahje mأ،إ‹ggaid sohkabuolvvaid أ،igge.
	#$â€“Dأ،s girddii garjأ، badjel dأ،hkki ja gahؤچahii varas dأ،vtti muvrarأ،iggi bodnأ،i.
	#$ Duvvأ،t borret riissaid, maid olbmot bأ،lkot nأ،ittosbأ،rra ala -ja dat bohtanit ؤچoavjjis ja duvvأ،t jأ،pmet.
	#$ إ livgii duإ،إ،e rأ،nu {mun} ala, ii lean ge dأ،rbu eanet go lei juo geassebأ،hkka.
	#$ Manne {mii} eai daid sأ،hte geavahit dan sadjأ،i go ؤچuovvut ameriikkalaإ، vieruid, loahpaha Johnsen ja muitala vuosttaإ، Soigosat doalut dollojuvvojedje 2003 njukؤچamأ،nus.
	#$ Dأ،bأ،laإ، spiehkastat lei maid atnit goalmmأ،t persovnna hأ،miid earأ، sojahanhأ،miid sajis, ovdamearkka dihte nأ، : â€¹ {Mun boahtأ،} â€؛, â€¹ moai lohkأ، â€؛, â€¹ don gomihii â€؛ ja â€¹ mأ،nأ،t أ،lggii â€؛, ؤچilge Ijأ¤s.
	##آ Dalle dolvon {ieإ،} ohcamuإ،a ja أ،dden dan ruovttubأ،lvalusa joؤ‘iheaddjأ،i, muitala Guovdageainnu nisu Aili Skum Norvang.
	 #$ Kirste Paltto romأ،nii Guhtoset dearvan min {bohccot} ؤچujuhuvvo ovdamearkan oanأ،dusain ( GDMB 9 ), dasgo lea أ،lkit geavahit dan go guhkit ؤچujuhusa ( Paltto 1987 : 9 ).
	 #$ Ruؤ‘ain galget sii oasttit sأ،mi stohkosiid Hأ،mmerfeasta buohccivissui - mأ،nأ،idossodahkii
	 #$ Jurddaإ، duإ،إ،e ieإ،, stuora lossa skuterin girdit 10 mehtera أ،immus, dadjأ، {Siri}, ja muitala ahte su eadni gal meastta cissai buvssaide go oinnii su njuikume.
	 #$ Hui ollusat leat duإ،إ،e geavahan luohte oasi ja Sverre Kjelsberg oasi leat guoؤ‘ؤ‘أ،n, dadjأ، Simona {Mأ،htte} ja lohkأ، son ii dieؤ‘e manne Sverre Kjelsberg ii lean mielde Gylne Tider joavkkus.
	 #$ In hأ،lit geange diktaؤچأ،lli stiilla geavahit, muhto, numo أپillohaإ،, de liikon {munge} modearna stiilla, mii ii leat ؤچatnon masage. 
	 #$ Norggas liikojit ovccis logi olbmos bohccobierggu ja fas gأ،vccis logi olbmos dadjet bohccobiergu lea dearvvaإ،laإ، borramuإ،, ؤچأ،jeha varas oaiviliskkus maid Synovate lea dahkan.
	 #$ Leat mii geat stivrejit, ja leat mii geat diehtit man ؤچeahpit mii leat.  
	 #$ Maإ‹إ‹أ، ؤچoahkkima mii lei أ،mmأ،tvirgeolbmأ،id dأ،sis njukؤچamأ،nus 2006, de galge Ruoإ§a departemeantta أ،irasat guorahalat dien أ،إ،إ،i {dأ،rkileappot}, earet earأ، gأ،vnnahit sierra lأ،hkavuoؤ‘u geahؤچؤچaladdandoaimmaide
	 #$ Finnmأ،rkku fylkkamأ،nni cuiggoda fylkkagieldda go eai dأ،rkkis oإ¾إ¾otgo mأ،nأ،t {geat} orrot mأ،nأ،idsuodjalusinstituإ،uvnnaid dan oahpu maid sis lea riekti oaإ¾إ¾ut.
	 #$ Danin orro leamen nu go mii jأ،hkiimet, ahte biehttaleapmi mielddisbuktأ، heajot أ،rvvoإ،tallama go doarjun, muhto eat {mii} almmatge ؤچuoؤچؤچut ahte dat lea أ،idna sivva dan govvii maid mii dأ،s oaidnit, mii ؤچأ،jeha makkأ،r oaidnu guؤ‘esge lea fondii.
	 #$ Son jearrala dan guovtti njuvؤچؤچas ahte diehtiba soai gos {Soria-Moria} sloahtta lea.
	 #$ Dأ،t lea vuosttaإ،, {ja} dأ،ssأ،إ¾ii أ،idna, suohkan lullisأ،meguovllus mii boؤ‘ii mielde hأ،lddaإ،anguvlui.	 
	 #$ Girkonjأ،rgga joatkkaskuvla lea fylkka أ،idna {joatkkaskuvla} geas lea ieإ¾as neahttasiidu sأ،megillii.
	 ## Mأ،htte cجŒأ،lii teavstta Elle fas heivehii dan nuhttii. 
	 # needs testing
     ## Mأ،htte mأ،rfu, Elle bassأ، ja Biera ؤچorge ovdal go mii vuolgit.
     ## Muhtumat lohket earأ،t ؤچأ،llet.
     #$ Arktalaإ، Rأ،ؤ‘ؤ‘i lea أ،idna guovlluguovdasaإ، ovttasbargoorgأ،na mii siskkilda gأ،vcci أ،rktalaإ، riikka ; vihtta davviriikka, USA.
     #$ Lأ،vdegoddi cealkأ، ahte sأ،mi jienastuslohku lea أ،idna lohku maid sii leat sأ،httأ،n atnit vuoؤ‘ؤ‘un barggusteaset.
     #$ Loabأ،ga gielda lea أ،idna gielda regiovnnas mii guovvamأ،nus 2008 lea mearridan ahte gielda dأ،httu ohcat beassat mielde sأ،megiela hأ،lddaإ،anguvlui.
     
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE ("ja" &punct-rihkku) IF (NEGATE -1 (","))(NEGATE 0 ADDED-BEFORE-BLANK);
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE (Nom &punct-rihkku) IF (NEGATE -1 (","))(NEGATE 0 ADDED-BEFORE-BLANK);
	 ## Soai muitaleaba soai hأ،liideaba olbmuid beroإ،tiإ،goahtit eambbo ieإ¾aset أ،ssanbأ،ikkiid birra.
     ## Cealkagiid gaskkas main lea oktasaإ، cealkkaoassi
     ## Elle finai vuos buvddas ja de manai ruoktot. (Oktasaإ، subjeakta)
     ## Johan أ،iggui vأ،ldit eksأ،mena ja mun maid. (Oktasaإ، verbأ،la ja objeakta) Mأ،htte manai oarjjabeallai ja Biera nuorttabeallai. (Oktasaإ، verbأ،la)
     ## Gaإ¾aldatmearkka ja cجŒuorvvasmearkka maإ‹is
     ## â€‌Manne lea mأ،ilbmi jorbbas?â€‌ jearai mأ،nnأ،. â€‌Vuoi daid cجŒأ،ppa lأ،bbأ،id!â€‌ cجŒurvii أ،hkku.
     ## Beaivأ،demiid oktavuoؤ‘as
     ## Buolbmأ،gis juovlamأ،nu 3. beaivvi 1995 Buolbmأ،gis juovlamأ،nu 3 beaivvi 1995 Buolbmأ،gis 2015-03-15
     
ADDRELATION ($2 LEFT) (CC &punct-rihkku) TO (-1 (ADDED-BEFORE-BLANK &punct-rihkku)) ;

    # vأ،ilu "ja" dahje rihkku listtus
    # -------------------------------
    
LIST 3-STAVVAL-IT-V = (".*dit"r V) (".*git"r V) (".*hit"r V) (".*kit"r V) (".*lit"r V) (".*mit"r V) (".*rit"r V) (".*إ،it"r V) (".*tit"r V) ;

ADD:xpunct-rihkku (&punct-rihkku) TARGET (Inf) OR (Ind Prs Pl1) OR 3-STAVVAL-IT-V + (Ind Prs Pl3) OR 3-STAVVAL-IT-V + (Ind Prt Sg2) IF (-1 Inf LINK NOT 0 <TH-Inf> OR <Inf> LINK -1 COMMA LINK -1 Inf); 
	## Guovddأ،إ، galgأ، ؤچohkket, ovddidit, vuogأ،dahttit, أ،igأ،dit, gieؤ‘ahallat,     heivehallat     gaskkustit أ،إ،إ،أ،isoahppevaإ، dieؤ‘uid ja duoؤ‘aإ،tusaid أ،lgoأ،lbmotvuoigatvuoؤ‘aid birra riikkalaإ، ja riikkaidgaskasaإ، dأ،sis. 
	
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE (V &punct-rihkku) IF (0 Inf OR (Ind Prs Pl1) OR 3-STAVVAL-IT-V + (Ind Prs Pl3) OR 3-STAVVAL-IT-V + (Ind Prt Sg2))(NEGATE -1 (","))(NEGATE 0 ADDED-BEFORE-BLANK);

ADDRELATION (LEFT) (&punct-rihkku) TO (-1 (ADDED-BEFORE-BLANK)) ;



	# Before fallback some specific rule
	# ----------------------------------

SELECT:PcleCompounds Adv IF (1 ("ge")) (0 (Adv Err/Orth-a-أ،));
	## Go suohkan dأ،l viimmأ،tge lea boahtأ،n nehtii, addأ، dat midjiide vejolaإ،vuoؤ‘aid njuolggo oktavuoؤ‘aide suohkana أ،ssiiguin.

	SECTION

	# Fallback error disambiguation
	# -----------------------------

# Remove Err/Orth and other Err/ readings if there are alternative, non-Err readings.
# Should block a number of false positives.
# NB! SUB:* rewritten as SUB:1, SUB:2, etc to work around a serious memory leak in vislcg3.
# Please leave as is until the leak has been fixed by Tino.
# NOT COERROR so we don't remove readings meant to stretch the squiggly underline of other cohort errors

#REMOVE:SuperfluousErrTags SUB:0 AllErrorTags IF (0/* AllErrorTags) (0/* NoErrorTags) (NOT 0 (COERROR)) (NOT 0 (typo)) ;
REMOVE:SuperfluousErrTags SUB:1 AllErrorTags IF (0/* AllErrorTags) (0/* NoErrorTags) (NOT 0 (COERROR)) (NOT 0 (typo)) ;
REMOVE:SuperfluousErrTags SUB:2 AllErrorTags IF (0/* AllErrorTags) (0/* NoErrorTags) (NOT 0 (COERROR)) (NOT 0 (typo)) ;
REMOVE:SuperfluousErrTags SUB:3 AllErrorTags IF (0/* AllErrorTags) (0/* NoErrorTags) (NOT 0 (COERROR)) (NOT 0 (typo)) ;

    # Fallback rules for the remaining errors
    # ---------------------------------------
    #
    # 1. speller output
    # 2. Err/Orth cases not dealt with in other rules
    # 3. Other Err/ type errors (Err/Lex, Err/DerSub, etc)
    # 4. Unrecognised words

# Fallback for Err/Orth â€“ want to underline these too, and preferably generate
# TODO: Different error tag for these? Currently the same as dynamically <spelled> errors.

# Speller suggestions rule - make sure the suggestions survive the cg mangling:
ADD:spelled (typo SUGGESTWF) (<spelled>) IF (NEGATE -1 ("â€‌") OR (""") OR ("â€œ") OR ("â€‌") OR ("â€‍") OR ("â€ں") LINK 2 ("â€‌") OR (""")) ;

	#### Err/Orth rules - make sure all Err/Orth analyses are generated as the normative counterpart of itself:
	# 1. Add a typo error tag if there is an Err/Orth tag __anywhere__ - including in subreadings:


SET NonErr/Orth = (*) - Err/Orth-any ;

ADD:Err/Orth-any (typo) TARGET (*) IF (NEGATE 0/* NonErr/Orth - Err/Lex - Err/Spellrelax)(0/* Err/Orth-any OR Err/Spellrelax)(NEGATE -1 ("â€‌") LINK 2 ("â€‌")) ;
	#$ Dأ،vjأ، dأ،t sأ،tni unnut geavahuvvo dalle go galggaإ،ii hأ،llat geahppأ،neami birra ( mii dieؤ‘usge fas lea أ،ibbas earأ، go {geahppun} ).
	## Dan sadjأ،i bealalaؤچؤچat leat diktan mأ،rkأ،nsأ،gaid leavvat, ja dainna lأ،giin rأ،إ‹ggaإ،tan dأ،rbbaإ،meahttumiid.
	## Girkovأ،lggain  ؤچakؤچamأ،nu  18.  b.  don  vأ،lljet  gosa  Ruoإ§a  girku  galgأ،  bidjat  fأ،mu  lagamuإ،  njeallje  jagi.  Geasa  attأ،t luohttamuإ،a?
	#disregarding simple citations for now
	## Jus dakkأ،r dieؤ‘أ،hus deaddiluvvo jienastanlihpuid {maإ‹أ،beallأ،i}, de galgأ، dan almmuhit ovddabealde.

	# 2. Copy to a new reading minus Err/Orth, to generate suggestions - main reading:

COPY:Err/Orth-any (SUGGEST) EXCEPT Err/Orth-any_OR_TV_IV TARGET (typo) IF (NOT 0/* (SUGGESTWF) OR (SUGGEST));

COPY:Err/Orth-any SUB:0 (SUGGEST) EXCEPT Err/Orth-any_OR_TV_IV TARGET (typo) IF (NOT 0/* (SUGGESTWF) OR (SUGGEST));

COPY:Err/Orth-any SUB:1 (SUGGEST) EXCEPT Err/Orth-any_OR_TV_IV TARGET (typo) IF (NOT 0/* (SUGGESTWF) OR (SUGGEST));
COPY:Err/Orth-any SUB:2 (SUGGEST) EXCEPT Err/Orth-any_OR_TV_IV TARGET (typo) IF (NOT 0/* (SUGGESTWF));
COPY:Err/Orth-any SUB:3 (SUGGEST) EXCEPT Err/Orth-any_OR_TV_IV TARGET (typo) IF (NOT 0/* (SUGGESTWF));
COPY:Err/Orth-any SUB:4 (SUGGEST) EXCEPT Err/Orth-any_OR_TV_IV TARGET (typo) IF (NOT 0/* (SUGGESTWF));
	#THIS does not work at the moment, but hopefully Tino can help

# 3. Substitute Err/Orth in subreadings to get something for generation.
# Cf: http://giellatekno.uit.no/bugzilla/show_bug.cgi?id=2317

#SUBSTITUTE:Err/Orth-any SUB:0 Err/Orth-any (*) TARGET (SUGGEST) ;
#SUBSTITUTE:Err/Orth-any SUB:1 Err/Orth-any (*) TARGET (SUGGEST) ;
#SUBSTITUTE:Err/Orth-any SUB:2 Err/Orth-any (*) TARGET (SUGGEST) ;
#SUBSTITUTE:Err/Orth-any SUB:3 Err/Orth-any (*) TARGET (SUGGEST) ;

	# Some regression tests:
	# 'sأ،tnejodiheaddji' â†’ 'sأ،tnejoؤ‘iheaddji' # Simple Err/Orth
	# 'vuoddoskuvlla' â†’ 'vuoؤ‘ؤ‘oskuvlla'       # Err/Orth in subreading, not main reading
	# 'olgoriikadepartementtas' â†’ 'olgoriikkadepartemeanttas' # Err/Orth in subreading
	# 'stnejodiheaddji' â†’ 'sأ،tnejoؤ‘iheaddji'  # simple <speller>
	# 'Finnmarku' â†’ 'Finnmأ،rku'               # Err/orth-a-أ،
	# 'johttigohte' â†’ 'johtigohte'            # disambiguator sometimes removes this
	# 'buorrre' â†’ 'buorre'                    # <speller>
	# 'husket' â†’ 'hukset'                     # <speller>

COPY:no-double-dot (VSTR:"$1"S SUGGESTWF) EXCEPT  ("<(.*)[.]>"r) TARGET ("<(.*)[.]>"r <spelled>) IF
        (1 ("<[.].*>"r))
        (NOT 0 ("<$1>"v))
        (NOT 0 (COERROR))
        (NOT 0 (SUGGESTWF))    # don't COPY more than once
        ;
REMOVE:no-double-dot (<spelled> "<.*[.]>"r) IF (1 ("<[.].*>"r));
# Avoid suggestions getting two periods in a row (if there's a following period)
	#$ 6-7 (maإ‹إ‹el rأ،إ‹ggaإ،tusؤچ.)

	#$ Dat beare guhkkأ، doppe, iige {daga} maidege ieإ¾أ،.

## Remove the prederivation transitivity tags Ex/TV and Ex/IV to allow generation. The generator takes input of the following forms:
#
# mearridit+Ex/V+Ex/TV+Der/PassL+V+IV+Ind+Prs+ConNeg
# mearridit+Ex/V+Ex/TV+Der/PassL+V+IV+Ind+Prs+Sg3
#
# mearridit+Ex/V+TV+Der/PassL+V+Ind+Prs+ConNeg
# mearridit+Ex/V+TV+Der/PassL+V+Ind+Prs+Sg3
#
# mearridit+Ex/V+Der/PassL+V+IV+Ind+Prs+ConNeg
# mearridit+Ex/V+Der/PassL+V+IV+Ind+Prs+Sg3
#
# mearridit+Ex/V+Der/PassL+V+Ind+Prs+ConNeg
# mearridit+Ex/V+Der/PassL+V+Ind+Prs+Sg3
#
# whereas we used to give it input like:
#
# mearridit+Ex/V+Ex/TV+Der/PassL+V+Ind+Prs+Sg3
#
# That didn't match up. Now it does.

SUBSTITUTE:Ex/tags SUB:0 (Ex/IV) (*) TARGET (SUGGEST) ;
SUBSTITUTE:Ex/tags SUB:1 (Ex/IV) (*) TARGET (SUGGEST) ;
SUBSTITUTE:Ex/tags SUB:2 (Ex/IV) (*) TARGET (SUGGEST) ;
SUBSTITUTE:Ex/tags SUB:3 (Ex/IV) (*) TARGET (SUGGEST) ;

SUBSTITUTE:Ex/tags SUB:0 (Ex/TV) (*) TARGET (SUGGEST) ;
SUBSTITUTE:Ex/tags SUB:1 (Ex/TV) (*) TARGET (SUGGEST) ;
SUBSTITUTE:Ex/tags SUB:2 (Ex/TV) (*) TARGET (SUGGEST) ;
SUBSTITUTE:Ex/tags SUB:3 (Ex/TV) (*) TARGET (SUGGEST) ;

# TODO: Examples where the below rule works, while the above COPY:Err/Orth-any does not:
COPY:Err/Orth (SUGGEST) EXCEPT (Ex/N Ex/V Ex/A Ex/IV Ex/TV Err/Orth)
                             OR (South Err/Orth)
                             OR (Err/Orth Err/SpaceCmp)
                             OR (Err/Orth)
                             OR (Err/Orth-a-أ،)
                             OR (Err/Orth-nom-acc)
                             OR (Err/Orth-nom-gen)
                         TARGET (Err/Orth typo)
                             OR (Err/Orth-a-أ، typo)
                             OR (Err/Orth-nom-acc typo)
                             OR (Err/Orth-nom-gen typo)
                         IF (NOT 0 (SUGGEST) ) ;
	#$ Muhto dalle gأ،rtأ، maiddأ،i {ؤچielgaseappon} man_lأ،hkأ،i mearrideaddjit stuorأ،t servvodagas, go sin fأ،pmu lea gأ،rtan dego semeantan, dagahit lأ،httenvuoؤ‘u muhtinlأ،gan eahpealbma bivdui ja gilvui, gos vel diehta ge gأ،rtأ، hiإ‹gأ،lastojuvvot dego ؤچأ،jأ،hussan meassuin ja eisevأ،lddiid buإ،eahtain.
	#$ Ii buot dأ،fus gal, muhto juste das {mainna lأ،giin} olmmoإ، lأ،htte ja makkأ،r gova ؤچأ،jeha earأ،ide lei sutnje hui deaإ§alaإ،.

# Fallback: Add typo tag to any other Err tag not covered above,
# to ensure that they are at least underlined - important to make the
# grammar checker catch the same errors as the speller:
# presently defined as:
#  Err/Not-Orth = Err/Lex Err/DerSub Err/CmpSub Err/HyphSub Err/Hyph Err/MissingHyph Err/Spellrelax ;
ADD:other-errors (typo) Err/Not-Orth (NEGATE 0t (*) - Err/Any);

# Add typo error tag to unkown words that are not corrected by the speller, so that they at least get a blue underline and a message
ADD:uncorrected-typos (typo) (?) ;

# Local Variables:
# cg-pre-pipe: "bash -o pipefail modes/smegram-dev9-cg.mode"
# cg-post-pipe: "divvun-suggest -g generator-gramcheck-gt-norm.hfstol -m errors.xml -l sme"
# End:

	# ====================== #
		AFTER-SECTIONS
	# ====================== #

	# Tag removal rules to prepare for generation

SUBSTITUTE (MWE) (*) TARGET MWE ;
	## Guollefestivأ،la geassemأ،nus ja Riddu Riؤ‘ؤ‘u suoidnemأ،nus.


#SUBSTITUTE (Gram/3syll) (*) TARGET Gram/3syll ;

# Only add the &typo tag if no other error tags:
SUBSTITUTE (typo) (&typo) TARGET (typo) IF (NEGATE 0 (/^&.*/r));
# Else drop it so it generates correctly:
SUBSTITUTE (typo) (*) TARGET SUGGEST OR SUGGESTWF;
