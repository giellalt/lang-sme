LIST 3-STAVVAL-IT-V = (".*dit"r V) (".*git"r V) (".*hit"r V) (".*kit"r V) (".*lit"r V) (".*mit"r V) (".*rit"r V) (".*ÅĄit"r V) (".*tit"r V) ;

ADD:xpunct-rihkku (&punct-rihkku) TARGET (Inf) OR (Ind Prs Pl1) OR 3-STAVVAL-IT-V + (Ind Prs Pl3) OR 3-STAVVAL-IT-V + (Ind Prt Sg2) IF (-1 Inf LINK NOT 0 <TH-Inf> OR <Inf> LINK -1 COMMA LINK -1 Inf); 
	## GuovddÃĄÅĄ galgÃĄ Äohkket, ovddidit, vuogÃĄdahttit, ÃĄigÃĄdit, gieÄahallat,     heivehallat     gaskkustit ÃĄÅĄÅĄÃĄisoahppevaÅĄ dieÄuid ja duoÄaÅĄtusaid ÃĄlgoÃĄlbmotvuoigatvuoÄaid birra riikkalaÅĄ ja riikkaidgaskasaÅĄ dÃĄsis. 
	
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE (V &punct-rihkku) IF (0 Inf OR (Ind Prs Pl1) OR 3-STAVVAL-IT-V + (Ind Prs Pl3) OR 3-STAVVAL-IT-V + (Ind Prt Sg2))(NEGATE -1 (","))(NEGATE 0 ADDED-BEFORE-BLANK);

ADDRELATION (LEFT) (&punct-rihkku) TO (-1 (ADDED-BEFORE-BLANK)) ;


