LIST BECOME-smn = "ĆĄoddĂąÄ" ;
SET BECOME = BECOME-sma OR BECOME-sme OR BECOME-smj OR BECOME-smn ;


LIST CAN-sma = "maehtedh" ;
LIST CAN-sme = "sĂĄhttit" ;
LIST CAN-smj = "mĂĄhttet" ;
LIST CAN-smn = "sĂ€ttiÄ" ;
SET CAN = CAN-sma OR CAN-sme OR CAN-smj OR CAN-smn ;

LIST BEGIN-sme = "ĂĄlgit" ;
LIST BEGIN-smn = "Ă€lgiÄ" ;
LIST BEGIN-sma = "aelkedh" ;
LIST BEGIN-smj = "ĂĄlgget" ;
SET BEGIN = BEGIN-smn OR BEGIN-sme OR BEGIN-sma OR BEGIN-smj ;	

LIST NOT-V-sma = "ij" ;
LIST NOT-V-smj = "ij" ;
LIST NOT-V-sme = "ii" ;
LIST NOT-V-smn = "ij" ;
SET NOT-V = NOT-V-sma OR NOT-V-smj OR NOT-V-sme OR NOT-V-smn ;

LIST I-smn = "mun" ;
LIST I-sme = "mun" ;
LIST I-sma = "manne" ;
LIST I-smj = "mĂ„n" ;
SET I = I-smn OR I-sme OR I-sma OR I-smj ;

LIST WE-2-smn = "muoi" ;
LIST WE-2-sme = "moai" ;
LIST WE-2-sma = "mĂ„nnoeh" ;
LIST WE-2-smj = "maÌj" ;
