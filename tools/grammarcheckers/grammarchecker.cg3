ADD:xsyn-comp (&syn-comp) TARGET A OR Adv IF (0 ("eanet") - Superl OR ("eambbo") - Superl LINK 1 (A Nom) OR (A Ess) OR Attr + <AttrPred> LINK NOT 0 ("vejolaĆĄ") OR ("nuorra") OR NO_COMP OR Der/lasj)(NEGATE 2 CS LINK *1 (A Nom) BARRIER NOT-ADV) (NEGATE -1 ("unnit") OR ("uhcit")) (NEGATE *-1 Neg BARRIER GRAMCHK-S-BOUNDARY) ;
#(-1 GRADE-ADV)
ADD:xsyn-comp (&syn-comp) TARGET A  IF (0 Sg + Nom OR Pl + Nom OR Ess OR Attr + <AttrPred>) (-1 ("eanet") - Superl OR ("eambbo") - Superl LINK 1 (A Nom) OR (A Ess) OR Adv OR Attr + ADJ_ATTR/NOM LINK NOT 0 ("vejolaĆĄ") OR ("nuorra") OR NO_COMP OR Der/lasj)(NEGATE 1 CS LINK *1 (A Nom) BARRIER NOT-ADV) (NEGATE -2 ("unnit") OR ("uhcit")) (NEGATE *-1 Neg BARRIER GRAMCHK-S-BOUNDARY);
#(-2 GRADE-ADV)

ADDRELATION (DELETE1) (A &syn-comp) TO (-1 ("eanet" &syn-comp) OR ("eambbo" &syn-comp)) ;

#ADDRELATION (DELETE1) ("eanet" &syn-comp) OR ("eambbo" &syn-comp) TO (1 (A Der/Comp) - &syn-comp) ;

COPY:syn-comp (Der/Comp SUGGEST) EXCEPT (&syn-comp) AFTER A TARGET (A &syn-comp) - Der/Comp - Comp (NEGATE 0 ("eanet") OR ("eambbo")) ;
COPY:syn-comp (Ex/A Der/Comp SUGGEST) EXCEPT (&syn-comp) BEFORE A TARGET (A &syn-comp) (NEGATE 0 ("eanet") OR ("eambbo"))(NEGATE 0 &syn-comp) ;

