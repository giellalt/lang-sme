    # Ãisttonmearkkat
    # ----------------

# General rule to select Err/Orth readings of quotation marks.
# The Err/Orth reading is coming from the morphological analysis.
# The idea is that we can easily correct things coming from the lexcicon,
# without further work.
# Outcommented for now, until we have decided which approach to take
# (this one, or the one below, with multiple, targeted cg rules).
# SELECT:PunctErrOrth Err/Orth IF (0 (PUNCT))(NOT 0 (typo))  ;

#1. Mun lean dÃĄppe." Son ii leat --- dÃĄppe.â
#2. Mun lean dÃĄppe. " Son ii leat -- â
#3. Mun lean dÃĄppe. "Son ii leat -- âSon



	# 1. Add error tags:
ADD:xpunct-aistton       (&punct-aistton)       TARGET (""") ;  # Delayed til later
MAP:punct-aistton-both  (&punct-aistton-both)  TARGET ("ÂŦ" PUNCT LEFT)  OR ("â" PUNCT LEFT) OR ("\"") OR ("â") OR ("â") OR ("'") OR ("âđ") OR ("â") OR ("â") OR ("`") OR ("â") OR ("â") OR ("â") OR ("âŪ") OR ("ã") OR ("ã")
IF (2 ("Âŧ") OR ("â") OR ("\"") OR ("'") OR ("âš") OR ("â") OR ("â") OR ("â") OR ("âŊ") OR ("ã") OR ("ïž")) ; #NOT THIS ONE! ("â")
	## Artihkkal Ii fal EU FinnmÃĄrkoaviisa "Mearrit", borgemÃĄnnu 1993

# "	ÂŦ Âŧ â â â â ' âđ âš â â â â â â â â âŪ âŊ ã ã ã ïž


ADD:punct-aistton-left  (&punct-aistton-left)  TARGET ("ÂŦ" PUNCT LEFT) - Err/Orth OR ("â" PUNCT LEFT) - Err/Orth OR ("â"  PUNCT LEFT) - Err/Orth OR ("â") - Err/Orth OR ("âđ") - Err/Orth OR ("â") - Err/Orth OR ("â") - Err/Orth OR ("â") - Err/Orth OR ("â") - Err/Orth OR ("â") - Err/Orth OR ("âŪ") - Err/Orth OR ("ã") - Err/Orth OR ("ã") - Err/Orth IF (NOT 0 <SpaceOnRightSide>);
	#$ lÃĄvlo âÃĄhku sÃĄvzzat lÃĄvlaga.
ADD:punct-aistton-right (&punct-aistton-right) TARGET ("ÂŦ" PUNCT LEFT <SpaceOnRightSide>) OR ("âđ" PUNCT LEFT <SpaceOnRightSide>)  OR ("âŪ" <SpaceOnRightSide>) OR ("â" <SpaceOnRightSide>) OR ("â" <SpaceOnRightSide>) OR ("â" <SpaceOnRightSide>) OR 
("ÂŦ" PUNCT LEFT <LastCohortOfParagraph>) OR ("âđ" PUNCT LEFT <LastCohortOfParagraph>)  OR ("âŪ" <LastCohortOfParagraph>) OR ("â" <LastCohortOfParagraph>) OR ("â" <LastCohortOfParagraph>) OR ("â" <LastCohortOfParagraph>)
IF (*-2 ("ÂŦ") OR ("âđ") OR ("âŪ") OR ("â") OR ("â") OR ("â") BARRIER PUNCT OR CLB);
	##  ObbalaÄÄat lei nu ahte eatnasat geat ÃĄigo sÃĄtnesaji oaivvildedje ahte ÂŦFjellfinnhua{ÂŦ} filbma ii dagat ahte buorrÃĄna gaskavuohta olbmoÄearddaid gaskka davviguovllus.
	## SÃĄmi fibmafestivÃĄla joÄiheaddji Anne Lajla Utsi duoÄaÅĄta ahte sii ÃĄigo geassÃĄdit ÂŦVillmarkssenter{ÂŦ} bÃĄikkis orrumis, go eaiggÃĄt ja sÃĄmepolitihkar IssÃĄn (Isak Mathis O. HÃĶtta) lea ovddidan cealkÃĄmuÅĄaid mÃĄid olluhat leat dulkon rasistalaÅūÅūan.

	# for undefined if left or right
ADD:punct-aistton-left  (&punct-aistton-left)  TARGET ("'" PUNCT) OR ("\"" PUNCT) (*-1 BOS BARRIER ("'" PUNCT) OR ("\"" PUNCT))(NEGATE -1> ("." CLB) OR ("!") OR ("?") LINK *-1 ("ÂŦ" PUNCT LEFT)  OR ("â" PUNCT LEFT) OR ("\"")  OR ("'")  LINK -1 BOS)(NEGATE 0 <SpaceOnRightSide>)(NEGATE 1 ("." CLB) OR ("!") OR ("?"));
	#$ Jos boaÄÃĄt dakko, go boaÄÃĄt stÃĄlu goahtÃĄi, de mon galggan neavvut du.{"} SÃĄpmelaÅĄ vulggii ruoktot.

ADD:punct-aistton-right (&punct-aistton-right) TARGET ("'" PUNCT) OR ("\"" PUNCT) OR ("ïž") (*-1 (&punct-aistton-left));
	## Don ÄuoÄÄut mu 'ovddas'.
	## Ii lean eambbo go okta vuohki dÃĄn eastadit, jus eisevÃĄldit eai hÃĄliidan vuotnabivddu oalÃĄt nohkat".
	## Muhto earenoamÃĄÅūit lei hÃĄvdda birra sÃĄhka: 1926:s dagai Davvesiidda suohkanstivra rÃĄfÃĄiduhttincealkÃĄmuÅĄa, vai lottit mat "dÃĄl leat hui unnÃĄn, eai galgga oalÃĄt nohkat" (FFF 1926: ÃĄÅĄÅĄi 88, s. 337).

ADD:punct-aistton-right (&punct-aistton-right) TARGET ("'" PUNCT) OR ("\"" PUNCT) OR ("ïž") OR ("Âŧ") OR ("â") (0 <SpaceOnRightSide> OR <LastCohortOfParagraph>);

ADD:punct-aistton-right (&punct-aistton-right) TARGET ("'" PUNCT) OR ("\"" PUNCT) OR ("ïž") OR ("Âŧ") OR ("â") (1 ("." CLB) OR ("!" CLB) OR ("?" CLB) OR COMMA OR (":" CLB) OR (";" CLB) OR ("-" PUNCT));
	## Doppe biddjui ovdan nu ahte sÃĄpmelaÄÄaide mearkkaÅĄa dÃĄt: ÂŦleat dahje ii leat{Âŧ}.

	# 2. Add COERROR tags to the preceding/following word (depending on LEFT or RIGHT quotation marks), to handle overlapping errors:
MAP:punct-aistton-both-link  (&punct-aistton-both COERROR )  TARGET (*) IF (-2 (&punct-aistton-both) LINK NOT 0 (COERROR)) ;
ADD:punct-aistton-left-link  (&punct-aistton-left COERROR )  TARGET (*) IF (-1 (&punct-aistton-left) LINK NOT 0 (COERROR)) ;
#ADD:punct-aistton-left-link  (&punct-aistton-left COERROR )  TARGET (*) IF (-*<1 (>>>) BARRIER (>>>) (&punct-aistton-left) LINK NOT 0 (COERROR)) ;
	# when it follows the next window

ADD:punct-aistton-right-link (&punct-aistton-right COERROR ) TARGET (*) IF (1 (&punct-aistton-right) LINK NOT 0 (COERROR)) ;

ADD:punct-aistton-right-link (&punct-aistton-right COERROR) TARGET ("." CLB) OR ("!" CLB) OR ("?" CLB) IF (1*> (>>>) BARRIER (>>>) LINK 1 ("'" PUNCT <SpaceOnRightSide>) OR ("\"" PUNCT <SpaceOnRightSide>) OR ("ïž" PUNCT <SpaceOnRightSide>) OR ("Âŧ" PUNCT <SpaceOnRightSide>) LINK NOT 0 (COERROR)) ;
	# when  jumping  to the next window

	# 3. Add relation RIGHT/LEFT from the sentral cohort to the LINKed cohort for extended underline:
ADDRELATION:punct-aistton-both-rel  (RIGHT) (&punct-aistton-both)  TO (2  COERROR LINK 0 (&punct-aistton-both) );
ADDRELATION:punct-aistton-left-rel  (RIGHT) (&punct-aistton-left)  TO (1  COERROR LINK 0 (&punct-aistton-left) );
ADDRELATION:punct-aistton-left-rel  (RIGHT) (&punct-aistton-left)  TO (1*> (>>>) BARRIER (>>>) LINK 1 COERROR  LINK 0 (&punct-aistton-left) );
	## Jos boaÄÃĄt dakko, go boaÄÃĄt stÃĄlu goahtÃĄi, de mon galggan neavvut du.{"} SÃĄpmelaÅĄ vulggii ruoktot.
ADDRELATION:punct-aistton-right-rel (LEFT)  (&punct-aistton-right) TO (-1 COERROR LINK 0 (&punct-aistton-right));
ADDRELATION:punct-aistton-right-rel (LEFT)  (&punct-aistton-right) TO (-1*< (<<<) BARRIER (<<<) LINK 0 COERROR LINK 0 (&punct-aistton-right));

	# 4. Generate suggestions including the following/preceeding word (ie matching underline):
	# Generer forslag for hermeteikn pÃĨ _begge_ sider viss me har feilen pÃĨ eitt og same ord:
COPY:punct-aistton-both-sugg KEEPORDER (VSTR:"â$1â"S SUGGESTWF) TARGET (&punct-aistton-both) IF
        (NOT 0 (COERROR))
        (2 &punct-aistton-both)
        (2 COERROR)
        (1 ("<(.*)>"r))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;

	# Generer forslag for doble hermeteikn pÃĨ _venstre_ side:
COPY:punct-aistton-left-sugg KEEPORDER (VSTR:"â$1"S SUGGESTWF) TARGET (&punct-aistton-left) IF
        (NOT 0 (COERROR))
        (NOT 0 ("'" PUNCT) OR ("â") OR ("â") OR ("â") OR ("â"))
        (1 &punct-aistton-left LINK 0 COERROR LINK 0 ("<(.*)>"r))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;

	# Generer forslag for enkle hermeteikn pÃĨ _venstre_ side:
COPY:punct-aistton-left-sugg KEEPORDER (VSTR:"â$1"S SUGGESTWF) TARGET (&punct-aistton-left) IF
		(0 ("'" PUNCT) OR ("â") OR ("â") OR ("â") OR ("â"))
        (NOT 0 (COERROR))
        (1 &punct-aistton-left LINK 0 COERROR LINK 0 ("<(.*)>"r))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;

	# Generer forslag for hermeteikn pÃĨ _hÃļgre_ side:
COPY:punct-aistton-right-sugg KEEPORDER (VSTR:"$1â"S SUGGESTWF) TARGET (&punct-aistton-right) IF
        (NOT 0 (COERROR))
        (NOT 0 ("'" PUNCT))
        (-1 &punct-aistton-right LINK 0 COERROR LINK 0 ("<(.*)>"r))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;
	# this one is after a clause/window boundary
COPY:punct-aistton-right-sugg KEEPORDER (VSTR:"$1â"S SUGGESTWF) TARGET (&punct-aistton-right) IF
        (NOT 0 (COERROR))
        (NOT 0 ("'" PUNCT))
        (-1*< (<<<) BARRIER (<<<) LINK 0 &punct-aistton-right LINK 0 COERROR LINK 0 ("<(.*)>"r))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;
   ## Jos boaÄÃĄt dakko, go boaÄÃĄt stÃĄlu goahtÃĄi, de mon galggan neavvut du{."} SÃĄpmelaÅĄ vulggii ruoktot.

	# Generer forslag for hermeteikn pÃĨ _hÃļgre_ side:
COPY:punct-aistton-right-sugg KEEPORDER (VSTR:"$1â"S SUGGESTWF) TARGET (&punct-aistton-right) IF
        (NOT 0 (COERROR))
        (0 ("'" PUNCT))
        (-1 &punct-aistton-right LINK 0 COERROR LINK 0 ("<(.*)>"r))
        (NOT 0 SUGGESTWF)      # don't COPY more than once
        ;

