	#$ Luonddugأ،httendoaimmahat lea addan lobi suodjalusbivdui golmma bidjui ja njeallje sierranas getkkiide danin go moadde ؤچearu إ،adde giؤ‘ؤ‘adأ،lvvi 2008 gillأ،t garrasit geatkki ja albasiid geaإ¾ilâ€¦


#LIST BIDDJUI-ADV =

ADD:real-biddjui (&real-biddjui) TARGET ("bidju" N Sg Ill) OR ("biedju" N Sg Ill)(*0 ("johtu" Sg Ill) OR Ill + Sem/Rule OR Ill + Sem/Org OR ("eret") OR ("ovdii") OR ("oktii") OR ("ovdan") OR ("vuostأ،laga") BARRIER GRAMCHK-S-BOUNDARY OR CC)(NEGATE *-1 Sem/Ani BARRIER NPNH);
    #$ De beaivvأ،إ، badjأ،na, dat geassأ،dit eret ja veallأ،nit bidjui.
   ## 1999:s bidjui nu gohؤچoduvvon Nyborg-lأ،vdegoddi johtui man ulbmil lei guorahallat doaimmaid mat sأ،httet hehttet gأ،vppaإ،andeattu mأ،nأ،id ja nuoraid ektui.
	## Flأ¸tten bidjui eret
	## 1992:i ؤچavؤچؤچa ja bidjui heaittihanortnegii, mii ii galgga goassege leamaإ، su ulbmil.
ADD:biddjui (&real-biddjui) TARGET ("bidju" N Sg Ill) OR ("biedju" N Sg Ill)(1 ("ovdan") OR ("oktan") OR ("vuostأ،laga") OR (N Sem/Hum Ess) OR (N Sem/Pos Ess) OR ("virgأ،i") OR ("virgi" N Sg Ill) OR Sem/Rule + Ill)(NEGATE *-1 Sem/Ani - Com BARRIER NPNH);
	## Rأ،ؤ‘ؤ‘ehusdoaimmahuvvon mearrأ،dus bellodagas dagahii ahte muhtin Megawatis vuostأ،lasti bidjui bellodatjoؤ‘iheaddjin.
    ## Mearrأ،dus : Evttohus boahtأ،n Nils Ole Turis bidjui vuostأ،laga evttohusain boahtأ،n Ellen Inga K. Hأ¦ttas.
    ## ؤŒoahkkinjoؤ‘ihangotti أ،rvalus bidjui vuostأ،lأ،ga Bargiidbellodaga eavttuhusain, mii guoskأ، آ§ 24, nuppi oassأ،i.
    ## Jahkeؤچoahkkima ovdii bidjui ge evttohus ahte Finnmأ،rkku fylkkasuohkana otnأ،إ، sأ،megielat namma ii leat rievttes namma, ja dan dihte galgأ، rievdaduvvot Sأ،mieanan fylkan, go dat otnأ،إ، namma ii mأ،vsse ii maidege sأ،megillii.
    ## Oahpahusdieؤ‘أ،husas mii bidjui ovdأ،n Sأ،medikkis dأ،n ؤچavؤچؤچa lea vuؤ‘olaؤچؤچat ؤچilgejuvvon sأ،mi skuvllaid dili birra.

    # biddjui with time
ADD:real-biddjui (&real-biddjui) TARGET ("bidju" N Sg Ill) OR ("biedju" N Sg Ill)(1 Sem/Time + Gen)(NEGATE *-1 Sem/Ani - Com BARRIER NPNH)(NEGATE -1 <TH-Acc-Any><DE-Ill-Any> OR <TH-Acc-Any><SO-Loc-Any><DE-Ill-Any> OR <DE-Ill-Plc> OR <DE-Ill-Any> OR <SO-Loc-*Ani><DE-Ill-*Ani>);
    ## Nuortasأ،mi musea // أکstsamisk museum // Nuأµrttsaa آ´mi mu آ´zei vuoؤ‘ؤ‘ogeaؤ‘gi bidjui borgemأ،nu 22. beaivvi Njأ،vdأ،mis.

    # biddjui with goal
ADD:real-biddjui (&real-biddjui) TARGET ("bidju" N Sg Ill) OR ("biedju" N Sg Ill)(*1 Sem/Plc + Ill)(NEGATE *-1 Sem/Ani - Com BARRIER NPNH)(NEGATE -1 <TH-Acc-Any><DE-Ill-Any> OR <TH-Acc-Any><SO-Loc-Any><DE-Ill-Any> OR <DE-Ill-Plc> OR <DE-Ill-Any> OR <SO-Loc-*Ani><DE-Ill-*Ani>);
    ## Go suohkanrأ،dji oؤ‘ؤ‘asit أ،iggi bidjui Unjأ،rgga (Nesseby) ja ؤŒأ،hcesullo gaskal, de bidjui ge dat juste dakko (Niemi 1983 : 190).

COPY:real-biddjui ("bidjat" Ex/V Ex/TV Der/PassS V IV Ind Prt Sg3 SUGGEST) EXCEPT ("bidju" N Sg Ill &real-biddjui) OR ("biedju" N Sg Ill &real-biddjui) TARGET (&real-biddjui) ;
	## Finnmأ،rkulأ،hka أ،rvalus bidjui ovdan mannan giؤ‘a ja lea boktأ،n stuorra digaإ،tallama sisriikalaؤچؤچat ja maiddأ،i riikaidgaskasaؤچؤچat, ؤچأ،llأ، sأ،meradio preassadieؤ‘أ،husas.
	#$ Nordlأ،nddas bأ،إ¾ii mأ،nnodaga stأ،hta luonddu bearraigeahؤچؤچu ( SNO ) guokte geatkki ؤچivgga bidjui, muhto ciikku ribahedje mannat bأ،htui.


	# bidjui not biddjui
	# ------------------

ADD:real-bidjui (&real-bidjui) TARGET ("bidjat" Ex/V Ex/TV Der/PassS V IV Ind Prt Sg3) - Err/Orth (NEGATE *1 ("johtu" Sg Ill) OR ("johtit" Der/PassS Ind Prt Sg3) OR ("eret") BARRIER GRAMCHK-S-BOUNDARY)(*0 Ind - Err/Any OR PrfPrc - @>N - Err/Any OR Inf - Err/Any OR Imprt - Err/Any BARRIER NOT-ADVL-PCLE - Adv - OBJ - (N Sem/Ani Nom) - @>P - Po - (Pron Sem/Hum Pers Gen) OR THEN-CS-ADV LINK 0 <TH-Acc-Any><DE-Ill-Any> OR <TH-Acc-Any><SO-Loc-Any><DE-Ill-Any> OR <DE-Ill-Plc> OR <DE-Ill-*Ani> OR <DE-Ill-Any>)(NEGATE *1 Inf OR (Ind Prs Pl1) BARRIER NOT-ADV-PCLE - @ADVL);
	#$ Galle geardde biddjui oؤ‘ؤ‘a mأ،ilmmiolahus dievdduid 5000 m luistemis Olympia Dأ،lvegilvvuin 1998:s?
	## â€“ Na vuolgu min biddjui de oaؤچؤچut skeaإ‹kka.
	## Vaikko lei vehأ، issoras, de fertiimet aإ‹kke boagustit go أ،hkku orui nu komiska go nahkأ،riid siste ii ipmirdan maide ja doaivvui roahtuid biddjui boahtأ،n.
	#$ Dat dagahedje ahte earit galge juhkkojuvvot nuvttأ، guolأ،steddjiide, muhto jus galggai sأ،httit oaإ¾إ¾ut eari de biddjui mearri man olu dorski fertii unnimusat bivdأ،n ovtta jagis, jagiin 1987:s 1989 rأ،djأ،i.
	#$ Jiellevأ،ri 23-jahkأ،saإ، bأ،rdni gii mannan vahkkoloahpa biddjui rأ،jusgiddagassii go navdojuvvui ahte son lea jأ،mas cأ،bmأ،n moarsis lea dأ،l luitojuvvon friddja, eaige politiijat navdde إ،at su dahkat makkأ،rge vearredagu.
	#$ Dalأ، maإ‹إ‹il soaؤ‘i, de biddjui Eanadoallodepartemeanttas joؤ‘ihit duodjأ،i gullevaإ، أ،إ،إ،iid.
	#$ Oahppi biddjui ؤچuoigat okto 10 kilomehtera amas meahcis bearrأ،igeahؤچu haga


ADD:real-bidjui (&real-bidjui) TARGET ("bidjat" Ex/V Ex/TV Der/PassS V IV Ind Prt Sg3)(NEGATE *1 ("johtu" Sg Ill) OR ("johtit" Der/PassS Ind Prt Sg3) OR ("eret") BARRIER GRAMCHK-S-BOUNDARY)(*1 BE + Ind BARRIER NOT-ADV-PCLE LINK *1 Inf OR PrfPrc BARRIER NOT-ADVL-PCLE - Adv - OBJ - (N Sem/Ani Nom) - @>P - Po - (Pron Sem/Hum Pers Gen) OR THEN-CS-ADV LINK 0 <TH-Acc-Any><DE-Ill-Any> OR <TH-Acc-Any><SO-Loc-Any><DE-Ill-Any> OR <DE-Ill-Plc> OR <DE-Ill-*Ani> OR <DE-Ill-Any>)(NEGATE *1 Inf OR (Ind Prs Pl1) BARRIER NOT-ADV-PCLE - @ADVL);
	## - Na it got don oainne, munno biddjui lea golgan dievva giؤ‘ؤ‘adulveؤچأ،hci, civkkأ،dii eadnegoddesأ،hpأ،n ja njuikestalai vulosbajأ،s.

ADD:real-bidjui (&real-bidjui) TARGET ("bidjat" Ex/V Ex/TV Der/PassS V IV Ind Prt Sg3) - Err/Orth (NEGATE *1 ("johtu" Sg Ill) OR ("johtit" Der/PassS Ind Prt Sg3) OR ("eret") BARRIER GRAMCHK-S-BOUNDARY)(-1 Sem/Ani + Gen OR Sem/Ani + Acc)(NEGATE *1 Inf OR (Ind Prs Pl1) BARRIER NOT-ADV-PCLE - @ADVL);
	##

ADD:real-bidjui (&real-bidjui) TARGET ("bidjat" Ex/V Ex/TV Der/PassS V IV Ind Prt Sg3)( *-1 (Num Sg Gen) BARRIER NPNH);
	## Luonddugأ،httendoaimmahat lea addan lobi suodjalusbivdui golmma biddjui ja njeallje sierranas getkkiide danin go moadde ؤچearu إ،adde giؤ‘ؤ‘adأ،lvvi 2008 gillأ،t garrasit geatkki ja albasiid geaإ¾il.

ADD:real-bidjui (&real-bidjui) TARGET ("bidjat" Ex/V Ex/TV Der/PassS V IV Ind Prt Sg3)(*0 THEME-DESTINATION-V OR ("ؤچivgat") OR ("geahؤچؤچat") OR ("geahؤچastit") OR ("geahؤچestit")  BARRIER NPNHA);
    ## Ferten maid boradit albma dievva ؤچoavjji ovdal go manan biddjui nohkat dajai son.
    ## Lean gullan dأ،ppe galget ollu guovإ¾إ¾at, muhto eat leat oaidnأ،n ovttage, in sأ،va ge oaidnit, lohkأ، son ja jأ،hkkأ، guovإ¾إ¾aid dأ،l mannan biddjui.
	## Lagamus biddjui olle أپigin.

ADD:real-bidjui (&real-bidjui) TARGET ("bidjat" Ex/V Ex/TV Der/PassS V IV Ind Prt Sg3)( -1 (Pron Pers Gen) OR (Pron Pers Acc));
	## - Na it got don oainne, munno biddjui lea golgan dievva giؤ‘ؤ‘adulveؤچأ،hci, civkkأ،dii eadnegoddesأ،hpأ،n ja njuikestalai vulosbajأ،s.
    ## - Dأ،l ii leat إ،at guhkki din biddjui, gullui vilgessأ،hpan gii ovddemusas lei dieؤ‘iheame.
    ## - Mun lean aiddo ؤچorgen bieju vai lea rأ،innas dassأ، go ؤچivggan, ja dal deavdأ، dat dulvi fas ruskkaid munno biddjui cihraidii son.


COPY:real-bidjui ("bidju" N Sg Ill SUGGEST) EXCEPT ("bidjat" Ex/V Ex/TV Der/PassS V IV Ind Prt Sg3 &real-bidjui) TARGET (&real-bidjui) ;



	# buorranaddat + Ill kjأ¦rtegne vs. buorrأ،naddat bli bedre
