	# ----------------
SET NUMBER = Sg1 OR Du1 OR Pl1 OR Sg2 OR Du2 OR Pl2 OR Sg3 OR Du3 OR Pl3;

SUBSTITUTE N (آ§AG N) TARGET N IF (0 Nom + Pl) (*0 (V <AG-Nom-Any>) + Pl BARRIER GRAMCHK-S-BOUNDARY1 OR (SUBJ آ§AG))(0 SUBJ)(NEGATE 0 آ§AG); #(NEGATE 0* (SUBJ آ§EX)) ;
SUBSTITUTE N (آ§AG N) TARGET N IF (0 Nom + Sg) (*0 (V <AG-Nom-Any>) + Sg BARRIER GRAMCHK-S-BOUNDARY1 OR (SUBJ آ§AG))(0 SUBJ)(NEGATE 0 آ§AG);
SUBSTITUTE Pron (آ§AG Pron) TARGET Pron IF (0 Pers LINK 0 Nom + $$NUMBER) (*0 (V <AG-Nom-Any>) + $$NUMBER BARRIER GRAMCHK-S-BOUNDARY1 OR (SUBJ آ§AG))(0 SUBJ)(NEGATE 0 آ§AG);

SUBSTITUTE Pron (آ§AG Pron) TARGET Pron IF (0 (Sg Nom)) (*0 (V <AG-Nom-Any>) + Sg3 BARRIER GRAMCHK-S-BOUNDARY1 OR (SUBJ آ§AG))(0 SUBJ)(NEGATE 0 آ§AG);
SUBSTITUTE Pron (آ§AG Pron) TARGET Pron IF (0 (Pl Nom)) (*0 (V <AG-Nom-Any>) + Pl3 BARRIER GRAMCHK-S-BOUNDARY1 OR (SUBJ آ§AG))(0 SUBJ)(NEGATE 0 آ§AG);

	# "map" REASON role
	# ----------------
	# needs to be before the TH rules

SUBSTITUTE N (آ§RS N) TARGET N IF (0 Acc) (p (V <RS-Acc-Reason>))(0 ("duإ،إ،i" N Pl Acc))(NEGATE 0 آ§RS);

SUBSTITUTE N (آ§RS N) TARGET N IF (0 Loc) (p (V <RS-Loc-Any>))(NEGATE 0 آ§RS);
SUBSTITUTE N (آ§RS N) TARGET Pron IF (0 Loc) (p (V <RS-Loc-Any>))(NEGATE 0 آ§RS);

SUBSTITUTE Pron (آ§RS Pron) TARGET Pron IF (0 Com LINK NOT 0 Pers) (p (V <RS-Com-Impers>))(NEGATE 0 آ§RS);
SUBSTITUTE N (آ§RS N) TARGET N IF (0 Com OR (Pl Loc)) (p (V <RS-Com-Any>))(NEGATE 0 آ§RS);

SUBSTITUTE Po (آ§RS Po) TARGET Po IF (0 ("dihte") OR ("dihtii")) (p (V <RS-dihte-Any>))(NEGATE 0 آ§RS);

	# "map" THEME role
	# ----------------

SUBSTITUTE Po (آ§TH Po) TARGET Po IF (p (V <TH-maإ‹إ‹أ،i-*Plc>))(0 ("maإ‹إ‹أ،i") LINK *-1 Gen LINK NOT 0 Sem/Place) ;


SUBSTITUTE N (آ§TH N) TARGET N - SUGGEST IF (p (V <TH-Ill-Any>))(0 Ill)(NEGATE 0 آ§TH OR  SUGGEST) ; # a bit scary
SUBSTITUTE Num (آ§TH Num) TARGET Num - SUGGEST IF (p (V <TH-Ill-Any>))(0 Ill)(NEGATE 0 آ§TH OR  SUGGEST) ;
SUBSTITUTE Pron (آ§TH Pron) TARGET Pron - SUGGEST IF (p (V <TH-Ill-Any>))(0 Ill OR ILL-LOC-PRON-ADV)(NEGATE 0 آ§TH OR SUGGEST) ;
	##
SUBSTITUTE Adv (آ§TH Adv) TARGET Adv - SUGGEST IF (p (V <TH-Ill-Any>))(0 DOHKO OR ILL-LOC-PRON-ADV)(NEGATE 0 آ§TH OR SUGGEST) ;

SUBSTITUTE N (آ§TH N) TARGET N IF (p (V <TH-Acc-*Plc>))(0 Acc - Sem/Place)(NEGATE 0 آ§TH) ;

SUBSTITUTE N (آ§TH N) TARGET N IF (p (V <TH-Acc-Edu>))(0 Acc + Sem/Edu)(NEGATE 0 آ§TH) ;

SUBSTITUTE N (آ§TH N) TARGET N IF (p (V <TH-Acc-Any>) OR (V <TH-Acc-Body>))(0 Acc)(NEGATE 0 آ§TH) ;
SUBSTITUTE Pron (آ§TH Pron) TARGET Pron IF (p (V <TH-Acc-Any>))(0 Acc)(NEGATE 0 آ§TH) ;
SUBSTITUTE Num (آ§TH Num) TARGET Num IF (p (V <TH-Acc-Any>))(0 Acc)(NEGATE 0 آ§TH) ;
	## Makkأ،r gova dأ،t addأ، luohttأ،muإ،إ،ii, go geahؤچؤچأ، moadde dأ،hpأ،husa أ،إ،إ،is ; Olbmot balle ieإ¾aset gozihuvvon, ja gأ،ibidedje dieؤ‘uid, go eai luohttأ،n eisevأ،lddiide.

SUBSTITUTE N (آ§TH N) TARGET N IF (p (V <TH-Acc-Any><RO-Ess-Any>))(0 Acc)(*0 Ess BARRIER GRAMCHK-S-BOUNDARY)(NEGATE 0 آ§TH) ;
SUBSTITUTE Pron (آ§TH Pron) TARGET Pron IF (p (V <TH-Acc-Any><RO-Ess-Any>))(0 Acc)(*0 Ess BARRIER GRAMCHK-S-BOUNDARY)(NEGATE 0 آ§TH) ;
SUBSTITUTE Num (آ§TH Num) TARGET Num IF (p (V <TH-Acc-Any><RO-Ess-Any>))(0 Acc)(*0 Ess BARRIER GRAMCHK-S-BOUNDARY)(NEGATE 0 آ§TH) ;

SUBSTITUTE N (آ§TH N) TARGET N IF (*0 (V <TH-Acc-*Ani>) BARRIER GRAMCHK-S-BOUNDARY1)(0 Acc LINK NOT 0 Sem/Animate)(NEGATE 0 آ§TH) ;

SUBSTITUTE Pron (آ§TH Pron) TARGET Pron IF (c (V <TH-Acc-Impers>))(0 Acc LINK 0 Pron)(NEGATE 0 آ§TH) ;

SUBSTITUTE N (آ§TH N) TARGET N IF (p (V <TH-Com-Any>))(0 Com)(NEGATE 0 آ§TH) ;
SUBSTITUTE Pron (آ§TH Pron) TARGET Pron IF (p (V <TH-Com-Any>))(0 Com)(NEGATE 0 آ§TH) ;
SUBSTITUTE Adv (آ§TH Adv) TARGET ("dainna" Adv) IF (p (V <TH-Com-Any>))(NEGATE 0 آ§TH) ;

SUBSTITUTE N (آ§TH N) TARGET N IF (p (V <TH-Com-*Ani>))(0 Com - Sem/Animate)(NEGATE 0 آ§TH) ;
SUBSTITUTE Pron (آ§TH Pron) TARGET Pron IF (p (V <TH-Com-*Ani>))(0 Com - Sem/Animate)(NEGATE 0 آ§TH) ;
SUBSTITUTE Adv (آ§TH Adv) TARGET ("dainna" Adv) IF (p (V <TH-Com-*Ani>))(NEGATE 0 آ§TH) ;

SUBSTITUTE Pron (آ§TH Pron) TARGET Pron IF (p (V <TH-Com-Impers>))(0 Com)(NEGATE 0 آ§TH) ;
SUBSTITUTE Adv (آ§TH Adv) TARGET Adv IF (p (V <TH-Com-Impers>))(0 ("dainna"))(NEGATE 0 آ§TH) ;

SUBSTITUTE N (آ§TH N) TARGET N IF (p (V <TH-Loc-Any>))(0 Loc)(NEGATE 0 آ§PART)(NEGATE 0 آ§TH) ;
SUBSTITUTE V (آ§TH V) TARGET V IF (p (V <TH-Loc-Any>))(0 (Actio Loc))(NEGATE 0 آ§TH) ;
SUBSTITUTE Pron (آ§TH Pron) TARGET Pron IF (p (V <TH-Loc-Any>))(0 Loc)(NEGATE 0 آ§PART)(NEGATE 0 آ§TH) ;
SUBSTITUTE Num (آ§TH Num) TARGET Num IF (p (V <TH-Loc-Any>))(0 Loc)(NEGATE 0 آ§PART)(NEGATE 0 آ§TH) ;

SUBSTITUTE Po (آ§TH Po) TARGET Po IF (p (V <TH-ala-*Plc>))(0 ("ala"))(NEGATE 0 آ§TH) ;

SUBSTITUTE Po (آ§TH Po) TARGET Po IF (p (V <TH-birra-Any>))(0 ("birra"))(NEGATE 0 آ§TH) ;

SUBSTITUTE Po (آ§TH Po) TARGET Po IF (p (V <TH-lusa-Any>))(0 ("lusa"))(NEGATE 0 آ§TH) ;

SUBSTITUTE Po (آ§TH Po) TARGET Po IF (p (V <TH-ovddas-Any>))(0 ("ovddas"))(NEGATE 0 آ§TH) ;

SUBSTITUTE Po (آ§TH Po) TARGET Po IF (p (V <TH-haga-Any>))(0 ("haga"))(NEGATE 0 آ§TH) ;

SUBSTITUTE Inf (آ§TH Inf) TARGET V IF (p (V <TH-Inf>))(NOT 0 @SUBJ)(NEGATE 0 آ§TH) ;
	## Liiko go du // dudno mأ،nnأ، leat mأ،nأ،idgأ،rddis ?
	## Duiskalaإ، Hans Sieck lea rأ،hkأ،snuvvan Finnmأ،rkku lundui ja liiko maid oaggut.
SUBSTITUTE Ind (آ§TH Ind) TARGET V IF (0 (Prs Pl3))(p (V <TH-Inf>))(0 Pl3-INF-V)(NOT 0 @SUBJ)(NEGATE 0 آ§TH) ;
	##

SUBSTITUTE V (آ§TH V) TARGET INF-LIKES IF (p (V <TH-Inf>))(NOT 0 @SUBJ)(NEGATE 0 آ§TH) ;
SUBSTITUTE PrfPrc (آ§TH PrfPrc) TARGET V IF (p (V <TH-Acc-Any><TH-PrfPrc>))(NOT 0 @SUBJ)(NEGATE 0 آ§TH) ;
	## Olbmot balle ieإ¾aset gozihuvvon, ja gأ،ibidedje dieؤ‘uid, go eai luohttأ،n eisevأ،lddiide.

SUBSTITUTE Actio (آ§TH Actio) TARGET V IF (0 (Actio Ess))(p (V <TH-Acc-Any><TH-AktioEss>))(NOT 0 @SUBJ)(NEGATE 0 آ§TH) ;

SUBSTITUTE Actio (آ§TH Actio) TARGET V IF (0 (Actio Loc))(p (V <TH-AktioLoc>))(NOT 0 @SUBJ)(NEGATE 0 آ§TH) ;

SUBSTITUTE V (آ§TH V) TARGET Inf IF (p (V <TH-Acc-Any><TH-Inf>) OR (V <AG-Acc-Ani><TH-Inf>))(NOT 0 @SUBJ)(NEGATE 0 آ§TH) ;
	## Muhto son goitge balai daid إ،addat heajos ovdamearkan أ،ssiide.

SUBSTITUTE Pron (آ§TH Pron) TARGET Pron IF (p (V <TH-Acc-Any><TH-Inf>))(0 Acc OR Gen)(NEGATE 0 آ§ANYROLE) ;
	##
SUBSTITUTE N (آ§TH N) TARGET N IF (p (V <TH-Acc-Any><TH-Inf>))(0 Acc OR Gen)(NEGATE 0 آ§ANYROLE) ;

SUBSTITUTE A (آ§TH A) TARGET A IF (p (V <TH-Acc-Any><TH-Inf>))(0 Acc OR Gen LINK 0 OBJ)(NEGATE 0 آ§ANYROLE) ;


SUBSTITUTE Pron (آ§AG Pron) TARGET Pron IF (p (V <AG-Acc-Ani><TH-Inf>))(0 Acc OR Gen)(NEGATE 0 آ§ANYROLE) ;
	## Linأ، lei ؤچohkkأ،n jأ،vohaga ja diktأ،n {sin} hupmat.

SUBSTITUTE N (آ§AG N) TARGET N IF (p (V <AG-Acc-Ani><TH-Inf>))(0 Acc OR Gen)(NEGATE 0 آ§ANYROLE) ;

SUBSTITUTE A (آ§AG A) TARGET A IF (p (V <AG-Acc-Ani><TH-Inf>))(0 Acc OR Gen LINK 0 OBJ)(NEGATE 0 آ§ANYROLE) ;


SUBSTITUTE V (آ§AG V) TARGET VFIN IF (*-1 THAT-CS)(0 @FS-OBJ OR @+FAUXV OR @FS-<ADVL LINK p (V <TH-ahte>))(NEGATE 0 آ§TH OR آ§AG) ;
	## Dأ،t fas ؤچأ،jeha ahte geavahedje riggodagaid hui mأ،إ‹gga lأ،dje, seammأ،s go mأ،hku ja liikon rievddadii guovlluid mielde ja mearridii makkأ،r buktagiid olbmot geavahedje.
	## Mii sأ،vvat ahte {sأ،httit} vأ،ikkuhit dasa ahte mأ،nأ،t geat leat min luhtte maiddai maإ‹إ‹il liikojit atnit goruda sihke falaإ،tallama ja stoahkama bokte.

SUBSTITUTE V (آ§TH V) TARGET VFIN IF (*-1 BECAUSE-WHEN)(0 @FS-OBJ OR @+FAUXV OR @FS-<ADVL LINK p (V <TH-go>))(NEGATE 0 آ§TH) ;
	## Sأ،mediggi liiko go kulturrأ،ؤ‘ؤ‘i أ،إ‹giruإ،إ،أ، sohkabeliid dأ،ssedeattokeahtesvuoؤ‘a vuostأ،.
	## Sأ،mediggi liiko go Sأ،mi ealأ،husrأ،ؤ‘ؤ‘i addأ، doarjaga nissoniidda mat أ،lggahit ealأ،husdoaimma.

SUBSTITUTE V (آ§TH V) TARGET VFIN IF (*-1 IF-CS)(0 @FS-OBJ OR @+FAUXV OR @FS-<ADVL LINK p (V <TH-jus>))(NEGATE 0 آ§TH) ;
	## - Muhto, mu vأ،hnemat eai liiko jus vilgessأ،hpaniiguin fal bearehaga ovttastallat.


	# nominal parents

SUBSTITUTE N (آ§TH N) TARGET N IF (p (N <TH-Ill-Any>))(0 Ill)(NEGATE 0 آ§TH) ; # not sure about this
SUBSTITUTE Adv (آ§TH Adv) TARGET Adv IF (p (N <TH-Ill-Any>))(0 DOHKO)(NEGATE 0 آ§TH) ;

SUBSTITUTE N (آ§TH N) TARGET N IF (p (N <TH-Loc-Any>))(0 Loc)(NEGATE 0 آ§TH) ;



	# "map" PATIENT role
	# -----------------------
SUBSTITUTE N (آ§PA N) TARGET N IF (p (V <PA-Acc-Any>) OR (V <PA-Acc-Food>) OR (V <PA-Acc-Ani>))(0 Acc)(NEGATE 0 آ§ANYROLE) ;
	## Muhtimat eai dasa liiko, muhto dat lea vuoiggalaإ،, ja buorida min barggu.

SUBSTITUTE Pron (آ§PA Pron) TARGET Pron IF (p (V <PA-Acc-Any>) OR (V <PA-Acc-Ani>))(0 Acc)(NEGATE 0 آ§PA) ;
	## Don liikot daid elliide, leat guhkأ، daid kohkken ja dovddat daid.

SUBSTITUTE N (آ§PA N) TARGET N IF (p (V <PA-Com-Any>))(0 Com)(NEGATE 0 آ§ANYROLE) ;

SUBSTITUTE Pron (آ§PA Pron) TARGET Pron IF (p (V <PA-Com-Any>))(0 Com)(NEGATE 0 آ§ANYROLE) ;



	# "map" INSTRUMENT role
	# -----------------------
SUBSTITUTE N (آ§IN N) TARGET N IF (p (V <IN-Acc-Any>))(0 Acc)(NEGATE 0 آ§IN) ;

SUBSTITUTE Pron (آ§IN Pron) TARGET Pron IF (p (V <IN-Acc-Any>))(0 Acc)(NEGATE 0 آ§IN) ;

SUBSTITUTE N (آ§IN N) TARGET N IF (p (V <IN-Com-Veh>))(0 Com + Sem/Veh)(NEGATE 0 آ§IN);
	## Go beassأ،إ¾iid leat ؤچأ،ppa dأ،lkkit ja beaivvأ،dat, de olbmot liikojit ؤچuoigat meahcis dahe vuodjit {mohtorgielkkأ،in}.

SUBSTITUTE N (آ§IN N) TARGET N IF (p (V <IN-Com-Lang>))(0 Com + Sem/Lang)(NEGATE 0 آ§IN);

SUBSTITUTE N (آ§IN N) TARGET N IF (p (V <IN-Com-Any>))(0 Com)(NEGATE 0 آ§IN);
SUBSTITUTE Pron (آ§IN Pron) TARGET Pron IF (p (V <IN-Com-Any>))(0 Com)(NEGATE 0 آ§IN);

SUBSTITUTE N (آ§IN N) TARGET N IF (p (V <IN-Acc-Lang>))(0 Acc + Sem/Lang)(NEGATE 0 آ§IN);
	## â€“ Liikon leat Guovdageainnus, dovddan olbmuid doppe ja beasan sأ،megiela hأ،llat, lohkأ، Gulsrud, geas maid leat fuolkkit Guovdageainnus.

SUBSTITUTE N (آ§IN N) TARGET N IF (p (V <IN-Ill-Lang>))(0 Ill + Sem/Lang)(NEGATE 0 آ§IN);
	##

	# "map" PRODUCT role
	# -----------------------
SUBSTITUTE N (آ§PR N) TARGET N IF (p (V <PR-Acc-Any>))(0 Acc)(NEGATE 0 آ§PR) ;
	## Danne lea dأ،rbu أ،sahit ؤچielga {prinsihpaid} ja rievttأ،laإ، dأ،siid vaikke vel buohkat eai liikoإ،ege dasa.

SUBSTITUTE Pron (آ§PR Pron) TARGET Pron IF (p (V <PR-Acc-Any>))(0 Acc)(NEGATE 0 آ§PR) ;
	## Son vel vuittii lasi 11.000 ruvnnu ja Mأ،rjأ،-Liissأ، lea hui movtta go lea vuoitأ،n ja ahte olbmot liikojit maid son lea designen.

	# "map" BENEFICIARY role
	# ----------------------
SUBSTITUTE N (آ§BE N) TARGET N IF (p (V <BE-Acc-Any>)) (0 Acc)(NEGATE 0 آ§BE) ;
SUBSTITUTE Pron (آ§BE Pron) TARGET Pron IF (p (V <BE-Acc-Any>)) (0 Acc)(NEGATE 0 آ§BE) ;
SUBSTITUTE N (آ§BE N) TARGET N IF (p (V <BE-Acc-Ani>)) (0 Sem/Hum + Acc OR Sem/Org + Acc)(NEGATE 0 آ§BE) ;
	## Oahpahus galgأ، veahkehit ohppiid liikot leat luonddus ja addit sidjiide vejolaإ،vuoؤ‘a ovdأ،nahttit fantasiija, hأ،bmengأ،lgga ja beroإ،tumi diؤ‘oإ،tit birrasa.
SUBSTITUTE Pron (آ§BE Pron) TARGET Pron IF (p (V <BE-Acc-Ani>)) (0 Sem/Hum + Acc OR Sem/Org + Acc)(NEGATE 0 آ§BE) ;

SUBSTITUTE Po (آ§BE Po) TARGET Po IF (p (V <BE-ovddas-Ani>)) (0 ("ovddas"))(NEGATE 0 آ§BE) ;
	##

SUBSTITUTE V (آ§TH V) TARGET Inf IF (p (V <BE-Acc-Ani><TH-Inf>)) (s Sem/Hum + Acc OR Sem/Org + Acc)(NEGATE 0 آ§TH) ;
	## Oahpahus galgأ، veahkehit ohppiid liikot leat luonddus ja addit sidjiide vejolaإ،vuoؤ‘a ovdأ،nahttit fantasiija, hأ،bmengأ،lgga ja beroإ،tumi diؤ‘oإ،tit birrasa.

SUBSTITUTE N (آ§BE N) TARGET N IF (p (V <BE-Acc-Any><TH-AktioLoc>)) (0 Acc OR Gen)(s (Actio Loc))(NEGATE 0 آ§BE) ;
SUBSTITUTE Pron (آ§BE Pron) TARGET Pron IF (p (V <BE-Acc-Any><TH-AktioLoc>)) (0 Acc OR Gen)(s (Actio Loc))(NEGATE 0 آ§BE) ;
SUBSTITUTE V (آ§TH V) TARGET V IF (p (V <BE-Acc-Any><TH-AktioLoc>)) (0 (Actio Loc))(s Acc OR Gen)(NEGATE 0 آ§TH) ;

	# "map" ROLE role
	# -----------------

SUBSTITUTE N (آ§RO N) TARGET N IF (p (V <TH-Acc-Any><RO-Ess-Any>) LINK c آ§TH)(0 Ess)(NEGATE 0 آ§RO) ;
SUBSTITUTE N (آ§RO N) TARGET N IF (p (V <TH-Acc-Any><RO-Ess-Any>) LINK c آ§TH)(0 Ess)(NEGATE 0 آ§RO) ; # a bit scary
SUBSTITUTE Num (آ§RO Num) TARGET Num IF (p (V <TH-Acc-Any><RO-Ess-Any>) LINK c آ§TH)(0 Ess)(NEGATE 0 آ§RO) ;
SUBSTITUTE Pron (آ§RO Pron) TARGET Pron IF (p (V <TH-Acc-Any><RO-Ess-Any>) LINK c آ§TH)(0 Ess)(NEGATE 0 آ§RO) ;


SUBSTITUTE N (آ§RO N) TARGET N IF (p (V <RO-Ess-Any>))(0 Ess)(NEGATE 0 آ§RO) ;
SUBSTITUTE Pron (آ§RO Pron) TARGET Pron IF (p (V <RO-Ess-Any>))(0 Ess)(NEGATE 0 آ§RO) ;
	## Dat gأ،vpot mii nagoda   ؤچohket  eanemus cummأ،steddjiid, vuoitأ، ja oaإ¾إ¾u ؤچevllohaddat Norggameaإ،ttirin, ja pأ،rain mat servet, lea ges vejolaإ، vuorbأ،demiin vuoitit 5000 ruvdnosaإ، skeaإ‹kakoartta, rأ،hkisvuoؤ‘a lupmui.

	# "map" TOPIC role
	# -----------------

SUBSTITUTE N (آ§TO N) TARGET N IF (p (V <TO-Acc-*Ani>))(0 Acc - آ§ANYROLE)(NEGATE 0 آ§TO) ;
SUBSTITUTE Num (آ§TO Num) TARGET Num IF (p (V <TO-Acc-*Ani>))(0 Acc)(NEGATE 0 آ§TO) ;
SUBSTITUTE Pron (آ§TO Pron) TARGET Pron IF (p (V <TO-Acc-*Ani>))(0 Ill)(NEGATE 0 آ§TO) ;


	# "map" POSSESSOR role
	# -----------------------
SUBSTITUTE N (آ§PO N) TARGET N IF (p (V <TH-Nom-Any><PO-Ill-Any>))(0 Ill)(NEGATE 0 آ§PO) ;
	## Lأ،vdegotti lahtut, geat gullet Ovddأ،dusbellodahkii, Olgeإ¾ii ja Kristtalaإ، أ،lbmotbellodahkii, eai liiko importasuodjأ،i, mii livؤچؤچii hatti vuoؤ‘ؤ‘un.
SUBSTITUTE Pron (آ§PO Pron) TARGET Pron IF (p (V <TH-Nom-Any><PO-Ill-Any>))(0 Ill)(NEGATE 0 آ§PO) ;
	## Dasa gullأ، earet earأ، boastta sirret ja registreret, ؤچuovvut أ،إ،إ،emeannudeami siskkأ،ldas bargodأ،biid ja njuolggadusؤچأ،llosiid ektui, gieؤ‘ahallat dieؤ‘uid, oaidnit dأ،rbbuid,   ؤچohket  ja gaskkustit dieؤ‘uid departemeantta bargiide.

	# "map" EXPERIENCER role
	# -----------------------
SUBSTITUTE N (آ§EX N) TARGET N IF (0 Sem/Animate + Nom) (p (V <EX-Nom-Ani>))(0 SUBJ)(NEGATE 0 آ§ANYROLE);

#SUBSTITUTE Pron (آ§EX Pron) TARGET Pron IF (0 Pers LINK 0 Nom + $$NUMBER) (p (V <EX-Nom-Ani>)  + $$NUMBER BARRIER GRAMCHK-S-BOUNDARY1 OR (SUBJ آ§EX))(0 SUBJ)(NEGATE 0 آ§ANYROLE); #(NEGATE 0* (SUBJ آ§EX) BARRIER GRAMCHK-S-BOUNDARY1 OR @CVP OR GRAMCHK-VFIN) ;

SUBSTITUTE Pron (آ§EX Pron) TARGET Pron IF (0 (Sg Nom)) (p (V <EX-Nom-Ani>) + Sg3)(0 SUBJ)(NEGATE 0 آ§ANYROLE);

SUBSTITUTE N (آ§EX N) TARGET N IF (0 Acc) (p (V <EX-Acc-Any>))(NEGATE 0 آ§ANYROLE) ;
SUBSTITUTE Pron (آ§EX Pron) TARGET Pron IF (0 Acc) (p (V <EX-Acc-Any>))(NEGATE 0 آ§ANYROLE) ;
	## Sii liikojedje sihke ؤچiehkأ،stallat ja maid gأ،rvodit ja baldit ieإ¾أ،id.

	# "map" LOCATION role
	# -------------------

SUBSTITUTE N (آ§LO N) TARGET N IF (p (V <LO-Loc-Plc>) OR (V <LO-Loc-Any>))(0 Loc + Sem/Place OR Loc + Sem/Furn OR Loc + Sem/Build OR Loc + Sem/Org OR Loc + Sem/Veh)(NEGATE 0 آ§LO OR آ§SO) ;
	## SETCHILD <LO-Loc-Plc> OR <LO-Loc-Any> TO (1 Sem/Place + Loc);
	## Rathke vأ،lddahallأ، sأ،pmelaؤچؤچaid liggosit ja liikomiin, maإ‹إ‹el go lea fitnan {Njأ،vdأ،mis} 1802:s.
	## Liiko go du // dudno mأ،nnأ، leat {mأ،nأ،idgأ،rddis}?

SUBSTITUTE N (آ§LO N) TARGET N IF (p (V <LO-Ill-Any>))(0 Ill + Sem/Place)(NEGATE 0 آ§LO OR آ§SO);
	## Dan dihte sii eai diehtأ،n buorebu, ja sii liikojedje vأ،hneneatnamii ( ) ja eallinvuohkأ،i nu bures, ahte seammأ، vuostemielain sii dan guoؤ‘أ،إ،e go bahأ،dahkki jأ،pminduopmobأ،ikأ،i manaإ،ii (Leem 1767 : 172).

SUBSTITUTE N (آ§LO N) TARGET N IF (p (V <LO-Acc-Time>))(0 Acc + Sem/Time)(NEGATE 0 آ§LO OR آ§SO) ;
	## mon أ،lggأ،n boahtte vahku bargagoahtit d. 700.

SUBSTITUTE Adv (آ§LO Adv) TARGET Adv IF (p (V <LO-Loc-Plc>) OR (V <LO-Loc-Any>))(0 Adv + Sem/Place)(NEGATE 0 آ§LO OR آ§SO) ;
	## Jos don it liiko, dus ii leat bأ،ggu leat doppe, don vأ،lljet ieإ،, dadjأ، Marita.

SUBSTITUTE Pron (آ§LO Pron) TARGET Pron IF (p (V <LO-Loc-Plc>) OR (V <LO-Loc-Any>))(0 Rel - Sem/Hum)(NEGATE 0 آ§LO OR آ§SO) ;

SUBSTITUTE Adv (آ§LO Adv) TARGET Adv IF (p (V <LO-Loc-Plc>) OR (V <LO-Loc-Any>))(0 DOPPE)(NEGATE 0 آ§LO OR آ§SO) ;


	# "map" RECIPIENT role
	# --------------------
SUBSTITUTE N (آ§RE N) TARGET N IF (p (V <RE-Loc-Ani>))(0 Loc)(NEGATE 0 آ§RE) ;
	## Visot journalisttat olles dأ،n riikkas leat Bأ¸rre Knudsenis ja Strandebarm bأ،hpain jearran manne sii eai hأ،lit homofiila olbmuid girkolaإ، virggiide, ja manne eai liiko abortii.
SUBSTITUTE Pron (آ§RE Pron) TARGET Pron IF (p (V <RE-Loc-Ani>))(0 Loc)(NEGATE 0 آ§RE) ;

SUBSTITUTE N (آ§RE N) TARGET N IF (p (V <RE-Acc-Ani>))(0 Acc)(NEGATE 0 آ§RE) ;
	##
SUBSTITUTE Pron (آ§RE Pron) TARGET Pron IF (p (V <RE-Acc-Ani>))(0 Acc)(NEGATE 0 آ§RE) ;

SUBSTITUTE N (آ§RE N) TARGET N IF (p (V <RE-Ill-Ani><TH-Acc-*Ani>) OR (V <TH-Acc-Any><RE-Ill-Any>))(0 Ill)(s Acc)(NEGATE 0 آ§RE) ;

SUBSTITUTE Pron (آ§RE Pron) TARGET Pron IF (p (V <RE-Ill-Ani><TH-Acc-*Ani>) OR (V <TH-Acc-Any><RE-Ill-Any>))(0 Ill)(s Acc)(NEGATE 0 آ§RE) ;
	## Sأ،mediggi liiko go Sأ،mi ealأ،husrأ،ؤ‘ؤ‘i addأ، doarjaga nissoniidda mat أ،lggahit ealأ،husdoaimma.

SUBSTITUTE N (آ§RE N) TARGET N IF (p (V <RE-Ill-Ani>))(0 Ill)(NEGATE 0 آ§RE) ;
SUBSTITUTE Pron (آ§RE Pron) TARGET Pron IF (p (V <RE-Ill-Ani>))(0 Ill)(NEGATE 0 آ§RE) ;

	# "map" CO-Agent role
	# --------------------


SUBSTITUTE N (آ§CO N) TARGET N IF (p (V <CO-Acc-Ani>))(0 Acc + Sem/Animate)(NEGATE 0 آ§CO) ;
	## Diehttelas boazu liiko varas, ruona إ،attuide juste seamma lأ،dje go mii olbmot liikojit varas lأ،ibأ،i.

SUBSTITUTE N (آ§CO N) TARGET N IF (p (V <CO-Com-Ani>))(0 Com + Sem/Animate)(NEGATE 0 آ§CO) ;
	## Son liiko ovttastallat earأ،iguin ja deaivvada ja oahpأ،snuvvأ، أ،lkit olbmuiguin.

SUBSTITUTE Pron (آ§CO Pron) TARGET Pron IF (p (V <CO-Com-Ani>))(0 Com + Sem/Animate)(NEGATE 0 آ§CO) ;

	# "map" MANNER role
	# --------------------

SUBSTITUTE Adv (آ§MA Adv) TARGET Adv IF (p (V <MA-Adv-Manner>))(0 MANNER-ADV)(NOT 0 آ§ANYROLE) ;
	##
SUBSTITUTE CS (آ§MA CS) TARGET CS IF (p (V <MA-Adv-Manner>))(0 MANNER-ADV OR ("nugo"))(NOT 0 آ§ANYROLE) ;
	#NOT SURE..

	# "map" EXTENT role
	# --------------------

SUBSTITUTE N (آ§XT N) TARGET N IF (*0 (V <XT-Com-Measure>) BARRIER GRAMCHK-S-BOUNDARY1 OR GRAMCHK-VFIN)(0 Com OR (Pl Loc))(NEGATE 0 آ§XT) ; ;
	## Norgalaؤچؤچat liikojit pestoi, maإ‹emus jagiid lea pesto johtu loktanan 29 proseanttain Norggas.


	# "map" DESTINATION role
	# ----------------------

SUBSTITUTE N (آ§DE N) TARGET N IF (p (V <DE-Ill-Plc>))(0 Ill LINK 0 Sem/Place)(NEGATE 0 آ§DE) ;
SUBSTITUTE Adv (آ§DE Adv) TARGET Adv IF (p (V <DE-Ill-Plc>))(0 DOHKO)(NEGATE 0 آ§DE) ;

SUBSTITUTE N (آ§DE N) TARGET N IF (*0 (V <DE-Ill-Any>) BARRIER GRAMCHK-S-BOUNDARY1)(0 Ill)(NEGATE 0 آ§DE) ;
SUBSTITUTE Pron (آ§DE Pron) TARGET Pron IF (*0 (V <DE-Ill-Any>) BARRIER GRAMCHK-S-BOUNDARY1)(0 Ill)(NEGATE 0 آ§DE) ;

SUBSTITUTE Po (آ§DE Po) TARGET DE-ILL-ADP IF (p (V <DE-Ill-Plc>))(NEGATE 0 آ§DE);
SUBSTITUTE Po (آ§DE Po) TARGET ("sisa") IF (p (V <DE-sisa-Build>))(-1 Gen LINK 0 Sem/Build)(NEGATE 0 آ§DE) ;

	# "map" ORIGIN role
	# -----------------

SUBSTITUTE N (آ§OR N) TARGET N IF (p (V <TH-Acc-Any><OR-Loc-Any>)) (0 Loc)(s Acc OR Gen)(NEGATE 0 آ§OR) ;
SUBSTITUTE Pron (آ§OR Pron) TARGET Pron IF (p (V <TH-Acc-Any><OR-Loc-Any>)) (0 Loc)(s Acc OR Gen)(NEGATE 0 آ§OR) ;


	# "map" ATTRIBUTE role
	# ---------------------

SUBSTITUTE N (آ§AT N) TARGET N IF (p (V <AT-Loc-Mat>)) (0 Sem/Mat + (Sg Loc));
	## Dat mearkkaإ،a ahte son rأ،hkada niibbii, guvssiid ja nأ،hpiid, dahje buot mii lea muoras ja ؤچoarvvis.

	# "map" REFERENT role
	# -----------------

SUBSTITUTE N (آ§RF N) TARGET N IF (p (V <RF-Ill-Any>)) (0 Ill)(NEGATE 0 آ§RF) ;

SUBSTITUTE Pron (آ§RF N) TARGET Pron IF (p (V <RF-Ill-Any>)) (0 Ill)(NEGATE 0 آ§RF) ;


	# "map" SOURCE role
	# -----------------

SUBSTITUTE N (آ§SO N) TARGET N IF (p (V <SO-Loc-*Ani>)) (0 Loc - Sem/Animate)(NEGATE 0 آ§SO OR آ§LO) ;
SUBSTITUTE Pron (آ§SO Pron) TARGET Pron IF (p (V <SO-Loc-*Ani>)) (0 Loc - Sem/Animate)(NEGATE 0 آ§SO OR آ§LO) ;

	# "map" PURPOSE role
	# -----------------

SUBSTITUTE V (آ§PU V) TARGET Inf IF (p (V <PU-Inf>))(NEGATE 0 آ§PU) ;
SUBSTITUTE V (آ§PU V) TARGET (Actio Ess) IF (p (V <PU-AktioEss>))(NEGATE 0 آ§PU) ;

SUBSTITUTE N (آ§PU N) TARGET N IF (p (<PU-Ill-*Ani>))(0 Ill)(NEGATE 0 آ§PU);


	# LATE FS-ARGUMENT MAPPING
	# ------------------------

SETCHILD (V <TH-FS>) (NONE c آ§TH) TO (*1 @FS-<ADVL BARRIER <mv>);
	## Gaskaboddosaإ، presideanta Sأ،medikkis, Laila Susanne Vars, liiko maid gullأ،.
SETCHILD (V <TH-FS-Qst>) (NONE c آ§TH) TO (*1 VFIN + Qst BARRIER <mv>);
SETCHILD (V <TH-FS-Qst>) (NONE c آ§TH) (NEGATE *3 VFIN BARRIER GRAMCHK-S-BOUNDARY OR CC LINK NOT 0 Inf) TO (2 BECAUSE-WHEN LINK -1 VFIN - Qst OR Inf - Qst);
	## Dasto jearaimet beroإ،tit go oahppat sأ،megiela buorebut, ja jos nu, de man suorggis ja mo hأ،liidit oahppat.
	#$ â€“ Evy ii leat ؤچilgen maidege, sutnje lea leamaإ، أ،lkit bأ،htarit fatnasis, ballأ، {duإ،إ،at} go fanas vuodju, dan sadjأ،i go ieإ¾as vأ،rjalit, nu han dahkأ، go ii vأ،stit.
	## Lea Mearkalأ،vdegotti duohken mearridit addet go mearka vai eai, lohkأ، son.

SETCHILD (V <TH-FS-Qst>) (NONE c آ§TH) TO (4 BECAUSE-WHEN LINK -1 VFIN - Qst OR Inf - Qst LINK -1 CC LINK -1 VFIN - Qst OR Inf - Qst);
	##

LIST FS-QPRON-ADV = ("gii" Pron Rel) "goas" "gokko" "gos" "gosa" "govt" ("got" Adv) "makkأ،r" "man" "manne" "manin" ("mii" Pron Rel) ("mii" Pron Indef) "mo" "mot" "mov" "movt" ("nugo" @CVP) ;

SETCHILD (V <TH-FS-Qpron>) TO (*1 FS-QPRON-ADV BARRIER GRAMCHK-S-BOUNDARY OR VFIN OR Inf OR OBJ LINK *1 VFIN BARRIER VFIN);
	#$ Mii hأ،lidit alcceseamet dakkأ،r politihkkariid geain leat viidأ،t jurdagat go hأ،lbbes viidni, ja mii hأ،stalit sin beroإ،tit buohkaid daid olbmuid {geat} guddet alkoholnoؤ‘iid ieإ¾aset olggiid alde.
	## Dolken ieإ¾an sأ،niide, ja hأ،lidin geahؤچؤچat maid earأ،t ؤچأ،llet, muitala Mari Boine.

SETCHILD (V <TH-FS-Qpron>) TO (1 ("maid") LINK *1 VFIN BARRIER VFIN);
	## Seamma أ،igge earأ، sajis mأ،ilmmis Statoil ؤچevllohallأ، ruonأ، politihkainis ja verddevuoؤ‘ainis eamiأ،lbmogiiguin dego sأ،miin, geat eai oro diehtimin dahje beroإ،teamen {maid} Statoil lea bargamin Kanadas ; mo dat lea mirkoheamen eamiأ،lbmogiid eatnamiid ja jogaid dahje duإ،إ،adeamen sin eallinvugiid, ealأ،husaid ja dearvvaإ،vuoؤ‘a.

SETCHILD (V <RE-Loc-Ani><TH-FS-Qpron>) TO (c Loc + Sem/Animate LINK 1 ("maid") OR ("mii" Pron Pl Acc) LINK *1 VFIN BARRIER VFIN);
	## Stuorra buvda Steen & Strأ¸m lea jearran 1600 olbmos maid sii ohcalit gأ،vpeguovddأ،إ¾is.


#SETCHILD (V <TH-Ill-Any>) (NEGATE c آ§TH) TO (*1 @FS-<ADVL BARRIER <mv>);
	## *Gaskaboddosaإ، presideanta Sأ،medikkis, Laila Susanne Vars, liiko maid gullأ،. - dasa maid gullأ،
	#$ Jos don it liiko, dus ii leat bأ،ggu {leat} doppe, don vأ،lljet ieإ،, dadjأ، Marita.



SETCHILD (V <TH-ahte>) (NEGATE c آ§TH) TO (1 THAT-CS LINK *1 @FS-OBJ OR @+FAUXV OR @+FMAINV LINK NOT 0 (N SUGGEST));
	## - Balan gal go ealga- ja rievssatbivdu أ،lgأ،, ahte olusat mannet meahccأ،i ja bargu bisأ،na, dadjأ، son.

SUBSTITUTE V (آ§TH V) TARGET VFIN IF (p (V <TH-FS>))(NEGATE 0 آ§TH) ;
SUBSTITUTE V (آ§TH V) TARGET VFIN + Qst IF (p (V <TH-FS-Qst>))(NEGATE 0 آ§TH) ;
SUBSTITUTE V (آ§TH V) TARGET VFIN - Qst OR Inf - Qst IF (p (V <TH-FS-Qst>))(1 BECAUSE-WHEN)(NEGATE 0 آ§TH) ;
SUBSTITUTE V (آ§TH V) TARGET VFIN IF (p (V <TH-FS-Qpron>))(NEGATE 0 آ§TH) ;

SUBSTITUTE V (آ§TH V) TARGET VFIN IF (p (V <RE-Loc-Ani><TH-FS-Qpron>))(0 VFIN)(NEGATE 0 آ§TH) ;
	## Stuorra buvda Steen & Strأ¸m lea jearran 1600 olbmos maid sii ohcalit gأ،vpeguovddأ،إ¾is.

