LIST INDIRECT-QST-V = "imaإ،tit" "imaإ،tallat" "jearrat" "jearralit" ; # Positiv
LIST INDIRECT-SPEECH-V = "dadjat" "diehtit" "jurddaإ،it" ; # Neg dahje/vai
	# Mun in dieؤ‘e boaؤ‘أ،ngo ihttin.  Neg
	# Mun dieؤ‘أ،n dأ،l boaؤ‘أ،ngo ihttin dahje odne.


ADD:xsyn-add-go (&syn-add-go) TARGET GRAMCHK-VFIN IF (*-1 INDIRECT-QST-V BARRIER GRAMCHK-S-BOUNDARY1 OR GRAMCHK-VFIN OR MO-MANge OR CC OR CS OR THEN-CS-ADV LINK 0 V LINK NEGATE *0 OBJ BARRIER NPNHA)(NOT 0 Qst) (NEGATE 1 BECAUSE-WHEN) (NEGATE -*1 ("manin") OR ("manne") OR ("makkأ،r") OR Rel BARRIER GRAMCHK-S-BOUNDARY)(NEGATE -1 SUBJ LINK -1 COMMA);
	#$ Mon gal eahpidan, ahte ollen obban dohko beaiveؤچuovggas.
	## Fertejedjen jearrat lea dien olbmos vehأ،ge jearga bأ،hcأ،n.
	#$ Mon gal jearan mo galggan boahtit.
	#$ Go seamma gaإ¾aldagat jerrojuvvui jagis 1950, de vأ،stidii duإ،إ،e 13,6 % ahte sii geavahit sأ،megiela ruovttus.
	#$ Mana eatnis jearrat, son soaitأ، muitit man birra dat lea.
	#$ Ii suovvan أپjlina maidege jearrat ovdal Mikku lei mannan.
	# in errors.xml	

ADD:xsyn-add-go (&syn-add-go) TARGET GRAMCHK-VFIN IF (-1 THAT-CS LINK *-1 INDIRECT-QST-V BARRIER GRAMCHK-S-BOUNDARY1 OR GRAMCHK-VFIN OR MO-MANge OR CC OR CS OR THEN-CS-ADV LINK 0 V LINK NEGATE *0 OBJ BARRIER NPNHA)(NOT 0 Qst) (NEGATE 1 BECAUSE-WHEN) (NEGATE *-1 ("manin") OR ("manne") OR ("makkأ،r") OR Rel BARRIER GRAMCHK-S-BOUNDARY)(NEGATE -1 SUBJ LINK -1 COMMA)(NEGATE 0 <vdic> LINK *1 @<SUBJ BARRIER NPNH);
		
ADD:xsyn-add-go (&syn-add-go) TARGET GRAMCHK-VFIN IF (*-1 INDIRECT-SPEECH-V BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN OR MO-MANge OR CC OR CS LINK 0 ConNeg)(NOT 0 Qst) (NEGATE 1 BECAUSE-WHEN)(NEGATE 0 <vdic> LINK *1 @<SUBJ BARRIER NPNH) ;
	#$ Mii fertet hupmat dأ،n birra, oainnat jus dأ،t joatkaإ،uvvأ،, de sأ،httأ، dأ،t إ،addat dego bomban mii sأ،httأ، bأ،vkkehit vaikko goas, ja mas eat dieؤ‘e vأ،ikkuhusaid, {lohkأ،} Buljo.
	#$ Moai rأ،hkadeimme ieإ¾ame ؤچiegus bأ،lgأ،id maid ii oktage diehtأ،n, snukkaime buoidagiid biejuid go dat eai lean ruovttus ja munnos ledje olu earأ، somأ،s ja vehأ،إ، issoras fearأ،nat. XXX
	#$ In dieؤ‘e, vأ،stida son gaإ¾aldahkii vuolggأ،إ،ii go fas sأ،gajoؤ‘iheaddjin diggأ،i oؤ‘ؤ‘a njealji jahkأ،i.XXX
	#$ Ja vaikko in ollenge dieؤ‘e visot, oahpan daؤ‘istaga eambbo. XXX
	#$ Ja jus ii diehtأ،n, de jierأ،snuvai.
	# in errors.xml
		
ADD:xsyn-add-go (&syn-add-go) TARGET GRAMCHK-VFIN IF (*-1 INDIRECT-SPEECH-V BARRIER GRAMCHK-S-BOUNDARY1 OR GRAMCHK-VFIN OR MO-MANge OR CC OR CS LINK 0 V)(*1 ("dahje") OR ("vai") OR (Adv Subqst) BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN)(NOT 0 Qst) (NEGATE 1 BECAUSE-WHEN)(NEGATE -*1 THAT-CS BARRIER NOT-ADV-PCLE - Nom LINK 1 @SUBJ> OR Nom) ;
ADD:xsyn-add-go (&syn-add-go) TARGET GRAMCHK-VFIN IF (-1 THAT-CS LINK *-1 INDIRECT-SPEECH-V BARRIER GRAMCHK-S-BOUNDARY1 OR GRAMCHK-VFIN OR MO-MANge OR CC OR CS LINK 0 V)(*1 ("dahje") OR ("vai") OR (Adv Subqst) BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN)(NOT 0 Qst) (NEGATE 1 BECAUSE-WHEN);
COPY:syn-add-go (Qst SUGGEST) EXCEPT (&syn-add-go) TARGET (V &syn-add-go) ;	
	#$ Ja easkka dan maiddأ،i galggaإ،ii guorahallat, maid إ،attuid min doloإ، mأ،ttut ja diehttit {leat} dovdan ja geavahan biebmun, dأ،lkkasin dahje bأ،idnun.
	## Mun in dieؤ‘e manne nu lei, muhto goit dأ،l juo dieؤ‘أ،n fأ،rgga oaؤچؤچun loana dahje stipeanda. Mun in dieؤ‘e manne nu lei, muhto goit dأ،l juo dieؤ‘أ،n fأ،rgga oaؤچؤچungo loana dahje stipeanda.
	## Go nأ، dأ،hpأ،huvvأ،, أ،lgأ، olmmoإ، jurddaإ،it lea veara bidjat أ،iggi dأ،kkأ،r bargui, lohkأ، Sara.
	## Olmmأ،i muitala ahte son lea ohcame Soria-Moria sloahta, ja jearrala vel أ،hkus ii son dieؤ‘e gos dat bأ،iki lea.
	## Son jearrala dan guovtti njuvؤچؤچas ahte diehtiba soai gos Soria-Moria sloahtta lea.
	#$ Eallibohcco vihkken gal lea Johan Mihkkala mielas veahأ،إ، أ،rtegis vuohki, ja son imaإ،tallأ، ahte {leat} go oba ge jurdilan mii das lea أ،vkkit, sii geat mearridedje ؤچaؤ‘ahit dأ،n.
	#$ Mun dieؤ‘أ،n muؤ‘ui ahte govva lea govvejuvvon juogo 1963 ؤچavؤچؤچa dahje 1964 giؤ‘a, dan dihte go أکygأ¥rd lei aitto boahtأ،n dalle doavttirin.
