	# biĆĄkuiÂą(verb,conc|biĆĄkkui)

SET CONC-3A-3B-4 = CONC-3A OR CONC-3B OR CONC-4 ;

SET CONC-3A-3B-4ABC = CONC-3A OR CONC-3B OR CONC-4A OR CONC-4B OR CONC-4C ;

SET CONC-2-3A-3B-4ABC = CONC-2 OR CONC-3A OR CONC-3B OR CONC-4A OR CONC-4B OR CONC-4C ;

SET CONC-2-3A-3B-3C-4ABC = CONC-2 OR CONC-3A OR CONC-3B OR CONC-3C OR CONC-4A OR CONC-4B OR CONC-4C ;

SET CONC-2-3C = CONC-2 OR CONC-3C ;

ADD:real-NomAgIll-PrtSg3 (&real-NomAgIll-PrtSg3) TARGET (Ex/V Der/NomAg N Sg Ill) - Gram/3syll OR (V Ind Prt Sg3 Err/Confused-NomAgIll) - Gram/3syll IF (NEGATE *0 VFIN BARRIER GRAMCHK-S-BOUNDARY OR CC OR COMMA)(NEGATE *-1 (<.*-Ill-.*>r) OR (<.*-Ill-.*><.*>r) OR N + Sem/Act BARRIER NOT-ADV-PCLE - Attr - (N Acc) - Gen - @CNP)(NEGATE 1 CC LINK *1 Ill BARRIER NPNHAPcle)(NEGATE -1 CC LINK *-1 Ill BARRIER NPNHAPcle - OBJ - @ADVL)(NEGATE 1 CC LINK 1 NPNHAPcle LINK 1 Ill)(NEGATE -1 COMMA LINK -1C (N Ill) LINK 3 COMMA LINK 1 (N Ill))(NEGATE -1 (Dem Sg Gen) OR (N Gen) OR Attr OR ADJ_ATTR/NOM OR Num)(NEGATE 0 A LINK -1 XT-ADV)(NEGATE 0 A LINK 1 CC LINK 1 A)(NEGATE 0 Err/Spellrelax OR (Ind Prt Sg3) - Err/Any OR Der/h)(NEGATE 0 ("<.*eaddjĂĄi>"r))(NEGATE 0 (Sg Ill) LINK *-1 (N Sg Ill) BARRIER NPNH - CC - COMMA - Gen - Acc)(NEGATE 1 Inf)(NEGATE -1 FOCUS-ADV)(NEGATE **1 Sem/Sur OR Sem/Mal OR Sem/Fem  BARRIER (*) - Attr LINK 0 (Sg Ill) OR (Sg Nom))(NEGATE *-1 (N Sg Loc) + Sem/Hum BARRIER (*) - Attr - @>N)(NEGATE *1 CC BARRIER (*) - Attr - COMMA - Ill LINK 1 (N Ill) + Sem/Hum OR (Pron Indef Ill));
	#$ Bargostipenda 3 jahkĂĄi juhkkojuvvui dramatihkkĂĄrii Sven Henriksen, Oslo, girjeÄĂĄllĂĄi Marry A. Somby, Tromsa ja lĂĄvlui Johan Sara jr., MĂĄze.
