    # IV with an object
    # -----------------
LIST WRONG-TR-V = "ovdĂĄnit" "rievdat" "duhtat" "goikat" "vuodjut" ;
LIST CORRECT-TR-V = "ovdĂĄnahttit" "ovddidit" "rievdadit" "duhtadit" "goiket"  "vuodjudit";    
#ÄÄÄ no testkorp
#DELETE SECOND ROUND
ADD:xlex-transitive (&lex-transitive) TARGET WRONG-TR-V IF (*1 Gen - @>N - <spelled> OR Acc - @>N - <spelled> BARRIER GRAMCHK-NPNH - @>N OR Ess LINK NOT 0 Sem/Time OR Sem/Route OR Sem/Hum OR (@SPRED) OR Ess)(NEGATE *1 Gen OR Acc BARRIER GRAMCHK-NPNH LINK *1 ("alde") OR ("nalde") BARRIER NPNHA - (\?))(NEGATE 0 PrfPrc OR N);
    ## Dasa lassin bargĂĄ suohkan dan ala ahte ovdĂĄnit ieĆŸas fĂĄlaldaga kvalitehta. Dasa lassin bargĂĄ suohkan dan ala ahte ovdĂĄnahttit ieĆŸas fĂĄlaldaga kvalitehta.
    #$ Manadettiin cuovkanii skiipa; duĆĄĆĄe okta olmmĂĄi rievddai skiippa gahppalaga nalde muhtun sullui.
	## Luondduruovttudoallu rievddai ruhtaruovttudoallun, ealut unno ja daid eai guoÄohan ĆĄat nu olu.
	    
ADD:xlex-transitive (&lex-transitive) TARGET WRONG-TR-V IF (*-1 Gen - @P< OR Acc - @P< BARRIER GRAMCHK-S-BOUNDARY1 OR COMMA OR Po OR THAT-CS OR CC OR Nom LINK NOT 0 TIME OR ROUTE OR HUMAN OR (@SPRED) OR (@>N) LINK NEGATE *-1 TV BARRIER GRAMCHK-S-BOUNDARY OR CS) (NEGATE *-1 Gen OR Acc BARRIER GRAMCHK-S-BOUNDARY1 OR Po OR THAT-CS OR CC OR Nom LINK 0 Nom)(NEGATE *-1 TV BARRIER GRAMCHK-S-BOUNDARY OR CS) ; 
	#$ Bargojuohku gaskal eaktodĂĄhtolaĆĄ ja almmolaĆĄ veahkkedoaimmaid rievddai , ja dagahii doaibmahehttejuvvon olbmuid organisaĆĄuvnnaide 	ĂĄibbas earĂĄ 	rolla.
	#$ Manaimet Kemijoga gĂĄddĂĄi bassat lĂĄhtterĂĄnuid vai gerget {goikat} beaivvi ĂĄigge dalle go vuolgĂĄ ĂĄiggil johttui.
COPY:lex-transitive ("ovdĂĄnahttit" TV SUGGEST) EXCEPT ("ovdĂĄnit" IV &lex-transitive) OR ("ovdĂĄnit" IV Err/Orth-a-ĂĄ &lex-transitive) BEFORE V-MOOD OR Inf TARGET ("ovdĂĄnit" IV &lex-transitive) ;
COPY:lex-transitive ("rievdadit" TV SUGGEST) EXCEPT ("rievdat" IV &lex-transitive) OR ("rievdat" IV Err/Orth-a-ĂĄ &lex-transitive) BEFORE V-MOOD OR Inf TARGET ("rievdat" IV &lex-transitive) ;
COPY:lex-transitive ("duhtadit" TV SUGGEST) EXCEPT ("duhtat" IV &lex-transitive) OR ("duhtat" IV Err/Orth-a-ĂĄ &lex-transitive) BEFORE V-MOOD OR Inf TARGET ("duhtat" IV &lex-transitive) ;
COPY:lex-transitive ("goiket" TV SUGGEST) EXCEPT ("goikat" IV &lex-transitive) BEFORE V-MOOD OR Inf TARGET ("goikat" V &lex-transitive) ;
COPY:lex-transitive ("vuodjudit" TV SUGGEST) EXCEPT ("vuodjut" IV &lex-transitive) BEFORE V-MOOD OR Inf TARGET ("vuodjut" V &lex-transitive) ;
    ## Dasa lassin bargĂĄ suohkan dan ala ahte ieĆŸas fĂĄlaldaga mĂĄstorĂĄnddi nu bures go vejolaĆĄ ja vaikko man joÄĂĄnit rievdat.
    #$ Badjel 200 sĂĄvcca, mĂĄĆggas dĂĄin Äoavjjis, goike jĂĄmas muhtin dĂĄlus Oppdal:as, Lulli-TrĂžndelagas.
    #$ Mii oaidnit ahte dat gielddat mat beroĆĄtit oapmedoalus, doppe mannĂĄ mihĂĄ buorebut go dain gielddain main lea unnĂĄn beroĆĄtupmi Äuovvut oapmedoalu, ja veahkehit dan ovdĂĄnit.
