	# jearrأ، (jearrat Prs Sg3) vs. jeara N (gjأ¦r)
	# -------------------------------------------
	
LIST NEG-PRONS = "oktage" "goassege" "giige" ;
#DELETE uncommon
ADD:xreal-jearrأ، (&real-jearrأ،) TARGET ("jeara" N Sg) IF (0 Gen OR Nom OR Acc)(NEGATE 0 (TV Imprt Sg2))(0* Sg + Nom OR Sg3 BARRIER GRAMCHK-S-BOUNDARY)(NEGATE *-1 NOT-V BARRIER GRAMCHK-S-BOUNDARY OR NEG-PRONS)(NEGATE *1 EOS + ("^excl"))(NEGATE 1 Sem/Human + Acc)(NEGATE *-1 CC BARRIER NPNH LINK -1 Sem/Food OR Sem/Drink OR Sem/Substnc)(NEGATE 0 @<OBJ LINK 1 @CNP LINK 1 @<OBJ);
	#$ Fأ،gamأ،httu, rievttes biergasat, rأ،innas ؤچأ،hci, gordni ja jeara dأ،rbbaإ،uvvo vuoi إ،addأ، buorre vuolla, lohkأ، Terje Johansen.
	#$ Vأ،ldأ، eret jeara ja proteinbأ،zahusaid vai vuolla إ،addأ، ؤچielggas.
	#$ â€“ Macka vuollabijahaga nanu bealli lea ahte ؤچأ،hci ja jeara أ،lo leat seammalأ،ganat.
	#$ Jus geavaha duإ،إ،e sohkara, ؤچأ،zi ja jeara, de ii leat juhkosis earأ،go alkohola mأ،istu.
ADD:xreal-jearrأ، (&real-jearrأ،) TARGET ("jearrat" V TV) IF (0 (Imprt ConNeg) OR (Ind Prs ConNeg) OR (VGen))(NEGATE *-1 NOT-V BARRIER GRAMCHK-S-BOUNDARY OR NEG-PRONS)(NEGATE *1 EOS + ("^excl")) ;
COPY:real-jearrأ، ("jearrat" V TV Ind Prs Sg3 SUGGEST) EXCEPT ("jeara" N Sg Gen &real-jearrأ،) OR ("jeara" N Sg Nom &real-jearrأ،) OR ("jeara" N Sg Acc &real-jearrأ،) OR ("jearrat" V TV Imprt ConNeg &real-jearrأ،) OR ("jearrat" V TV Ind Prs ConNeg &real-jearrأ،) OR ("jearrat" V TV VGen &real-jearrأ،) TARGET (&real-jearrأ،) ;
