LIST HUM-PRON = ("buohkat" Pron Indef Pl) ("earأ،" Pron Indef Pl Nom) "eambbosat" "eambbogat" "earrأ،sa" "eatnagat" "gaikkat" "gallأ،dat" ("gii nu") "guoktأ،sat" ("juohkehaإ،" Pron Indef) "mun" "don" "son" "dii" "sii" "gallis" "giiat" "giijai" "giinai" "gii" "ieإ،" "ieإ،gii" "ieإ،giijai" "ieإ،giinai" "olus" "ollut" "olut" "ollugat" ;

LIST HUM-A = "kiinnأ،laإ،" ("vuosttaإ،" A Ord Pl Nom);

SUBSTITUTE Pron (Pron Sem/Hum) TARGET HUM-PRON (NEGATE 0 Sem/Hum);
SUBSTITUTE N (N Sem/Hum) TARGET Der/NomAg (NEGATE 0 Sem/Hum);
SUBSTITUTE A (A Sem/Hum) TARGET HUM-A - Attr (NEGATE 0 Sem/Hum);


