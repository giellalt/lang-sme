LIST LAHKAGEN-NOUN = "آ§" "buohkaidvuoigatvuohta" "cealkka" ("fأ،pmu" Ill)"hأ،pmi" "johtolatvuoigatvuohta" "kapihtal" "lأ،hkavuoؤ‘ؤ‘u" "ovdabargu" "rأ،mma" "rأ،hkkananbargu" "rأ،idu" "sأ،tnemearkkaإ،upmi" "ulbmilparagrأ،fa" "vuoؤ‘ؤ‘u" "vuoؤ‘ؤ‘oeaktu" "vuolit" "V";

# "vuolit" is an adj. but suit pragmatically to the set.

LIST LAHKA-ASAHUS = "alimusriekti" "Odeldiggi" "Stuoradiggi" "Stuorradiggi" "stuoradiggi" "stuorradiggi" "vuolleriekti" ;

LIST LAHKA-POST = "bokte" "olis" "mielde" "vuoؤ‘ul" ;

SET NOT-LAHKA = N - LAHKA ;


LIST GIELDA = "fylkkagielda" "gielda" "guovddأ،إ،gielda" "hأ،lddaإ،angielda" "riddogielda" "ruovttugielda" "sأ،megielda" "Sأ،megielda" "vuotnagielda" ;

  # We need this set because there is ambiguity between "gielda"+Gen/Acc and "gieldda"+Nom.

LIST GIELDDA = "gieldda" ;


# Nominal sets defined according to their semantical properties
# -------------------------------------------------------------

# Here we will write what sets we have and how we divide them.

# Spatial nouns. These nouns behave like postpositions
LIST SPATIALNOUN = "guovlu" "osku" "sadji" "vuoؤ‘ؤ‘u" ;

# These nouns in essiv get @ADVL:
LIST ESS-ADVL-N = "arvi" "أ،rga" "baika" ("bassi" N) ("bأ،hkka" N) "beaivvأ،dat" "biegga" "bievla" ("buolaإ،" N) "ؤچuoika" "ؤچuovga"  (".*dأ،lki"r) "dulvi" "mأ،noheahpi" "muohta" "njأ،hcu" ("seavdnjat" N) "varra" "veaigi";

# These nouns/adjectives in essiv can get @ADVL:
LIST ESS-PROB-ADVL-N = ("bassi" N) "boaris" ("nuorra" N) ;


# Time sets
# - - - - -

LIST MANNU = "oؤ‘ؤ‘ajagemأ،nnu" "oؤ‘ؤ‘ajagimأ،nnu" "guovvamأ،nnu" "njukؤچamأ،nnu" "njuvؤچؤچamأ،nnu" "mأ،rsmأ،nnu" "cuoإ‹omأ،nnu" "cuoإ‹osmأ،nnu" "cuoإ‹umأ،nnu" "gأ،ranasmأ،nnu" "miessemأ،nnu" "mأ،imأ،nnu" "geassemأ،nnu" "suoidnemأ،nnu" "borgemأ،nnu" "إ،njilؤچamأ،nnu" "إ،njilإ¾amأ،nnu" "ؤچakؤچamأ،nnu" "golggotmأ،nnu" "skأ،bmamأ،nnu" "novembermأ،nnu" "ritnemأ،nnu" "juovlamأ،nnu" ;


LIST AIGODAT = "أ،igi" (".*أ،igodat"r) "أ،lgoأ،igi" "bargoأ،igi" "soahteأ،igi" "soahtegaskaأ،igi" ;

LIST VAHKKU-DUR = "beaivi" "jأ،ndor" "bodda" "ؤچakؤچa" "ؤچakؤچageassi" "ؤچakؤچaseavdnjat" "ؤچuohtejahki" "dأ،lvi" "diibmu" "eahket" "eahketbodda" "geassi" "giؤ‘ؤ‘a" "idja" "iؤ‘it" "iؤ‘itbodda" "jahki" "jahkebealle" "jahkeؤچuohti" "kaleanddarjahki" "loahppajahki" ("[0-9]*-lohku"r) "mأ،nnu" "minukta" "njealjأ،dasjahki" "skuvlajahki" "tiibma" "vahkkoloahppa" "vahkku" ;
# these are periodes and can be Acc

LIST VAHKKU-TIME = "b" "bievlajahki" "bivdoأ،igi" (".*beaivi"r) "D-beaivi" "dienasjahki" "doaibmajahki" "eamiأ،lbmotjahki" "earrejahki" "gaskaidja" "geardi"  "juovlabassi" "luomejahki" "luopmojahki" "mihcamأ،rra" "muorjejahki" "nissonjahki" "vuoitojahki" "vuoؤ‘ؤ‘oskuvlavahkku" ("[0-9]*-jahki"r) ("[0-9]*-jahki"r) "[0-9]*-[0-9]*-jahki"  "[0-9]*-[0-9]*-lohku" ("[0-9]*-lohku"r) ("[0-9]*-lohku"r) ;

 # The quoteless jahki here is since the preprocessor is not fine-tuned
 # yet, it still gives '"1870-" # jahki N Sg Com'. # lets see if "dbm" works

SET VAHKKU = VAHKKU-DUR OR VAHKKU-TIME ;

LIST NUM-JAHKI = "jahki" "skuvlajahki";

    # Years which can be numerated

LIST PARTTIME = "ؤچavؤچؤچabealle" ;
	# This set is for finding Gen in expressions like PARTTIME OR TIME Gen.

LIST AIGI = "أ،igi" (".*أ،igi"r) ;

LIST SP-BEAIVI = "albmأ،imannanbeaivi" "bargoؤچoahkkinbeaivi" "beassأ،إ،beaivi" "mأ،nnodat" "vuossأ،rga" "disdat" "maإ‹إ‹ebأ،rga" "gaskavahkku" "duorastat" "bearjadat" "juovlabeaivi" "lأ،vvardat" "lأ،vvordat" "sotnabeaivi" "sأ،bbأ،t" "skilleduorastat" ;

LIST GEN-BEAIVI = "أ،lbmotbeaivi" "أ،rgabeaivi" "bargobeaivi" "beaivi" "duopmobeaivi" "riegأ،danbeaivi" "skuvlabeaivi"  ;
# General-beaivi can have Gen modifier, like "skuvlla أ،rgabeaivi".

SET BEAIVI = SP-BEAIVI OR GEN-BEAIVI ;

SET TIME = MANNU OR VAHKKU OR BEAIVI OR AIGI ;

  # Do not add AIGODAT, it has some other characteristics in some cases.
  # But fix!!
  # "Sأ،mediggerأ،ؤ‘ؤ‘i   lea أ،igodagas doallan   5 ؤچoahkkima."
  # Today believed to be obj.

SET NOTIME = N - TIME ;

LIST GEASSET = "dأ،lvet" "dأ،lvit" "giؤ‘ؤ‘at" "geasset" ("geassit" Adv) "ؤچakؤچat" ;
 # What is special here?

LIST PAST-MARKER = ("mأ،nnأ،" Ess) "dalle" "diibmأ،" "dolin" "doloإ،" "dovle" "duvle" "eske" "gieskat" "ikte" ("nuorra" Ess) "ovdal" ("ovdditbeaivi" Gen) ("vأ،ssأ،nأ،igi" Loc) ("boaresأ،igi" Gen) ;

LIST PRESENT-MARKER = "dأ،l" "ihttin" "odne" "otne" ("boahtteأ،igi" Loc) ("boahtteأ،igi" Gen)  ;

SET TIME-MARKER = PAST-MARKER OR PRESENT-MARKER ;

LIST OTHER-TIME-ADV =  "agأ،laؤچؤچat" ("agأ،laإ،" Ex/A Adv) "أ،rabuإ،" "أ،rrat" "easkka" "easka" "guhkأ،" ("guhkit" Adv) "maإ‹emustأ،" "maإ‹إ‹el" "maإ‹إ‹elaإ،" "maإ‹إ‹eleappos" "maإ‹إ‹it" "muhtumin" "ovdal" ;

SET TIME-ADV = TIME-MARKER OR OTHER-TIME-ADV OR GEASSET;


# Amount sets
# - - - - - -

LIST VOLUME = "cl" "lihtar" (".*lihtter"r) "dl" "lihtter" "ml"  ;

LIST WEIGHT = "mg" "kg" "kilo" "kilu" "gilo" "tonna" ;

LIST LENGTH = "ؤچuoldabadji" "dumأ،" "fierbmebadji" "gaska" "miila" (".*mehtar"r) (".*mehter"r) "mehtar" "mehter" "sente" "cm" "tumأ،" "أ،llan" "salla" ;

LIST TEMPERATURE = "buolaإ،ceahkki" "buolaإ،grأ،da" "lieggaceahkki" "lieggagrأ،da" ;

LIST AMOUNT = "uhcأ،naإ،" "unnأ،naإ،" ;

LIST TIME-UNIT = "jahki" "minukta" "sekunda" "vahkku" "mأ،nnu" "diibmu" ;
	# For use for rules hitting "maإ‹إ‹el" as Adv instead of Po. Also in MEASURE-set.

SET MEASURE = VOLUME OR WEIGHT OR LENGTH OR AMOUNT OR TEMPERATURE OR TIME-UNIT ;

LIST CURRENCY = "denara" "dollأ،r" "euro" "kruvdnu" "kr" "ru" "rubel" "ruvdno" "ruvdnu" "آ¢" "â‚¬" "$";

SET CURRENCY-GEN = CURRENCY + Gen ;

SET NOT-CURRENCY-GEN = N - CURRENCY-GEN ;


LIST NUMUNIT = "ؤچuohti" "duhأ،t" "miljon" "millijovdna" "milliovdna" "mill" "milj" "miljo" "miljarda" "mrd";

LIST KIND = (".*إ،lأ،dja"r)  ;

LIST COUNTABLE = "gأ،hppأ،lat" "oassi" "kapihttal" "paragrأ،fa" ;

LIST NUMMAR = "identifiserennummar" "njuolggotlf" "nr" (".*nummar"r) "nummir" "tabeallanummar" "Vuorkأ،أ،إ،إ،enr" ;

LIST KLASS = "أ،إ،إ،i" "bأ،lkأ،ceahkki" "ؤچuokkis" "s" "siidu" "آ§" "آ§آ§" "paragrأ،fa" "oassi" "kap" "kapihttal" "kapihtal";

LIST PEOPLE-NUM = "guovttis" "golmmas" "njealjis" "viؤ‘as" "guؤ‘as" "ؤچieإ¾as" "gأ،vccis" "ovccis" "logis" ;

SET PLURAL-QUANTIFIERS-smj = ("moadda" Nom)آ OR ("moadda" Indef Sg Acc) ORآ ("moattes" Nom) OR (Num Sg Nom) - ("akta") ;
SET PLURAL-QUANTIFIERS-sme = ("moadde" Nom)آ OR ("moadde" Indef Sg Acc) ORآ ("moattes" Nom) OR (Num Sg Nom) - ("okta") ;
SET PLURAL-QUANTIFIERS-sma = ("mأ¥edtie" Nom)آ OR ("mأ¥edtie" Indef Sg Acc) ORآ ("moattes" Nom) OR (Num Sg Nom) - ("akte") ;
SET PLURAL-QUANTIFIERS-smn = ("moadda" Nom)آ OR ("moadda" Indef Sg Acc) ORآ ("moattes" Nom) OR (Num Sg Nom) - ("akta") ;
SET PLURAL-QUANTIFIERS = PLURAL-QUANTIFIERS-smj OR PLURAL-QUANTIFIERS-sme OR PLURAL-QUANTIFIERS-sma OR PLURAL-QUANTIFIERS-smn ;

