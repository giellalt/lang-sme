	#          congruence case number
	#          actio vs. inf



LIST HUM-PRON = ("buohkat" Pron Indef Pl) ("earÃĄ" Pron Indef Pl Nom) "eambbosat" "eambbogat" "earrÃĄsa" "eatnagat" "gaikkat" "gallÃĄdat" ("gii nu") "guoktÃĄsat" ("juohkehaÅĄ" Pron Indef) "mun" "don" "son" "dii" "sii" "gallis" "giiat" "giijai" "giinai" "gii" "ieÅĄ" "ieÅĄgii" "ieÅĄgiijai" "ieÅĄgiinai" "olus" "ollut" "olut" "ollugat" ;

LIST HUM-A = "kiinnÃĄlaÅĄ" ("vuosttaÅĄ" A Ord Pl Nom);

SUBSTITUTE Pron (Pron Sem/Hum) TARGET HUM-PRON (NEGATE 0 Sem/Hum);
SUBSTITUTE N (N Sem/Hum) TARGET Der/NomAg (NEGATE 0 Sem/Hum);
SUBSTITUTE A (A Sem/Hum) TARGET HUM-A - Attr (NEGATE 0 Sem/Hum);


