SET ADJ_ATTR/NOM = ADJ_ATTR/NOM ;
SET NO_COMP = NO_COMP ;



SET PRE-NP-HEAD = (Prop Attr) OR (Prop @>N) OR (A Attr) OR (ABBR Attr) OR ("buorre") OR (Pron Pers Gen) OR (N Gen) OR (Pron @>Pron) OR
         Num OR Cmp/SplitR OR CC OR (Pron Dem) OR (Pron Refl Gen) OR (Pron Indef) OR
         (PrfPrc @>N) OR PrsPrc OR (A Ord) OR ("njiإ‹إ‹elas" Sg Nom) OR ("njiإ‹إ‹أ،las" Sg Nom) OR ("varis" Sg Nom) OR ("ollu" Sg Nom);
         # The strict version of items that can only be premodifiers, not parts of the predicate

SET V-PRE-NP = PrfPrc OR PrsPrc OR NOMAG OR Actio OR (V A) OR (Ind Prs Sg3) OR (Ind Prs Sg1) OR (Imprt Du2) ;
    # to be used together with PRE-NP-HEAD before @>N is disambiguated

SET NP-MEMBER   = PRE-NP-HEAD OR N ;

SET PRE-A-N     = (Pron Pers Gen) OR (Pron Indef) OR Num OR (A Ord) OR (Pron Dem) OR (Pron Refl Gen) ;

SET NOT-PRE-A-N = WORD - PRE-A-N ;




SET PRE-APP   = COMMA OR PUNCT-LEFT OR PRE-NP-HEAD ;
 # This set ist not only for what can
                            # stand in front of appositions but also
                            # postmodifiers.

# V NPNHAIIP... N
# BOS ... N V

# There must be a sensible naming convention for these sets...
# Most strict BARRIERs...
SET NPNH     = (*) - PRE-NP-HEAD OR ABBR  OR (Adv Subqst);
# NPNH  = "NOT-PRE-NP-HEAD"
SET NPNH1     = NPNH - Acc OR ABBR  OR (Adv Subqst);
# To be used in mappingrules, before hte disambuation of Acc and Gen.

SET NPNHV    = (*) - PRE-NP-HEAD - V-PRE-NP OR (Adv Subqst);
# including possible verbal premodifiers
SET NPNHA    = (*) - PRE-NP-HEAD - Adv OR (Adv Subqst);
# NPNHA = "NOT-PRE-NP-HEAD-OR-ADV"
SET NPNHAPcle = (*) - PRE-NP-HEAD - Adv - Pcle OR (Adv Subqst);
SET NPNHAV   = (*) - PRE-NP-HEAD - Adv - V-PRE-NP ;
# including possible verbal premodifiers
SET NPNHAI   = (*) - PRE-NP-HEAD - Adv - Indef ;
# NPNHAI = "     ...-OR-INDEF"
SET NPNHAII  = (*)  - PRE-NP-HEAD - Adv - Indef - Ill ;
# Illative indir.obj.
SET NPNHAIIP = (*)  - PRE-NP-HEAD - Adv - Indef - Ill - Pcle ;
# <== is this our NPNH set?
SET NPNHC    = (*) - PRE-NP-HEAD - Com ;
# "njaإ‹ggofirpmiiguin bivdin"
SET NPNHCCC  = (*)  - PRE-NP-HEAD - COMMA ;
SET NPNHCC   = (*)  - PRE-NP-HEAD - COMMA - LCRD ;
SET NPNHCCA  = (*)  - PRE-NP-HEAD - COMMA - CC - Adv ;
SET NAPP     = (*)  - PRE-APP ;

SET GRAMCHK-NPNHA    = (*)  - PRE-NP-HEAD - Adv - PUNCT-LEFT-RIGHT;
SET GRAMCHK-NPNHA2    = (*)  - PRE-NP-HEAD - Adv - PUNCT-LEFT-RIGHT - ? ;
	# barriers for the grammerchecker need to less exclusive in many case
SET GRAMCHK-NPNH    = (*)  - PRE-NP-HEAD - PUNCT-LEFT-RIGHT;
SET GRAMCHK-NPNH-2    = (*)  - PRE-NP-HEAD - PUNCT-LEFT-RIGHT - ?;
SET GRAMCHK-NPNHCCA  = (*)  - PRE-NP-HEAD - COMMA - CC - Adv - PUNCT-LEFT-RIGHT ;

# SET TOLERANT-PRENPP = V ; (everything non-NP-head!)
# ... Most sloppy BARRIERs

# Set for NP with participle premodifier
# ... IF *-1 X BARRIER GRAMCHK-NPNH OR
# LocComIll are ok, but only with a PrfPcc to the right

# Other negatively defined morphosyntactic noun sets
# - - - - - - - - - - - - - - - - - - - - - - - - -

SET NOT-N = WORD - N ;

SET NOT-A = WORD - A ;

SET NOT-NA = WORD - N - A ;

SET NOT-NAPrfCC = WORD - N - A - CC - PrfPrc ;

SET NOT-NP = VFIN-NOT-NEG OR ConNeg OR Inf OR Pcle OR Interj OR CS ;
 # The set NP-BOUNDARY is bigger.
SET NPROP = N - PROP ;

SET NOT-COMMA = CLB - COMMA OR PUNCT-LEFT-RIGHT ;

SET ANYTHING-BUT-COMMA = (*) - COMMA ;

SET NOT-QMARK = WORD OR CLB OR PUNCT - QMARK ;

SET W-NOT-ACC-GEN = WORD - Acc - Gen ;


