ADD:xmsyn-wrong-case-in-coordination (&msyn-wrong-case-in-coordination) TARGET N - Cmp/SplitR IF (-1 CC OR COMMA LINK -1 $$CASE LINK NOT 0 <spelled>)(NEGATE 1 NP-HEAD)(1 CC OR COMMA LINK 1 $$CASE)(NEGATE 0 $$CASE)
(NEGATE 0 (Sg Gen) + <NomGenSg> LINK -1 CC OR COMMA LINK -1 (Sg Nom)); 
COPY:msyn-wrong-case-in-coordination (Sg Gen SUGGEST) EXCEPT (Ess &msyn-wrong-case-in-coordination) TARGET (Ess &msyn-wrong-case-in-coordination) IF (-1 CC OR COMMA LINK -1 Gen);   #2nd
COPY:msyn-wrong-case-in-coordination (Gen SUGGEST) EXCEPT (Nom &msyn-wrong-case-in-coordination) OR (Loc &msyn-wrong-case-in-coordination) OR (Com &msyn-wrong-case-in-coordination) OR (Ill &msyn-wrong-case-in-coordination) TARGET (&msyn-wrong-case-in-coordination) - Ess IF (-1 CC OR COMMA LINK -1 Gen);   #2nd
COPY:msyn-wrong-case-in-coordination (Sg Acc SUGGEST) EXCEPT (Ess &msyn-wrong-case-in-coordination) TARGET (Ess &msyn-wrong-case-in-coordination) IF (-1 CC OR COMMA LINK -1 Acc);
COPY:msyn-wrong-case-in-coordination (Acc SUGGEST) EXCEPT (Nom &msyn-wrong-case-in-coordination) OR (Loc &msyn-wrong-case-in-coordination) OR (Com &msyn-wrong-case-in-coordination) OR (Ill &msyn-wrong-case-in-coordination) TARGET (&msyn-wrong-case-in-coordination) - Ess IF (-1 CC OR COMMA LINK -1 Acc);  #2nd
COPY:msyn-wrong-case-in-coordination (Sg Ill SUGGEST) EXCEPT (Ess &msyn-wrong-case-in-coordination) TARGET (Ess &msyn-wrong-case-in-coordination) IF (-1 CC OR COMMA LINK -1 Ill);
COPY:msyn-wrong-case-in-coordination (Ill SUGGEST) EXCEPT (Nom &msyn-wrong-case-in-coordination) OR (Loc &msyn-wrong-case-in-coordination) OR (Com &msyn-wrong-case-in-coordination) OR (Gen &msyn-wrong-case-in-coordination) TARGET (&msyn-wrong-case-in-coordination) - Ess IF (-1 CC OR COMMA LINK -1 Ill);  #2nd
COPY:msyn-wrong-case-in-coordination (Sg Loc SUGGEST) EXCEPT (Ess &msyn-wrong-case-in-coordination) TARGET (Ess &msyn-wrong-case-in-coordination) IF (-1 CC OR COMMA LINK -1 Loc); 
