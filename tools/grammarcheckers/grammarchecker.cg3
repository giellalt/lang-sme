ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE ("ja" &punct-rihkku) IF (NEGATE -1 (","))(NEGATE 0 ADDED-BEFORE-BLANK);
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE (Nom &punct-rihkku) IF (NEGATE -1 (","))(NEGATE 0 ADDED-BEFORE-BLANK);
	 ## Soai muitaleaba soai hÃĄliideaba olbmuid beroÅĄtiÅĄgoahtit eambbo ieÅūaset ÃĄssanbÃĄikkiid birra.
