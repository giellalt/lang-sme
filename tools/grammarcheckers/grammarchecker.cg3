 # These verbs typically combine with place adverbials in the genitive case @ADVL
 # (i.e. not accusative) I am not sure if the verbs in the second line do that too. They denote movement anyway.
 # These verbs take GEOGRAPHICAL-PLACE in Acc @OBJ.

LIST HUMAN-ACTIVITY-V = "bassit" "bealuإ،tit" "beaskidit" "beastit" "bivdit" "boaldit" "botket" "buktit" "buvttadit" "ؤچaskit" "ؤچatnat" "ؤچأ،jehit" "ؤچأ،llit" "ؤچoaggit" "ؤچoavdit" "ؤچugget" "ؤچuohppat" "dearvvahit" "deavdit" "devdnet" "dikإ،ut" "divvut" "doarrأ،dallat" "doidit" "dubmet" "duddjot" "duvdilit" "ferdnet" "gأ،hkket" "gأ،rvodit" "gأ،sttaإ،it" "gأ،vkat" "geahؤچؤچat" "gilvit" "goarrut" "goddit" "goؤ‘ؤ‘it" "gohؤچؤچut" "goikadit" "goivet" "gokؤچat" "gottihit" "guldalit" "guolأ،stit" "hأ،bmet" "hervet" "hoigat" "hoitأ،t" "hukset" "huإ،kut" "juhkat" "juksat" "juogadit" "juohkit" "lأ،ibut" "lأ،ktadit" "loaiddastit" "luddet" "merket" "mihtidit" "murret" "nannet" "nأ،italit" "njuoskadit" "oahpahit" "ohcat" "rahpat" "rأ،hkadit" "rأ،idnet" "rأ،tkit" "registreret" "rekruteret" "ruohkkat" "sأ،ddet" "sأ،ltet" "sأ،rgut" "sihkkut" "skihtardit" "skoalkalit" "tevdnet" "vadjat" "veahkehit" "vikإ،et" "vuoؤ‘ؤ‘udit" "vuosehit" "vuoidat" "vuoiddadit" "vuoitit" "vuostأ،ivأ،ldit" "vuoإ،إ،at" "vurket" ;

  # in contrast to abstract "activities" and static verbs.
  # According to the rules choosing Loc or Com, all activity-verbs do not select TOOL, ABSTR-TOOL, CONCEPT or HUMAN in (Pl Loc).

LIST BODY-ACTIVITY-V = "borrat" "ؤچiekؤچat" "ؤچujuhit" "ؤچuorbmat" "gullat" "guoskkahit" "lihkahit" "lihkastahttit" "njأ،vkkadit" "njأ،vkkastit" "oaidnit" "seavvit" ;

    # These verbs can also have BODY as a tool. The verb-set belongs to the superset of dynamic-verbs, so they will also work with TOOL and ABSTR-TOOL in Com. "Giehta" is in both the TOOL-set and the BODY-set because it selects in Com to a lot of verbs.

LIST PLACING-ACTIVITY-V = "bidjat" "buonjostit" ;

#LIST HUNTING-ACTIVITY-V = "bivdit" "goddit" "luossa-bivdit" ;

#LIST FOOD-ACTIVITY-V = "ferdnet" ;

#LIST WORKING-ACTIVITY-V = ;

LIST WRITING-ACTIVITY-V = "ؤچأ،llit" ;

LIST HANDICRAFT-ACTIVITY-V = "buddet" "botnit" "goarrut" "hervet" "vadjat" "vikإ،et" ;

SET ACTIVITY-V = BODY-ACTIVITY-V OR WRITING-ACTIVITY-V OR PLACING-ACTIVITY-V OR HUMAN-ACTIVITY-V OR HANDICRAFT-ACTIVITY-V ;

#LIST DADJAT = "dadjat" "lohkat" ;
# This set is for  cealkkavأ،stta: DADJAT + Acc + Inf - Not in use for the time being

LIST HUPMAT =  "dأ،ikit" "dأ،rostit" "digأ،إ،tallat" "digaإ،tit" "duoldat"  "hأ،ladit" "hأ،leإ،tit" "hأ،llat" "hoallat" "humadit" "hupmat" "logaldallat" "mأ،idnut" "mأ،innaإ،it" "muitaladdat" "njurgut" "oaivvildit" "savkalit" "sأ،gastaddat" "sأ،gastallat" "sأ،gastit" "sأ،mأ،stit" "sأ،mistit" "sأ،rdnidit" "sأ،rdnut" "sأ،rtnodit" "solإ¾at" "suomastit" ;
# These should not take HUMAN as object

LIST VERBAL-ACTIVITY =  "أ،rvalit" "cealkit" "ؤچilget" "basuhit" "cuoigut" "ؤچuorvut" "ؤچurvet"  "dadjat" "gielistit" "gilljut" "gopmulit" "hأ،ladit" "hأ،leإ،tit" "hأ،llat" "hoallat" "huikit" "huikkأ،dit" "jearrat" "juoigat" "kommenteret" "lأ،vlut" "lohkat"  "muitalit"  "rأ،vvet" "sivdnidit" "vأ،ruhit" "vأ،stidit" ;

