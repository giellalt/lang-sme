COPY:real-DerNomActSgGen-PrtSg1 (V TV Ind Prt Sg1 SUGGEST) EXCEPT (Actio Gen &real-DerNomActSgGen-PrtSg1) OR (Actio Nom &real-DerNomActSgGen-PrtSg1) OR (Der/NomAct N Sg Nom &real-DerNomActSgGen-PrtSg1) OR (Der/NomAct N Sg Gen &real-DerNomActSgGen-PrtSg1) OR (Der/NomAct N Ess &real-DerNomActSgGen-PrtSg1) OR (Der/NomAct N Sg Loc South Err/Orth &real-DerNomActSgGen-PrtSg1) TARGET (V &real-DerNomActSgGen-PrtSg1) ;


	# Imprt/Px  vs passiv, a-stam, i-stam; konsonantgrupper 2, 3C, ddj-dj-j, infinitive grad II
	# --------------------------------------------------------------------------------------
	# atnonآ¢(verb,conc|adnon)
	# atnon	atnit+V+TV+Imprt+Sg1
	# atnit+V+TV+Der/PassS+V+IV+PrfPrc
	# V+TV+Der/PassS+V+IV+PrfPrc+Err/Confused-NSgPxSg1

ADD:real-ImprtSg1-DerPassPrfPrc (&real-ImprtSg1-DerPassPrfPrc) TARGET (V Imprt Sg1) OR (Der/PassS PrfPrc Err/Confused-NSgPxSg1) IF (NEGATE *1 ("!"))(NEGATE 0 N - Px OR Ind OR PrfPrc  - Err/Confused-NSgPxSg1 OR Der/InchL)(NEGATE 0 Der/alla OR Der/adda OR Der/h OR Der/d OR Der/l OR Der/st);
    #$ ؤŒuvvon su dugo bأ،ddegeaإ¾in lأ،idejuvvon gأ،lbi إ،illjui, dugo dأ،pmon meahcce-ealli. # ؤŒuvvon!! -vv- ii galgga mielde!
    #$ Olju vudjon fatnasis آ«Panton -300 آ» olggobeale Ovttastuvvon arab emirأ،htaid lea nuoskkideamen stuorra osiid guovllu eallimis ja rittus. #Ovttastuvvon
    #$ Ealggat vأ،tnon. #vأ،tnon
    ## Lأ،vdegoddi lea ؤچoagganan guovtte gearddi jagis, muhto ollu أ،igi lea atnon guorahallat أ،iddiid.   ---   atnon
    ## Kapos إ،addأ، nubbi : son lea atnon earأ،lأ،ganin earأ،id ektui.   ---   atnon
    ## Barggut mat doppe leat tearbma barggut servodatfأ،gas ja matematihkas, bidjat oahpponeavvuid mat leat atnon Elgأ¥ skuvllas oahpponeavvoportأ،lai ovttas.no.   ---   atnon
    ## Muhto de ledje olles guoktأ،sis dodjon sabehat, ja go ledje bأ،ljes duoddaris, de eai gأ،vdnan dan meare nuora ahte livؤچؤچe heahtesabehiid sأ،httأ،n dahkat.-- dodjon
    ## Son vujii aإ‹kke badjel beali heata dodjon julggiin ja dohppestii vel silbba!--dodjon
	## Kommiإ،uvdna lea jagi 1997 cuoإ‹omأ،nu rأ،jis bargan doaimmaiguin mat dasa ledje bidjon ja lea odne, ؤچoahkkimis Helssegis, loahpahan barggu ovttajienalaإ، evttohusain.---bidjon
	## Oktasaإ، sأ،melأ،hka ii bidjon goassege fأ،pmui Finnmأ،rkku boazodollui.---bidjon.
	## Sأ،pmelaإ، eallinvuohki ja أ،rvvut eai leat lأ،hpon, muhto dain baicce sأ،httأ، oaidnit mearkkaid ain dأ،lge.---lأ،hpon
    ## Girji lea lأ،hpon, muhto Alaj Mikhalkova 1606-1608 " olmmoإ،logut " galget leahkit Agalina girjji mielde. ---lأ،hpon
    #$ Oktiibuot njeallje mأ،nأ، ledje {bovdehallon} vieإ¾إ¾at girjji.

COPY:real-ImprtSg1-DerPassPrfPrc (Ex/V Ex/TV Der/PassS V IV PrfPrc SUGGEST) EXCEPT (V TV Imprt Sg1 &real-ImprtSg1-DerPassPrfPrc) OR (Ex/V Ex/TV Der/PassS V IV PrfPrc Err/Confused-NSgPxSg1 &real-ImprtSg1-DerPassPrfPrc) TARGET (&real-ImprtSg1-DerPassPrfPrc) ;

	# Imprt/Px  vs passiv, a-stam, i-stam; konsonantgrupper 2, 3C, ddj-dj-j, infinitive grad II
	# --------------------------------------------------------------------------------------
	# bidjotآ¢(verb,conc|biddjot)



ADD:xreal-ImprtPl1-DerPassInf (&real-ImprtPl1-DerPassInf) TARGET CONC-2-3C-DDJ IF (0 IT-AT-VERBS + (V Imprt Pl1))(NEGATE *1 ("!"));	#DUOMMأپ
	## Stأ،htaide sأ،httet maiddأ،i bidjot geatnegasvuoؤ‘at dehe dأ،hkiduvvot vuoigatvuoؤ‘at dan vuoؤ‘ul go dahkko mearrأ،dus stأ،daidgaskasaإ، organisaإ،uvnnas. ---   bidjot
	## Rأ،ؤ‘ؤ‘ehus deattuha ahte boazodoallopolitihkka galgأ، oppalaؤچؤچat bidjot oktavuhtii sأ،mi politihkain, ja sأ،mi أ،lbmot galgأ، ieإ، hأ،bmet mihttomeriid ja sisdoalu.  ---   bidjot
	## Jus badjelmeare vikkat ؤچavget dأ،vggi, de sأ،httأ، dat dodjot.--dodjot
	## â€“ Jus ؤچavge juvlaboalttuid badjelmeare, de sأ،httأ، boaltu dodjot ja juvla beassat.---dodjot
    ## Interneahtta dagaha vejolaإ¾إ¾an gulahallat earأ،iguin teavstta, hupmأ،ma dehe govaid bakte, giehtatelefuvdna sأ،httأ، adnot teakstatelefuvdnan ja dihtormأ،إ،iidnan.---adnot
    ## Departemeanta evttoha ahte lأ،gas mearriduvvo ahte Saint Laguأ«s vuohki galgأ، adnot أ،irasiid juohkimis biiriid gaskkas danin_go أ،irrasjuohkinvuohki lea guovddأ،إ، oassi vأ،lgaortnegis.---adnot
	## Mأ،nأ،in hأ،leإ،tettiin vأ،ldit vuhtii oppalaؤچؤچat buot أ،إ،إ،أ،i gullevaإ، dahkkiid, muhto ii galgga lأ،hpot siidoأ،إ،إ،iide. ---lأ،hpot
	## Doloإ، tearpmaid galggaإ،ii sihkkarastit amaset dat lأ،hpot.---lأ،hpot

#COPY:real-ImprtPl1-DerPassInf (Der/PassS Inf SUGGEST) EXCEPT (Imprt Pl1 &real-ImprtPl1-DerPassInf) TARGET (&real-ImprtPl1-DerPassInf) ;


	# noun vs noun,  u-stam, a-stam, i-stam; konsonantgrupper: iX - iXX CONC-4B, nomsg grad III
	# -------------------------------------------------------------------------
	# أ،ggiآ¢(noun,typo|أ،iggi) أ،ggi+N+Sg+Nom vs. أ،igi+N+Sg+Acc, gummiineasetآ¢(recipr,vow|guimmiineaset)
	# not the same lemma
	#lexc: أ،ggi "أ،igi" N Sg Gen Confused

ADD:xreal-PlNomPxSg2-PlNom (&real-PlNomPxSg2-PlNom) TARGET (N Sg Nom Err/Confused) IF (0 EVEN-VERBS + CONC-i);	#DUOMMأپ
	## Jos bagadeapmi galggaإ، leat أ،vkkأ،laإ،, de dan berre struktureret ja berre vأ،rret أ،ggi bagadeapmأ،i. ---أ،ggi
    ## Dat geat bohte mأ،rkaniidda ledje gaikkat sorjavaؤچؤچat guؤ‘et gummiineaset. ---gummiineaset
    ## De vأ،lde duon biggأ،, ja nأ،italii ge bأ،rdni suinna, ja lأ،ikkes nieida bأ،zii dasa.---biggأ،
    ## Deavdأ، go SOF rأ،ggi maid earأ، ruhtadeaddjit eai nأ،kce deavdit, lea go foanda deavddan earأ،ide ?---rأ،ggi
    ## Hأ،pmir â€“ Sirkأ،s guovlu Vأ،sأ،husat ؤچأ،jehit ahte beaivvأ،laإ، dilis ii doamma dat bures go riikarأ،dji lea guohtunrأ،djin ja dasa_lassin velأ، leat rأ،djeأ،iddit. ---  doamma


	# Prs Sg1 - PrfPrc: -ut, CONC-4A  nomsg grade III
	# ------------------------------
	# baskkun - baskon

#

#JO A-vearbbaide grade III-II konsgroups 2, 3a,3b,3c,4a,4b,4c

ADD:real-PrsSg1-PrfPrc (&real-PrsSg1-PrfPrc) TARGET AT-VERBS IF (0 (Ind Prs Sg1) LINK 0 CONC-2-3A-3B-3C-4ABC)(*-1 COPULAS + Pl3 BARRIER NOT-ADV-PCLE LINK *-1 (N Pl Nom) OR (Pl3 Nom) OR (Rel Pl Nom) BARRIER NOT-ADV-PCLE)(NEGATE 0 PrfPrc) ;

ADD:real-PrsSg1-PrfPrc (&real-PrsSg1-PrfPrc) TARGET AT-VERBS IF (0 (Ind Prs Sg1) LINK 0 CONC-2-3A-3B-3C-4ABC)(*-1 COPULAS + Sg3 BARRIER NOT-ADV-PCLE LINK *-1 (N Sg Nom) OR (Sg3 Nom) OR (Rel Sg Nom) BARRIER NOT-ADV-PCLE)(NEGATE 0 PrfPrc) ;
	## أپlggus sأ،httأ، vأ،idalit njuolga dan olbmui guhte lea iskkan dahje dikإ،un du.
	## Nأ،vet lea أ،igأ، jo mieskkan ja gahؤچؤچan.
	
ADD:real-PrsSg1-PrfPrc (&real-PrsSg1-PrfPrc) TARGET AT-VERBS IF (0 (Ind Prs Sg1) LINK 0 CONC-2-3A-3B-3C-4ABC)(*-1 (N Pl Nom) OR (Pl3 Nom) BARRIER NOT-ADV-PCLE LINK *-1 COPULAS + Pl3 BARRIER NOT-ADV-PCLE)(NEGATE 0 PrfPrc) ;

ADD:real-PrsSg1-PrfPrc (&real-PrsSg1-PrfPrc) TARGET AT-VERBS IF (0 (Ind Prs Sg1) LINK 0 CONC-2-3A-3B-3C-4ABC)(*-1 (N Sg Nom) OR (Sg3 Nom) BARRIER NOT-ADV-PCLE LINK *-1 COPULAS + Sg3 BARRIER NOT-ADV-PCLE)(NEGATE 0 PrfPrc) ;

ADD:real-PrsSg1-PrfPrc (&real-PrsSg1-PrfPrc) TARGET AT-VERBS IF (0 (Ind Prs Sg1) LINK 0 CONC-2-3A-3B-3C-4ABC)(*-1 (Pers Nom) + $$PERS-NUM BARRIER NOT-ADV-PCLE LINK *-1 COPULAS + $$PERS-NUM BARRIER NOT-ADV-PCLE)(NEGATE 0 PrfPrc) ;

ADD:real-PrsSg1-PrfPrc (&real-PrsSg1-PrfPrc) TARGET AT-VERBS IF (0 (Ind Prs Sg1) LINK 0 CONC-2-3A-3B-3C-4ABC)(-1 ("visot") OR ("buot") OR ("ollأ،sit") LINK -1 COPULAS + Ind)(NEGATE 0 PrfPrc) ;
	##  Lean visot njuoskkan.
	## Dأ،n ؤچavؤچؤچa loahpahuvvo okta golbmajahkأ،saإ، naإ،unأ،la proإ،eakta gos dutkit leat lohkan rievssahiid ja iskkan makkأ،r guovlluin leat hui unnأ،n rievssahat.
	
