# Valency sets
# - - - - - - -

LIST INFV = "astat" "ÃĄdjÃĄnit" "ÃĄigut" "ÃĄlgit" "ÃĄsahit" "bÃĄgget" "bÃĄvÄÄagit" "beassat" "berret" "bivdit" "bivvat" "bistit" "boahtit" "bovdet" "ÄohkkÃĄt" "Äohkkedit" "ÄohkkÃĄnit" "ÄuoÄÄahit" "ÄuoÄÄastit" "Äuorvut" "Äurggodit" ("dadjat" Der/PassL) ("dadjat" Der/PassS) "dagahit" "dÃĄhttut" "dÃĄidit" "dÃĄrbbaÅĄit" "defineret" "diktit" "doaivut" "doapmat" "duostat" "fertet" "fuobmÃĄt" "fuolahit" "galgat" "gÃĄibidit" "gÃĄrrut" "gÃĄrtat" "geahÄÄalit" "geargat" "geatnegahttit" "gierdat" "gillet" "gohÄÄut" "hÃĄhppehit" "hÃĄlidit" "hÃĄliidit" "hÃĄrjÃĄnit" "heivet" "lÃĄvet" "mannat" "mÃĄhttit" "mÃĄÅĄÅĄat" "movttiidahttit" "muitit" "nagodit" "navdit" "oahpahit" "oahpÃĄstuvvat" "oahppat" "oaÅūÅūut" "ollet" "ribahit" "riepmat" "sÃĄhttit" "seahtit" "sihtat" "soaitit" "suovvat" "ÅĄaddat" "staÄÄat" "veadjit" "viggat" "viÅĄÅĄat" "vuogÃĄiduvvat" "vuolgit" "vuollÃĄnit" "vuordit";


LIST ACC-INFV = "bivdit" "Äuorvut" "dagahit" "diktit" "gohÄÄut" "movttiidahttit" "sihtat" "suovvat" ;

