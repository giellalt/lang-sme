	# those are adverbs and Po:s that has same function as comparatives: mon lean 2 jagi nuorat go don vs. mon orun 2 miilla dأ،bbelis go don

LIST NOM-ACC-NUM = (".*guokte"r) (".*golbma"r) (".*njeallje"r) (".*vihtta"r) (".*guhtta"r) (".*ؤچieإ¾a"r)  (".*gأ،vcci"r) (".*ovcci"r) (".*logi"r) ("moadde") ("galle") ;

LIST NOM-GEN-NUM = (".*ؤچieإ¾a"r)  (".*gأ،vcci"r) (".*ovcci"r) (".*logi"r) ("galle") ;



ADD:xmsyn-acc-to-adv (&msyn-acc-to-adv) TARGET Num IF (0 NOM-ACC-NUM)(NOT 0 Acc OR Nom OR ACC-NUM-ATTR LINK 1 Sem/Measr OR MEASURE OR Sem/Time LINK 1 ACC-ADV OR ("boaris")) ;  #2nd
ADD:xmsyn-acc-to-adv (&msyn-acc-to-adv) TARGET Num IF (NOT 0 NOM-ACC-NUM)(NOT 0 Acc OR Gen OR ACC-NUM-ATTR OR GEN-NUM-ATTR LINK 1 Sem/Measr OR MEASURE OR Sem/Time LINK 1 ACC-ADV OR ("boaris")) ;  #2nd

ADD:xmsyn-acc-to-adv (&msyn-acc-to-adv) TARGET ACC-ADV OR ("boaris") IF (-1 Sem/Measr OR MEASURE OR Sem/Time LINK *-1 (Num &msyn-acc-to-adv));

COPY:msyn-acc-to-adv (Acc SUGGEST) EXCEPT (Gen) TARGET (Gen Num &msyn-acc-to-adv) ;  #2nd
	#$ Dأ،n mأ،nnأ، lea buorre muddui olahan go lea birrasii golbma jagi boaris.
    #$ Min viessu lea vihtta mehtera alu.
    #$ Dalle lei 10 kilomettar guhkkosaإ، lأ،httu أپlttأ، guvlui mas 170:s ledje mielde. XXX
    ## Min viessu lea viؤ‘ainlot mehtera alu.
    #$ Sus lea njealje mehtera guhkkosaإ، biila.
    #$ Suorpmas lea guokte millimehtera govdat.
    #$ Lean vihttalot jagi boaris.
    #R Nickel1994:485,488 genitive: at least
    # in errors.xml

ADDRELATION:msyn-acc-to-adv (RIGHT $2) (Num &msyn-acc-to-adv) TO (*1 &msyn-acc-to-adv + ACC-ADV);
    
ADD:xmsyn-acc-to-velggolaإ، (&msyn-acc-to-velggolaإ،) TARGET Num IF (NOT 0 ACC-NUM-ATTR OR Acc LINK 1 CURRENCY OR Sem/Money LINK 1 ("velggolaإ،")) ;  #2nd
COPY:msyn-acc-to-velggolaإ، (Acc SUGGEST) EXCEPT Gen AFTER Sg OR Pl TARGET (Num &msyn-acc-to-velggolaإ،) ;  #2nd
    ## أپndde lea munnje viؤ‘alot ruvnnu velggolaإ،.
    #$ أپndde lea munnje vihttalot ruvnnu velggolaإ،.
    ## أپndde lea munnje guovtti ruvnnu velggolaإ،.
    #R Nickel1994:485 "Akkusativformen stأ¥r ogsأ¥ som attributt til adjektivene boaris, 'gammel' og velggolaإ، 'skyldig'."
    # in errors.xml
    
ADD:xmsyn-acc-to-velggolaإ، (&msyn-acc-to-velggolaإ،) TARGET ("velggolaإ،") IF (-1 CURRENCY OR Sem/Money LINK -1 Num) ; 

ADDRELATION:msyn-acc-to-velggolaإ، (RIGHT $2) (Num &msyn-acc-to-velggolaإ،) TO (*1 ( "velggolaإ،" &msyn-acc-to-velggolaإ،));
 
ADD:xmsyn-acc-to-comp (&msyn-acc-to-comp) TARGET Num IF (NOT 0 Acc OR Nom OR ACC-NUM-ATTR LINK 1 Sem/Measr OR MEASURE OR Sem/Time OR CURRENCY LINK 1 ("maإ‹إ‹il") OR ("maإ‹إ‹el") OR ("ovdal") OR ("maإ‹إ‹elaإ،") OR ("ovdalaإ،") OR Comp OR ADV-COMP-FUNCTION ) (NEGATE 0 Gen LINK 1 Sem/Measr OR MEASURE OR Sem/Time OR CURRENCY LINK 1 Comp OR ADV-COMP-FUNCTION LINK 1 Loc)(NOT 0 (Num Arab)) ;  #2nd
    ## Mأ،htte lea viؤ‘a jagi nuorat go mun. PROBLEM
    ## Dat إ،attai guovtti mehtera guhkit go galggaإ،ii.
    ## Son vuvddii daid bohccuid viؤ‘a ruvnno hأ،lbbibui.
    #$ Kisumu أ،ssit muitalit, ahte friijasit golgi إ،addu fأ،rredaddأ، Kisumu ja Homabay gaskkas, mii leat {200} kilomehtera mأ،ddelis go Kisumu.
ADD:xmsyn-acc-to-comp (&msyn-acc-to-comp) TARGET Num IF (NOT 0 Acc OR ACC-NUM-ATTR LINK 1 Sem/Measr OR MEASURE LINK *1 Gen OR Acc BARRIER GRAMCHK-NPNHA LINK 1 ADV-COMP-FUNCTION ) ;  #2nd
	# difficult to searching for
    
ADD:xmsyn-acc-to-comp (&msyn-acc-to-comp) TARGET Num IF (NOT 0 Acc OR ACC-NUM-ATTR LINK 1 Sem/Measr OR MEASURE LINK *1 Loc BARRIER GRAMCHK-NPNHA  LINK *1 ("eret") BARRIER GRAMCHK-S-BOUNDARY ) ;  #2nd

COPY:msyn-acc-to-comp (Num Sg Acc SUGGEST) EXCEPT (Num Sg Gen) OR (Num Sg Loc Attr) OR (Num Sg Ill Attr) OR (Num Sg Nom) TARGET (Num &msyn-acc-to-comp) ;  #2nd
	#$ Mأ،htte lea vihtta jagi nuorat go mun.
    #$ Mأ،htte lea viؤ‘a jagi nuorat mus.    
    ## Lأ،sse lea riegأ،dan viؤ‘a jagi ovdal go mon. DISAMBPROBLEM: "viؤ‘a" Po is chosen
    ## Dat dأ،hpأ،huvai viؤ‘a jagi maإ‹إ‹il. - Duommأ،: why is this example here?
    ## أپdjأ، viessu lea guovtti miilla bajأ،beale mأ،rkana.
    ## Mun oidnen guovإ¾إ¾a golmma kilomehtera dأ،bbelis.
    ## Guovdageaidnu lea golmma miilla duoin eret.
    ## Guovdageaidnu lea golmma miilla Kأ،rأ،إ،jogas eret.
    ## Guovdageaidnu lea golmma miilla duoin viesuin eret.
    ## أپdjأ، viessu lea guovtti miilla mأ،rkana bajأ،beale.

    #$ Guovdageaidnu lea golbma miilla duoin eret.
    #$ Guovdageaidnu lea golbma miilla Kأ،rأ،إ،jogas eret.
    #$ Guovdageaidnu lea golbma miilla duoin viesuin eret.
    #$ أپdjأ، viessu lea guokte miilla mأ،rkana bajأ،beale.
    #R: Nickel1994:486 "I أ¸st brukes ogsأ¥ genitiv i forbindelse med komparasjon, dersom komparativen er predikativ i steningen, og det andre sammanligningsleddet stأ¥r i lokativ: Mأ،htte lea viؤ‘a jagi nuorat mus."
    # in errors.xml

ADD:xmsyn-acc-to-comp (&msyn-acc-to-comp) TARGET Comp OR ADV-COMP-FUNCTION IF (-1 Sem/Measr OR MEASURE OR Sem/Time OR CURRENCY LINK -1 Num)(NEGATE 0 &msyn-acc-to-adv);

ADDRELATION:msyn-acc-to-comp (RIGHT $2) (Num &msyn-acc-to-comp) TO (*1 Comp OR ADV-COMP-FUNCTION LINK 0 &msyn-acc-to-comp);


