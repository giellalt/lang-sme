#DELETE uncommon	
ADD:xreal-jearran (&real-jearran) TARGET ("jeara" N Ess) OR ("jeara" N Sg Loc South Err/Orth) OR ("jeara" N Sg Acc PxSg1) OR ("jeara" N Sg Nom PxSg1) OR ("jeara" N Sg Gen PxSg1) OR ("jearrat" V TV Ind Prs Sg1) IF (NEGATE 0* Sg1 + Nom BARRIER GRAMCHK-S-BOUNDARY)(*-1 NOT-V OR BE BARRIER GRAMCHK-S-BOUNDARY);

COPY:real-jearran ("jearrat" V TV PrfPrc SUGGEST) EXCEPT ("jeara" N Ess &real-jearran) OR ("jeara" N Sg Loc South Err/Orth &real-jearran) OR ("jeara" N Sg Acc PxSg1 &real-jearran) OR ("jeara" N Sg Nom PxSg1 &real-jearran) OR ("jeara" N Sg Gen PxSg1 &real-jearran) OR ("jearrat" V TV Ind Prs Sg1 &real-jearran) TARGET (&real-jearran);
