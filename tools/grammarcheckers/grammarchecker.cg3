LIST OPREDV = "alidit" "atnit" "dadjat" "dahkat" "dulkot" "geavahit" "geahÄÄat" "gohÄodit" "gohÄÄut" "meroÅĄtallat" "navdit" "vÃĄldit" "vÃĄlljet";

 # Verbs that occur with objects that have secondary predicates.

LIST OKTII-V = ("boallu" Der/huvva) "goallostuvvot" "beaÅĄkkehat" "bidjat" "Äatnat" "suddat" "heivet" "bidjat" "Äaskit" "geassit" "gullat" "rehkenastit" "ordnet" "soahpat" "gÃĄvnnadit" "heivehit" "doaibmat" "iskat" "laktit" "seaguhit";

