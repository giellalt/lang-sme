  # TIME/AIGODAT are locative

LIST STATE-V = "eallit" ;


LIST REM-WITH-PARTS = "gaikkihit" ;

    # Belongs to the DYNAMIC-V. They also take PARTS in comitative case.

LIST CONTRAST-V = "rأ،tkit" ;

    # two arguments, the second of which is locative


LIST EMOTION-V = "heahpanaddat" "heahpanit" "rأ،hkistit" ;

LIST PERCEPTION-V = "أ،icat" "dovdat" "ealvit" "fuomأ،إ،it" "fuobmأ،t" "gullat" "hأ،ksit" "huobmأ،t" "huomihit" "oaidnit" ;

LIST ILLNESS-V = "buohcat" "dearvvaإ،mahttit" "dearvvaإ،muvvat" "dearvvaإ،nuvvat" "dearvvaإ،tuvvat" ;


# HIERARCHY:

#SET STATIC-V = PLACE-V OR EMOTION-V OR PERCEPTION-V ;

SET DYNAMIC-V = ACTIVITY-V OR MOVEMENT-V OR VERBAL-ACTIVITY-V OR HUMAN-AGENT-V OR INTELLECTUAL-ACTIVITY-V OR ABSTR-ENTITY-COM-V OR HUMAN-SOURCE-VEHICLE-V OR REM-WITH-PARTS ;

    # According to the rules choosing Loc or Com, dynamic-verbs do not select TOOL, ABSTR-TOOL or CONCEPT in (Pl Loc).
    # Human becomes either Loc or Com depending on its subset membership.

SET N-TIMEOBJECT-V = MOVEMENT-V OR ACTIVITY-V OR VERBAL-ACTIVITY-V OR INTELLECTUAL-ACTIVITY-V OR PLACE-V ;

    # Those verb sets in addition to TIMEADVERBIAL-V do not take TIME expressions as objects

# Adverbs
# -------

# Adverbs as predicates
# - - - - - - - - - - -
    # in combination with verbs

LIST COM-ADV = "fأ،rrolaga" "oktan" "oktanaga" "ovttamielas" "ovttas" "ovttasrأ،ؤ‘iid" "searvأ،lagaid" "searvأ،laga" "searvأ،l" "searvأ،la" ;

    # Could also be perceived as particles within complexs verbs.

# others: vuhti combines with vأ،ldit - Com

# Other adverb sets
# - - - - - - - - -

LIST GRADE-ADV =  "ain" "أ،ibbas" "beare" "duإ،إ،e" ("eanet" Adv) "erenoamأ،n" "erenoamأ،إ،" "earenoamأ،إ،" "hirbmat" "hui" "ihأ،na" "ila" "ilأ،" "issoras" "liiggأ،s" ("man" Adv) ("mealgat" Adv) "measta" "menddo" "mihأ،" "muhtun_muddui" "nie" "nu" "oalle" "oba" ("oppa" Adv) ("ollu" Adv) "sakka" "seamma" "seammأ،" ("veahأ،إ،" Adv) "vehأ،" "vehأ،إ،" "veahأ،" "veahأ،إ،" "vel" "velأ،" "viehka" ;

LIST GRADE-ADV-2 =  "ain" "أ،ibbas" "erenoamأ،n" "erenoamأ،إ،" "earenoamأ،إ،" "hirbmat" "hui" "ihأ،na" "ila" "ilأ،" "issoras" ("man" Adv) "menddo" "mihأ،" "oalle" "oba" ("oppa" Adv) "seamma" "seammأ،" "viehka" ;

LIST XT-ADV = "doarvأ،i" "eambbo" "eanet" "hirbmosit" "garrasit" "issorasat" "ollu" "sakka" "uhccأ،n" "unnأ،n" "vehأ،" "vehأ،إ،" "veahأ،" "veahأ،إ،" ;
	## often the case that a verb that is otherwise used with a theme argument can stand alone, i.e. with an XT-ADV
	
LIST FOCUS-ADV = "erenoamأ،إ¾it" "vuohؤچؤچan" ;

LIST PLURALIZER = "buot" "buotlأ،gan" "buotlأ،gأ،n" "buotlأ،gأ،إ،" "earأ،lأ،gan" "ieإ¾أ،lأ،gan" "ieإ¾أ،lأ،gأ،n" "gait" "gaitlأ،gan" "gaitlأ،gأ،n" "goappeإ،" "goappaإ،at"  "mأ،إ‹ggalأ،gan" "mأ،إ‹ggalأ،gأ،n" "moattelأ،gan" "moattelأ،gأ،n" "moattilأ،gan" "moattilأ،gأ،n" ;
    # Singular nouns can have a plural form combined with those


# Adjectives
# ----------

# Lexical valency sets
# - - - - - - - - - - -
    # here we have adjectives according to their semantic properties
    # in periphrastic constructions (together with "leat") they subcategorize for comitative, locative etc. depending on the noun's semantic properties

LIST COM-ADJ = "olles" "oppa" ;

LIST ILL-ADJ = "gullevaإ،" "bahأ،";
    ## Ja danin son lei إ،addan nu bahأ، tأ،laide ja bustأ،vaide.

LIST ACTIVITY-ADJ = "hilbat" "oskkأ،ldas" ;

    # denote som kind of activity, might take HUMAN comitative?

LIST DEHALAS = "dأ،bأ،laإ،" "dehأ،laإ،" "suohtas" ;
	# When Attr = pred.form
	## Lea suohtas kurssas. - not Attr
	## Lea ؤچuovvovaإ، kurssas. - Attr

#LIST ATTITUDE-ADJ =

#LIST ATTRIBUTE-ADJ = "ؤچeahppi" ;

# Nickel: predicative adjectives (take a complement) "fargat" "heavnnas" "sأ،iggas" "suhtas"

# Other adjective sets
# - - - - - - - - - - -
    # In order to disambiguate between N and A
    # Those are nouns/adjectives with zero derivation

LIST DER-ADJ-N = "addi" "lأ،vlu" "lohkki" "ovddasteaddji" "rأ،ؤ‘ؤ‘ejeaddji" "sadjأ،saإ،" "vأ،zzi" "vuoddji" "vuoiti" "vuovdi";

LIST ADJ-N = "buoidi" "ؤچeahppi" "headju" "heittot" "jalla" "neavri" "nuorra" "oahpis" "oarbbis" "rأ،hkis" "rikkis" "vأ،ivvأ،إ،" "vuoras";

    # nouns that have very specific semantics and are derived from adjectives
    # those nouns are animate

LIST ADJ-N-CASE = "varas" ;
    # adjectives which are also nouns in other cases than nominative

LIST NON-GRADE-ADJ = "sأ،pmelaإ،" "alternatiiva" ;
    # gradable under certain circumstances, for example if we write "nu" "hirbmat" "hui" "oalle" "oppa" "vehأ،إ،"
    ## mon dagahallan NU sأ،pmelaإ¾إ¾an = jeg later som jeg er Sأ…أ… same/samisk?
    ## mon anأ،n du VIEHKA sأ،pmelaإ¾إ¾an

LIST GRADE-ADJ = "fأ،vru" "headju";
    # The ones that have a strong adjective meaning, and are inclined to be adjectives rather than nouns in Ess constructions

LIST LEX-ADJ = "bassi" "guovddأ،إ،" "nuorra" "oahpis" "vأ،ivi" "oainnus";
    # Those are quite strongly lexicalized as nouns.

LIST TIME-A = "boahtte" "ؤچuovvovaإ،" "maإ‹emus" "maإ‹imus" ("maإ‹it" A Attr) "ovddit" ("mannat" PrfPrc) ("vأ،ssأ،t" PrfPrc)   ;

LIST DURATION-A = "heila" "eanas" "eanet" "geaإ¾o" "geaإ¾os" "guhkki" "obba" "oba" "ollis" "oppa" "visot" ;

LIST DURATION-ADV = "meastui" "measta" "masأ،" "varga" "vargui" "vargahui" "goasii" "goase" ;

LIST POINT-IN-TIME-SPEC = "doloإ،" "earأ،" "nubbi" ;



# NP sets defined according to their morphosyntactic features
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

LIST N-SG-NOM = (N Sg Nom);
LIST N-PL-NOM = (N Pl Nom);

SET LEX-N = N - N-DER;

LIST PROP = (N Prop);

SET CNOUN = N - Prop;

SET HNOUN = N - Cmp/SplitR ;

SET HNOUN-NOM = (N Nom) - Cmp/SplitR ;

SET N-NOT-GEN = N - (N Gen) ;

SET NP = N OR A ;                      # anything that can take except numerals
SET NP-HEAD        = Pron OR HNOUN - ("buorre") ;
SET NP-HEAD-SG     = SGPRON OR (N Sg) OR (A Sg) - Cmp/SplitR  - Dem - ("buorre");
SET NP-HEAD-PL     = PLPRON OR (N Pl) OR (A Pl) - Cmp/SplitR  - Dem - ("buorre");
SET NP-HEAD-SG-NOM = SGPRON + Nom OR (N Sg Nom) OR (A Sg Nom) - ("buorre") - Cmp/SplitR ;
SET NP-HEAD-PL-NOM = PLPRON + Nom OR (N Pl Nom) OR (A Pl Nom) - Cmp/SplitR  - ("buorre");
SET NP-HEAD-NOM    = NP-HEAD-SG-NOM OR NP-HEAD-PL-NOM ;
SET NP-HEAD-ACC    = (Pron Acc) OR (N Acc) OR (A Acc) - Cmp/SplitR - Dem - ("buorre");
SET NP-HEAD-GEN    = (Pron Gen) OR (N Gen) OR (A Gen) - Cmp/SplitR - Dem - ("buorre");

SET NOT-NP-HEAD-COMMA-CC = WORD - NP-HEAD - COMMA - CC ;
SET NOT-NP-HEAD-COMMA-CC-Adv-Neg = WORD - NP-HEAD - COMMA - CC - Adv - Neg ;


