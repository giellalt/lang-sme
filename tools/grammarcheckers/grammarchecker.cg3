    # ------------------
    
ADD:xreal-luohti (&real-luohti) TARGET ("luohttit") IF (0  (V IV Imprt Du2) OR (V IV PrsPrc) OR (V IV Der/NomAg N Sg Nom) OR (V IV Der/NomAg N Sg Gen) OR (V IV Der/NomAg N Sg Acc)) (NEGATE *0 Ill OR ILL-LOC-PRON-ADV BARRIER GRAMCHK-S-BOUNDARY) ;

COPY:real-luohti ("luohti" N Sg Nom SUGGEST) EXCEPT ("luohttit" V IV Imprt Du2) OR ("luohttit" V IV PrsPrc) OR ("luohttit" V IV Der/NomAg N Sg Nom) OR ("luohttit" V IV Der/NomAg N Sg Gen) OR ("luohttit" V IV Der/NomAg N Sg Acc) TARGET (V &real-luohti) ;
	## Luohtti fأ،moleabbo go leat mأ،إ‹ggas.
	## Leai miellagiddevaإ، gullat man lأ،hkai boares Lars Nilsson Ruong luohtti gullui.
	

	# mahkأ، iige mahkkأ،
	# -----------------

ADD:xreal-mahkأ، (&real-mahkأ،) TARGET ("mahkkit" V IV Ind Prs Sg3) IF (NEGATE *0 Ill OR ILL-LOC-PRON-ADV BARRIER GRAMCHK-S-BOUNDARY) ;

COPY:real-mahkأ، ("mahkأ،" Adv SUGGEST) EXCEPT ("mahkkit" V IV Ind Prs Sg3 &real-mahkأ،) TARGET (V &real-mahkأ،) ;
	
	## Sأ،mediggi sأ،httأ، mأ،ksit massojuvvon bargodietnasa ovddas njuolga bargoaddأ،i (gildii dahje stأ،hta fitnodagaide ) go refuإ،uvdnagأ،ibأ،dus buktojuvvo, ja go dأ،t lea إ،iehtaduvvon bargoaddi ja bargi gaskkas, nu go mahkkأ، virgelohpeohcamuإ،.
	## Jus galggaإ،ii mahkkأ، Finnmأ،rkui rأ،hkadit dakkأ،r meieriija mii buot dieid rأ،hklada, de إ،attaإ،ii muhtun meieriijأ، mأ،ddin heaitit.
	## - In nagot oaidnit maid	mahkkأ،	Sأ،mediggi sأ،htأ،إ،ii dahkat, lohkأ، son.
	## Doloإ، skuvlema ja boradeami ؤچأ،jأ،lmasain nekte sihke suoma- ja sأ،meluohkأ،id oahpaheaddjit skuvlema jagis 1958, mas	mahkkأ،	ledje أ،vvudeamen skuvlabiepmu 10-jagi أ،vvudeami.
	## Doloإ، skuvlema ja boradeami ؤچأ،jأ،lmasain nekte sihke suoma- ja sأ،meluohkأ،id oahpaheaddjit skuvlema jagis 1958, mas	mahkkأ،	ledje أ،vvudeamen skuvlabiepmu 10-jagi أ،vvudeami.
	## Su mielas lea somأ،t buktit biktasiid Gatsby:ii go	mahkkأ،	Fretexii.
	## Daid bijat nu mot heive buoؤ‘ؤ‘obأ،ikai,	mahkkأ،	maإ‹إ‹أ،laga dahje bأ،lddalaga.
	## Jakt & Fiske ( Bivdu & Guolli ) sivahallo doalvumin bealle duإ،إ،i sأ،gaid, NJFF galgأ،	mahkkأ،	organisaإ،uvdnan bilideamen sأ،mi suohkaniid beaggima.
	## NJFF ii sأ،hte moktige mieؤ‘ihit dasa ahte ovttasbargosoahpamuإ، Statskog:in	mahkkأ،	rihkoإ،ii duoid.
	## NJFF lea ؤچujuhan mii min mielas doalvvoإ،ii endorii jos	mahkkأ،	ؤچuolddأ،إ،ii bivdo- ja guolأ،stushأ،lddaإ،eami Finnmأ،rkkus mii guoskkaإ،ii koartaguovlluide ja sierralأ،gan bivdo- // guolأ،stusأ،iggiide ja hattiide.
	## Hearrأ، Gaski, du ؤچuoؤچؤچuheamit NSR njunuإ،vأ،lljemii mii	mahkkأ،	gulaإ،e gأ،ktأ،i, bohccuide, gillii ja duovdagiidda anأ،إ،eimmet gullamin fastivuhtii ja ii ge bأ،lljo gulaإ،e sأ،mepolitihkalaإ، أ،igumuإ،aide.
	## Mu mielas leat dego cukcasat ahte ؤچأ،llit sأ،mi أ،viissas, ja	mahkkأ،	anonymiseret olbmuiid.
	## â€“ Mii أ،igut njulgestaga geahؤچؤچalit ؤچأ،jehit nissonlaإ، klovneriija, mii	mahkkأ،	dأ،hpأ،huvvأ، Sأ،mis, muitala bagadalli Harriet Nordlund.
	## Sأ،mi أ،lbmot, earenoamأ،إ¾it boazodoallu lea hirbmadit cuiggohallan dأ،إ¾a mediain go	mahkkأ،	billistit luonddu.
	## II أپDDE:Sأ،mediggerأ،ؤ‘i lahttu Svein P. Pedersen ii أ،dde gos Egil Olli lea vieإ¾إ¾an daid loguid maiguin mii	mahkkأ،	lasihit goluid hأ،lddahusas.
	## Dأ،n dأ،vdda sأ،httأ، sulأ،stahttit dainna jus	mahkkأ،	ealga dahje luossabivdi ii beasأ،إ،ii bivdit, lohkأ، Sverre duoؤ‘alaؤچؤچat.
	## Dat lea billaإ،uvvan maإ‹gga sajis,	mahkkأ،	ovtta luohkkalanjas lea rأ،igi lahttis.
	## - Jos leaإ، nu ahte muhtun gielda Sأ،mis, nugo	mahkkأ،	Kأ،rأ،إ،johka dahje Guovdageaidnu lokte أ،إ،إ،i Sأ،mediggأ،i ja gأ،ibida leat vأ،ldogأ،vpogin Sأ،mis, de fertet أ،rvvoإ،tallat أ،إ،إ،i.

    # maإ‹إ‹it vs. maإ‹it (maإ‹إ‹i)
    # -------------------------
    # condition:
#DELETE uncommon 
ADD:xreal-maإ‹إ‹it (&real-maإ‹إ‹it) TARGET  ("maإ‹it" A Comp);
COPY:real-maإ‹إ‹it ("maإ‹إ‹it" Adv SUGGEST) EXCEPT ("maإ‹إ‹i" N Pl Nom &real-maإ‹إ‹it) OR ("maإ‹it" A Comp Sg Nom &real-maإ‹إ‹it) OR ("maإ‹it" A Comp Attr &real-maإ‹إ‹it) OR ("maإ‹idit" V TV VGen &real-maإ‹إ‹it) OR ("maإ‹idit" V TV Imprt Sg2 &real-maإ‹إ‹it) OR ("maإ‹idit" V TV Imprt ConNeg &real-maإ‹إ‹it) OR ("maإ‹idit" V TV Ind Prs ConNeg &real-maإ‹إ‹it) TARGET (&real-maإ‹إ‹it) ;
    ## Loddenأ،igi lea maإ‹it eahket, ihkku ja iؤ‘ؤ‘esija. Loddenأ،igi lea maإ‹إ‹it eahkes, ihkku ja iؤ‘ؤ‘esija.
