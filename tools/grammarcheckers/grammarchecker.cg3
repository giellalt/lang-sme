    ## Muhto min informĂĄnttaid dieÄuid vuoÄul orro liikkĂĄ leamen vĂĄttis oaĆŸĆŸut dien tilla.
    ## EisevĂĄlddiid bealis orro Äielgasit eaktuduvvon ahte SĂĄmediggi ii leat ieĆĄstivrejeaddji riektesubjeakta, muhto dat lea gaĆŸaldat masa sĂĄhttet leat mĂĄĆgga ieĆĄguÄetlĂĄgĂĄn oaivila. #COPULAS + Adv + PrfPrc + ahte
    ## Ahte plĂĄna geavaha doahpagiid nugo ĂĄlgoĂĄlbmotperspektiivva, sĂĄmi perspektiiva ja mĂĄĆggakultuvrralaĆĄ perspektiivva lea positiivalaĆĄ, muhto suohkaniidda orro vĂĄttisin skuvlla geavatlaĆĄ hĂĄbmemis ollĂĄsit Äuovvolit dakkĂĄr perspektiivvaid. #N Pl Ill + COPULAS + A Ess + Inf


    # CS + COPULAS + A

ADD:real-PrtPl3-PrsSg3 (&real-PrtPl3-PrsSg3) TARGET UT-VERBS - <spelled> - Der/h - Der/d IF (0 (ConNegII) OR (Ind Prs Du1) OR (Ind Prt Pl3) OR (Imprt ConNegII))(-1 CS)(0 COPULAS)(*1 (A Attr) OR PrfPrc BARRIER NOT-ADV-PCLE LINK *1 (N Sg Nom) - PL3-N BARRIER (*) - (A Attr) - CC)(NEGATE *1 (Pl Nom) OR (Pers Pl3 Nom) OR (Sem/Org Nom) OR (Prop Sem/Obj Sg Nom) OR (Sg Nom) + Sem/Group OR ("dat" Pron Dem Sg Nom) OR ("diet" Pron Dem Sg Nom) OR Num - ONE OR Arab BARRIER NPNHAPcle - PrfPrc - Inf - (Actio Ess))(NEGATE *-1 (N Sg Com) OR (N Pl Loc) BARRIER NOT-ADV-PCLE LINK -1 ("eanemus"))(NEGATE *1 (N Sg Nom) BARRIER GRAMCHK-S-BOUNDARY OR CC OR COMMA OR VFIN OR Inf OR Arab OR Num LINK 1 COMMA OR CC LINK 1 (N Nom))(NEGATE 0 (V Sg3) - Err/Orth);
    ## Muhtimat gal dieÄusge lohke ahte {orro} gelddolaĆĄ ja dehĂĄlaĆĄ fĂĄddĂĄ, muhto oppalohkĂĄi vĂĄsihin ahte dĂĄt lea juoga man birra eanas olbmot eai dieÄe nu olu.


    # COPULAS + Ess + Inf

ADD:real-PrtPl3-PrsSg3 (&real-PrtPl3-PrsSg3) TARGET UT-VERBS - <spelled> - Der/h - Der/d IF (0 (ConNegII) OR (Ind Prs Du1) OR (Ind Prt Pl3) OR (Imprt ConNegII))(0 COPULAS)(*1 (N Ess) BARRIER NPNHA - CC LINK NOT 0 (Actio Ess) LINK *1 Inf OR THAT-CS BARRIER NOT-ADV-PCLE - (A Sg Nom))(NEGATE *-1 ("ii"))(NEGATE *-1 (Pl Nom) OR (Pers Pl3 Nom) OR (Sem/Org Nom) OR (Prop Sem/Obj Sg Nom) OR (Sg Nom) + Sem/Group OR SG-PL-NOM-DEM + (Sg Nom) BARRIER GRAMCHK-S-BOUNDARY OR VFIN)(NEGATE *1 (Pl Nom) OR (Pers Pl3 Nom) OR (Sem/Org Nom) OR (Prop Sem/Obj Sg Nom) OR (Sg Nom) + Sem/Group OR ("dat" Pron Dem Sg Nom) OR ("diet" Pron Dem Sg Nom) OR Num - ONE OR Arab BARRIER NPNHAPcle - PrfPrc - Inf - (Actio Ess))(NEGATE *-1 (N Sg Com) OR (N Pl Loc) BARRIER NOT-ADV-PCLE LINK -1 ("eanemus"))(NEGATE *1 (N Sg Nom) BARRIER GRAMCHK-S-BOUNDARY OR CC OR COMMA OR VFIN OR Inf OR Arab OR Num LINK 1 COMMA OR CC LINK 1 (N Nom))(NEGATE 0 (V Sg3) - Err/Orth);
    ## ja go maĆimus namuhuvvomat ollĂĄsit dĂĄrbbaĆĄit sĂĄidebĂĄikkiid ja vuonaid doalahuvvot alcceseaset guollebĂĄikin, orro lunddolaĆĄ ja Äielga doaibman gieldit soaikonuohttuma dĂĄin bĂĄikkiin ". #COPULAS + A Sg Nom/ Ess + Inf

COPY:real-PrtPl3-PrsSg3 (Ind Prs Sg3 SUGGEST) EXCEPT (ConNegII &real-PrtPl3-PrsSg3) OR (Ind Prs Du1 &real-PrtPl3-PrsSg3) OR (Ind Prt Pl3 &real-PrtPl3-PrsSg3) OR (Imprt ConNegII &real-PrtPl3-PrsSg3) TARGET (V &real-PrtPl3-PrsSg3) ;
	## DĂĄl son ĂĄigo  vuoiĆĆastit guokte mĂĄnu ieĆŸas lagĂĄmuĆĄaid luhtte.
	## DĂĄl vĂĄilo  vel dat duoÄalaĆĄ bargu, ja NSR lea gearggus bargat ulbmillaÄÄat Stuorradikke ektui.
	# needs testing
	# in errors.xml


	#uncommon Inf vs. Pl3, -ot vs. -ut
	# -------------------------

#uncommon
ADD:xreal-Inf-PrsPl3 (&real-Inf-PrsPl3) TARGET UT-VERBS IF (0 (V Inf) OR (V Imprt Pl1) OR (V Imprt Pl2) OR (V Ind Prs Pl1)  OR (Ex/V Der/NomAg N Pl Nom))(*-1 (Pron Dem Nom) OR (Pron Pers Pl3 Nom) OR (N Pl Nom) OR ("dat" Pcle) BARRIER GRAMCHK-S-BOUNDARY OR CC OR COMMA OR (Pron Pers Pl1 Nom) LINK NEGATE *-1 (Ind Pl3))(*1 Inf BARRIER GRAMCHK-S-BOUNDARY)(NEGATE *-1 <TH-Inf> OR <Inf> BARRIER NOT-ADV - @<ADVL)(NONE p (V <TH-Acc-Any><TH-Inf>))  ;
	#$ Ovttasbargoguoimmit ĂĄigot oaĆŸĆŸut rĂĄhkaduvvot dakkĂĄr mearrasĂĄmi ealĂĄhusstrategiija mii fuolaha dan.
	#$ RomsalaÄÄat eai liiko olbmorĂĄiddus ÄuoĆŸĆŸut ja vuordit vuoruset ja dan dihte ĆĄaddet dĂĄvjĂĄ riiddut Romssa gĂĄvpogis, oaivvilda Geir T. H. Norbye.
	#$ Mii ĂĄigut bargat dan ala ahte buot sĂĄmit ja sĂĄmi vuorrasat erenoamĂĄĆŸit oĆŸĆŸot ĂĄrvugas dearvvaĆĄvuoÄa- ja fuolahusfĂĄlaldaga, jĂĄ {ĂĄigut} ovttas SĂĄmedikki vuorrasiidrĂĄÄiin hĂĄbmet sĂĄmi vuorrasiidstrategiija.
    #$ DĂĄl vigget vuoiĆĆat sus {oaĆŸĆŸut} veahkki beassat rĂĄfi vuoiĆĆadeapmĂĄi.

COPY:real-Inf-PrsPl3 (Ind Prs Pl3 SUGGEST) EXCEPT (Inf &real-Inf-PrsPl3) OR (Imprt Pl1 &real-Inf-PrsPl3) OR (Imprt Pl2 &real-Inf-PrsPl3) OR (Ind Prs Pl1 &real-Inf-PrsPl3) OR (Der/NomAg N Pl Nom &real-Inf-PrsPl3) TARGET (&real-Inf-PrsPl3) ;
	## Dat ĂĄigut visot gĂĄrĆŸĆŸidit.
	# in errors.xml


	# PrfPrc vs. Actio Nom, HUOM! just for words with monophthong in infinitive, others are very uncommon
	# --------------------

ADD:xreal-ActioNom-PrfPrc (&real-ActioNom-PrfPrc) TARGET UT-VERBS IF (0 (Actio Gen) OR (Actio Nom) OR (Der/NomAct N Sg Gen Allegro) OR (Der/NomAct N Sg Nom) OR (Der/NomAg N Ess))(NEGATE 0 Ess - Der/NomAg OR DIPHTONG-ROOT)(*-1 BE + VFIN OR BE + Inf BARRIER GRAMCHK-S-BOUNDARY OR PrfPrc)(NEGATE 0 (Actio Gen) LINK 1 Po)(NEGATE 0 Der/Pass)(NEGATE 0 (Prt ConNeg))(NEGATE 0 (N Sg Nom) - Der/NomAg LINK *-1 BE + Sg3 BARRIER GRAMCHK-S-BOUNDARY OR PrfPrc)(NEGATE *-1 (Dem Sg Nom) BARRIER NPNH - (Sg Nom <NomGenSg>) - Acc );

	# for cases with immediate objects where it's more evident that it is a PrfPrc

ADD:xreal-ActioNom-PrfPrc (&real-ActioNom-PrfPrc) TARGET UT-VERBS + TV IF (0 (Actio Gen) OR (Actio Nom) OR (Der/NomAct N Sg Gen Allegro) OR (Der/NomAct N Sg Nom) OR (Der/NomAg N Ess))(NEGATE 0 DIPHTONG-ROOT)(*-1 BE + VFIN OR BE + Inf BARRIER GRAMCHK-S-BOUNDARY OR PrfPrc LINK *-1 @OBJ> BARRIER S-BOUNDARY)(NEGATE 0 (Actio Gen) LINK 1 Po)(NEGATE 0 Der/Pass)(NEGATE 0 (Prt ConNeg));
	## Maid lei KeaisĂĄr Augustus gohÄÄun?
	
ADD:xreal-ActioNom-PrfPrc (&real-ActioNom-PrfPrc) TARGET UT-VERBS + TV IF (0 (Actio Gen) OR (Actio Nom) OR (Der/NomAct N Sg Gen Allegro) OR (Der/NomAct N Sg Nom) OR (Der/NomAg N Ess))(NEGATE 0 DIPHTONG-ROOT)(*-1 BE + VFIN OR BE + Inf BARRIER GRAMCHK-S-BOUNDARY OR PrfPrc)(*1 @OBJ> OR @<OBJ BARRIER NPNHA)(NEGATE 0 (Actio Gen) LINK 1 Po)(NEGATE 0 Der/Pass)(NEGATE 0 (Prt ConNeg));
	## Ikte eahkedis Äoahkkinasttii SĂĄB stivrra ja lei gohÄÄun olles stivrra oktan vĂĄrrelahtuiguin boahtit, vĂĄlgga ĂĄrvvoĆĄtallamii ja divaĆĄtallan dihtii maid sii sĂĄhttet Bb gĂĄibidit jus sii galget Bb doarjut dĂĄn ĂĄigodaga.


COPY:real-ActioNom-PrfPrc (IV PrfPrc SUGGEST) EXCEPT (IV Actio Gen &real-ActioNom-PrfPrc) OR (IV Actio Nom &real-ActioNom-PrfPrc) OR (Ex/V IV Der/NomAct N Sg Gen &real-ActioNom-PrfPrc) OR (Ex/V IV Der/NomAct N Sg Nom &real-ActioNom-PrfPrc) OR (Ex/V IV Der/NomAg N Ess &real-ActioNom-PrfPrc) TARGET (IV &real-ActioNom-PrfPrc) ;

COPY:real-ActioNom-PrfPrc (TV PrfPrc SUGGEST) EXCEPT (TV Actio Gen &real-ActioNom-PrfPrc) OR (TV Actio Nom &real-ActioNom-PrfPrc) OR (Ex/V TV Der/NomAct N Sg Gen &real-ActioNom-PrfPrc) OR (Ex/V TV Der/NomAct N Sg Nom &real-ActioNom-PrfPrc) OR (Ex/V TV Der/NomAg N Ess &real-ActioNom-PrfPrc) TARGET (TV &real-ActioNom-PrfPrc) ;
	#$ Ii son leat olmmoĆĄ gean don livÄÄet {doivun} leat mielde Norgga muhtin lĂĄhkai eanemus ekstremalaĆĄ bellodagas.
	## DĂĄt smĂĄvva Äuvllat, leat maid gorrojuvvon biktasiin mat ledje nie baskun.
	#$ Konfereanssa ulbmil lea  Äohket  buot fylkka nuoraid {oaĆŸĆŸun} dihtii ĂĄrvalusaid mo FinnmĂĄrku sĂĄhttĂĄ ĆĄaddat ain buoret orrunbĂĄikin.
	#$ Go hĂĄllojuvvo sĂĄmegielddaid ja sĂĄmedikkiid ĂĄĆĄĆĄebĂĄhpĂĄriid jorgaleamis sĂĄmegillii, de hĂĄliidan muittuhit dakkĂĄr beali ĂĄĆĄĆĄis, ahte dĂĄs lea sĂĄhka sĂĄmegiela ovddideamis virgegiellan ja politihkalaĆĄ {bargoneavvun}. 

	# Nom - Gen/Acc
	# -------------

ADD:real-GenSg-NomSg (&real-GenSg-NomSg) TARGET Ă-A-E-O-U-NOUNS + CONC-2-3-4ABC - <spelled> - Prop - Err/Orth IF (0 (N Sg Acc) - PxSg2 OR (N Sg Gen) - PxSg2)(-1 GRADE-ADV - ("oba") - ("vel") LINK -1 COPULAS)(NEGATE 0 Der/vuota)(NEGATE 0 (A Sg Nom) OR (A Attr) OR Ess)(NEGATE 1 N OR Po OR Actio)(NEGATE *1 TV BARRIER NOT-ADV-PCLE);
	#$ Mis lea gal juo mĂĄtki diĆgojuvvon ja mĂĄkson, muhto jus mannĂĄ bures ekonomalaÄÄat dĂĄppe, de besset mĂĄnĂĄt oassĂĄlastit doaimmaide gos soitet vel {oahpu} ge gazzat, nu go historjjĂĄlaĆĄ bĂĄikkiid oaidnit, ja nu ain.
	#$ ja mariidna bioteknologiija olis, de lea dĂĄrbu ahte stĂĄhta searvĂĄ ovddidan- ja ĂĄlggahandĂĄsis nana ruhtademiin DjO-doaimmaide ja earĂĄ doaimmaide, main Davvi-Norggas leat erenoamĂĄĆĄ {luonddu} addin lihkostuvvanovdamunit.
	#$ Ja sii ĆĄaddet orrut beare {ĂĄimmu} siste.
	#$ â Mun lean mĂĄilmmi duhtavaĆĄ, ledje duĆĄĆĄe riikajoavkku bĂĄhÄÄit geat Äaskkiiga mu, soai han leaba Davvi-Norgga buoremus bĂĄhÄÄit, lohkĂĄ Nils Rune Eira.
    ## Mannan vahkkoloahpa dĂĄhpĂĄhusas orro ealgabivdis leamaĆĄan beare hoahpu bĂĄhÄit. #case error: hoahpu>hoahppu
    #$ NSR oaivvilda ahte nissonolbmuin ja dievdduin galget leat seamma ieĆĄovdĂĄnahttin vejolaĆĄvuoÄat, oahpu gazzamis ja fidnodoaimma vĂĄlljemis, ja galget lea seamma vejolaĆĄvuoÄat vĂĄikkuhit servodatovdĂĄneami.
    #$ DĂĄl go beaivvit leat guhkkon dĂĄidĂĄ leat earenoamĂĄĆĄ {suohtas} olgun stoagadit.

COPY:real-GenSg-NomSg (Nom SUGGEST) EXCEPT (Gen &real-GenSg-NomSg) OR (Acc &real-GenSg-NomSg) TARGET (&real-GenSg-NomSg);

	# DerNomAgPlNom-Inf
	# -----------------
	# adnit > atnit

ADD:real-DerNomAgPlNom-Inf (&real-DerNomAgPlNom-Inf) TARGET IT-EVEN-VERBS + CONC-2-3C-DDJ OR IT-EVEN-VERBS + CONC-3A-GRADE-II IF (0 (Ex/V Ex/IV Der/NomAg N Pl Nom) OR (Ex/V TV Der/NomAg N Pl Nom) OR (Ex/V IV Der/NomAg N Pl Nom))(*-1 AUX - BE)(NEGATE 0 Inf)(NEGATE -1 CC OR COMMA LINK -1 N)(NEGATE 0 Inf OR Pl1) ;
	#$ Dasa masa sĂĄhttĂĄ guorrasit, lea ahte geassevuodjin njealjejuvllagiiguin lea hĂĄstalus, muhto mii {jĂĄhkkit} ahte gielddat ieĆŸa buoremusat sĂĄhttet ja mĂĄhttet dan hĂĄlddaĆĄit.
	## SĂĄvvamis mun vuoitĂĄn dĂĄn gilvvu, lea nu lĂĄittas vuoddjit biilla musihka haga.
	## SĂĄmedikki dievasÄoahkkima meannudeami ii sĂĄhte adnit siskkĂĄldas proseassan ja danne ii ĂĄdde SĂĄmediggerĂĄÄÄi NÄE ĂĄkkasteami.
	#$ BargolĂĄvdegottis galge leat kommiĆĄuvnna joÄiheaddji, delegaĆĄuvdnajoÄiheaddjit (dĂĄrbbu mielde), goappĂĄge riikka ÄoahkkinÄĂĄllit ja vĂĄldo ÄĂĄlli.
	# same as ImprtPl2-Inf?
	#$ Jus ehpet ĂĄddejuvvo, de geahÄÄalehket geardduhit dan maid dadjabehtet, muhto adnit dalle earĂĄ sĂĄniid!
	
ADD:real-DerNomAgPlNom-Inf (&real-DerNomAgPlNom-Inf) TARGET IT-EVEN-VERBS + CONC-2-3C-DDJ OR IT-EVEN-VERBS + CONC-3A-GRADE-II IF (0 (Ex/V Ex/IV Der/NomAg N Pl Nom) OR (Ex/V TV Der/NomAg N Pl Nom) OR (Ex/V IV Der/NomAg N Pl Nom))(-1 (A <TH-Inf>) LINK *-1 BE + Sg3 BARRIER NOT-ADV-PCLE)(NEGATE 0 Inf)(NEGATE -1 CC OR COMMA LINK -1 N)(NEGATE *1 (V Pl3) BARRIER NOT-ADV-PCLE) ;
	## SĂĄvvamis mun vuoitĂĄn dĂĄn gilvvu, lea nu lĂĄittas vuoddjit biilla musihka haga.
	
ADD:real-DerNomAgPlNom-Inf (&real-DerNomAgPlNom-Inf) TARGET IT-EVEN-VERBS + CONC-2-3C-DDJ OR IT-EVEN-VERBS + CONC-3A-GRADE-II OR IT-EVEN-VERBS + CONC-2-GRADE-II IF (0 (Ex/V Ex/IV Der/NomAg N Pl Nom) OR (Ex/V TV Der/NomAg N Pl Nom) OR (Ex/V IV Der/NomAg N Pl Nom))(-1 PrfPrc LINK -1 BE)(NEGATE 0 Inf OR Pl1)(NEGATE -1 CC OR COMMA LINK -1 N) ;
	## Lean giitevaĆĄ go lean beassan {johttit} mĂĄilmmes ja miehtĂĄ sĂĄmi ja dakko bokte oĆŸĆŸon inspisraĆĄuvnna ieĆŸan ÄĂĄllin dĂĄidagiid ja duodjĂĄi, lohkĂĄ Thomas.

COPY:real-DerNomAgPlNom-Inf (Inf SUGGEST) EXCEPT (Ex/V Ex/IV Der/NomAg N Pl Nom &real-DerNomAgPlNom-Inf) TARGET (Ex/V Ex/IV &real-DerNomAgPlNom-Inf) ;

COPY:real-DerNomAgPlNom-Inf (V TV Inf SUGGEST) EXCEPT (Ex/V TV Der/NomAg N Sem/Hum Pl Nom &real-DerNomAgPlNom-Inf) TARGET (TV &real-DerNomAgPlNom-Inf) ;

COPY:real-DerNomAgPlNom-Inf (V IV Inf SUGGEST) EXCEPT (Ex/V IV Der/NomAg N Sem/Hum Pl Nom &real-DerNomAgPlNom-Inf) TARGET (IV &real-DerNomAgPlNom-Inf) ;

	# i > e (Der/NomAct Sg Gen > Actio Ess)
	# -------------------------------------
	
ADD:xreal-DerNomActSgGen-ActioEss (&real-DerNomActSgGen-ActioEss) TARGET IT-UNEVEN-VERBS IF (0 (Der/NomAct Sg Gen) OR (Der/NomAct Sg Acc))(*-1 ("leat") OR ("orrut") OR ("gullot") OR ("oidnot") OR ("joatkit") BARRIER NOT-ADV - (N Nom))(NEGATE 1 Po OR N)(NEGATE 0 (Actio Ess))(NEGATE 1 CC LINK 1 (N Sg Gen))(NEGATE -1 CC LINK -1 (N Sg Gen));
	## Duortnoseanu luosa dearvvaĆĄvuohta lea buorrĂĄneami. > buorrĂĄneame
	#$ Jaskatvuohta ja Äiegadeapmi ii buvtte buorrĂĄneami.
	#$ Danin sĂĄhttĂĄ leat vĂĄttis geavahit ekonomiija buorrĂĄneami mihttun.
	
	# coordination

ADD:xreal-DerNomActSgGen-ActioEss (&real-DerNomActSgGen-ActioEss) TARGET IT-UNEVEN-VERBS IF (0 (Der/NomAct Sg Gen) OR (Der/NomAct Sg Acc))(-1 ("ja") LINK -1 &real-DerNomActSgGen-ActioEss OR (Actio Ess))(NEGATE 0 (Actio Ess));
	## In jĂĄhke ahte ieĆŸĂĄt livÄÄe oaidnĂĄn maidege, sii gal duĆĄĆĄe gullojedje sĂĄgasteami ja boagusteami.	

COPY:xreal-DerNomActSgGen-ActioEss (V IV Gram/3syll Actio Ess SUGGEST) EXCEPT (Ex/V IV Der/NomAct Gram/3syll N Sg Gen) OR (Ex/V IV Gram/3syll Der/NomAct N Sg Acc) TARGET (IV &real-DerNomActSgGen-ActioEss) ;

COPY:xreal-DerNomActSgGen-ActioEss (V TV Gram/3syll Actio Ess SUGGEST) EXCEPT (Ex/V TV Der/NomAct Gram/3syll N Sg Gen) OR (Ex/V TV Gram/3syll Der/NomAct N Sg Acc) TARGET (TV &real-DerNomActSgGen-ActioEss) ;

	# A Sg Loc > A Attr
	# -----------------

	# -i (is>es)
	# -un (umis>un)
	# -at (adis>es)

LIST I-ADJ = (".*i" A) ;
LIST UN-ADJ = (".*un" A) ;
