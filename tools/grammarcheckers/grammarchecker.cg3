COPY:real-nuorain ("nuorra" N Sg Com SUGGEST) EXCEPT ("nuorrat" V TV Ind Prs Sg1 &real-nuorain) TARGET (&real-nuorain) ; 
	## Ingebrigtsen muitalii bearjadaga, ahte sus lei seksuأ،la oktavuohta 2004:is  ovtta AUF nuoran, gii lei dalle 17-jahkkأ،saإ،.
	
	# nuorran (nuorra+N+Ess) vs. nuorrأ،n (nuorrat+V+TV+Der/NomAg+N+Sg+Nom+PxSg1, nuorri+N+Sg+Nom+PxSg1)
    # -------------------------------------------------------
#DELETE Px:t luottahuhtton  
ADD:xreal-nuorran (&real-nuorran) TARGET (PxSg1)(0 ("nuorrat" V TV Der/NomAg N Sg PxSg1) OR ("nuorri" N Sg) LINK 0 Nom OR Gen OR Acc);  

COPY:real-nuorran ("nuorra" N Ess SUGGEST) EXCEPT ("nuorrat" V TV Der/NomAg N Sg Nom PxSg1 &real-nuorran) OR ("nuorrat" V TV Der/NomAg N Sg Gen PxSg1 &real-nuorran) OR ("nuorrat" V TV Der/NomAg N Sg Acc PxSg1 &real-nuorran) OR ("nuorri" N Nom Sg PxSg1 &real-nuorran) OR ("nuorri" N Gen Sg PxSg1 &real-nuorran) OR ("nuorri" N Acc Sg PxSg1 &real-nuorran) TARGET (&real-nuorran) ; 
	## Vuoruhit spأ،bbaؤچiekؤچama Adam Klemet lأ،vi maid nuorrأ،n ؤچiekؤچat spأ،ppa, muhto ii vuoruhan spأ،bbaؤچiekؤچama gal nu nuorran go dan maid Marja Sofe lea. 
	## Inga Nordsletta Pedersen lea riegأ،dan Kأ،rأ،إ،jogas muhto fأ،rrii Mأ،tta-Norgii jo nuorrأ،n. 
		
	# nuppأ،dassii vs. nuppأ،dussii
	# ---------------------------
	
#DELETE uncommon
ADD:xreal-nuppأ،dassii (&real-nuppأ،dassii) TARGET ("nuppأ،dus" N Sg Ill) IF (*0 V BARRIER NPNHAPcle);
COPY:real-nuppأ،dassii ("nuppأ،dassii" Adv SUGGEST) EXCEPT ("nuppأ،dus" N Sg Ill &real-nuppأ،dassii) TARGET (&real-nuppأ،dassii) ;
	##  Vaikko juristtat eai leat geargan guorahallamis rihkku go Finnmأ،rkolأ،hka أ،rvalus أ،lbmotrivttiin, de Stuoradikki Justislأ،vdegoddi lea boahtأ،n Finnmأ،rkui gullat nuppأ،dussii maid أ،lbmot oaivvilda lأ،hkaأ،rvalussii.
	## Dأ،l ballet Romssa sأ،mit dأ،n nuppأ،dussii dأ،hpأ،huvvat. 


	# oainnat iige oainnأ،t
	# --------------------

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 (Pron Sem/Hum Pers Nom) LINK NOT 0 Sg2);
	## Mun oainnأ،t ؤچohkkأ،n ieإ، searvegotterأ،ؤ‘is, muitala Johanne Gaup.
	## Mun oainnأ،t maid ledjen gأ،rtan duon mأ،innaإ،uvvon geaidnobargui Ruoإ،إ،a beallأ،i.
	## Mun oainnأ،t ballen dan أ،hkus, dat lأ،vii ovtto

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 Nom - Sg2 OR (N Sg Gen Err/Orth-nom-gen) OR ( N Sg Gen Err/Orth-nom-acc) OR (N Sg Loc) OR (N Prop Sem/Fem Sg Gen) OR (N Prop Sem/Fem Sg Acc) OR (N Prop Sem/Mal Sg Gen) OR (N Prop Sem/Mal Sg Acc) OR (N Prop Sem/Sur Sg Gen) OR (N Prop Sem/Sur Sg Acc) OR (N Prop Sem/Org ACR Sg Acc) OR COMMA)(*1 (V Ind) + VFIN - Neg OR COMMA BARRIER (*) - (N Nom) - (Pron Nom));
	#D? Nom-Gen Prop Sem/Fem Sem/Mal Sem/Sur ???
	#$ Dasto lea perseptuأ،lalaإ، latnja, dovdanlatnja, gos oainnأ،t, gulat, havssأ،t, gamus dovddat jna..
	#$ Norggas gأ،ibiduvvo ahte oainnأ،t ja nagodat lohkat biilagalbba mii lea 20 mehtera dus eret.
	## Lأ،hka oainnأ،t gأ،ibida buohkaid boazologuid, dietnasiid ja vahأ،giid fievrredit â€¹ â€¹ أ،hؤچiid â€؛ â€؛ boazodoallodieؤ‘أ،hussii ja sutnje dat mأ،ksojit nأ،vdevahأ،t buhtadusat ja boazodoalloإ،iehtadusa doarjagat.
	## Liisa oainnأ،t lea leamaإ، أ،lggu rأ،jes mielde juo lأ،gideamin filbmafestivأ،la Anأ،ris, mii vuosttas geardde dollui 1997:s.
	## Mii leimmet, oainnأ،t, ؤچأ،llأ،n ahte mii doarjut oljo- ja gأ،ssabohkama Barentsأ،bis.

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 Nom - Sg2 OR (N Sg Gen Err/Orth-nom-gen) OR (N Sg Gen Err/Orth-nom-acc) OR (N Sg Loc) OR (N Prop Sem/Fem Sg Gen) OR (N Prop Sem/Fem Sg Acc) OR (N Prop Sem/Mal Sg Gen) OR (N Prop Sem/Mal Sg Acc) OR (N Prop Sem/Sur Sg Gen) OR (N Prop Sem/Sur Sg Acc) OR (N Prop Sem/Org ACR Sg Acc) OR COMMA)(*1 VFIN + Neg BARRIER (*) - (N Nom) - (Pron Nom) LINK 1 ConNeg OR ("go" Pcle Qst));
	## - Gielda oainnأ،t ii sأ،hte أ،lgit olbmuin gأ،ibidit mأ،vssu jus kloأ،hkat eai leat gurrejuvvon.
	## Dainna lأ،gin oainnأ،t ii leat boazodoallalأ،hka, oaivvilda Bأ¦hr.
	## Jahkeؤچoahkkin oainnأ،t أ،vإ¾إ¾uhii stivra bargat dainna أ،إ،إ،iin.
	## Soai oainnأ،t eaba lean vuordأ،n vuoitit, go eaba lean إ،addan hأ،rjehallat ovttas bearehaga.
	## ILO oainnأ،t أ،lgأ، oؤ‘ؤ‘asit vieإ¾إ¾at dieؤ‘uid Rأ،ؤ‘ؤ‘ehusas, أ،kkasta Nystad.
	## - Soaؤ‘i أ،igge lأ،vejin ieإ¾an oappأ،iguin ja vieljaguin doalvut suoli borramuإ،a tuiska fأ،إ‹ggaide duos tuiskaguolbanis, oainnأ،t sii gillأ،jedje, muitala son.
	## Vuojahagas oainnأ،t ferte أ،lo okta gii fأ،kte.
	## - Mun in أ،dde mainna son smiehttأ،, oainnأ،t ii go son galgأ، leat viehka guhkأ، juo ؤچohkkأ،n Sأ،medikkis.

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 @OBJ> OR @ADVL> LINK -1 BOS)(*1 (V Ind) + Neg BARRIER (*) - (N Nom) - (Pron Nom) LINK 1 ConNeg OR ("go" Pcle Qst));
	## Dan oainnأ،t ii dieؤ‘e okta ge, go Finnmأ،rkku Komiإ،uvdna, mii galgأ، kأ،rtet finnmأ،rkkulaؤچؤچaid vuoigatvuoؤ‘aid, ii leat boahtأ،n vel johtui.

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (*-1 @OBJ> OR @ADVL> BARRIER NOT-PCLE LINK NOT 0 CS LINK -1 BOS)(*1 (V Ind) + VFIN - Neg - <spelled> OR COMMA BARRIER (*) - (N Nom) - (Pron Nom));
	## Ihttin oainnأ،t nohkأ، dأ،n أ،إ،إ،i gulaskuddanأ،igemearri.
	## Ollu han oainnأ،t dأ،hpأ،huvvأ، gitta ؤچoahkkimiin ja joatkkaؤچoahkkimiin.
	## Nugo oainnأ،t, de dien govas lea du أ،hkku ja govvaؤچeahppi lea fأ،hten hui bures daid dehأ،leamos beliid أ،hkustat. 

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (*-1 (V Ind) + VFIN - Err/Any OR BE + Inf BARRIER NOT-ADV-PCLE - ConNeg);
    ## Dat lea ovdal oainnأ،t dأ،hpأ،huvvan, go Sis-Finnmأ،rkku suohkaniid vأ،lljejeaddjit mobiliserejedje ja jienastedje 1993:s Guovddأ،إ،bellodaga Johanne Gaup Stuorradiggأ،i..
    #$ ؤŒalbmegeahؤچestagain oidno, don modjestat sutnje, duoؤ‘as oainnأ،t su, doalahat ieإ¾at su lahka dahje manat su lahka, bovdet su olggos omd. kiinoi, du ustibat muitalit sutnje ahte don leat rأ،hkأ،snuvvan, jus ieإ، it duostta muitalit.

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (1 Neg LINK 1 ConNeg) ;
    ## Dan geasi oainnأ،t eat إ،atta borrat maidege earأ، go luonddu njأ،lgأ،id.

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 BUT-CC OR THEN-CS-ADV OR BOS)(*1 (N Nom) BARRIER NPNHAPcle LINK *1 (V Ind) + VFIN BARRIER NOT-ADV-PCLE);
	## Dat leamaإ، olbmot ؤچigإ‹أ،i dalle, muhto oainnأ،t dat soaؤ‘i أ،igi hui ollu goaridii...
	
ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 COMMA LINK NEGATE *-1 (Ind Prs Sg2) OR (Pron Pers Sg2))(1 IF-CS LINK 1 Nom - Sg2);
	## Munnje lea mأ،ilmme dehأ،laإ، beassat Riddu Riؤ‘ؤ‘ui, oainnأ،t jus mun dأ،ppe gulahalan riikkaidgaskasaإ، gehؤچؤچiiguin, de dalle mun gal gulahalan vaikko olles mأ،ilmmi gehؤچؤچiiguin, dadjala vel loahpas.
	
ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 COMMA LINK NEGATE *-1 (Ind Prs Sg2) OR (Pron Pers Sg2))(1 (N Nom) OR (<NomGenSg> Sg Acc) + Sem/Hum OR (<NomGenSg> Sg Gen) + Sem/Hum LINK 1 COMMA);
	## Muhto de eahpأ،dus ؤچأ،إ‹ai mu jurdagiidda, {oainnأ،t} guldaleaddji, bأ،lkأ، lea hirbmat somأ،.
	
SET OAINNAT-SEM = Sem/Measr OR Sem/Time OR Sem/Plc ;

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 COMMA LINK *-1 $$OAINNAT-SEM BARRIER NOT-ADV-PCLE  - Po - N LINK NEGATE *-1 (Ind Prs Sg2) OR (Pron Pers Sg2))(*1 $$OAINNAT-SEM BARRIER NPNHA);	
