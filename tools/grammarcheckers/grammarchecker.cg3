	# Strictly transitiv-verbs - a start. This set is ment as a help choosing Acc or Gen. Example: "Mun borren eatni kafeÃĄs." - there is Gen, no Acc, even if the verb is transitive. ThatÂīs why "borrat" is not in this set.
	# These verbs: "addit", "fidnet" and "oaÅūÅūut" can, when itÂīs about sex, be without object: "Son oaÄÄui gonagasa bÃĄrtnis."

SET STV = STVLIST - Der/Pass ;


SET STV-NOT-ACT = STV - (Actio Nom) - (Actio Gen) - (Actio Acc) - (Actio Loc) - (Actio Ill) - (Actio  Com) - NOMAG ;


LIST LOCV = "ÃĄvkkÃĄstallat" "ballat" "beassat" "beroÅĄtit" "biehttalit" "bihtit" "ceavzit" "dinet" "dolkat" "eastadallat" "eastadit" "fuolahit" "fuollat" "geargat" "heaitit" "ilbmat" "jearrat" "luohpat" "mÃĄinnaÅĄit" "nohkkot" "oassÃĄlastit" "spiehkastit" "vÃĄruhit" "vÃĄstidit" ;

		#Note that "fuolahit" obviously has two homonymous variants:
		#fuolahit1+Acc, fuolahit2+Loc

LIST COMV = "ÃĄrvalit" "ÃĄrvvohuÅĄÅĄat" "ÃĄvkaÅĄuvvat" "bÃĄlddalastit" "bÃĄrtaÅĄuvvat" "birgehallat" "birget" "buohtastahttit" "deaivvadit" "gulahallat" "gulaskuddat" "hilboÅĄit" "joatkit" "leaikkastallat" "lohpÃĄdaddat" "lohpÃĄdallat" "lonuhit" "meannudit" "malssidit" "molssodit" "ovttasbargat" "ovttastahttit" "riidalit" "servvoÅĄtallat" "servvoÅĄtaddat" "soabadit" "soahpat" "ÅĄiehtadallat" "ÅĄiehtadit" ;

		#Note that "leaikkÃĄstallat" has two homonymous variants:
		#leaikkÃĄstallat1 (IV), leaikkÃĄstallat2+Com

LIST ILLV = "ÃĄibbaÅĄit" "ÃĄlgit" "ÃĄsaiduvvat" "bÃĄitit" "beassat" "Äohkkedit" "Äujuhit" "Äuohcit" "deaivat" "doaÅĄkut" "dorvvastit" "doÅĄket" "duhtat" "geahÄÄat" "gullat" "guoskat" "gustot" "hÃĄrjÃĄnit" "heivet" "irggÃĄstallat" "jÃĄhkkit" "liikot" "luohttit" "mannat" "mÃĄhccat" "mieÄihit" "oahpÃĄsmuvvat" "oahpÃĄsnuvvat" "ollet" "oskut" "riepmat" "rÃĄhkkanit" "soahpat" "searvat" "suhttat" "vÃĄstidit" "vuolgit";


LIST TRANSLV = "jÃĄpmit" "duÅĄÅĄat" "hÃĄvkat" "nÃĄitalit" "gaskkalduvvat" "nohkat" "goarrÃĄnit" "heahpanit" "boakÄÃĄnit" "ÅĄlundut" "rÃĄigÃĄnit" "vuollÃĄnit" "gopmÃĄnit" "fuotnÃĄnit" "roahppÃĄnit" "reakÄanit" "bieÄganit" "luoddanit" "guvggodit" "liegganit" "suorganit" "bÃĄhkkanit" "cuovkanit" "hedjonit" "lohppet" "goikat" "galbmot" "goallut" "ruostut" "buoidut" "guvggodit" "suvrut" "suddat" ;

  # Taken from Helander (2001) p. 89, might be useful in the future as those verbs typically take humans and places in illative case.

LIST REKSV = "ÃĄibbaÅĄit" "deaivat" "dorvvastit" "duhtat" "gustot" "hÃĄrjÃĄnit" "jÃĄhkkit" "liikot" "mieÄihit" "ollet" "rÃĄhkkanit" "soahpat" "searvat" "vuolgit" "beroÅĄtit" "biehttalit" "bihtit" "ceavzit" "dinet" "dolkat" "eastadallat" "eastadit" "fuolahit" "fuollat" "geargat" "heaitit" "luohpat" "oassÃĄlastit" "vÃĄruhit" ;
# This set is for giving infitives @ADVL after the verb.

LIST ACC-LOCV = "biehttalit" "earuhit" "gieldit" "jearrat" ;

LIST ACC-ILLV = "addit" "bidjat" "mearkkaÅĄit";
    # Two-place predicates that take a direct object and an illative adverbial.

LIST MIELDE-V = "addit" "bidjat" "dÃĄidit" "leat" "oastit" "oaÅūÅūut" "vÃĄldit" ;
    # Phrasal verbs that take mielde as their complement.

# Son attii girjji mielde.

LIST TIMEADVERBIAL-V = "ÃĄdjÃĄnit" "ÃĄssat" "bargat" "bistit" "bivdit" "eallit" "fievrridit" "guohtut" "joatkit" "lÃĄddet" "oahpahit" "oÄasmahttit" ;

