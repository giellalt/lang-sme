LIST NOM-ACC-NUM = (".*guokte"r) (".*golbma"r) (".*njeallje"r) (".*vihtta"r) (".*guhtta"r) (".*ÄieĆŸa"r)  (".*gĂĄvcci"r) (".*ovcci"r) (".*logi"r) ("moadde") ("galle") ;

LIST NOM-GEN-NUM = (".*ÄieĆŸa"r)  (".*gĂĄvcci"r) (".*ovcci"r) (".*logi"r) ("galle") ;



ADD:xmsyn-acc-to-adv (&msyn-acc-to-adv) TARGET Num IF (0 NOM-ACC-NUM)(NOT 0 Acc OR Nom OR ACC-NUM-ATTR LINK 1 Sem/Measr OR MEASURE OR Sem/Time LINK 1 ACC-ADV OR ("boaris")) ;  #2nd
ADD:xmsyn-acc-to-adv (&msyn-acc-to-adv) TARGET Num IF (NOT 0 NOM-ACC-NUM)(NOT 0 Acc OR Gen OR ACC-NUM-ATTR OR GEN-NUM-ATTR LINK 1 Sem/Measr OR MEASURE OR Sem/Time LINK 1 ACC-ADV OR ("boaris")) ;  #2nd

ADD:xmsyn-acc-to-adv (&msyn-acc-to-adv) TARGET ACC-ADV OR ("boaris") IF (-1 Sem/Measr OR MEASURE OR Sem/Time LINK *-1 (Num &msyn-acc-to-adv));

COPY:msyn-acc-to-adv (Acc SUGGEST) EXCEPT (Gen) TARGET (Gen Num &msyn-acc-to-adv) ;  #2nd
	#$ DĂĄn mĂĄnnĂĄ lea buorre muddui olahan go lea birrasii golbma jagi boaris.
    #$ Min viessu lea vihtta mehtera alu.
    #$ Dalle lei 10 kilomettar guhkkosaĆĄ lĂĄhttu ĂlttĂĄ guvlui mas 170:s ledje mielde. XXX
    ## Min viessu lea viÄainlot mehtera alu.
    #$ Sus lea njealje mehtera guhkkosaĆĄ biila.
    #$ Suorpmas lea guokte millimehtera govdat.
    #$ Lean vihttalot jagi boaris.
    #R Nickel1994:485,488 genitive: at least
    # in errors.xml

ADDRELATION:msyn-acc-to-adv (RIGHT $2) (Num &msyn-acc-to-adv) TO (*1 &msyn-acc-to-adv + ACC-ADV);
    
ADD:xmsyn-acc-to-velggolaĆĄ (&msyn-acc-to-velggolaĆĄ) TARGET Num IF (NOT 0 ACC-NUM-ATTR OR Acc LINK 1 CURRENCY OR Sem/Money LINK 1 ("velggolaĆĄ")) ;  #2nd
COPY:msyn-acc-to-velggolaĆĄ (Acc SUGGEST) EXCEPT Gen AFTER Sg OR Pl TARGET (Num &msyn-acc-to-velggolaĆĄ) ;  #2nd
    ## Ăndde lea munnje viÄalot ruvnnu velggolaĆĄ.
    #$ Ăndde lea munnje vihttalot ruvnnu velggolaĆĄ.
    ## Ăndde lea munnje guovtti ruvnnu velggolaĆĄ.
    #R Nickel1994:485 "Akkusativformen stĂ„r ogsĂ„ som attributt til adjektivene boaris, 'gammel' og velggolaĆĄ 'skyldig'."
    # in errors.xml
    
ADD:xmsyn-acc-to-velggolaĆĄ (&msyn-acc-to-velggolaĆĄ) TARGET ("velggolaĆĄ") IF (-1 CURRENCY OR Sem/Money LINK -1 Num) ; 

ADDRELATION:msyn-acc-to-velggolaĆĄ (RIGHT $2) (Num &msyn-acc-to-velggolaĆĄ) TO (*1 ( "velggolaĆĄ" &msyn-acc-to-velggolaĆĄ));
 
ADD:xmsyn-acc-to-comp (&msyn-acc-to-comp) TARGET Num IF (NOT 0 Acc OR Nom OR ACC-NUM-ATTR LINK 1 Sem/Measr OR MEASURE OR Sem/Time OR CURRENCY LINK 1 ("maĆĆil") OR ("maĆĆel") OR ("ovdal") OR ("maĆĆelaĆĄ") OR ("ovdalaĆĄ") OR Comp OR ADV-COMP-FUNCTION ) (NEGATE 0 Gen LINK 1 Sem/Measr OR MEASURE OR Sem/Time OR CURRENCY LINK 1 Comp OR ADV-COMP-FUNCTION LINK 1 Loc)(NOT 0 (Num Arab)) ;  #2nd
    ## MĂĄhtte lea viÄa jagi nuorat go mun. PROBLEM
    ## Dat ĆĄattai guovtti mehtera guhkit go galggaĆĄii.
    ## Son vuvddii daid bohccuid viÄa ruvnno hĂĄlbbibui.
    #$ Kisumu ĂĄssit muitalit, ahte friijasit golgi ĆĄaddu fĂĄrredaddĂĄ Kisumu ja Homabay gaskkas, mii leat {200} kilomehtera mĂĄddelis go Kisumu.
ADD:xmsyn-acc-to-comp (&msyn-acc-to-comp) TARGET Num IF (NOT 0 Acc OR ACC-NUM-ATTR LINK 1 Sem/Measr OR MEASURE LINK *1 Gen OR Acc BARRIER GRAMCHK-NPNHA LINK 1 ADV-COMP-FUNCTION ) ;  #2nd
	# difficult to searching for
    
ADD:xmsyn-acc-to-comp (&msyn-acc-to-comp) TARGET Num IF (NOT 0 Acc OR ACC-NUM-ATTR LINK 1 Sem/Measr OR MEASURE LINK *1 Loc BARRIER GRAMCHK-NPNHA  LINK *1 ("eret") BARRIER GRAMCHK-S-BOUNDARY ) ;  #2nd

COPY:msyn-acc-to-comp (Num Sg Acc SUGGEST) EXCEPT (Num Sg Gen) OR (Num Sg Loc Attr) OR (Num Sg Ill Attr) OR (Num Sg Nom) TARGET (Num &msyn-acc-to-comp) ;  #2nd
	#$ MĂĄhtte lea vihtta jagi nuorat go mun.
    #$ MĂĄhtte lea viÄa jagi nuorat mus.    
    ## LĂĄsse lea riegĂĄdan viÄa jagi ovdal go mon. DISAMBPROBLEM: "viÄa" Po is chosen
    ## Dat dĂĄhpĂĄhuvai viÄa jagi maĆĆil. - DuommĂĄ: why is this example here?
    ## ĂdjĂĄ viessu lea guovtti miilla bajĂĄbeale mĂĄrkana.
    ## Mun oidnen guovĆŸĆŸa golmma kilomehtera dĂĄbbelis.
    ## Guovdageaidnu lea golmma miilla duoin eret.
    ## Guovdageaidnu lea golmma miilla KĂĄrĂĄĆĄjogas eret.
    ## Guovdageaidnu lea golmma miilla duoin viesuin eret.
    ## ĂdjĂĄ viessu lea guovtti miilla mĂĄrkana bajĂĄbeale.

    #$ Guovdageaidnu lea golbma miilla duoin eret.
    #$ Guovdageaidnu lea golbma miilla KĂĄrĂĄĆĄjogas eret.
    #$ Guovdageaidnu lea golbma miilla duoin viesuin eret.
    #$ ĂdjĂĄ viessu lea guokte miilla mĂĄrkana bajĂĄbeale.
    #R: Nickel1994:486 "I Ăžst brukes ogsĂ„ genitiv i forbindelse med komparasjon, dersom komparativen er predikativ i steningen, og det andre sammanligningsleddet stĂ„r i lokativ: MĂĄhtte lea viÄa jagi nuorat mus."
    # in errors.xml

ADD:xmsyn-acc-to-comp (&msyn-acc-to-comp) TARGET Comp OR ADV-COMP-FUNCTION - Po - Pr - ("ovdal") IF (-1 Sem/Measr OR MEASURE OR Sem/Time OR CURRENCY LINK -1 Num)(NEGATE 0 &msyn-acc-to-adv)(NEGATE 0 Attr LINK 1 N);
	#$ Hagen lohkĂĄ ahte dan lea vĂĄttis dadjat, muhto orro ahte lastamĂĄÄuid lassĂĄneami sĂĄhttĂĄ Äatnat maĆemus logi jagi lieggasat dĂĄlkkiide.

ADDRELATION:msyn-acc-to-comp (RIGHT $2) (Num &msyn-acc-to-comp) TO (*1 Comp OR ADV-COMP-FUNCTION LINK 0 &msyn-acc-to-comp);


    # adverbs and certain cases
