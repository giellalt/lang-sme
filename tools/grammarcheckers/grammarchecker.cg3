    #$ Manadettiin cuovkanii skiipa; duإ،إ،e okta olmmأ،i rievddai skiippa gahppalaga nalde muhtun sullui.
    #DUOMMأپ: test this rule
	    
ADD:xlex-transitive (&lex-transitive) TARGET WRONG-TR-V IF (*-1 Gen - @P< OR Acc - @P< BARRIER GRAMCHK-S-BOUNDARY1 OR COMMA OR Po OR THAT-CS OR CC OR Nom LINK NOT 0 TIME OR ROUTE OR HUMAN OR (@SPRED) OR (@>N) LINK NEGATE *-1 TV BARRIER GRAMCHK-S-BOUNDARY OR CS) (NEGATE *-1 Gen OR Acc BARRIER GRAMCHK-S-BOUNDARY1 OR Po OR THAT-CS OR CC OR Nom LINK 0 Nom)(NEGATE *-1 TV BARRIER GRAMCHK-S-BOUNDARY OR CS) ; 
	#$ Bargojuohku gaskal eaktodأ،htolaإ، ja almmolaإ، veahkkedoaimmaid rievddai , ja dagahii doaibmahehttejuvvon olbmuid organisaإ،uvnnaide 	أ،ibbas earأ، 	rolla.
	#$ Manaimet Kemijoga gأ،ddأ،i bassat lأ،htterأ،nuid vai gerget {goikat} beaivvi أ،igge dalle go vuolgأ، أ،iggil johttui.
COPY:lex-transitive ("ovdأ،nahttit" TV SUGGEST) EXCEPT ("ovdأ،nit" IV &lex-transitive) OR ("ovdأ،nit" IV Err/Orth-a-أ، &lex-transitive) BEFORE V-MOOD OR Inf TARGET ("ovdأ،nit" IV &lex-transitive) ;
COPY:lex-transitive ("rievdadit" TV SUGGEST) EXCEPT ("rievdat" IV &lex-transitive) OR ("rievdat" IV Err/Orth-a-أ، &lex-transitive) BEFORE V-MOOD OR Inf TARGET ("rievdat" IV &lex-transitive) ;
COPY:lex-transitive ("duhtadit" TV SUGGEST) EXCEPT ("duhtat" IV &lex-transitive) OR ("duhtat" IV Err/Orth-a-أ، &lex-transitive) BEFORE V-MOOD OR Inf TARGET ("duhtat" IV &lex-transitive) ;
COPY:lex-transitive ("goiket" TV SUGGEST) EXCEPT ("goikat" IV &lex-transitive) BEFORE V-MOOD OR Inf TARGET ("goikat" V &lex-transitive) ;
COPY:lex-transitive ("vuodjudit" TV SUGGEST) EXCEPT ("vuodjut" IV &lex-transitive) BEFORE V-MOOD OR Inf TARGET ("vuodjut" V &lex-transitive) ;
    ## Dasa lassin bargأ، suohkan dan ala ahte ieإ¾as fأ،laldaga mأ،storأ،nddi nu bures go vejolaإ، ja vaikko man joؤ‘أ،nit rievdat.
    #$ Badjel 200 sأ،vcca, mأ،إ‹ggas dأ،in ؤچoavjjis, goike jأ،mas muhtin dأ،lus Oppdal:as, Lulli-Trأ¸ndelagas.
    #$ Mii oaidnit ahte dat gielddat mat beroإ،tit oapmedoalus, doppe mannأ، mihأ، buorebut go dain gielddain main lea unnأ،n beroإ،tupmi ؤچuovvut oapmedoalu, ja veahkehit dan ovdأ،nit.
    #$ Dan maإ‹إ‹أ، leat أ،إ،إ،it ovdأ،nan ieإ¾aset deattuin.
    #$ Dat han mearkkaإ،a ge dan ahte guottut leat rievdan, ja ahte obbalaإ، servodat lea ؤچuoإ¾إ¾ilan.
    #$ Muhto dan 11 jagis go dأ،t ؤچoagganeapmi lea bistأ،n, lea juoga maid rievdan.
    # DISAMBPROBLEM: this rule works when not using the disambiguator but "joؤ‘أ،nit" gets @SPRED> and that crashes everything
       
   #################
   # Lexical rules #
   #################
   
    # maإ‹is vs. maإ‹إ‹elis
    # ------------------

#DELETE uncommon
ADD:xlex-maإ‹إ‹elis-maإ‹is (&lex-maإ‹إ‹elis-maإ‹is) TARGET ("maإ‹إ‹elis")(NEGATE -1 Sem/Time OR TIME OR Sem/Event)  ;
COPY:lex-maإ‹إ‹elis-maإ‹is ("maإ‹is" Po SUGGEST) EXCEPT ("maإ‹إ‹elis" Po &lex-maإ‹إ‹elis-maإ‹is) OR ("maإ‹إ‹elis" Adv &lex-maإ‹إ‹elis-maإ‹is) TARGET (&lex-maإ‹إ‹elis-maإ‹is) ;
#OLD: lex-maإ‹is-not-maإ‹إ‹elis
    ## 	Beakkأ،n Terje Hأ¥konsen ؤچierastii muohtafielluin hearggi maإ‹إ‹elis. Beakkأ،n Terje Hأ¥konsen ؤچierastii muohtafielluin hearggi maإ‹is.
    ## Sii leat gal ؤچiekؤچan eanet ؤچiekؤچamiid go golbmajoavku mat 	sin maإ‹إ‹elis 	leat tabeallas . (error Duommأ،:ok
    # in errors.xml
    # maإ‹إ‹elis - lengre bak
    # maإ‹is - etter
    
    # ollugat vs. maإ‹ggas
    # -------------------
#DELETE ok according to GG
#DELETE  "man mأ،إ‹ggas" is unusual, "nu" mأ،إ‹ggas is VERY common, I think we must let it be 
ADD:xlex-mأ،إ‹ggas-ollugat (&lex-mأ،إ‹ggas-ollugat) TARGET ("mأ،إ‹ggas") IF (-1 GRADE-ADV OR ("nie") OR ("nأ،") OR ("man") OR ("mii") + Sg + Gen) ;
COPY:lex-mأ،إ‹ggas-ollugat ("ollugat" Pron Indef Pl Nom SUGGEST) EXCEPT ("mأ،إ‹ggas" N Coll Sg Nom &lex-mأ،إ‹ggas-ollugat) OR ("mأ،إ‹ggas" N Coll Sg Acc &lex-mأ،إ‹ggas-ollugat) TARGET (N &lex-mأ،إ‹ggas-ollugat) ;
	# OLD: lex-ollugat-not-mأ،إ‹ggas
    ## Earأ،t eai bovde nu mأ،إ‹gasa dahje eai heajastala ge. 
    ## Ii aktage lean jأ،hkkأ،n nu mأ،إ‹gasa dovdat alddineasetge 13-jahkأ،saإ، Agnesa identitehtavأ،ttisvuoؤ‘a Sohppara sأ،pmelaؤچؤچaid searvvis.
    ## Mii sihtat nu mأ،إ‹gasa go vejolaإ، oassأ،lastit gait buoremus festivأ،ladأ،hpأ،hussii goassege, dadjأ، movttegis Riddu Nuoraid joؤ‘iheaddji Kine Anita Lyshaug.
    ## Olles olmmoإ،logu ektui diehttelasat sأ،pmelaإ، lesbat ja homofiillat eai leat beare stuora joavku, muhto lea dattege joavku mas leat oalle mأ،إ‹gasat mielde.
    # in errors.xml
    
    # ollu vs. mأ،إ‹ga
    # --------------
#DELETE ok according to GG
ADD:xlex-not-maإ‹ga (&lex-not-maإ‹ga) TARGET ("mأ،إ‹ga") IF (-1 ("man") OR ("mii") + Sg + Gen)(*1 NP-HEAD BARRIER GRAMCHK-NPNH) ;
ADD:xlex-maإ‹ga (&lex-not-maإ‹ga) TARGET ("mأ،إ‹ga") IF (-1 ("man") OR ("mii") + Sg + Gen OR ("mii") + Sg + Acc)(*1 N + Gen BARRIER GRAMCHK-NPNH LINK 1 Adv OR Po) ;
COPY:lex-not-maإ‹ga ("ollu" Adv SUGGEST) EXCEPT ("mأ،إ‹ga" Pron Indef Sg Nom &lex-not-maإ‹ga) OR ("mأ،إ‹ga" Pron Indef Sg Acc &lex-not-maإ‹ga) TARGET (Pron &lex-not-maإ‹ga) ;	
COPY:lex-not-maإ‹ga ("galle" SUGGEST) EXCEPT ("mأ،إ‹ga" &lex-not-maإ‹ga) OR ("mأ،إ‹ga" &lex-not-maإ‹ga) TARGET (Pron &lex-not-maإ‹ga) ;	
    ## Man mأ،إ‹ga olbmo doppe ledje? Man ollu olbmot doppe ledje?
    #? Beare unnأ،n doarjja juolluduvvo, man mأ،إ‹ga 	jagi أ،igi juo cuiggodiإ،gohte. 
    # in errors.xml
    
    # Upper case instead of lower case where there is a propernoun reading
    # ----------------------------------------------------------

ADD:xlex-majuscule (&lex-majuscule) TARGET ("<sأ،medi[gk].*>"r) IF (0 Sg)(NOT *-1 Num BARRIER NOT-ADJ)(NEGATE 0 <cohort-with-dynamic-compound>);
	## Dأ،id gأ،vdnأ، sأ،medikki ruovttusiidduin sأ،gat-gaskablأ،ؤ‘i olis. Dأ،id gأ،vdnأ، Sأ،medikki ruovttusiidduin sأ،gat-gaskablأ،ؤ‘i olis. 
	
COPY:lex-majuscule (VSTR:"%u$1"S SUGGESTWF <fixedcase>) TARGET ("<(.*)>"r &lex-majuscule) ;

# COPY:titlecase (VSTR:"%u$1"S SUGGESTWF <fixedcase>) TARGET ("<(.*)>"r ) IF (0 looks-like-it-should-be-proper-but-is-lowercase) ; # you may want <fixedcase> to be sure divvun-suggest doesn't do anything more to casing

	# ollis vs. miehtأ،
	# ----------------
	# miehtأ، Sأ،mis > miehtأ، Sأ،mi / olles Sأ،mis
	
#DELETE miehtأ،+Adv + uncommon?
ADD:xlex-miehtأ،-olles (&lex-miehtأ،-olles &msyn-miehtأ،-Acc) TARGET ("miehtأ،") IF (0 Pr OR Po) (*1 GEOGRAPHICAL-PLACE + Loc OR POLITICAL-PLACE + Loc OR GENERAL-PLACE + Loc OR Sem/Plc + Loc BARRIER NOT-NP-HEAD-COMMA-CC) ;

ADD:xlex-miehtأ،-olles (&lex-miehtأ،-olles &msyn-miehtأ،-Acc) TARGET (N Loc) IF (0 GEOGRAPHICAL-PLACE OR POLITICAL-PLACE OR GENERAL-PLACE OR Sem/Plc)(*-1 (Pr &lex-miehtأ،-olles) OR (Po &lex-miehtأ،-olles) BARRIER NOT-NP-HEAD-COMMA-CC) ;

COPY:lex-miehtأ،-olles ("ollis" A Attr SUGGEST) EXCEPT ("miehtأ،" Po &msyn-miehtأ،-Acc) OR ("miehtأ،" Pr &msyn-miehtأ،-Acc) TARGET (&lex-miehtأ،-olles) IF (0 Pr OR Po);

COPY:lex-miehtأ،-olles (SUGGEST) EXCEPT (&msyn-miehtأ،-Acc)  TARGET (N &lex-miehtأ،-olles) ;


ADDRELATION:xlex-miehtأ،-olles (RIGHT $2)(Pr &lex-miehtأ،-olles) TO (1 (N Loc &lex-miehtأ،-olles));

	#2n suggestion

COPY:msyn-miehtأ،-Acc (Acc SUGGEST) EXCEPT (Loc &lex-miehtأ،-olles) TARGET (Loc &lex-miehtأ،-olles);

COPY:msyn-miehtأ،-Acc (SUGGEST) EXCEPT (&lex-miehtأ،-olles) TARGET ("miehtأ،" &lex-miehtأ،-olles);

ADDRELATION:xmsyn-miehtأ،-Acc (RIGHT $2) (Pr &msyn-miehtأ،-Acc) OR (Po &msyn-miehtأ،-Acc) TO (1 (N Acc &msyn-miehtأ،-Acc));
    ## Mii hأ،liidit ahte Guovdageaidnu ja Sأ،mi allaskuvla dأ،l maid galgأ، leat sأ،mi nuoraid ja earأ،id deaivvadanbأ،iki, ja ؤچohkket ollu sأ،mi studeanttaid miehtأ، Sأ،mis.
