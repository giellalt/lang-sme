SET PXNOTSG1 = Px - PxSg1 ;
SET PXNOTSG2 = Px - PxSg2 ;
SET PXNOTSG3 = Px - PxSg3 ;

SET PXNOTDU1 = Px - PxDu1 ;
SET PXNOTDU2 = Px - PxDu2 ;
SET PXNOTDU3 = Px - PxDu3 ;

SET PXNOTPL1 = Px - PxPl1 ;
