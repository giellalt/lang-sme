	# in errors.xml


	# PrfPrc vs. Actio Nom, HUOM! just for words with monophthong in infinitive, others are very uncommon
	# --------------------

ADD:xreal-ActioNom-PrfPrc (&real-ActioNom-PrfPrc) TARGET UT-VERBS IF (0 (Actio Gen) OR (Actio Nom) OR (Der/NomAct N Sg Gen Allegro) OR (Der/NomAct N Sg Nom) OR (Der/NomAg N Ess))(NEGATE 0 Ess)(*-1 BE + VFIN OR BE + Inf BARRIER GRAMCHK-S-BOUNDARY OR PrfPrc)(NEGATE 0 (Actio Gen) LINK 1 Po)(NEGATE 0 Der/Pass)(NEGATE 0 (Prt ConNeg)) ;
