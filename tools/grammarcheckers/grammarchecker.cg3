ADD:xreal-vأ،ldii (&real-vأ،ldii) TARGET ("vأ،ldi" N Sg Acc) OR ("vأ،ldit" V TV VGen) OR ("vأ،ldi" N Sg Gen) IF (NEGATE *-1 VFIN OR Inf BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN)(*0 Gen OR Acc BARRIER TV);
COPY:real-vأ،ldii ("vأ،ldit" V TV Ind Prt Sg3 SUGGEST) EXCEPT ("vأ،ldi" N Sg Acc &real-vأ،ldii) OR ("vأ،ldit" V TV VGen &real-vأ،ldii) OR ("vأ،ldi" N Sg Gen &real-vأ،ldii) TARGET (&real-vأ،ldii) ;
    ## Dأ،t ahte vأ،ldأ، nأ، guhkes أ،iggi dohkkehit sأ،mi museaid, ؤچأ،jeha duإ،إ،e ahte mo sأ،mi museaid meannudit, vaikko Sأ،mediggi juo logi jagi أ،igi vأ،lddi badjelasas sأ،mi museaid, dadjأ، Andreassen.
    #$ Lea olggobealde lأ،vdegotti vأ،lddi evttohit dأ،id mearrrأ،dusaid rievdaduvvot.
    #$ أپإ،إ،it mat gusket ovttaskas olbmuid boazodollui leat olggobealde orohatstivrra vأ،lddi.
    #$ Sأ،mi bأ،ikenamaid nammakonsuleanttat Bأ،ikenammalأ،ga آ§ 11 addأ، Sأ،mediggأ، vأ،lddi nammadit sأ،mi bأ،ikenammakonsuleanttaid.
	#$ Sii doalahedje vأ،lddi mearridit vearu sturrodaga.
     
    # varra vs. vأ،rra
