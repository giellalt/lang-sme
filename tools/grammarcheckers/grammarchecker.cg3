	# diehtit iige diehttit
	# ----------------------

ADD:xreal-diehttit-diehtit (&real-diehttit-diehtit) TARGET ("diehtit" Ex/V TV Der/NomAg N Pl Nom) OR ("diehtti" N NomAg Sem/Hum Pl Nom) OR ("diehtit" V TV Imprt Pl2) IF (*-1 <TH-Acc-Any><TH-Inf> OR <TH-Inf> OR <Inf> OR WHAT + (Sg Nom) OR I + ( Pron Sem/Hum Pers Pl1 Nom) BARRIER NOT-ADV-PCLE - SUBJ)(NEGATE *1 (V Prs Pl3) BARRIER NOT-ADV-PCLE) ; 
	#$ DĂĄ leat ÄuoÄÄuhusat mat eai doala deaivĂĄsa ja professor ja earĂĄ diehttit eai galggaĆĄe fallehit nie ovtta ealĂĄhusjoavkku.
	## KĂĄrĂĄĆĄjoga festivĂĄla buvttadeaddji Anne Berit Anti ii lohkan vel diehttit man olu olbmot ledje ikte konsearttas, muhto measta buot ÄohkkĂĄnsajit ledje dievvan
	## Lea maiddĂĄi dehĂĄlaĆĄ diehttit 
	## DĂĄn dĂĄrbbaĆĄa SĂĄmediggi diehttit! 
	## Dan dii ehpet dĂĄidĂĄn diehttit NSR birra, ahte mii maiddĂĄi ĂĄimmahuĆĄĆĄat romantihkalaĆĄ beliid!
	## Vihtta mĂĄnu maĆĆil dĂĄrbbaĆĄit mii ain diehttit vai ĂĄddet.
	#$ LĂĄvdegottis leat 17 miellahtu geat leat oahppĂĄn doaktĂĄrat, buorĂĄdallit geat geavahit earĂĄ vugiid go doaktĂĄroahpu, nu go akupunktura, servvodat diehttit ja lĂĄhkadovdit.
	#$ Vaikko diehttit Äurvot ahte dĂĄl leat heajos ĂĄiggit ja ahte Norggas ii leat nu sihkkaris ekonomiija, de goitge ÄĂĄjehit logut ahte bargguhisvuohta FinnmĂĄrkkus lea veahĂĄĆĄ njiedjan.
	#$ Ja easkka dan maiddĂĄi galggaĆĄii guorahallat, maid ĆĄattuid min doloĆĄ mĂĄttut ja diehttit leat dovdan ja geavahan biebmun, dĂĄlkkasin dahje bĂĄidnun.

ADD:xreal-diehttit-diehtit (&real-diehttit-diehtit) TARGET ("diehtit" Ex/V TV Der/NomAg N Pl Nom) OR ("diehtti" N NomAg Sem/Hum Pl Nom) OR ("diehtit" V TV Imprt Pl2) IF (*-1 WHAT + (Sg Nom) OR I + ( Pron Sem/Hum Pers Pl1 Nom) BARRIER NOT-ADV-PCLE - SUBJ LINK -1 CS LINK -1 BOS); 
	## Nugo mii diehttit leat ollu
		
ADD:xreal-diehttit-diehtit (&real-diehttit-diehtit) TARGET ("diehtit" Ex/V TV Der/NomAg N Pl Nom) OR ("diehtti" N NomAg Sem/Hum Pl Nom) OR ("diehtit" V TV Imprt Pl2) IF (*-1 (Acc Sem/Hum) BARRIER NOT-ADV-PCLE - SUBJ LINK -1 <TH-Acc-Any><TH-Inf>)(NEGATE *1 (V Prs Pl3) BARRIER NOT-ADV-PCLE) ;
	## KylmĂ€niemi lohkĂĄ su diehttit, ahte maiddĂĄi dutkanguovddĂĄĆŸis dihtet ĂĄĆĄĆĄi birra.
	
ADD:xreal-diehttit-diehtit (&real-diehttit-diehtit) TARGET ("diehtit" Ex/V TV Der/NomAg N Pl Nom) OR ("diehtti" N NomAg Sem/Hum Pl Nom) OR ("diehtit" V TV Imprt Pl2) IF (-1 (A Sg Nom) LINK *-1 COPULAS + Sg3 BARRIER NOT-ADV-PCLE LINK *-1 BOS BARRIER NOT-ADV-PCLE - ("â")) ;	
	## Ovddamearkka dihte mo diehttit mieÄiha go buohcci vai lea go son duoÄaid nuppi oaivilis.

ADD:xreal-diehttit-diehtit (&real-diehttit-diehtit) TARGET ("diehtit" Ex/V TV Der/NomAg N Pl Nom) OR ("diehtti" N NomAg Sem/Hum Pl Nom) OR ("diehtit" V TV Imprt Pl2) IF (-1 ("mo") OR ("movt") OR ("got") LINK *-1 BOS BARRIER VFIN) ;	
	## â Lea hui buorre diehttit dan ja lean hui giitevaĆĄ dan veahki ovddas ja dan liekkusis beroĆĄtumi ovddas maid ĂĄlbmot lea ÄĂĄjehan, dadjĂĄ duhtavaĆĄ bĂĄhppa.

ADD:xreal-diehttit-diehtit (&real-diehttit-diehtit) TARGET ("diehtit" Ex/V TV Der/NomAg N Pl Nom) OR ("diehtti" N NomAg Sem/Hum Pl Nom) OR ("diehtit" V TV Imprt Pl2) IF (1 ("maid") OR Rel OR MO-MANge LINK *1 VFIN) ;	
	## diehttit maid earĂĄ persovnnat smihttet.
	## maĆosguvlui bokte diehttit mii Heaikkain lea geavvan ovddeĆŸis.
	
ADD:xreal-diehttit-diehtit (&real-diehttit-diehtit) TARGET ("diehtit" Ex/V TV Der/NomAg N Pl Nom) OR ("diehtti" N NomAg Sem/Hum Pl Nom) OR ("diehtit" V TV Imprt Pl2) IF (1 VFIN + Qst) ;	
	## diehttit leago Heaikkas leamaĆĄan moarsi.
	
COPY:real-diehttit-diehtit ("diehtit" V TV Inf SUGGEST) EXCEPT ("diehtit" Ex/V TV Der/NomAg N Pl Nom &real-diehttit-diehtit) OR ("diehtti" N NomAg Sem/Hum Pl Nom &real-diehttit-diehtit) OR ("diehtit" V TV Imprt Pl2 Dial/-GG &real-diehttit-diehtit) TARGET (&real-diehttit-diehtit) ;	
 
	

		
	# dihtii vs. dihti
