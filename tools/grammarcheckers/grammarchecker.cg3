LIST LAHKAGEN-NOUN = "Â§" "buohkaidvuoigatvuohta" "cealkka" ("fĂĄpmu" Ill)"hĂĄpmi" "johtolatvuoigatvuohta" "kapihtal" "lĂĄhkavuoÄÄu" "ovdabargu" "rĂĄmma" "rĂĄhkkananbargu" "rĂĄidu" "sĂĄtnemearkkaĆĄupmi" "ulbmilparagrĂĄfa" "vuoÄÄu" "vuoÄÄoeaktu" "vuolit" "V";

