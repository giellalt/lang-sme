ADD:xreal-sأ،htأ،إ، (&real-sأ،htأ،إ،) TARGET ("sأ،htaإ،it") OR CAN + (IV Cond Prs Err/Orth-a-أ،) IF (NEGATE *-1 (@OBJ>) + Sem/Hum OR (@OBJ>) + Sem/Fem  OR (@OBJ>) + Sem/Mal OR (@OBJ>) + Sem/Sur OR (@OBJ>) + (Pron Pers) OR (@OBJ>) + ("dat") OR (@OBJ>) + SأپHTAإ IT-OBJ BARRIER V OR GRAMCHK-S-BOUNDARY)(1 OBJ OR Acc + (Pron Pers) OR Acc + N OR Adv LINK 1 (TV Inf))(NOT 0 Der/Pass); #OR CAN + (IV Cond Prs Err/Orth) 
	#$ Dأ،s lea dievasmahttinskuvlejumis ja oahpaheaddjeoahpus mearkkaإ،ahtti rolla, ja olu bargu dasgo leat olu suorggit maiguin {sأ،htأ،إ،ii} eambo bargat nugo أ،rbevirolaإ، mahtu rollain skuvllain dahje olgobiraspedagogihkain, sأ،megiela ja girjjأ،laإ،vuoؤ‘a didaktihkain, sأ،me- ja mأ،إ‹ggagielat أ،lgooahpahusain, giellaealأ،skahttimiin, ieإ،guؤ‘etge oahpahusfأ،ga didaktihkaiguin jna.
