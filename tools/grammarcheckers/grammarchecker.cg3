	## Dolvon dan boarrasiid siidii Deanus, muhto doppe ii ballen gal govva heaĆgat beare guhka seainnis.
	## Juoga mii lea oahpis ĂĄssiide, go dĂĄt logot galget buot telefunboksaide biddjot olles Australiai ja heaĆgat das golbma jagi.
	## Idivuoma lohkĂĄ almmis heaĆgat jearaldaga ahte man veara lea divvut ĂĄiddiid, mat leat Norgga ja RuoĆ§a ealuid gaskkas konvenĆĄuvnna guovlluin.

ADD:real-heaĆgĂĄt (&real-heaĆgĂĄt) TARGET ("heaĆgahit" Ind Prs ConNeg) OR ("heaĆgahit" Imprt Sg2) OR ("heaĆgahit" Imprt ConNeg) IF (-1 ("nĂĄ") OR ("nu") OR ("nuvt") LINK NEGATE *-1 NOT-V BARRIER GRAMCHK-S-BOUNDARY);
	## 58B:1 : Lei issoras bĂĄvÄÄas nĂĄ heaĆgat, ja su vuolĂĄbealde lei gorĆŸi dego stuora duoldi mĂĄlesbĂĄhti.

ADD:real-heaĆgĂĄt (&real-heaĆgĂĄt) TARGET ("heaĆgahit" Ind Prs ConNeg) OR ("heaĆgahit" Imprt Sg2) OR ("heaĆgahit" Imprt ConNeg) IF (-1 ("duĆĄĆĄe") LINK *-1 (V <duĆĄĆĄe><TH-Inf>) BARRIER GRAMCHK-S-BOUNDARY);
	## Mika LĆ nsman lohkĂĄ heargevuodjimis diehttelasat adnojit maiddĂĄi searat, go ii leat duĆĄĆĄe heaĆgat hearggi maĆis mollii.

ADD:real-heaĆgĂĄt (&real-heaĆgĂĄt) TARGET ("heaĆgahit" Ind Prs ConNeg) OR ("heaĆgahit" Imprt Sg2) OR ("heaĆgahit" Imprt ConNeg) IF (*-1 (A Nom) BARRIER WORD - Loc - DOPPE - (Acc PxSg3) - (Gen PxSg3) LINK *-1 COPULAS BARRIER NPNHA);
    ##  Hilde : Beatnaga maĆis lea hui suohtas heaĆgat.
    ## Ii ĂĄlo leat somĂĄ girjjis heaĆgat ja dĂĄt proĆĄeakta lea buorre movttiidahttin nuoraide go besset nu go huksenfĂĄga, mekanihkkafĂĄga ja duodjefĂĄgaid geahÄÄalit.
    ## Lei veahĂĄ issoras heaĆgat nu badjin, ja dasa lassin lei maid oalle garra biegga dan beaivvi.
    ## Ii leat nu ĂĄlki heaĆgat ja stivret oktanaga.


ADD:real-heaĆgĂĄt (&real-heaĆgĂĄt) TARGET ("heaĆgahit" Ind Prs ConNeg) OR ("heaĆgahit" Imprt Sg2) OR ("heaĆgahit" Imprt ConNeg) IF (-1 PrfPrc LINK *-1 COPULAS BARRIER NPNHA);
    ## Lei daÄistaga ÄĂĄhpodan heaĆgat seainnis.

ADD:real-heaĆgĂĄt (&real-heaĆgĂĄt) TARGET ("heaĆgahit" Ind Prs ConNeg) OR ("heaĆgahit" Imprt Sg2) OR ("heaĆgahit" Imprt ConNeg) IF (*-1 VFIN - Neg BARRIER NPNHA);
    ## Dat ÄĂĄhpoda daÄistaga heaĆgat seainnis.
    #$ Odne eai heaĆgat boarrĂĄsat dorvves seainnis, sii ÄohkkĂĄjit dihtora ovddas.

ADD:real-heaĆgĂĄt (&real-heaĆgĂĄt) TARGET ("heaĆgahit" Ind Prs ConNeg) OR ("heaĆgahit" Imprt Sg2) OR ("heaĆgahit" Imprt ConNeg) IF (*-1 BECAUSE-WHEN BARRIER WORD - Loc - DOPPE - Adv - (Acc PxSg3) - (Gen PxSg3) LINK -1 Inf LINK *-1 (A Der/Comp) BARRIER WORD - Loc - DOPPE - Adv - (Acc PxSg3) - (Gen PxSg3));
    ## Na, jus duoÄas hĂĄliidat ieĆŸat sorbmet, de lea goit mihĂĄ buoret girkodoartnas gahÄÄat go muoras heaĆgat, dajai son.

ADD:real-heaĆgĂĄt (&real-heaĆgĂĄt) TARGET ("heaĆgahit" Ind Prs ConNeg) OR ("heaĆgahit" Imprt Sg2) OR ("heaĆgahit" Imprt ConNeg) IF (-1 Acc LINK *-1 TV BARRIER NPNHA);
    ## Sorjalit olgguldasbĂĄiddi murrii, Äuolbmadit soajĂĄiguin rissĂĄi ja sodjalahttet bĂĄs seahkaĆŸa heaĆgat gitta eanalahpĂĄi.

ADD:real-heaĆgĂĄt (&real-heaĆgĂĄt) TARGET ("heaĆgahit" Ind Prs ConNeg) OR ("heaĆgahit" Imprt Sg2) OR ("heaĆgahit" Imprt ConNeg) IF (*-1 ("heivet") BARRIER WORD - MANNER-ADV - COM-ADV - Pcle - Loc - DOPPE - (Acc PxSg3) - (Gen PxSg3));
    ## Halse ja Nango govat heivejedje ge ovttas heaĆgat seamma lanjas, go dat ollistit ollislaĆĄgova vuohkkasit, juoga mii dĂĄsseda.

ADD:real-heaĆgĂĄt (&real-heaĆgĂĄt) TARGET ("heaĆgahit" Ind Prs ConNeg) OR ("heaĆgahit" Imprt Sg2) OR ("heaĆgahit" Imprt ConNeg) IF (-1 Nom) (1 ("maĆis") OR ("maĆĆi" Loc));
    ## SĂĄmedikkis eai gĂĄvdno viĆĄuvnnat eaige strategiijat politihkalaĆĄ bealis, nu ahte mii heaĆgat maĆis, lohkĂĄ Mathisen NRK SĂĄmi Radioi.


COPY:real-heaĆgĂĄt ("heaĆgĂĄt" Inf SUGGEST) EXCEPT ("heaĆgahit" Gram/3syll Ind Prs ConNeg &real-heaĆgĂĄt) OR ("heaĆgahit" Gram/3syll Imprt Sg2 &real-heaĆgĂĄt) OR ("heaĆgahit" Gram/3syll Imprt ConNeg &real-heaĆgĂĄt) TARGET (&real-heaĆgĂĄt) ;


    # jamas (japmat or japma) vs. jĂĄmas (Adv)
    # ----------------------------------
    # condition: verbs that go with jĂĄmas (ballat, dolkat, etc.)

LIST JAMAS-VERB = "bĂĄhÄit" "bĂĄhkkanit" "ballat" "barggahit" "bargat" "beahttahuvvat" "beahttaĆĄuvvat"  "behtohallat" "berostit" "beroĆĄtit" "bĂĄhÄalit" "bĂĄĆŸĂĄhallat" "biidnaĆĄuvvat" "biinnidit" "bilkidit" "bivddaĆĄit" "buollit" "boagustit" "boaldit" "borrat" "buvvĂĄnit" "Äaibmat" "Äaskit" "cĂĄbmit" "cĂĄpmahallat" "cĂĄpmit" "cielahit" "Äaskit" "Äaskkahallat" "ÄievÄÄastit" "Äukkohallat" "Äuoggut" "Äuollat" "Äugget" "deaivat" "dearpat" "dearpalit" "dearppastit" "doarostit" "doaĆĄkut" "dolkat" "doĆĄket" "dulmmohallat" "duolbmat" "duolbmut" "fierrat" "gahÄÄat" "gĂĄhttet" "galbmot" "gaikkodit" "galmmihit" "gaskit" "gĂĄskit" "geÄget" "geÄget" "geaÄgut" "geaÄgĂĄdit" "girdit" "givssidit" "goallut" "goikat" "goikadit" "gĂĄsset" "hĂĄvkat" "hĂĄvkadit" "heahpanit" "huĆĄkut" "huĆĄkkastit" "huĆĄkkohallat" "juhkat" "kodet" "liikot" "lĂĄittastuvvat" "mannat" "meannudit" "moraĆĄtit" "nealgudit" "nealgut" "ovdĂĄnit" "reaivat" "reaivvahaddat" "reaivvahallat" "riidet" "risset" "sallut" "sivahallat" "ĆĄluvgit" "speaĆŸĆŸut" "suhttat" "surgehit" "sorbmahuvvat" "suorganit" "vardĂĄt" "vardit"  "vĂĄibat" "vuodjat" "vuodjit" "vuodjut" "vuojahallat" "vuojĂĄhallat" ; #XXX this is really a non-finite list...

ADD:real-jĂĄmas (&real-jĂĄmas) TARGET ("japmat" Der/st) OR ("japma" N Sg) IF (0 VGen OR (Imprt Sg2) OR (ImprtConNeg) OR (Prs ConNeg) OR (Acc PxSg3) OR (Gen PxSg3) OR Loc)(*0 JAMAS-VERB OR <jĂĄmas> BARRIER GRAMCHK-S-BOUNDARY - THAT-CS - (PUNCT LEFT) - (PUNCT RIGHT) OR GRAMCHK-VFIN) ;
    ## Lea go imĂĄĆĄ ahte balan jamas go soames namuha skuvlla munnje? Lea go imĂĄĆĄ ahte balan jĂĄmas go soames namuha skuvlla munnje?
    ## Badjel 200 sĂĄvcca, mĂĄĆggas dĂĄin Äoavjjis, goike jamas muhtin dĂĄlus Oppdal:as, Lulli-TrĂžndelagas.
    ## De fallehii duon olbmĂĄ ; muhto olmmĂĄi dohppii dan soappi ja Äaskkii beatnaga ( ruĆŸĆŸahortti ) jamas.
    ## Bueng gal vĂĄruha ahte SĂĄmedikkis lea dĂĄhttu âč âč nealgudit âș âș jamas Norgga beale SĂĄmi stuorĂĄmus heargesearvvi, SHL, go presideanta eahpida juolludeames stuorĂĄmus heargebirrasii ruÄaid.
    ## Dat logut geaĆŸuhit ahte lea ĂĄigi festivĂĄlain buorebut gulahallat ja ovttas plĂĄnet doaluid, vai dĂĄn Â« vahkkoloahpagilvvu Â» vĂĄikkuhus ii ĆĄatta nu ahte nubbi festivĂĄla Â« ÄaskĂĄ Â» nuppi festivĂĄla jamas.
    # in error.xml

ADD:real-jĂĄmas (&real-jĂĄmas) TARGET ("japmat" Der/st) OR ("japma" N Sg) IF (0 VGen OR (Imprt Sg2) OR (ImprtConNeg) OR (Prs ConNeg) OR (Acc PxSg3) OR (Gen PxSg3) OR Loc)(-1 GRADE-ADV) ;
ADD:real-jĂĄmas (&real-jĂĄmas) TARGET ("japmat" Der/st) OR ("japma" N Sg) IF (0 VGen OR (Imprt Sg2) OR (ImprtConNeg) OR (Prs ConNeg) OR (Acc PxSg3) OR (Gen PxSg3) OR Loc)(-1 BE) ;

COPY:real-jĂĄmas ("jĂĄmas" Adv SUGGEST) EXCEPT ("japmat" V IV Der/st) OR ("japma" N Sg Loc) OR ("japma" N Sg Acc PxSg3) OR ("japma" N Sg Gen PxSg3) TARGET (&real-jĂĄmas) ;
    ## Kotusa sĂĄmegiela lĂĄvdegoddi lea leamaĆĄ jahkeviissaid hui jamas ja dĂĄt linnjĂĄ joatkahuvvĂĄ dĂĄs duohkonai, daningo Kotusis eai leat mangelĂĄgĂĄn resurssat sĂĄmi giellapolitihkalaĆĄ bargui. --works
    ## Kotusa sĂĄmegiela lĂĄvdegoddi lea leamaĆĄ jahkeviissaid hui jamas ja dĂĄt linnjĂĄ joatkahuvvĂĄ dĂĄs duohkonai, daningo Kotusis eai leat mangelĂĄgĂĄn resurssat sĂĄmi giellapolitihkalaĆĄ bargui. Kotusa sĂĄmegiela lĂĄvdegoddi lea leamaĆĄ jahkeviissaid hui jĂĄmas ja dĂĄt linnjĂĄ joatkahuvvĂĄ dĂĄs duohkonai, daningo Kotusis eai leat mangelĂĄgĂĄn resurssat sĂĄmi giellapolitihkalaĆĄ bargui.
    ## Ja mun, gii gal arvvan boaldit vaikko du ieĆŸatge vel jamas, jos muinna lĂĄhtteĆŸat skiluheamet.
    # in error.xml

ADD:real-jĂĄmas (&real-jĂĄmas) TARGET ("japmat" Der/st) OR ("japma" N Sg) IF (-1 CC LINK -1 (A Sg Nom));
    ## Borgguheddjiid liiki lea rĂĄnis ja roavis, ĆĄlinccas ja jamas.

ADD:real-jĂĄmas (&real-jĂĄmas) TARGET ("japmat" Der/st) OR ("japma" N Sg) IF (-1 ("man") OR ("mii" Rel Sg Acc Known) OR ("mii" Rel Sg Gen))(1 COPULAS);
    ## BoaresvuoÄa nĂĄvccahisvuoÄa geaĆŸil Ăhkku dovddai hui Äielgasit, man jamas lei dĂĄllu.

ADD:real-jĂĄmas (&real-jĂĄmas) TARGET ("japmat" Der/st) OR ("japma" N Sg) IF (-1 (N Acc) LINK *-1 JAMAS-VERB OR <jĂĄmas> BARRIER NPNHA LINK 0 TV) ;
    ## Seamma ahkĂĄsaĆĄ bĂĄrdni lea vĂĄldon giddagassii, go balahuvvo Äuggen nuppi dievddu jamas.


LIST JAMAS-COMPOUND = (".*japma"r);

ADD:real-jĂĄmas (&real-jĂĄmas) TARGET JAMAS-COMPOUND IF (0 VGen OR (Imprt Sg2) OR (ImprtConNeg) OR (Prs ConNeg) OR (Acc PxSg3) OR (Gen PxSg3) OR Loc)(*0 JAMAS-VERB OR <jĂĄmas> BARRIER GRAMCHK-S-BOUNDARY - THAT-CS OR GRAMCHK-VFIN) ;


	# lĂĄnjastuvvat vs. lanjastuvvat
    # -----------------------------

ADD:xreal-lĂĄnjastuvvat (&real-lĂĄnjastuvvat) TARGET ("latnjat" Ex/V TV Der/stuvva) IF (*0 (N Nom) BARRIER GRAMCHK-S-BOUNDARY LINK 0 Sem/Plc OR Sem/Sur OR NATURE-PLACE) ;

COPY:real-lĂĄnjastuvvat ("lĂĄnjastuvvat" SUGGEST) EXCEPT ("latnjat" Ex/V TV Der/stuvva &real-lĂĄnjastuvvat) TARGET (V &real-lĂĄnjastuvvat) ;
SUBSTITUTE:real-lĂĄnjastuvvat (V) (V IV) TARGET (V &real-lĂĄnjastuvvat) ;
	## Gieddi lanjastuvvĂĄ.
	# in errors.xml
	
    # lĂĄse vs. lasse (lasset)
    # ----------------------
    # lĂĄsset - lĂĄssehallat (V) - lĂĄssa (N) "lĂ„s"
    # lĂĄse - "glass"
    # lasset (V) - lassa (N) "karm"
#DELETE uncommon
ADD:xreal-lĂĄse (&real-lĂĄse) TARGET ("lasset" V) IF (0 VGen OR Imprt OR Prs)(-1 Num);   

COPY:real-lĂĄse ("lĂĄse" N Sg Acc SUGGEST) EXCEPT ("lasset" V TV VGen &real-lĂĄse) OR ("lasset" V TV Imprt Sg2 &real-lĂĄse) OR ("lasset" V TV Imprt ConNeg &real-lĂĄse) OR ("lasset" V TV Ind Prs Sg3 &real-lĂĄse) OR ("lasset" V TV Ind Prs ConNeg &real-lĂĄse) TARGET (&real-lĂĄse) ;
    ## Jus hĂĄliidat rahkadit dan, de don dĂĄrbbaĆĄat 1 kg jaffuid, salti, 2 lasse ÄĂĄzi ja 1 pahkka biergudĂĄiggi. Jus hĂĄliidat rahkadit dan, de don dĂĄrbbaĆĄat 1 kg jaffuid, salti, 2 lĂĄse ÄĂĄzi ja 1 pahkka biergudĂĄiggi.
    # in errors.xml
    
    # lasse (lasset) > lassi (tilleggs)
    # ---------------------------------
    
LIST LASSET-N = "uksa" "lĂĄse" ;

ADD:real-lasse-lassi (&real-lasse-lassi) TARGET ("lasset" V) IF (0 (VGen) OR (Imprt Sg2) OR (Imprt ConNeg) OR (Ind Prs Sg3) OR (V TV Ind Prs ConNeg))(*1 N BARRIER (*) - Attr LINK NEGATE 0 LASSET-N)(NEGATE 0 &real-lĂĄse); 

COPY:real-lasse-lassi ("lassi" A Attr SUGGEST) EXCEPT ("lasset" V TV VGen &real-lĂĄse) OR ("lasset" V TV Imprt Sg2 &real-lĂĄse) OR ("lasset" V TV Imprt ConNeg &real-lĂĄse) OR ("lasset" V TV Ind Prs Sg3 &real-lĂĄse) OR ("lasset" V TV Ind Prs ConNeg &real-lĂĄse) TARGET (&real-lasse-lassi) ;
	## Dalle vĂĄldojuvvo lasse mammongrĂĄfagovat ja dalle dutkojuvvo dĂĄvjĂĄ maid Ultra-jienain.
	## Doaivvabiebmu ja lasse juhkamuĆĄ.

	
	# lahkalagaid vs. lĂĄhkalĂĄgaid
	# ---------------------------

ADD:xreal-lĂĄhkalĂĄgaid-lahkalagaid (&real-lĂĄhkalĂĄgaid-lahkalagaid) TARGET ("lĂĄhka" N Pl Gen) OR ("lĂĄhka" N Pl Acc) OR ("lĂĄga" N Pl Gen) OR ("lĂĄga" N Pl Acc) IF (0/1 ("lĂĄhka")) ;

COPY:real-lĂĄhkalĂĄgaid-lahkalagaid ("lahkalagaid" Adv SUGGEST) EXCEPT ("lĂĄhka" N Pl Gen &real-lĂĄhkalĂĄgaid-lahkalagaid) OR ("lĂĄhka" N Pl Acc &real-lĂĄhkalĂĄgaid-lahkalagaid) OR ("lĂĄga" N Pl Gen &real-lĂĄhkalĂĄgaid-lahkalagaid) OR ("lĂĄga" N Pl Acc &real-lĂĄhkalĂĄgaid-lahkalagaid) TARGET (&real-lĂĄhkalĂĄgaid-lahkalagaid) ;
	## Giellabargit bohtet bargat hui lĂĄhkalĂĄgaid giellajuhkosiin.

	# liikkĂĄstuvvat vs. liikkastuvvat
    # -----------------------------

ADD:xreal-liikkĂĄstuvvat (&real-liikkĂĄstuvvat) TARGET ("liikkastuvvat") IF (*0 (N Nom) BARRIER GRAMCHK-S-BOUNDARY LINK 0 Sem/Clth OR Sem/Obj-clo) ;
COPY:real-liikkĂĄstuvvat ("liikkĂĄstuvvat" SUGGEST) EXCEPT ("liikkastuvvat" &real-liikkĂĄstuvvat) TARGET (V &real-liikkĂĄstuvvat) ;
	## GĂĄrvvut liikkastuvvat.
	# in errors.xml
	
ADD:xreal-liikkastuvvat (&real-liikkastuvvat) TARGET ("liikkĂĄstuvvat") OR ("liikkĂĄstuvvat" V IV Ind Prt Err/Orth Sg3) IF (*0 (Nom) BARRIER GRAMCHK-S-BOUNDARY LINK 0 Sem/Hum OR Sem/Mal OR Sem/Fem OR Sem/Sur OR PPRON-NOM-NOT-DAT) ;
COPY:real-liikkastuvvat ("liikkastuvvat" SUGGEST) EXCEPT ("liikkĂĄstuvvat" &real-liikkastuvvat) TARGET (V &real-liikkastuvvat) ;
	## LiikkĂĄstuvai visot Bengtsson.
	## LiikkĂĄstuvai visot gal son.
	# in errors.xml

    # lohkat (V) vs. lohkadit (VGEN, Imprt, ConNeg) OR lohkka (PxSg2)
    # ---------------------------------------------------------------
    #   
 
   
ADD:xreal-lohkat (&real-lohkat) TARGET ("lohkka") IF (0 (N Sg Nom PxSg2) OR ("lohkat" Inf Err/Confused-ImprtSg2))(NEGATE *0 DON BARRIER GRAMCHK-S-BOUNDARY LINK *0 GRAMCHK-VFIN LINK 0 Sg2)(NEGATE 0 (Ind Prs ConNeg) LINK -1 CC LINK -1 ConNeg)(NEGATE *1 ("!"))(NEGATE *1 Acc OR Gen BARRIER NPNHA LINK 0 Sem/Veh OR Sem/Buildpart OR Sem/Build-room);  
ADD:xreal-lohkat (&real-lohkat) TARGET ("lohkkadit" V TV VGen) OR ("lohkkadit" V TV Imprt Sg2) OR ("lohkkadit" Imprt ConNeg) OR ("lohkkadit" Imprt nd Prs ConNeg) OR ("lohkat" Inf Err/Confused-ImprtSg2) IF (*-1 AUX + VFIN BARRIER S-BOUNDARY)(NEGATE 0 (Ind Prs ConNeg) LINK -1 CC LINK -1 ConNeg)(NEGATE *1 ("!"))(NEGATE *1 Acc OR Gen BARRIER NPNHA LINK 0 Sem/Veh OR Sem/Buildpart OR Sem/Build-room);
	#$ Son namuha dĂĄs joÄĂĄnit ahte sii leat gĂĄvdnan vuolabohtaliid sĂĄvnnjiin, ahte ĂĄvdnasat eai biddjo ruovttoluotta gosa galget ja ahte geavaheaddjit eai Äorge ja lohkkat maĆĆel go gerget.
  
COPY:real-lohkat ("lohkat" V TV Inf SUGGEST) EXCEPT ("lohkkadit" V TV VGen &real-lohkat) OR ("lohkkadit" V TV Imprt Sg2 &real-lohkat) OR ("lohkkadit" V TV Imprt ConNeg &real-lohkat) OR ("lohkkadit" V TV Ind Prs ConNeg &real-lohkat) OR ("lohkka" N Sg Nom PxSg2 &real-lohkat) OR ("lohkat" Inf Err/Confused-ImprtSg2) TARGET (&real-lohkat) ;   
  ## Eat mii viĆĄa dien lohkkat, mii hĂĄliidit lohkat eambbo Mari birra.
  
    # lohkĂĄ (lohkat+V+TV+Ind+Prs+Sg3) vs. lohka (lohka+N+Sg+Nom lohkka+N+Sg+Gen lohkka+N+Sg+Acc)
    # ------------------------------------------------------------------------------------------


ADD:xreal-lohkĂĄ (&real-lohkĂĄ) TARGET ("lohka" N Sg Nom) OR ("lohkka" N Sg Gen) OR ("lohkka" N Sg Acc) OR ("lohkat" V TV Ind Prs Sg3 Err/Orth-a-ĂĄ) IF (NOT 0 PxSg2  OR Foc/ba)(*1 V - VFIN BARRIER GRAMCHK-S-BOUNDARY OR V);  
ADD:xreal-lohkĂĄ (&real-lohkĂĄ) TARGET ("lohka" N Sg Nom) OR ("lohkka" N Sg Gen) OR ("lohkka" N Sg Acc) OR ("lohkat" V TV Ind Prs Sg3 Err/Orth-a-ĂĄ) IF (NOT 0 PxSg2 OR Foc/ba)(-1 COMMA)(*1 Sem/Hum + Nom OR Sem/Sur + Nom OR Sem/Mal + Nom OR Sem/Fem + Nom BARRIER NPNH);  

COPY:real-lohkĂĄ ("lohkat" V TV Ind Prs Sg3 SUGGEST) EXCEPT ("lohka" N Sg Nom &real-lohkĂĄ) OR ("lohkka" N Sg Gen &real-lohkĂĄ) OR ("lohkka" N Sg Acc &real-lohkĂĄ) OR ("lohkat" V TV Ind Prs Sg3 Err/Orth-a-ĂĄ &real-lohkĂĄ) TARGET (&real-lohkĂĄ) ; 
	## GaĆŸĂĄldat sĂĄhttĂĄ go rievdadit ovttasbargoĆĄiehtadusa, boahtĂĄ das mot mii leat ĆĄiehttan go vuollaiÄĂĄliimet ĆĄiehtadusa, lohka Laila Susanne Vars.
	## BoazoeaiggĂĄt Magne Huva lohka gĂĄvdnan rĂĄppiid.
	## Nu ahte ii oktage sĂĄhte lohkat ahte muhtun bĂĄikkit filkkas eai leat sĂĄmi, lohka SĂĄmediggepresideanta.
	## Sii jotket nu dĂĄlĂĄ oamasteaddji vuoÄuin, lohka Martinsen.
	## Son vĂĄsiha, ahte sii eai buohkat ÄĂĄga deike, fitnodat galgĂĄ vuolgit eret dĂĄppe, ii sin ovttasbargu doaimma, vĂĄikke dĂĄn gohÄodit oktasaĆĄbargun, muhto dat ii doaimma, dasa dĂĄrbbaĆĄuvvojit guktot bealit, lohka Blind.
	## BĂĄikki olmmoĆĄ, Sara Juusu lohka  dĂĄhpĂĄhusa leat suorggahahttin, ja su mielas lei maid nu ilgat go skuvlla uvssat ledje gittĂĄ  go galggai mĂĄnĂĄid vieĆŸĆŸat ruoktot.
	## Ja oainnĂĄn ahte sĂĄtnejoÄiheaddjit suohkaniin gos leat ruvkedoaimmat, ĂĄlget ovddidit  (divvamĂĄkso jurdagiid), lohka Olli.
	# needs to be tested

	
	
    # logĂĄt (Num) iige logat (lohkat)
    # ----------------------------------

LIST LOGAT = ("lohka" N Pl Nom) ("lohka" N Sg Gen PxSg2) ("lohka" N Sg Acc PxSg2)("lohkat" V TV Der/h V TV Imprt Sg2) ("lohkat" V TV Der/h V TV Imprt ConNeg)("lohkat" V TV Der/h V TV Ind Prs ConNeg)("lohkat" V TV Der/d V Imprt Sg2)("lohkat" V TV Der/d V Imprt ConNeg)("lohkat" V TV Der/d V Ind Prs ConNeg)("lohkat" V TV Ind Prs Sg2)("logahit" V TV Imprt Sg2 Gram/3syll)("logahit" V TV Imprt ConNeg)("logahit" V TV Ind Prs ConNeg Gram/3syll)("logadit" V TV Imprt Sg2 Gram/3syll)("logadit" V TV Imprt ConNeg Gram/3syll)("logadit" V TV Ind Prs ConNeg Gram/3syll);

ADD:real-logĂĄt (&real-logĂĄt) TARGET LOGAT IF (*1 (Sg Nom) + Sem/Hum - A - Prop OR COUNTABLE - Prop OR N + Sem/Time BARRIER NPNHA - Gen - Acc OR Dem OR Prop)(NEGATE *-1 YOU + Nom BARRIER VFIN)(NEGATE -1 (Pcle Qst) LINK -1 Adv LINK -1 BOS) ;
	#$ Maid logat geasset?
    ## Logat luohkĂĄlaÄÄaid joavkojoÄiheaddji Biret Astrid Utsi muitala fas ahte okta njealljadat oassi logat luohkĂĄlaÄÄain leat oĆŸĆŸon guÄeĆŸa ieĆĄguÄetge njĂĄlmmĂĄlaĆĄ fĂĄgain, nugo servodatfĂĄgain, luonddu- ja birasfagain, eaĆgalasgielas ja matematihkas.
    ## SirpmĂĄ valĂĄĆĄtallansearvi bovde olbmuid sotnabeaivvi borgemĂĄnu logat beaivvi searvat goargĆut bajĂĄs RĂĄstegĂĄissĂĄ, mii lea 1066 mehtera bajĂĄbealde meara.
    ## DĂĄn girjjis mii leat vĂĄldan logat kapihtala, Skuvllat.
    #$ DĂĄ moadde gĂĄĆŸaldaga maid sĂĄhtĂĄĆĄit smiehtadit go logat ÄuovvovaĆĄ kapihtala.
    ## Skuvlenbeaivi dollojuvvo logat beaivve ÄakÄamĂĄnus.
    ## âą Leat gĂĄvcci oahpposaji, ovccĂĄt ja logat luohkĂĄ ohppiide ja skuvllas leat golbma oahpaheaddji.
	## GiellarĂĄÄÄi lea bidjĂĄn ĂĄigemearri logat beaivĂĄi skĂĄbmamĂĄnus.
	## Soai vĂĄzziba goappaĆĄagat logat luohkĂĄs KĂĄrĂĄĆĄjoga nuoraidskuvllas.
	## Logat luohkĂĄlaÄÄaid joavkojoÄiheaddji Biret Astrid Utsi muitala fas ahte okta njealljadat oassi logat luohkĂĄlaÄÄain leat oĆŸĆŸon guÄeĆŸa ieĆĄguÄetge njĂĄlmmĂĄlaĆĄ fĂĄgain, nugo servodatfĂĄgain, luonddu- ja birasfagain, eaĆgalasgielas ja matematihkas.
	## Michael Lindblad, SĂ„hkie Ubmi sĂĄmi searvvi joÄiheaddji, bovde Ubmi logat SĂĄmi vahkkui.

LIST MORE-COUNTABLE = "beaivi" "ceahkki" "geardi" ("geardde" Adv) "hĂĄvvi" "kapihtal" "klĂĄssa" "luohkkĂĄ" ("luohkkĂĄ" Der/lasj) "sadji" ;


ADD:real-logĂĄt (&real-logĂĄt) TARGET LOGAT IF (1 MORE-COUNTABLE)(NEGATE *-1 YOU + Nom BARRIER VFIN) ;
	## Ny GIV proĆĄeakta jagi 2010, das lei deaddu intensiivaoahpahus lohkamis, ÄĂĄllimis ja rehkenastimis ohppiide geain lea logat luohkĂĄs fĂĄgalaĆĄ dĂĄssi vuolemusas.
	## Nu movt lea leamaĆĄ juo ovcci jagi, lĂĄgiduvvo SGP dĂĄn nai jagi, ja leage logat hĂĄve go ÄaÄahuvvo.
	## Indigenus Youth gathering ( IYG ) lĂĄgiduvvo logat geardde dĂĄn jagĂĄĆĄ Riddu RiÄÄus, ja sii fĂĄllet stuorat ja viidĂĄt progrĂĄmma go goassege ovdal.
	## De lĂĄgiduvvo MĂĄrkomeannu logat geardde.
	## LĂĄvvordaga lei son nubbin buoremus NorgalaĆĄ, duĆĄĆĄe Petter Tande ĆĄattai buorebut su logat sajiin.
	## Oktiibuot leat 95% buot gĂĄvccĂĄt, ovccĂĄt ja logat luohkĂĄin FinnmĂĄrkku nuoraidskuvllain searvan FRI duhpĂĄteastadeaddji proĆĄektii.
	## SkĂĄbmamĂĄnu logat beaivvi ÄĂĄlihii FinnmĂĄrkku Opmodat ( FeFo ) sponsorĆĄiehtadusa FinnmĂĄrkku spĂĄbbaÄiekÄan- ja Äuoiganbiirriin, mas lea miljovdnasaĆĄ ĂĄrvu golmma jahkĂĄi ( 2010-2012 ).
	## Ja oÄÄaseamos oÄas ges sĂĄmegillii lea ÄĂĄllĂĄn Egil Olli mannan mĂĄnu logat beaivvi.
	#$ â MĂĄid logat, ahte ii ĆĄatta dĂĄn jagi SĂĄmi_Cupa, lea bat dat gal duohta ?
	## â Mii gal eat ĆĄat lusttiit borrat klementiinnaid ĆĄat, lohket Mihkkal Ănte Oskal, Mikkel Eirik Triumf ja Martin HĂŠtta, sii leat Guovdageainnu nuoraidskuvlla logat klĂĄssa oahppit.
	## MĂĄnĂĄidĂĄittardeaddji Reidar Hjermann sĂĄgastii ja bĂĄlkkaĆĄii KĂĄrĂĄĆĄjoga logat ceahki nuoraid gaskavahku SĂĄmedikkis.
	#$ â Min kurssaiguin lea ulbmil ahte nagodat Äuovvut sĂĄmedikki giella ĂĄigumuĆĄaid, ja nu leatge bivdĂĄn SĂĄmi_Allaskuvlla, Guovdageainnus, ovttasbargat minguin, muitala Nystad ĂĄĆgirit, ja lasiha ahte go sis {logat} sĂĄmegiela, de lea vejolaĆĄ LoatnakĂĄssa bokte ohcat sihke stipeandda ja loana.
	## Lars Heaika geavai maĆemuĆŸĆŸii, logat sadjĂĄi dĂĄn beaivve.
	## GolggotmĂĄnu logat beaivvi lea vejolaĆĄ Äatnat reanttu, dieÄiha Dine Penger neahttaaviisa.
	## Unna oassi stĂĄhta skuvlla oahppin ÄeavĆŸĂĄ logat luohkkĂĄ iskosa ja fidne School Leaving Certificata, man maĆĆĂĄ sĂĄhttet ohcat Universitehtaide.
	## SirpmĂĄ valĂĄĆĄtallansearvi bovde olbmuid sotnabeaivvi borgemĂĄnu logat beaivvi searvat goargĆut bajĂĄs RĂĄstegĂĄissĂĄ, mii lea 1066 mehtera bajĂĄbealde meara.


ADD:real-logĂĄt (&real-logĂĄt) TARGET LOGAT IF (-1 ("juohke"));
    ## Okta golbmasis lea bijahan oÄÄa rĂĄinnasboaldin muorraommana, ja juohke logat lea bijahan lieggapumppa.


COPY:real-logĂĄt ("logĂĄt" A Ord Attr SUGGEST) EXCEPT LOGAT TARGET (&real-logĂĄt) ;
