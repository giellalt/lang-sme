#DELETE this seems right
ADD:xsyn-ge_not_ja (&syn-ge_not_ja) TARGET ("ja") (1 (Neg)) (NEGATE *1 ConNeg BARRIER GRAMCHK-S-BOUNDARY)(NEGATE *1 ("goassege") OR ("goassige") OR ("ge") OR Foc/Neg-ge BARRIER GRAMCHK-S-BOUNDARY)(NEGATE *1 ("ge") BARRIER NPNHA - ("ii"))(NEGATE 1 ("goassege") OR ("ge") OR Foc/Neg-ge) ;

ADD:xsyn-ge_not_ja (&syn-ge_not_ja) TARGET Neg (-1 ("ja")) (NEGATE *1 ConNeg BARRIER GRAMCHK-S-BOUNDARY)(NEGATE *1 ("ge") BARRIER NPNHA - ("ii"))(NEGATE 1 ("goassege") OR ("ge") OR Foc/Neg-ge) ;


