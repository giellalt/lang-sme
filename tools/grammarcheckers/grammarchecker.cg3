# comma error: Dan vuoÄul maid ovdelis lean namuhan balan{,} ahte KÃĄrÃĄÅĄjoga nuoraidruovttus ii leat sihkkaris boahtteÃĄigi.
     ## Sii muitaledje maid doppe ledje gullan muhto Ãnde gal ii orron jÃĄhkkimin dasa.
     
ADD:xpunct-rihkku (&punct-rihkku) TARGET THEN-CS-ADV IF (*-1 BOS LINK 1 THAT-CS OR IF-CS OR ("jos") OR BECAUSE-WHEN OR ("vaikke") OR ("vaikko") OR ("ovdal go") OR ("maÅÅel go") OR ("dassÃĄ go") OR ("dan botta go") OR ("dalle go"))(NEGATE -1 COMMA OR BOS OR ("-") OR ("â") OR ("/") OR (":"))(NEGATE -1 CC OR CS LINK -1 BOS)(NEGATE *-1 ("ja") BARRIER NPNHA - Po)(NEGATE -1 BECAUSE-WHEN LINK -1 NOT-V LINK -1 COMMA)(NEGATE -1 ("ii" Qst) LINK -1 COMMA);
	#$ Go de dadjÃĄ ahte dÃĄt gapmu lea historjjÃĄlaÄÄat, kultuvrralaÄÄat ja sosiÃĄlalaÄÄat Äadnon, de adden ahte vÃĄsÃĄhusat justa leat Äoagganan rupmaÅĄii, ja daid vuoÄul {de} sÃĄhttit gamus dovdat ovdal go mÃĄhttit dan Äilget.
	#$ Go de ÄuÄit bohtet sudno vissui, ferteba soai ÄiehkÃĄdit.
	## Jos mii dalle eat livcĖcĖe vuolgÃĄn ruoktot de gal leimmet gÃĄrtat vuordit mÃĄÅga beaivvi.
	## Vaikke ledjege vÃĄiban de dat dattetge ain jotke.
	## Ovdal go mun bohten de vulggii ÃĄhÄÄi.
	
	# subclause first, main clause with subject first
	# - - - - - - - - - - - - - - - - - - - - - - - -
ADD:xpunct-rihkku (&punct-rihkku) TARGET V IF (0 VFIN)(NEGATE 0 <aux> LINK NOT *1 Inf OR PrfPrc)(NEGATE 0 (Inf SUGGEST) OR (PrfPrc SUGGEST) OR (Adv SUGGEST))(*-1 (Pron Pers Nom) OR (Pron Dem Nom) - @>N OR (N Nom) OR ("dat" Pcle) BARRIER Rel OR CS OR THEN-CS-ADV LINK NOT 0 Rel OR <firstCohortOfParagraph> LINK *-1 VFIN BARRIER CS OR Rel OR COMMA LINK  NOT 0 <vdic> LINK *-1 THAT-CS OR IF-CS OR ("jos") OR BECAUSE-WHEN OR ("vaikke") OR ("vaikko") OR ("ovdal go") OR ("maÅÅel go") OR ("dassÃĄ go") OR ("dan botta go") OR ("dalle go") BARRIER COMMA OR (":") OR (";") OR CS LINK -1 BOS)(NEGATE *-1 (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) LINK *-1 COMMA OR BOS BARRIER NPNHAPcle - THEN-CS-ADV)(NEGATE *-1 COMMA OR (";") OR (":") OR ("-") BARRIER (*) - THEN-CS-ADV - Pcle - CS - @SUBJ> - Adv - CC)(NEGATE *1 THEN-CS-ADV LINK -1 COMMA)(NEGATE -1 Adv LINK -1 CC);
	#$ Go dÃĄn digaÅĄtallama loktejit guovllulaÅĄ dÃĄssÃĄi de das lea buoret vuoÄÄu gÃĄvdnat vel eanet  buori ÃĄkkaid  ja buorebut {} sÃĄhttet oktiiÄatnat fierpmÃĄdagaid Norggas ja Suomas.
	#$ Vaikko nÃĄ buorit ovdamunit leat; eahpelihkostuvvat mii atnit vejolaÅĄvuoÄaideamet ja {} leat vuoittahallit ruovttuguovllus.
	#$ Jus livÄÄe ÄaÄahuvvon albma dutkamat, ja eai livÄÄe duÅĄÅĄe Äaskan oivviid eret vÃĄldoolbmuin, de sihkkarit ÄÃĄllojuvvon historja maÅÅil 1852 {livÄÄii} ÅĄaddan ÃĄibbas earÃĄ.
	#$ Jus leaÅĄ dieÄut govvii - {sÃĄhttibehtet} riÅget dahje fitnat min luhtte.
	#$	SÃĄmediggi atnÃĄ dÃĄrbun deattuhit dÃĄn ja muittuhit ahte seammÃĄs go boazodoalu guohtongeavaheapmi guhkÃĄ lea mearriduvvon lÃĄgas, de leat lÃĄgat ja hÃĄlddaÅĄeapmi uhccÃĄn beroÅĄtan ja gozihan earÃĄ sÃĄmi resursageavaheami.
    #$ Jus dat leat duoÄat sÃĄhttÃĄ dat mielddisbuktit eahpÃĄdusa ja balu nuorra sÃĄpmelaÄÄaid gaskkas {joatkit} / ÃĄlgit oahpu vÃĄldit HÃĄpmira joatkkaskuvllas.
    #$ Ahte earÃĄt eai ÅĄat galgga stivret vel dan ge maid {mii} jurddaÅĄit ieÅūamet oaivvisteamet.
    #$ Go geahÄÄÃĄ mo ovddeÅĄ ÃĄigge ÃĄrbevirolaÅĄ mÃĄhtut fievrriduvvojedje boazodoalus ja buohtastahttÃĄ dan otnÃĄ diliin, de sÃĄhttÃĄ buorebut addet mii odne gÃĄibiduvvo mÃĄhtuid seailluheapmÃĄi.
    #$ Jos dii livÄÄiidet adden maid dÃĄt sÃĄtni mearkkaÅĄa : VÃĄibmolÃĄÄisvuoÄa mun dÃĄhtun, in ge oaffara, de ehpet livÄÄe dubmen sivahemiid.
   #$ Go maÅÅÃĄ fas lean oaidnÃĄn dan seamma lÃĄttÃĄna, gurÅūo dahje turista, go son {leat} bivddus lihkostuvvan, de lea son aiddo loktaneamen ÃĄvvudeamis.
	#$ Vaikke vel KÃĄrÃĄÅĄjogas ja Guovdageainnus leat matematihkalaÄÄat menddo unnÃĄn ÃĄirasat, de dat {leat} liikkÃĄ ÃĄidna ovttaskas gielddat mat sÃĄddejit ieÅūaset ÃĄirasiid SÃĄmediggÃĄi, almmÃĄ gilvaleami haga earÃĄ gielddaiguin.	
	#$ Jos eadni dahje ÃĄhÄÄi lea ÃĄidna olmmoÅĄ {gii} hÃĄllÃĄ sÃĄmegiela mÃĄnnÃĄi, de ÅĄaddÃĄ lossat oahpahit giela.
	## MaÅÅil go ÃĄhÄÄi boÄii mun vulgen.
	## DassÃĄ go Niillas boahtÃĄ mun vuorddÃĄn.
	## Dalle go mii leimmet mu ÃĄhÄiin ovtta siiddas mun galgen ieÅĄ vuolgit merrii.

ADD:xpunct-rihkku (&punct-rihkku) TARGET V IF (0 VFIN)(NEGATE 0 <aux> LINK NOT *1 Inf OR PrfPrc)(*-1 (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) OR ("dat" Pcle) BARRIER Rel LINK NOT 0 Rel OR <firstCohortOfParagraph> LINK *-1 VFIN LINK *-1 ("rÃĄjes") LINK -1 ("dat" Pron Dem Sg Acc) OR ("dat" Pron Dem Sg Gen) LINK -1 BOS)(NEGATE *-1 (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) LINK *-1 COMMA OR BOS BARRIER NPNHAPcle - THEN-CS-ADV)(NEGATE *-1 COMMA OR (";") BARRIER (*) - THEN-CS-ADV - Pcle);
	## Dan rÃĄjes go nÃĄitaleigga dat juo leaba juo huksen dÃĄlu.
	
ADD:xpunct-rihkku (&punct-rihkku) TARGET V IF (0 VFIN LINK 0 NOT-V + Ind LINK *1 ConNeg BARRIER NOT-ADV-PCLE LINK *1 ONE + (Pron Indef Sg Nom Foc/Neg-ge) BARRIER GRAMCHK-S-BOUNDARY)(*-1 VFIN BARRIER <firstCohortOfParagraph> LINK *-1 THAT-CS OR IF-CS OR ("jos") OR BECAUSE-WHEN OR ("vaikke") OR ("vaikko") OR ("ovdal go") OR ("maÅÅel go") OR ("dassÃĄ go") OR ("dan botta go") OR ("dalle go") LINK -1 BOS)(NEGATE *-1 (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) LINK *-1 COMMA OR BOS BARRIER NPNHAPcle - THEN-CS-ADV)(NEGATE *-1 COMMA OR (";") BARRIER (*) - THEN-CS-ADV - Pcle);	
	## Ahte nu galggai geavvat dan ii lean gal oktage ÃĄrvidan.

	# subclause first, main clause without subject first
	# - - - - - - - - - - - - - - - - - - - - - - - - - -
ADD:xpunct-rihkku (&punct-rihkku) TARGET V IF (0 VFIN LINK NOT 0 Inf OR (Gram/3syll Ind Prs Pl3))(NEGATE 0 (PrfPrc SUGGEST) OR (Inf SUGGEST) OR (Adv SUGGEST))(*-1 VFIN BARRIER NOT-ADV-PCLE LINK *-1 THAT-CS OR IF-CS OR ("jos") OR BECAUSE-WHEN OR ("vaikke") OR ("vaikko") OR ("ovdal go") OR ("maÅÅel go") OR ("dassÃĄ go") OR ("dan botta go") OR ("dalle go") BARRIER (";") LINK -1 BOS)(NEGATE *-1 (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) LINK -1 COMMA OR BOS)(NEGATE -1 THEN-CS-ADV LINK -1 BECAUSE-WHEN LINK -1 NOT-V LINK -1 COMMA)(NEGATE -1 ("ii" Qst) LINK -1 THEN-CS-ADV LINK -1 COMMA)(NEGATE 0 &syn-double-negation)(NEGATE -1 (V Neg));
	#$ Vaikko luohti lea muhtun guovlluin ealli ÃĄrbevierru, muhtun sajiin dat fas lea ÃĄibbaÅĄ jÃĄvkan.
	#$ Go mÃĄnÃĄid ÃĄlo galgÃĄ Äalmmis doallat, amaset {eai} ÅĄatta biilla vuollai, vÃĄidala Gerd ja Biret-ÃĄhkku lea ovtta oaivilis.		
	## Dan botta go mÃĄnnÃĄ oaÄÄÃĄ ÃĄiggun gohpuid bassat.
    #$ Go geahÄÄat leavttu ja dan guÄe guvlui leat manname, ii go {de} livÄÄe kapteainnas buot eanemus jierpmÃĄlaÅĄ jurdda stivregoahtit nuppe guvlui ja dÃĄhttut buot olbmuid mannat gÃĄdjunfatnasiidda?
    #$ Go oahppit leat {adden} dahje ipmirdan ieÅĄ dan sisdoalu dÃĄhpÃĄhusas, sÃĄhttÃĄ oahpaheaddji jearrat ahte leat go sii ovttaoaivilis dÃĄinna sisdoaluin.

ADD:xpunct-rihkku (&punct-rihkku) TARGET ("daÄe") IF (*-1 BOS LINK 1 ("maÄe"))(NEGATE -1 COMMA OR BOS);
	## MaÄe losit siivu daÄe njoazebut mannÃĄ mÃĄtki.

ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE ("ja" CC) IF  (1 ("de" &punct-rihkku))(NEGATE 0 ADDED-BEFORE-BLANK);
	## Jus mii dal joatkit vuovdimiin, de ii njuolgga mÃĄrkan goassege ja de bÃĄllejit kilohatti njeaidit daÄi eanet jagis jahkÃĄi ja loahpas ÄohkkÃĄt mii 5 kr. kilohattiin, ballÃĄ Eira.
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE ("muhto" &punct-rihkku) OR ("de" &punct-rihkku) OR ("daÄe" &punct-rihkku) IF (NEGATE -1 CC LINK -1 (","))(NEGATE -1 ("<,>"))(NEGATE 0 ADDED-BEFORE-BLANK);
	#$ Jus mii dal joatkit vuovdimiin, de ii njuolgga mÃĄrkan goassege ja de bÃĄllejit kilohatti njeaidit daÄi eanet jagis jahkÃĄi ja loahpas ÄohkkÃĄt mii 5 kr. kilohattiin, ballÃĄ Eira.
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE (Pron Pers Nom) OR (Pron Dem Nom) OR (N Nom) OR ("dat" Pcle) IF (*1 VFIN + (V &punct-rihkku) BARRIER NOT-ADV-PCLE)(NEGATE -1 ("<,>"))(NEGATE 0 ADDED-BEFORE-BLANK) ;
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE VFIN IF (0 (V &punct-rihkku))(*-1 VFIN BARRIER NOT-ADV-PCLE)(NEGATE -1 ("<,>"))(NEGATE 0 ADDED-BEFORE-BLANK) ;

	# this one takes into account the position of the parent of a preceeding accusative
ADDCOHORT:punct-rihkku ("<,>" "," CLB ADDED-BEFORE-BLANK &punct-rihkku) BEFORE Acc IF (rp V) (1 (V &punct-rihkku))(NEGATE -1 ("<,>"))(NEGATE 0 ADDED-BEFORE-BLANK) ;


