ADD:lex-badjel-bokte (&lex-badjel-bokte) TARGET ("badjel") IF (*0 ("mأ،ksit") OR ("oaإ¾إ¾ut") OR ("sأ،ddet") BARRIER GRAMCHK-S-BOUNDARY)(-1 ("bأ،إ‹ku") OR ("telefuvdna") OR ("interneahtta") OR ("e-poasta") OR ("poasta") OR Sem/Obj-el) (NEGATE 1 Num OR Sem/Measr OR Sem/Curr);
 
COPY:lex-badjel-bokte ("bokte" Po SUGGEST) EXCEPT ("badjel" Pr &lex-badjel-bokte) OR ("badjel" Po &lex-badjel-bokte) TARGET (&lex-badjel-bokte) ; 
