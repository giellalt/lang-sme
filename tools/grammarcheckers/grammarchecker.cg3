	## Ărvalus 1 mearriduvvui ovttajienalaÄÄat ja ĂĄrvalus 2 gessojuvvui ja bidjui mearkkaĆĄupmin.

ADD:real-biddjui (&real-biddjui) TARGET ("bidju" N Sg Ill) OR ("biedju" N Sg Ill)(*1 Ill OR DE-ILL-ADV OR DE-ILL-ADP BARRIER GRAMCHK-S-BOUNDARY OR THEN-CS-ADV LINK NEGATE -1 (N Sem/Time Sg Acc) OR (N Sem/Time Sg Gen))(NEGATE -1 (Pron Pers) + Gen)(NEGATE *-1 Sem/Ani BARRIER NPNH)(NEGATE -1 <TH-Acc-Any><DE-Ill-Any> OR <TH-Acc-Any><SO-Loc-Any><DE-Ill-Any> OR <DE-Ill-Plc> OR <DE-Ill-Any> OR <SO-Loc-*Ani><DE-Ill-*Ani>)(NEGATE *-1 (Num Sg Gen) OR (Num Sg Ill Attr) BARRIER NPNH);
	## Davvenuortta oassi orohat 12:s, Borsejogas davvin gitta DĂĄrjohkii mĂĄddin biddjo orohat 9:i ( mĂĄttaoasseguovlu Oarje-Deanus ) mii lea ovddeĆĄ BuolbmĂĄga boazosuohkanis, ja mĂĄttaoarjeoassi DĂĄrjogas davvin gitta VĂĄljohkii // ĂstevĂĄrrĂĄi mĂĄddin bidjui orohat 17:i.
	## Harstad BB sĂĄtnejoÄiheaddji, Marianne Bremnes gal oaivvilda ahte Ingebrigtsen bidjui dĂĄn dillĂĄi Vibeke Ek bealis go son joÄiha nissoniid ĂĄĆĄĆĄiid Romssa bargiidbellodagas, ja son livÄÄii galgan earĂĄ ĂĄrvvoĆĄtallama dahkat dĂĄs.
	## StuoradiggedieÄĂĄhusas, mii almmuhuvvui 1992:s, nammaduvvui teĂĄhter naĆĄunĂĄlateĂĄhteriin, muhto 2002:s bidjui teĂĄhter SĂĄmedikki vuollĂĄi.
	#$ FjellstrĂ¶m muitala ahte dat goarjada almmĂĄ mangelĂĄgĂĄĆĄ biepmu haga dan ĂĄiggi rĂĄjes ÄakÄat mĂĄnu gaskamuttus golggot go mannĂĄ bidjui gitta Tiburtiusa beaivvi rĂĄdjĂĄi Stil.
	#$ LuonddugĂĄhttendoaimmahat lea addan lobi suodjalusbivdui golmma bidjui ja njeallje sierranas getkkiide danin go moadde Äearu ĆĄadde giÄÄadĂĄlvvi 2008 gillĂĄt garrasit geatkki ja albasiid geaĆŸilâŠ
	## OÄastus 97 bidjui dat oassin oba riikka vuoÄÄaskuvlaoahpahussii.

ADD:real-biddjui (&real-biddjui) TARGET ("bidju" N Sg Ill) OR ("biedju" N Sg Ill)(1 Adv LINK 1 Ill OR DE-ILL-ADV OR DE-ILL-ADP LINK NEGATE -1 (N Sem/Time Sg Acc) OR (N Sem/Time Sg Gen))(NEGATE -1 (Pron Pers) + Gen)(NEGATE *-1 Sem/Ani BARRIER NPNH)(NEGATE -1 <TH-Acc-Any><DE-Ill-Any> OR <TH-Acc-Any><SO-Loc-Any><DE-Ill-Any> OR <DE-Ill-Plc> OR <DE-Ill-Any> OR <SO-Loc-*Ani><DE-Ill-*Ani>)(NEGATE *-1 (Num Sg Gen) OR (Num Sg Ill Attr) BARRIER NPNH);
    ## BĂĄrdni bidjui de olggos.

ADD:real-biddjui (&real-biddjui) TARGET ("bidju" N Sg Ill) OR ("biedju" N Sg Ill)(*-1 Ill BARRIER GRAMCHK-S-BOUNDARY OR THEN-CS-ADV)(NEGATE -1 (Pron Pers) + Gen)(NEGATE *-1 Sem/Ani BARRIER NPNH)(NEGATE *0 THEME-DESTINATION-V BARRIER GRAMCHK-S-BOUNDARY OR THEN-CS-ADV OR COMMA OR CC OR V)(NEGATE *-1 (Num Sg Gen) OR (Num Sg Ill Attr) BARRIER NPNH);
	## StuoradiggedieÄĂĄhusas Samedikke doaimma birra, mii StĂĄhtarĂĄÄÄĂĄi bidjui mannan bearjadaga, boÄii ovdan ahte Stuoradiggi hĂĄlida eambbo vĂĄlddi addit SĂĄmediggĂĄi.
	#$ Muhto rieban lĂĄve Äoaggit stuorĂĄt nĂĄvddiid bĂĄzahusaid ja doalvut daid bidjui.
	#$ LuonddugĂĄhttendoaimmahat lea addan lobi suodjalusbivdui golmma bidjui ja njeallje sierranas getkkiide danin go moadde Äearu ĆĄadde giÄÄadĂĄlvvi 2008 gillĂĄt garrasit geatkki ja albasiid geaĆŸilâŠ


#LIST BIDDJUI-ADV =

ADD:real-biddjui (&real-biddjui) TARGET ("bidju" N Sg Ill) OR ("biedju" N Sg Ill)(*0 ("johtu" Sg Ill) OR Ill + Sem/Rule OR Ill + Sem/Org OR ("eret") OR ("ovdii") OR ("oktii") OR ("ovdan") OR ("vuostĂĄlaga") BARRIER GRAMCHK-S-BOUNDARY OR CC)(NEGATE *-1 Sem/Ani BARRIER NPNH);
    #$ De beaivvĂĄĆĄ badjĂĄna, dat geassĂĄdit eret ja veallĂĄnit bidjui.
   ## 1999:s bidjui nu gohÄoduvvon Nyborg-lĂĄvdegoddi johtui man ulbmil lei guorahallat doaimmaid mat sĂĄhttet hehttet gĂĄvppaĆĄandeattu mĂĄnĂĄid ja nuoraid ektui.
	## FlĂžtten bidjui eret
	## 1992:i ÄavÄÄa ja bidjui heaittihanortnegii, mii ii galgga goassege leamaĆĄ su ulbmil.
ADD:biddjui (&real-biddjui) TARGET ("bidju" N Sg Ill) OR ("biedju" N Sg Ill)(1 ("ovdan") OR ("oktan") OR ("vuostĂĄlaga") OR (N Sem/Hum Ess) OR (N Sem/Pos Ess) OR ("virgĂĄi") OR ("virgi" N Sg Ill) OR Sem/Rule + Ill)(NEGATE *-1 Sem/Ani - Com BARRIER NPNH);
	## RĂĄÄÄehusdoaimmahuvvon mearrĂĄdus bellodagas dagahii ahte muhtin Megawatis vuostĂĄlasti bidjui bellodatjoÄiheaddjin.
    ## MearrĂĄdus : Evttohus boahtĂĄn Nils Ole Turis bidjui vuostĂĄlaga evttohusain boahtĂĄn Ellen Inga K. HĂŠttas.
    ## ÄoahkkinjoÄihangotti ĂĄrvalus bidjui vuostĂĄlĂĄga Bargiidbellodaga eavttuhusain, mii guoskĂĄ Â§ 24, nuppi oassĂĄi.
    ## JahkeÄoahkkima ovdii bidjui ge evttohus ahte FinnmĂĄrkku fylkkasuohkana otnĂĄĆĄ sĂĄmegielat namma ii leat rievttes namma, ja dan dihte galgĂĄ rievdaduvvot SĂĄmieanan fylkan, go dat otnĂĄĆĄ namma ii mĂĄvsse ii maidege sĂĄmegillii.
    ## OahpahusdieÄĂĄhusas mii bidjui ovdĂĄn SĂĄmedikkis dĂĄn ÄavÄÄa lea vuÄolaÄÄat Äilgejuvvon sĂĄmi skuvllaid dili birra.

    # biddjui with time
ADD:real-biddjui (&real-biddjui) TARGET ("bidju" N Sg Ill) OR ("biedju" N Sg Ill)(1 Sem/Time + Gen)(NEGATE *-1 Sem/Ani - Com BARRIER NPNH)(NEGATE -1 <TH-Acc-Any><DE-Ill-Any> OR <TH-Acc-Any><SO-Loc-Any><DE-Ill-Any> OR <DE-Ill-Plc> OR <DE-Ill-Any> OR <SO-Loc-*Ani><DE-Ill-*Ani>);
    ## NuortasĂĄmi musea // Ăstsamisk museum // NuĂ”rttsaa ÂŽmi mu ÂŽzei vuoÄÄogeaÄgi bidjui borgemĂĄnu 22. beaivvi NjĂĄvdĂĄmis.

    # biddjui with goal
ADD:real-biddjui (&real-biddjui) TARGET ("bidju" N Sg Ill) OR ("biedju" N Sg Ill)(*1 Sem/Plc + Ill)(NEGATE *-1 Sem/Ani - Com BARRIER NPNH)(NEGATE -1 <TH-Acc-Any><DE-Ill-Any> OR <TH-Acc-Any><SO-Loc-Any><DE-Ill-Any> OR <DE-Ill-Plc> OR <DE-Ill-Any> OR <SO-Loc-*Ani><DE-Ill-*Ani>);
    ## Go suohkanrĂĄdji oÄÄasit ĂĄiggi bidjui UnjĂĄrgga (Nesseby) ja ÄĂĄhcesullo gaskal, de bidjui ge dat juste dakko (Niemi 1983 : 190).

COPY:real-biddjui ("bidjat" Ex/V Ex/TV Der/PassS V IV Ind Prt Sg3 SUGGEST) EXCEPT ("bidju" N Sg Ill &real-biddjui) OR ("biedju" N Sg Ill &real-biddjui) TARGET (&real-biddjui) ;
	## FinnmĂĄrkulĂĄhka ĂĄrvalus bidjui ovdan mannan giÄa ja lea boktĂĄn stuorra digaĆĄtallama sisriikalaÄÄat ja maiddĂĄi riikaidgaskasaÄÄat, ÄĂĄllĂĄ sĂĄmeradio preassadieÄĂĄhusas.
	#$ NordlĂĄnddas bĂĄĆŸii mĂĄnnodaga stĂĄhta luonddu bearraigeahÄÄu ( SNO ) guokte geatkki Äivgga bidjui, muhto ciikku ribahedje mannat bĂĄhtui.


	# bidjui not biddjui
	# ------------------

ADD:real-bidjui (&real-bidjui) TARGET ("bidjat" Ex/V Ex/TV Der/PassS V IV Ind Prt Sg3) - Err/Orth (NEGATE *1 ("johtu" Sg Ill) OR ("johtit" Der/PassS Ind Prt Sg3) OR ("eret") BARRIER GRAMCHK-S-BOUNDARY)(*0 Ind - Err/Any OR PrfPrc - @>N - Err/Any OR Inf - Err/Any OR Imprt - Err/Any BARRIER NOT-ADVL-PCLE - Adv - OBJ - (N Sem/Ani Nom) - @>P - Po - (Pron Sem/Hum Pers Gen) OR THEN-CS-ADV LINK 0 <TH-Acc-Any><DE-Ill-Any> OR <TH-Acc-Any><SO-Loc-Any><DE-Ill-Any> OR <DE-Ill-Plc> OR <DE-Ill-*Ani> OR <DE-Ill-Any>)(NEGATE *1 Inf OR (Ind Prs Pl1) BARRIER NOT-ADV-PCLE - @ADVL);
	#$ Galle geardde biddjui oÄÄa mĂĄilmmiolahus dievdduid 5000 m luistemis Olympia DĂĄlvegilvvuin 1998:s?
	## â Na vuolgu min biddjui de oaÄÄut skeaĆkka.
	## Vaikko lei vehĂĄ issoras, de fertiimet aĆkke boagustit go ĂĄhkku orui nu komiska go nahkĂĄriid siste ii ipmirdan maide ja doaivvui roahtuid biddjui boahtĂĄn.
	#$ Dat dagahedje ahte earit galge juhkkojuvvot nuvttĂĄ guolĂĄsteddjiide, muhto jus galggai sĂĄhttit oaĆŸĆŸut eari de biddjui mearri man olu dorski fertii unnimusat bivdĂĄn ovtta jagis, jagiin 1987:s 1989 rĂĄdjĂĄi.
	#$ JiellevĂĄri 23-jahkĂĄsaĆĄ bĂĄrdni gii mannan vahkkoloahpa biddjui rĂĄjusgiddagassii go navdojuvvui ahte son lea jĂĄmas cĂĄbmĂĄn moarsis lea dĂĄl luitojuvvon friddja, eaige politiijat navdde ĆĄat su dahkat makkĂĄrge vearredagu.
	#$ DalĂĄ maĆĆil soaÄi, de biddjui Eanadoallodepartemeanttas joÄihit duodjĂĄi gullevaĆĄ ĂĄĆĄĆĄiid.
	#$ Oahppi biddjui Äuoigat okto 10 kilomehtera amas meahcis bearrĂĄigeahÄu haga


ADD:real-bidjui (&real-bidjui) TARGET ("bidjat" Ex/V Ex/TV Der/PassS V IV Ind Prt Sg3)(NEGATE *1 ("johtu" Sg Ill) OR ("johtit" Der/PassS Ind Prt Sg3) OR ("eret") BARRIER GRAMCHK-S-BOUNDARY)(*1 BE + Ind BARRIER NOT-ADV-PCLE LINK *1 Inf OR PrfPrc BARRIER NOT-ADVL-PCLE - Adv - OBJ - (N Sem/Ani Nom) - @>P - Po - (Pron Sem/Hum Pers Gen) OR THEN-CS-ADV LINK 0 <TH-Acc-Any><DE-Ill-Any> OR <TH-Acc-Any><SO-Loc-Any><DE-Ill-Any> OR <DE-Ill-Plc> OR <DE-Ill-*Ani> OR <DE-Ill-Any>)(NEGATE *1 Inf OR (Ind Prs Pl1) BARRIER NOT-ADV-PCLE - @ADVL);
	## - Na it got don oainne, munno biddjui lea golgan dievva giÄÄadulveÄĂĄhci, civkkĂĄdii eadnegoddesĂĄhpĂĄn ja njuikestalai vulosbajĂĄs.

ADD:real-bidjui (&real-bidjui) TARGET ("bidjat" Ex/V Ex/TV Der/PassS V IV Ind Prt Sg3) - Err/Orth (NEGATE *1 ("johtu" Sg Ill) OR ("johtit" Der/PassS Ind Prt Sg3) OR ("eret") BARRIER GRAMCHK-S-BOUNDARY)(-1 Sem/Ani + Gen OR Sem/Ani + Acc)(NEGATE *1 Inf OR (Ind Prs Pl1) BARRIER NOT-ADV-PCLE - @ADVL);
	##

ADD:real-bidjui (&real-bidjui) TARGET ("bidjat" Ex/V Ex/TV Der/PassS V IV Ind Prt Sg3)( *-1 (Num Sg Gen) BARRIER NPNH);
	## LuonddugĂĄhttendoaimmahat lea addan lobi suodjalusbivdui golmma biddjui ja njeallje sierranas getkkiide danin go moadde Äearu ĆĄadde giÄÄadĂĄlvvi 2008 gillĂĄt garrasit geatkki ja albasiid geaĆŸil.

ADD:real-bidjui (&real-bidjui) TARGET ("bidjat" Ex/V Ex/TV Der/PassS V IV Ind Prt Sg3)(*0 THEME-DESTINATION-V OR ("Äivgat") OR ("geahÄÄat") OR ("geahÄastit") OR ("geahÄestit")  BARRIER NPNHA);
    ## Ferten maid boradit albma dievva Äoavjji ovdal go manan biddjui nohkat dajai son.
    ## Lean gullan dĂĄppe galget ollu guovĆŸĆŸat, muhto eat leat oaidnĂĄn ovttage, in sĂĄva ge oaidnit, lohkĂĄ son ja jĂĄhkkĂĄ guovĆŸĆŸaid dĂĄl mannan biddjui.
	## Lagamus biddjui olle Ăigin.

ADD:real-bidjui (&real-bidjui) TARGET ("bidjat" Ex/V Ex/TV Der/PassS V IV Ind Prt Sg3)( -1 (Pron Pers Gen) OR (Pron Pers Acc));
	## - Na it got don oainne, munno biddjui lea golgan dievva giÄÄadulveÄĂĄhci, civkkĂĄdii eadnegoddesĂĄhpĂĄn ja njuikestalai vulosbajĂĄs.
    ## - DĂĄl ii leat ĆĄat guhkki din biddjui, gullui vilgessĂĄhpan gii ovddemusas lei dieÄiheame.
    ## - Mun lean aiddo Äorgen bieju vai lea rĂĄinnas dassĂĄ go Äivggan, ja dal deavdĂĄ dat dulvi fas ruskkaid munno biddjui cihraidii son.


COPY:real-bidjui ("bidju" N Sg Ill SUGGEST) EXCEPT ("bidjat" Ex/V Ex/TV Der/PassS V IV Ind Prt Sg3 &real-bidjui) TARGET (&real-bidjui) ;



	# buorranaddat + Ill kjĂŠrtegne vs. buorrĂĄnaddat bli bedre
