	## Dutkit leat dĂĄl duoÄaĆĄtan dan maid olusat leat ballan; Ii duĆĄĆĄe goÄa biebmodorski biebmodorskerusttega siskkobealde, muhto dan dorskemeaÄÄemat besset leavvat viiddis stuorra guovlluide.
	## Diet dat lei dat geavvan maid balai.
SETCHILD (V <TH-Acc-Impers>) TO (*-1 @<SUBJ OR @SUBJ> BARRIER NPNHA - <aux> - <TH-Inf> - ? LINK *-1 CC BARRIER NPNHA LINK -1 @<SUBJ OR @SUBJ> LINK *-1 Loc + Rel BARRIER NPNHA - ? ) ;
	## â Dat maid mii ballat eanemusat lea ahte Nussir ASA bidjĂĄ merrii bĂĄzahusdeponiija, ja guolit dan geaĆŸil jĂĄvket mearas, lohkĂĄ son.

SETCHILD (V <TH-Acc-Impers>) (NONE s Â§TH)(NEGATE 1 @>N) TO (1 (Pron Dem Sg Acc) - @>N) ;
SETCHILD (V <TH-Acc-Impers>) (NONE s Â§TH)(NEGATE 2 @>N) TO (1 @>N OR Adv OR Pcle LINK 1 (Pron Dem Sg Acc) - @>N) ;
SETCHILD (V <TH-Acc-Impers>) (NONE s Â§TH)(NEGATE 2 @>N) TO (1 @>N OR Adv OR Pcle LINK 1 @>N OR Adv OR Pcle LINK 1 (Pron Dem Sg Acc) - @>N) ;

SETCHILD (V <TH-ovddas-Any>) (NONE s Â§TH) TO (*1 ("ovddas") BARRIER NPNHA) ;
	##
SETCHILD (V <TH-ovddas-Any>) (NONE s Â§TH) TO (*-1 ("ovddas") BARRIER NPNHA - (?) - <aux>) ;
	## Go de duoÄaĆĄtuvvo ahte oalle stuorra oasi ovddas eai sĂĄhte gielddanjunnoĆŸat vĂĄstidit, de dat dieÄus ge lea moaittehahtti, muhto dat ballamis ii earrĂĄn nu sakka daid earĂĄ gielddaid ja suohkaniid dili dĂĄfus.

#SETCHILD (V <TH-ovddas-Any>) (NONE s Â§TH) TO (*-1 *1 ("ovddas") BARRIER NPNHA) ;
	##

SETCHILD (V <TH-haga-Any>) (NONE s Â§TH) TO (*1 Gen OR Acc BARRIER NPNHA LINK 1 ("haga")) ;
SETCHILD (V <TH-haga-Any>) (NONE s Â§TH) TO (*-1  ("haga") BARRIER NOT-ADV-PCLE) ;
	##  birget su haga

SETCHILD (V <CO-Com-Ani>) TO (*1 Com + Sem/Animate BARRIER NPNHA) ;
	## Son liiko ovttastallat earĂĄiguin ja deaivvada ja oahpĂĄsnuvvĂĄ ĂĄlkit olbmuiguin.
SETCHILD (V <CO-Com-Ani>) TO (rc Â§TH LINK *1 Com + Sem/Animate BARRIER NPNHA)(NONE c Â§CO) ;
	## Olbmuide lea dĂĄrbu beassat njuolgga sĂĄgastallat dilĂĄlaĆĄvuoÄa birra njunuĆĄ politihkĂĄriiguin, vĂĄstida Berit Ranveig Nilssen.
SETCHILD (V <CO-Com-Ani>) TO (*-1 Com + Sem/Animate BARRIER NPNHA) ;
SETCHILD (V <CO-Com-Ani>) TO (*-1 Com + Sem/Hum BARRIER NPNHA) ;
	##
SETCHILD (V <CO-Com-Ani>) TO (lc Â§TH LINK *-1 Com + Sem/Animate BARRIER NPNHA) ;

SETCHILD (V <XT-Com-Measure>) TO (*1 (Sg Com) + Sem/Measr OR (Sg Com)  + Sem/Part OR (Pl Loc) + Sem/Measr OR (Pl Loc)  + Sem/Part BARRIER NOT-NUM) ;
	## NorgalaÄÄat liikojit pestoi, maĆemus jagiid lea pesto johtu loktanan 29 proseanttain Norggas.

SETCHILD (V <XT-Acc-Time>) TO (*1 (Sg Gen) + Sem/Measr LINK p (Num Acc)) ;
	## DĂĄt mĂĄtki heive measta buohkaide ja lea rehkenaston ĂĄdjĂĄnit sullii golbma {diimmu} bottoĆŸiiguin

SETCHILD (V <PU-AktioEss>) TO (1 (Actio Ess)) ;
	## fitnat...
SETCHILD (V <PU-Inf>) TO (1 Inf) ;

SETCHILD (V <PU-Ill-*Ani>) TO (1 (N Ill) OR (Pron Ill) - Sem/Animate) ;
	## Ulbmil lea movttiidahttit lohkamii ja oaĆŸĆŸut eambbosiid liikot girjiide.

SETCHILD (V <RF-Ill-Any>)(NONE c WORD) TO (1 Ill) ;
	## Dan geaĆŸil mĂĄĆggas eai beroĆĄtan searvat mĂĄrkaniidda.

SETCHILD (V <RF-Ill-Any>)(NONE c WORD) TO (1 Adv LINK 1 Ill) ;
	## DĂĄt mĂĄtki heive measta {buohkaide} ja lea rehkenaston ĂĄdjĂĄnit sullii golbma diimmu bottoĆŸiiguin go vĂĄzzet olles bĂĄlgĂĄ mii lea 10,8 km, muhto lea vejolaĆĄ maid jorggihit ÄohkkĂĄs ruovttoluotta jus hĂĄlidat oanehit mĂĄtkki.

	# some noun rules??

SETPARENT Com TO (0* (N <CO-Com-Hum>) OR (N <CO-Com-Ani>)) ;
	## - liiko ovttasbargat ieĆĄguÄetlĂĄgĂĄn olbmuiguin CHECK
	## DĂĄt lea dehĂĄlaĆĄ ĂĄĆĄĆĄi ja mun sakka liikon go mus lea nu buorre gulahallan komisearain Damanaki:n ja EurohpĂĄ parlameantta guolĂĄstuskomitĂ©ain, dadjĂĄ Berg-Hansen.

SETPARENT Com + Sem/Veh TO (-1 (N <IN-Com-Veh>)) ;
	## â Oljorevrrat maid ruoĆĄĆĄat plĂĄnejit Oarje-Sibiras MurmĂĄnskii sĂĄhttet lasihit vĂĄralaĆĄ oljofievrrideami dĂĄmppaiguin olggobeale Norgga rittu, ballĂĄ Norgga LuonddugĂĄhttensearvi.

SETPARENT Loc TO (-1 (N <TH-Loc-Any>)) ;
	##

SETPARENT Com (NEGATE 0 @>N LINK *1 Com BARRIER NPNH) TO (*-1 (N <TH-Com-Any>) OR (A <TH-Com-Any>) BARRIER NPNHA) ;

	# PV
	# --

SETPARENT Loc TO (-1 (N <PV-Loc-Any>));
	## SĂĄhtĂĄn namuhit ahte sĂĄhtaĆĄii oasi ĂĄlgoĂĄlbmotfilmmain ÄĂĄjehit, mat leat ÄĂĄjehuvvon maĆimuĆĄ 9 jagi.


	# "map" PARTITIVE
	# ---------------
#SUBSTITUTE N (Â§PART N) TARGET (N Loc) IF (-1 OASSI OR HEADOFPARTS LINK -1 Num) ;
	#$ NorgalaÄÄat liikojit pestoi, maĆemus jagiid lea pesto johtu loktanan 29 proseanttain Norggas.
SUBSTITUTE N (Â§PART N) TARGET (N Loc) IF (-1 (A Ord) OR (Num Sg Loc Attr) LINK *-1 (Num Sg)  BARRIER NPNH - Num)(NEGATE 0 Â§PART) ;
	## Jearahallamis ÄĂĄjehuvvo ahte okta juohke njealjĂĄt olbmos ballĂĄ roasmmehuvvat rakeahtaid geaĆŸil. --- make a rule for juohke njealjĂĄt olbmos...
SUBSTITUTE Pron (Â§PART Pron) TARGET (Pron Sem/Hum Loc) IF (-1 (A Ord) OR (Num Sg Loc Attr) LINK *-1 (Num Sg)  BARRIER NPNH - Num)(NEGATE 0 Â§PART) ;
	## okta mĂĄĆgga boazodolliin

SUBSTITUTE N (Â§PART N) TARGET (N Loc) IF (-1 @>N LINK *-1 (N Coll Sg) BARRIER NPNH - Num)(NEGATE0 Â§PART);
	## Norggas liikojit ovccis logi olbmos bohccobierggu ja fas gĂĄvccis logi olbmos dadjet bohccobiergu lea dearvvaĆĄlaĆĄ borramuĆĄ, ÄĂĄjeha varas oaiviliskkus maid Synovate lea dahkan.

SUBSTITUTE N (Â§PART N) TARGET (N Loc) IF (0 Sem/Org LINK *-1 ("muhtin") BARRIER NPNH - (?))(NEGATE 0 Â§PART) ;
	#Needs testing
SUBSTITUTE Pron (Â§PART Pron) TARGET (Pron Sem/Hum Loc) IF (*-1 ("muhtin") OR (Num Sg Nom) BARRIER NPNH - (?))(NEGATE 0 Â§PART) ;

SUBSTITUTE N (Â§PART N) TARGET (N Loc) IF (p <PV-Loc-Any>)(NEGATE 0 Â§PART) ;


	# more global rules (apply after the local rules)
	# -----------------------------------------------


SETPARENT Acc (NEGATE p V)(-1 BOS LINK *0 ("?" CLB))(NEGATE 0 @-FSUBJ>) TO (0* <TH-Acc-Any> OR <IN-Acc-Any> LINK NEGATE c Acc) ;
	## âą Maid don liikot bargat friddjabottuin?
	## â Äuojahin vuosttas geardde dĂĄn lĂĄvlaga VĂĄrjjat-festivĂĄlas mannan vahkkoloahpa ja ollosat liikojedje ĆĄuoĆa ja muitalusa, lohkĂĄ Boine. <IN-Acc-Any>

SETPARENT Acc (NEGATE p V)(-1 BOS LINK *0 ("?" CLB))(NEGATE 0 @-FSUBJ>) TO (0 Sem/Animate)(0* <CO-Acc-Ani> LINK NEGATE c Acc OR Inf) ;

SETPARENT Acc (NEGATE p V)(NEGATE 0 @-FSUBJ>)(NEGATE 0 @>N)(NEGATE -1 Acc LINK NOT 0 @>N OR @>A)(NEGATE -1 VFIN LINK *1 COMMA LINK 1 VERBAL-ACTIVITY-V + VFIN)(NEGATE 0 <vdic> LINK -1 COMMA LINK *-1 VFIN)(NEGATE 0 Rel LINK -1 COMMA)(NEGATE 0 Â§TIME-ADJUNCT)(NEGATE 0* <TH-Acc-Any> OR <IN-Acc-Any> OR <PR-Acc-Any> BARRIER <mv> OR @CVP LINK 0 <vdic> LINK -1 COMMA LINK *-1 VFIN LINK 0 <mv>)(NEGATE 0* <TH-Acc-Any> OR <IN-Acc-Any> OR <PR-Acc-Any> BARRIER <mv> OR @CVP OR Â§TH LINK c N OR V OR Po OR Adv) TO (0* <TH-Acc-Any> OR <IN-Acc-Any> OR <PR-Acc-Any> BARRIER <mv> OR @CVP OR COMMA OR Inf OR Rel OR THEN-CS-ADV OR Â§TH); # LINK NEGATE c Acc) ;
	#$ Jus mii nannet mĂĄhttu  ja {diÄolaĆĄvuoÄa} dĂĄid birra dutkamuĆĄaid bokte, de lea ĂĄlgoĂĄlbmogiidda ĂĄlkit ĂĄkkastallat ĂĄigumuĆĄaid ja politihka, muitala Retter.
	#$ â Lea hĂĄstalus ja ĆĄaddĂĄ somĂĄ oahppat daid birra {maid} mun beroĆĄtan.
	#$ DĂĄt ÄĂĄjeha ahte FSG ii luohte min {sĂĄpmelaÄÄaid} ieĆŸamet sĂĄhttit ĂĄĆĄĆĄiideamet demokrĂĄhtalaĆĄ vuogi mielde bargat, lohkĂĄ KSG Eilif Norvang, ja muitala ge juste diekkĂĄr stivremis ballan go cagge SG searvamis mannan sĂĄmedikki vĂĄlgii.
	#$ â Liikon hirbmadit 1920- logu, ja lean lohkan girjii ja filmma The Great Gatsby, danin ĆĄattai Gatsby, muitala Ann.
	#$ â KarĂĄte lea dakkĂĄr valĂĄĆĄtallan masa liiko dahje ii liiko {dan}, dadjĂĄ Joks.
	## â Äuojahin vuosttas geardde dĂĄn lĂĄvlaga VĂĄrjjat-festivĂĄlas mannan vahkkoloahpa ja ollosat liikojedje ĆĄuoĆa ja muitalusa, lohkĂĄ Boine.
	## âą Maid don liikot bargat friddjabottuin ?
	# maybe this rule should actually be in the beginning?
	#$ Oahpahus galgĂĄ veahkehit ohppiid liikot leat luonddus ja addit sidjiide vejolaĆĄvuoÄa ovdĂĄnahttit fantasiija, hĂĄbmengĂĄlgga ja beroĆĄtumi diÄoĆĄtit birrasa.
	#$ GuolĂĄstusbearrĂĄigeahÄÄi dovddahii ahte son balai hui olu dan oÄÄa bivddu vĂĄikkuhusain.
	#$ Lea vejolaĆĄvuohta dalĂĄn go njuovvĂĄ bohcco, smĂĄvvet ruovjji dakkĂĄr bihtĂĄide ahte joÄĂĄnit mĂĄizet ja duĆĄĆĄo ĆĄnjirahahttit bĂĄistos ja dasa vel lasiheastet juogalĂĄgan rutta {mĂĄid} liiko.
	#$ Äuojahin vuosttas geardde dĂĄn lĂĄvlaga VĂĄrjjat-festivĂĄlas mannan vahkkoloahpa ja ollosat liikojedje {ĆĄuoĆa} ja muitalusa, lohkĂĄ Boine.

SETPARENT Acc (NEGATE p V)(NEGATE 0 @-FSUBJ>)(NEGATE -1 Acc LINK NOT 0 @>N OR @>A)(NEGATE -1 VFIN LINK *1 COMMA LINK 1 VERBAL-ACTIVITY-V + VFIN) TO (0 Sem/Animate)(0* <CO-Acc-Ani> BARRIER <mv> OR @CVP)(NEGATE 0 <vdic> LINK -1 COMMA LINK *-1 VFIN);
	## ĂĆĄĆĄu deaivvai MĂĄrjĂĄ Sofe GĂĄrtnetluohkĂĄ mĂĄnaidgĂĄrddis, ja son muitala ahte son liiko spĂĄppa ÄiekÄat ja ĆĄukkulade borrat.

SETPARENT Com - Sem/Hum - Sem/Ani (NEGATE p V) TO (*0 <TH-Com-*Ani> - Der/Pass BARRIER <mv> OR CS) ;
	#$ SĂĄmediggi galgĂĄ konsulteret eanadoallodepartemeanttain ovdal soahpamuĆĄat boazodoalloĆĄiehtadusa oktavuoÄas {ĂĄlggahuvvojit}.
    ## Guorahallojuvvon leat ĂĄrgabeaidĂĄhpĂĄ-husat, {maiguin} sii liikojit buÄaldit, mo sin ieĆŸaset mielas lea sin dilli, ja mo sii vĂĄsihit almmolaĆĄ bĂĄlvalusaddima.
    #$ â Dat ii dĂĄrbbaĆĄuvvo nu olu suohkana bealis, mii ÄĂĄjeha ahte suohkan beroĆĄta ieĆŸas nuoraiguin ja hĂĄlida sin ruoktot boahtit bargat, loahpaha Barbro Lill HĂŠtta.

SETPARENT ("ovttas")  TO (*0 Com LINK 0* <ovttas><CO-Com-Ani>)  ;


	# "map" AGENT role
	# ----------------
SET NUMBER = Sg1 OR Du1 OR Pl1 OR Sg2 OR Du2 OR Pl2 OR Sg3 OR Du3 OR Pl3;

SUBSTITUTE N (Â§AG N) TARGET N IF (0 Nom + Pl) (*0 (V <AG-Nom-Any>) + Pl BARRIER GRAMCHK-S-BOUNDARY1 OR (SUBJ Â§AG))(0 SUBJ)(NEGATE 0 Â§AG); #(NEGATE 0* (SUBJ Â§EX)) ;
SUBSTITUTE N (Â§AG N) TARGET N IF (0 Nom + Sg) (*0 (V <AG-Nom-Any>) + Sg BARRIER GRAMCHK-S-BOUNDARY1 OR (SUBJ Â§AG))(0 SUBJ)(NEGATE 0 Â§AG);
SUBSTITUTE Pron (Â§AG Pron) TARGET Pron IF (0 Pers LINK 0 Nom + $$NUMBER) (*0 (V <AG-Nom-Any>) + $$NUMBER BARRIER GRAMCHK-S-BOUNDARY1 OR (SUBJ Â§AG))(0 SUBJ)(NEGATE 0 Â§AG);

SUBSTITUTE Pron (Â§AG Pron) TARGET Pron IF (0 (Sg Nom)) (*0 (V <AG-Nom-Any>) + Sg3 BARRIER GRAMCHK-S-BOUNDARY1 OR (SUBJ Â§AG))(0 SUBJ)(NEGATE 0 Â§AG);
SUBSTITUTE Pron (Â§AG Pron) TARGET Pron IF (0 (Pl Nom)) (*0 (V <AG-Nom-Any>) + Pl3 BARRIER GRAMCHK-S-BOUNDARY1 OR (SUBJ Â§AG))(0 SUBJ)(NEGATE 0 Â§AG);

	# "map" REASON role
	# ----------------
	# needs to be before the TH rules

SUBSTITUTE N (Â§RS N) TARGET N IF (0 Acc) (p (V <RS-Acc-Reason>))(0 ("duĆĄĆĄi" N Pl Acc))(NEGATE 0 Â§RS);

SUBSTITUTE N (Â§RS N) TARGET N IF (0 Loc) (p (V <RS-Loc-Any>))(NEGATE 0 Â§RS);
SUBSTITUTE N (Â§RS N) TARGET Pron IF (0 Loc) (p (V <RS-Loc-Any>))(NEGATE 0 Â§RS);

SUBSTITUTE Pron (Â§RS Pron) TARGET Pron IF (0 Com LINK NOT 0 Pers) (p (V <RS-Com-Impers>))(NEGATE 0 Â§RS);
SUBSTITUTE N (Â§RS N) TARGET N IF (0 Com OR (Pl Loc)) (p (V <RS-Com-Any>))(NEGATE 0 Â§RS);

SUBSTITUTE Po (Â§RS Po) TARGET Po IF (0 ("dihte") OR ("dihtii")) (p (V <RS-dihte-Any>))(NEGATE 0 Â§RS);

	# "map" THEME role
	# ----------------

SUBSTITUTE Po (Â§TH Po) TARGET Po IF (p (V <TH-maĆĆĂĄi-*Plc>))(0 ("maĆĆĂĄi") LINK *-1 Gen LINK NOT 0 Sem/Place) ;


SUBSTITUTE N (Â§TH N) TARGET N - SUGGEST IF (p (V <TH-Ill-Any>))(0 Ill)(NEGATE 0 Â§TH OR  SUGGEST) ; # a bit scary
SUBSTITUTE Num (Â§TH Num) TARGET Num - SUGGEST IF (p (V <TH-Ill-Any>))(0 Ill)(NEGATE 0 Â§TH OR  SUGGEST) ;
SUBSTITUTE Pron (Â§TH Pron) TARGET Pron - SUGGEST IF (p (V <TH-Ill-Any>))(0 Ill OR ILL-LOC-PRON-ADV)(NEGATE 0 Â§TH OR SUGGEST) ;
	##
SUBSTITUTE Adv (Â§TH Adv) TARGET Adv - SUGGEST IF (p (V <TH-Ill-Any>))(0 DOHKO OR ILL-LOC-PRON-ADV)(NEGATE 0 Â§TH OR SUGGEST) ;

SUBSTITUTE N (Â§TH N) TARGET N IF (p (V <TH-Acc-*Plc>))(0 Acc - Sem/Place)(NEGATE 0 Â§TH) ;

SUBSTITUTE N (Â§TH N) TARGET N IF (p (V <TH-Acc-Edu>))(0 Acc + Sem/Edu)(NEGATE 0 Â§TH) ;

SUBSTITUTE N (Â§TH N) TARGET N IF (p (V <TH-Acc-Any>) OR (V <TH-Acc-Body>))(0 Acc)(NEGATE 0 Â§TH) ;
SUBSTITUTE Pron (Â§TH Pron) TARGET Pron IF (p (V <TH-Acc-Any>))(0 Acc)(NEGATE 0 Â§TH) ;
SUBSTITUTE Num (Â§TH Num) TARGET Num IF (p (V <TH-Acc-Any>))(0 Acc)(NEGATE 0 Â§TH) ;
	## MakkĂĄr gova dĂĄt addĂĄ luohttĂĄmuĆĄĆĄii, go geahÄÄĂĄ moadde dĂĄhpĂĄhusa ĂĄĆĄĆĄis ; Olbmot balle ieĆŸaset gozihuvvon, ja gĂĄibidedje dieÄuid, go eai luohttĂĄn eisevĂĄlddiide.

SUBSTITUTE N (Â§TH N) TARGET N IF (p (V <TH-Acc-Any><RO-Ess-Any>))(0 Acc)(*0 Ess BARRIER GRAMCHK-S-BOUNDARY)(NEGATE 0 Â§TH) ;
SUBSTITUTE Pron (Â§TH Pron) TARGET Pron IF (p (V <TH-Acc-Any><RO-Ess-Any>))(0 Acc)(*0 Ess BARRIER GRAMCHK-S-BOUNDARY)(NEGATE 0 Â§TH) ;
SUBSTITUTE Num (Â§TH Num) TARGET Num IF (p (V <TH-Acc-Any><RO-Ess-Any>))(0 Acc)(*0 Ess BARRIER GRAMCHK-S-BOUNDARY)(NEGATE 0 Â§TH) ;

SUBSTITUTE N (Â§TH N) TARGET N IF (*0 (V <TH-Acc-*Ani>) BARRIER GRAMCHK-S-BOUNDARY1)(0 Acc LINK NOT 0 Sem/Animate)(NEGATE 0 Â§TH) ;

SUBSTITUTE Pron (Â§TH Pron) TARGET Pron IF (c (V <TH-Acc-Impers>))(0 Acc LINK 0 Pron)(NEGATE 0 Â§TH) ;

SUBSTITUTE N (Â§TH N) TARGET N IF (p (V <TH-Com-Any>))(0 Com)(NEGATE 0 Â§TH) ;
SUBSTITUTE Pron (Â§TH Pron) TARGET Pron IF (p (V <TH-Com-Any>))(0 Com)(NEGATE 0 Â§TH) ;
SUBSTITUTE Adv (Â§TH Adv) TARGET ("dainna" Adv) IF (p (V <TH-Com-Any>))(NEGATE 0 Â§TH) ;

SUBSTITUTE N (Â§TH N) TARGET N IF (p (V <TH-Com-*Ani>))(0 Com - Sem/Animate)(NEGATE 0 Â§TH) ;
SUBSTITUTE Pron (Â§TH Pron) TARGET Pron IF (p (V <TH-Com-*Ani>))(0 Com - Sem/Animate)(NEGATE 0 Â§TH) ;
SUBSTITUTE Adv (Â§TH Adv) TARGET ("dainna" Adv) IF (p (V <TH-Com-*Ani>))(NEGATE 0 Â§TH) ;

SUBSTITUTE Pron (Â§TH Pron) TARGET Pron IF (p (V <TH-Com-Impers>))(0 Com)(NEGATE 0 Â§TH) ;
SUBSTITUTE Adv (Â§TH Adv) TARGET Adv IF (p (V <TH-Com-Impers>))(0 ("dainna"))(NEGATE 0 Â§TH) ;

SUBSTITUTE N (Â§TH N) TARGET N IF (p (V <TH-Loc-Any>))(0 Loc)(NEGATE 0 Â§PART)(NEGATE 0 Â§TH) ;
SUBSTITUTE V (Â§TH V) TARGET V IF (p (V <TH-Loc-Any>))(0 (Actio Loc))(NEGATE 0 Â§TH) ;
SUBSTITUTE Pron (Â§TH Pron) TARGET Pron IF (p (V <TH-Loc-Any>))(0 Loc)(NEGATE 0 Â§PART)(NEGATE 0 Â§TH) ;
SUBSTITUTE Num (Â§TH Num) TARGET Num IF (p (V <TH-Loc-Any>))(0 Loc)(NEGATE 0 Â§PART)(NEGATE 0 Â§TH) ;

SUBSTITUTE Po (Â§TH Po) TARGET Po IF (p (V <TH-ala-*Plc>))(0 ("ala"))(NEGATE 0 Â§TH) ;

SUBSTITUTE Po (Â§TH Po) TARGET Po IF (p (V <TH-birra-Any>))(0 ("birra"))(NEGATE 0 Â§TH) ;

SUBSTITUTE Po (Â§TH Po) TARGET Po IF (p (V <TH-lusa-Any>))(0 ("lusa"))(NEGATE 0 Â§TH) ;

SUBSTITUTE Po (Â§TH Po) TARGET Po IF (p (V <TH-ovddas-Any>))(0 ("ovddas"))(NEGATE 0 Â§TH) ;

SUBSTITUTE Po (Â§TH Po) TARGET Po IF (p (V <TH-haga-Any>))(0 ("haga"))(NEGATE 0 Â§TH) ;

SUBSTITUTE Inf (Â§TH Inf) TARGET V IF (p (V <TH-Inf>))(NOT 0 @SUBJ)(NEGATE 0 Â§TH) ;
