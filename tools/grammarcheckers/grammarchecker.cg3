	# أ،lo vs. alo #in release
	# -----------
	
ADD:real-alo-أ،lo (&real-alo-أ،lo) TARGET ("allut" V) OR ("أ،lo" Err/Orth-a-أ، Adv) OR ("أ،lo" Err/Orth Adv) IF (0 (Ind Prs ConNeg) - Err/Orth OR (Imprt Sg2) OR (Imprt ConNeg))(*0 VFIN OR Inf OR BE + (PrfPrc) BARRIER GRAMCHK-S-BOUNDARY)(NEGATE -1 Sem/Measr OR (\?)) ;
ADD:أ،lo (&real-alo-أ،lo) TARGET ("أ،lo" Err/Orth-a-أ، Adv)(*0 VFIN OR Inf OR BE + (PrfPrc) BARRIER GRAMCHK-S-BOUNDARY)(NEGATE -1 Sem/Measr OR (\?)) ;
ADD:أ،lo (&real-alo-أ،lo) TARGET ("allut" V) OR ("أ،lo" Err/Orth-a-أ، Adv) IF (0 (Ind Prs ConNeg) - Err/Orth OR (Imprt Sg2) OR (Imprt ConNeg))(-1 ("nugo")) ;
ADD:أ،lo (&real-alo-أ،lo) TARGET ("أ،lo" Err/Orth-a-أ، Adv)(-1 ("nugo")) ;
ADD:أ،lo (&real-alo-أ،lo) TARGET ("allut" V) OR ("أ،lo" Err/Orth-a-أ، Adv) IF (0 (Ind Prs ConNeg) - Err/Orth OR (Imprt Sg2) OR (Imprt ConNeg))(-1 BECAUSE-WHEN LINK -1 ("nu")) ;
ADD:أ،lo (&real-alo-أ،lo) TARGET ("أ،lo" Err/Orth-a-أ، Adv)(-1 BECAUSE-WHEN LINK -1 ("nu")) ;
ADD:أ،lo (&real-alo-أ،lo) TARGET ("allut" V) OR ("أ،lo" Err/Orth-a-أ، Adv) IF (0 (Ind Prs ConNeg) - Err/Orth OR (Imprt Sg2) OR (Imprt ConNeg))(1 ("rabas") OR ("doaibma" Loc)) ;
ADD:أ،lo (&real-alo-أ،lo) TARGET ("أ،lo" Err/Orth-a-أ، Adv)(1 ("rabas") OR ("doaibma" Loc)) ;
COPY:real-alo-أ،lo ("أ،lo" Adv SUGGEST) EXCEPT ("allut" V IV Ind Prs ConNeg &real-alo-أ،lo) OR ("allut" V IV Imprt Sg2 &real-alo-أ،lo) OR ("allut" V IV Imprt ConNeg &real-alo-أ،lo) OR ("أ،lo" Err/Orth-a-أ، Adv &real-alo-أ،lo) TARGET (V &real-alo-أ،lo) ;	
	## Dأ،n أ،iggi ollu vأ،hnemat eai إ،at oro mأ،nnأ،vuoؤ‘abأ،ikkis eai ge alo  gأ،vdno lagas fuolkkit lahkosis veahkkin mأ،nأ،id bajأ،sgeassit.
	## Dأ،ppe mii dovdat ieإ¾amet alo buresboahtin. 
	## - Maإ‹emus minuvttat leat alo buot guhkimusat, logai أ،delhearrأ، geas ain lei veahأ،إ، jأ،lluvuohta. 
	## Manai ge alo bures.
	## Go dan eai lأ،ve politihkarat alo dahkat.
	## Nu guittotge mis buohkain lei somأ، guؤ‘et guimmiideamet, vaikke alo ii leat leamaإ،an nie.
	## Nugo alo, de ii lean son dakkأ،r geas lei dأ،rbu bahkket vuosttaإ¾ii.
	## Nu go alo, de Sأ،ؤ‘is ؤچأ،jehii eahpeluohttأ،muإ،a.
	## Ammun Peder muitala ahte sin sogas leamaإ، alo guvhllأ،rat.
	## Vaikko dأ،sa gal sأ،httأ، historjjأ،laؤچؤچat bidjat stuorra gaإ¾aldatmearkka leamaإ، go alo nu gal.
	## - Mu oaivilin leamaإ،an alo  ahte mii sأ،pmelaؤچؤچat galgat beassat mearridit ieإ¾amet beaivvأ،laإ، dili.
	## ADSL lea â€œalo rabasâ€‌ oktavuohta nehttii.
	## Stuoris ja gievra, ja alo doaimmas.



	
	# أ،lo vs. alu
	# -----------
		


ADD:xreal-alu-أ،lo (&real-alu-أ،lo) TARGET ("allut" V IV Ind Prs ConNeg Err/Orth) OR ("allut" V IV VGen) OR ("alu" Po) IF (NEGATE -1 Gen OR Sem/Measr OR (\?)) ;
COPY:real-alu-أ،lo ("أ،lo" Adv SUGGEST) EXCEPT ("allut" V IV Ind Prs ConNeg Err/Orth &real-alu-أ،lo) OR ("allut" V IV VGen &real-alu-أ،lo) OR ("alu" Po &real-alu-أ،lo) TARGET (&real-alu-أ،lo) ;		
	## Indiviidalaإ، ja oktasaإ، osku- ja eallinoaidnofriddjavuohta ii biste alu.
	## Oaإ¾إ¾ut namuhit : Servostivren, ABS-goazanat, 2 kolliإ،uvdnadustenseahka, guovddأ،إ،lأ،ssa, أ،ibmojoؤ‘ihanrusttet, goallostat, CD-stereo mas leat 4 skأ،janasa ( hأ¸yttalere ), alu. ???
