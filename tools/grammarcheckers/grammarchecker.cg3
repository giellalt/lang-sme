    # galgأ، (galgat) vs. gأ،lga (gأ،lga N) OR gأ،lgأ، (gأ،lgat V)
    # -------------------------------------------------------
ADD:real-galgأ، (&real-galgأ،) TARGET ("gأ،lgat" V TV Ind Prs Sg3) OR ("gأ،lga" N Sg Nom) IF (*0 Inf OR (Ind Prs Pl1) OR Ill + Sem/Ctain OR Ill + Sem/Plc BARRIER S-BOUNDARY OR VFIN)(NEGATE 0 ("galgat" V IV Ind Prs Sg3))(NEGATE -1 NOT-V - Foc/Neg-ge) ;
	#$ Gumppet eai {galga} bأ،llet ؤچivgagoahtit Finnmأ،rkkus oba ge go olles Finnmأ،rku lea boazdoalloguovlu.
	## Jua, de gأ،lga leat. Jua, de galgأ، leat.
	## Go boahttevuoؤ‘as gأ،lga iskat man ollu أ،vki gielladoarjagiin lea, de savأ،إ،ii Guovdageainnu suohkan ahte ؤچaؤ‘ahivؤچؤچe kvalitatiiva mihtidemiid maid, eai ge duإ،إ،e kvantitatiiva.
	## Dalle sأ،httأ، ihtit vuogأ،datlaإ، givssideapmi jus rأ،visolbmos ii leat gelbbolaإ،vuohta ja gأ،lga bidjat rأ،jiid ja bagadallat ovttasdoaibmama. 
	## NAؤŒ 2001:3 ؤچielggadeamis آ» Velgere, valgordning, valgte آ» ( vأ،lljejeaddjit, vأ،lgaortnet, vأ،lljejuvvon ) ؤچujuha vأ،lgalأ،hkalأ،vdegoddi dasa ahte lea govttolaإ، ahte vأ،lgalatnja almmolaإ، bأ،ikkiin galgأ، leat olأ،muttos buohkaide, maiddأ،i doaibmahehttejuvvon olbmuide, muhto ahte إ،addأ، bienasta bitnii reguleren suohkaniid badjel jus dأ،n gأ،lga lأ،ga bakte mearriduvvot. 

ADD:real-galgأ، (&real-galgأ،) TARGET ("gأ،lgat" V TV Ind Prs Sg3) OR ("gأ،lga" N Sg Nom) IF (-1 (Pron Prs3) OR ("mii" Pron Sg Nom))(NEGATE 0 ("galgat" V IV Ind Prs Sg3))(NEGATE -1 NOT-V - Foc/Neg-ge) ;
	## Dأ، lea Inger-Marie gorron erenoamأ،إ، ؤچiإ‹a mii gأ،lga dan rumbui. 
	#$  In eahpit ahte Sأ¦theris lea guhkit hأ،rjأ،neapmi politihkas go eatnasiin, muhto go juhkkojuvvui dat {gأ،lga} movt oaإ¾إ¾ut oahpu ja mأ،htu, de doaivvun ahte GB miellahtut eai lean nu beare maإ‹أ،bealde rأ،iddus. 
	## Dan gأ،lga DN dohkkehit ja vuhtii vأ،ldit. 
	#$ gأ،lgat ؤچuolmma/fierpmi/vuovttaid.
	## Dat lea nu go gأ،lga muitalit muitalusa, de lea mus dat oaidnu ahte ii don أ،but ؤچiegadit dat mii lei bahؤچa ja vأ،ivi ja lossat, go eallimis leat mأ،إ‹ggalأ،gan vأ،sأ،husat ja mun dovddan ahte mun lean muitalan dien ja mun lean olu lأ،vlagiid ؤچأ،llأ،n dieid birra.
COPY:real-galgأ، ("galgat" V IV Ind Prs Sg3 SUGGEST) EXCEPT ("gأ،lgat" V TV Ind Prs Sg3 &real-galgأ،) OR ("gأ،lga" N Sg Nom &real-galgأ،) TARGET (&real-galgأ،) ;
