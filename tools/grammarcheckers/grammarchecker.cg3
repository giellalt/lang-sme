	# Prs Sg1 vs. Der/NomAct for nouns with double consonants and consonant gradation,Â INFINITIVEÂ GRADEÂ III
	# -----------------------------------------------------------------------------------------------------
	# u-stam, a-stam ; alla konsonantgrupper utom 1 och 4D gÄ: buoidunÂą(verb,conc|buoiddun) infinitive in Grade III

SET UT-AT-VERBS = UT-VERBS OR AT-VERBS ;

ADD:real-PrsSg1-DerNomActNom (&real-PrsSg1-DerNomActNom) TARGET UT-AT-VERBS + CONC-2-3-4ABC IF (0 (Ind Prs Sg1))(*1 CC BARRIER NOT-ADV-PCLE LINK 1 (N Sg Nom))(NEGATE *-1 (Pron Sg1) OR BE + Ind BARRIER NOT-ADV-PCLE)(NEGATE 0 <spelled>)(NEGATE 0 (N Sg Nom) OR &real);

COPY:real-PrsSg1-DerNomActNom (Ex/V Ex/TV Der/NomAct N Sg Nom SUGGEST) EXCEPT (V TV Ind Prs Sg1 &real-PrsSg1-DerNomActNom) TARGET (&real-PrsSg1-DerNomActNom) ;
	## Dutkkan ja turisma leat ĆĄaddan dehĂĄlaĆĄ liigeealĂĄhussan lassin SvalbĂĄrdda UniversitehtaguovddĂĄĆŸii ja SvalbĂĄrdda mĂĄilmmiviidosaĆĄ siepmanvĂĄrrehussii.
	# definitely needs testing
	# in errors.xml
	#DUOMMĂ DĂL

    # -u vs. -o (ĂĄigu vs. ĂĄigo) alle konsonantgrupper, infinitive grad iii eller ii HUOM: rules should be made for these words only: orro, vĂĄilo, unno, ĂĄigo, others are very uncommon
	# -----------------------------------------------------------------------------

LIST SG-PL-NOM-DEM = ("dat") ("diet") ("duot") ("dot") ("dĂĄt") ("do-dot") ("duo-duot") ("dĂĄ-dĂĄt") ("die-diet") ("die-dat");

LIST PL3-N = (".*oassi"r) ;

ADD:real-PrtPl3-PrsSg3 (&real-PrtPl3-PrsSg3) TARGET UT-VERBS - <spelled> - Der/h - Der/d IF (0 (ConNegII) OR (Ind Prs Du1) OR (Ind Prt Pl3) OR (Imprt ConNegII))(*-1 SHE + (Pron Pers Sg3 Nom) OR ("mii" Pron Sg Nom) OR I + (Pron Pers Pl1 Nom) OR ("soames" Pron Indef Sg Nom) OR (N Sg Nom) - <NomGenSg> - Sem/Time - Sem/Org - Sem/Group - Sem/Plc - PL3-N - Num - Px - Coll - ("Dan") OR (Pron Rel Sg Nom) OR (Pron Indef Sg Nom) - ("unnĂĄn") - ("mĂĄĆga") - ("moadde")  BARRIER GRAMCHK-S-BOUNDARY - @ADVL  - ("â") OR VFIN OR Inf OR CC OR COMMA OR (N Sg Nom) + Sem/Group OR (Pron Pl Nom) OR (Indef Pl Nom) OR Rel OR (N Pl Nom) OR (A Pl Nom) +  Sem/Ani OR (A Pl Nom) +  Sem/Hum OR MO-MANge OR THEN-CS-ADV LINK NOT 0 (N Pl Nom) OR (N Sg Loc) OR Adv LINK NOT 1 QMARK LINK NEGATE *-2 CC BARRIER NPNH LINK -1 (N Nom))
(NEGATE *-1 (N Sg Gen) OR (A Sg Gen) BARRIER GRAMCHK-S-BOUNDARY - @ADVL  - ("â") OR VFIN OR Inf OR CC OR COMMA OR (N Sg Nom) + Sem/Group OR (Pron Pl Nom) OR (Indef Pl Nom) OR Rel OR (N Pl Nom) OR (A Pl Nom) +  Sem/Ani OR (A Pl Nom) +  Sem/Hum OR MO-MANge OR THEN-CS-ADV LINK NOT 0 (N Pl Nom) LINK *-1 Num - OKTA - ("1") OR ("mĂĄĆga") OR ("moadde") BARRIER NPNH)
(NEGATE *-1 NOT-V BARRIER COMMA OR GRAMCHK-S-BOUNDARY OR CS)(NEGATE 1 CC LINK 1 (Prt Pl3))(NEGATE *1 (N Pl Nom) OR (Pron Nom Pl3) OR (Pron Nom Pl) BARRIER NOT-ADV - Attr)(NEGATE 1 COPULAS LINK 0 (Actio Ess) LINK *1 (N Pl Nom) OR (Pron Nom Pl3) OR (Pron Nom Pl) BARRIER NPNHA)(NEGATE 0 (V Sg3) - Err/Orth)
(NEGATE 0 (N Nom));
	#$ SĂĄmediggi ĂĄvĆŸĆŸuha fas bidjat johtui 5 km rĂĄji siseatnanbivdui FinnmĂĄrkkus SĂĄmediggi {dĂĄhtto} SĂĄmediggerĂĄÄi gulahallat FinnmĂĄrkkuopmodagain (FeFo) ĂĄrvvoĆĄtallat fas rĂĄdjet siseatnanguolĂĄsteami vuoigatvuoÄaid sidjiide geat eai leat bĂĄikkĂĄlaĆĄ olbmot FinnmĂĄrkkus.
