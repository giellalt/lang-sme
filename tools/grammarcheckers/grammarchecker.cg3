LIST ESS-ADVL-N = "arvi" "ĂĄrga" "baika" ("bassi" N) ("bĂĄhkka" N) "beaivvĂĄdat" "biegga" "bievla" ("buolaĆĄ" N) "Äuoika" "Äuovga"  (".*dĂĄlki"r) "dulvi" "mĂĄnoheahpi" "muohta" "njĂĄhcu" ("seavdnjat" N) "varra" "veaigi";

# These nouns/adjectives in essiv can get @ADVL:
LIST ESS-PROB-ADVL-N = ("bassi" N) "boaris" ("nuorra" N) ;


# Time sets
# - - - - -

LIST MANNU = "oÄÄajagemĂĄnnu" "oÄÄajagimĂĄnnu" "guovvamĂĄnnu" "njukÄamĂĄnnu" "njuvÄÄamĂĄnnu" "mĂĄrsmĂĄnnu" "cuoĆomĂĄnnu" "cuoĆosmĂĄnnu" "cuoĆumĂĄnnu" "gĂĄranasmĂĄnnu" "miessemĂĄnnu" "mĂĄimĂĄnnu" "geassemĂĄnnu" "suoidnemĂĄnnu" "borgemĂĄnnu" "ĆĄnjilÄamĂĄnnu" "ĆĄnjilĆŸamĂĄnnu" "ÄakÄamĂĄnnu" "golggotmĂĄnnu" "skĂĄbmamĂĄnnu" "novembermĂĄnnu" "ritnemĂĄnnu" "juovlamĂĄnnu" ;


LIST AIGODAT = "ĂĄigi" (".*ĂĄigodat"r) "ĂĄlgoĂĄigi" "bargoĂĄigi" "soahteĂĄigi" "soahtegaskaĂĄigi" ;

LIST VAHKKU-DUR = "beaivi" "jĂĄndor" "bodda" "ÄakÄa" "ÄakÄageassi" "ÄakÄaseavdnjat" "Äuohtejahki" "dĂĄlvi" "diibmu" "eahket" "eahketbodda" "geassi" "giÄÄa" "idja" "iÄit" "iÄitbodda" "jahki" "jahkebealle" "jahkeÄuohti" "kaleanddarjahki" "loahppajahki" ("[0-9]*-lohku"r) "mĂĄnnu" "minukta" "njealjĂĄdasjahki" "skuvlajahki" "tiibma" "vahkkoloahppa" "vahkku" ;
# these are periodes and can be Acc

LIST VAHKKU-TIME = "b" "bievlajahki" "bivdoĂĄigi" (".*beaivi"r) "D-beaivi" "dienasjahki" "doaibmajahki" "eamiĂĄlbmotjahki" "earrejahki" "gaskaidja" "geardi"  "juovlabassi" "luomejahki" "luopmojahki" "mihcamĂĄrra" "muorjejahki" "nissonjahki" "vuoitojahki" "vuoÄÄoskuvlavahkku" ("[0-9]*-jahki"r) ("[0-9]*-jahki"r) "[0-9]*-[0-9]*-jahki"  "[0-9]*-[0-9]*-lohku" ("[0-9]*-lohku"r) ("[0-9]*-lohku"r) ;

 # The quoteless jahki here is since the preprocessor is not fine-tuned
 # yet, it still gives '"1870-" # jahki N Sg Com'. # lets see if "dbm" works

SET VAHKKU = VAHKKU-DUR OR VAHKKU-TIME ;

LIST NUM-JAHKI = "jahki" "skuvlajahki";

    # Years which can be numerated

LIST PARTTIME = "ÄavÄÄabealle" ;
	# This set is for finding Gen in expressions like PARTTIME OR TIME Gen.

LIST AIGI = "ĂĄigi" (".*ĂĄigi"r) ;

LIST SP-BEAIVI = "albmĂĄimannanbeaivi" "bargoÄoahkkinbeaivi" "beassĂĄĆĄbeaivi" "mĂĄnnodat" "vuossĂĄrga" "disdat" "maĆĆebĂĄrga" "gaskavahkku" "duorastat" "bearjadat" "juovlabeaivi" "lĂĄvvardat" "lĂĄvvordat" "sotnabeaivi" "sĂĄbbĂĄt" "skilleduorastat" ;

LIST GEN-BEAIVI = "ĂĄlbmotbeaivi" "ĂĄrgabeaivi" "bargobeaivi" "beaivi" "duopmobeaivi" "riegĂĄdanbeaivi" "skuvlabeaivi"  ;
# General-beaivi can have Gen modifier, like "skuvlla ĂĄrgabeaivi".

SET BEAIVI = SP-BEAIVI OR GEN-BEAIVI ;

SET TIME = MANNU OR VAHKKU OR BEAIVI OR AIGI ;

  # Do not add AIGODAT, it has some other characteristics in some cases.
  # But fix!!
  # "SĂĄmediggerĂĄÄÄi   lea ĂĄigodagas doallan   5 Äoahkkima."
  # Today believed to be obj.

SET NOTIME = N - TIME ;

LIST GEASSET = "dĂĄlvet" "dĂĄlvit" "giÄÄat" "geasset" ("geassit" Adv) "ÄakÄat" ;
 # What is special here?

LIST PAST-MARKER = ("mĂĄnnĂĄ" Ess) "dalle" "diibmĂĄ" "dolin" "doloĆĄ" "dovle" "duvle" "eske" "gieskat" "ikte" ("nuorra" Ess) "ovdal" ("ovdditbeaivi" Gen) ("vĂĄssĂĄnĂĄigi" Loc) ("boaresĂĄigi" Gen) ;

LIST PRESENT-MARKER = "dĂĄl" "ihttin" "odne" "otne" ("boahtteĂĄigi" Loc) ("boahtteĂĄigi" Gen)  ;

SET TIME-MARKER = PAST-MARKER OR PRESENT-MARKER ;

LIST OTHER-TIME-ADV =  "agĂĄlaÄÄat" ("agĂĄlaĆĄ" Ex/A Adv) "ĂĄrabuĆĄ" "ĂĄrrat" "easkka" "easka" "guhkĂĄ" ("guhkit" Adv) "maĆemustĂĄ" "maĆĆel" "maĆĆelaĆĄ" "maĆĆeleappos" "maĆĆit" "muhtumin" "ovdal" ;

SET TIME-ADV = TIME-MARKER OR OTHER-TIME-ADV OR GEASSET;


# Amount sets
# - - - - - -

LIST VOLUME = "cl" "lihtar" (".*lihtter"r) "dl" "lihtter" "ml"  ;

LIST WEIGHT = "mg" "kg" "kilo" "kilu" "gilo" "tonna" ;

LIST LENGTH = "Äuoldabadji" "dumĂĄ" "fierbmebadji" "gaska" "miila" (".*mehtar"r) (".*mehter"r) "mehtar" "mehter" "sente" "cm" "tumĂĄ" "ĂĄllan" "salla" ;

