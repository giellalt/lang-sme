LIST TIMEOBJECT-V = "addit" "atnit" "ÃĄrvalit" "bÃĄlvalit"  "Äuovvut" "deavdit" "diÅgot" "evttohit" "fÃĄtmmastit" "gÃĄibidit" "gÃĄvdnat" "geavahit" "gierdat" "guhkidit" "hÃĄbmet" "jorgalit" "juolludit" "lasihit" "liigudit" "loahpahit" "loaktit" "markeret" "mearridit" "molsut" "oanidit" "oaÅūÅūut" "soahpat" "ÅĄiehttat" "vÃĄrret" "viiddidit" ;

