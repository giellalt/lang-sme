    # gen + jahkÃĄsaÅĄ + vahkkusasj, tjiluk, jahkÃĄsasj
    # - - - - - - - - - - - - - - - - - - - - - - - -
    
LIST JAHKASAS = "minuhttasaÅĄ" "sekundasaÅĄ" "diibmosaÅĄ" "tiibmosaÅĄ" "beaivÃĄsaÅĄ" "vahkkosaÅĄ" "mÃĄnnosaÅĄ" "jahkkÃĄsaÅĄ" "ruvdnosaÅĄ" "kruvdnosaÅĄ"  "jahkÃĄsaÅĄ" "tonnasaÅĄ" "kilosaÅĄ" "gilosaÅĄ" "grÃĄmmasÃĄÅĄ" "dÃĄssÃĄsaÅĄ" "miellahttosaÅĄ" "siidosaÅĄ"  "idjasaÅĄ";

ADD:xmsyn-gen-numeral-jahkasaÅĄ (&msyn-gen-numeral-jahkasaÅĄ) TARGET (Num Sg Nom) IF (1 JAHKASAS + A) ;

COPY:msyn-gen-numeral-jahkasaÅĄ (Num Sg Gen SUGGEST) EXCEPT (Num Sg Nom &msyn-gen-numeral-jahkasaÅĄ) OR (Num Sg Acc &msyn-gen-numeral-jahkasaÅĄ) OR (Num Sg Nom) TARGET (&msyn-gen-numeral-jahkasaÅĄ) (NEGATE 0 Arab) ; 

COPY:msyn-gen-numeral-jahkasaÅĄ (Num Arab Sg Gen SUGGEST) EXCEPT (Num Arab Sg Nom &msyn-gen-numeral-jahkasaÅĄ) TARGET (Arab &msyn-gen-numeral-jahkasaÅĄ) ; 


ADDRELATION ($2 RIGHT) (Num &msyn-gen-numeral-jahkasaÅĄ) TO (1 A - &msyn-gen-numeral-jahkasaÅĄ) ;

SUBSTITUTE (&msyn-gen-numeral-jahkasaÅĄ) (co&msyn-gen-numeral-jahkasaÅĄ) TARGET (SUGGEST);
    ## PolitihkalaÅĄ dÃĄsis leat leamaÅĄ {guokte}ÂĢ{guovtti} jahkÃĄsaÅĄ ovttasbargoÄoahkkima.
