	# allet ("ii" Imprt) vs. أ،llet (V TV)
	# ----------------------------------

LIST CONNEG-VGEN-V = (".*at"r) (".*ot"r) (".*et"r) (".*أ،t"r) ;
	


ADD:xreal-أ،llet-allet (&real-أ،llet-allet) TARGET ("أ،llet" V TV Inf) OR ("أ،llet" V TV Ind Prs Sg2) OR ("أ،llet" V TV Ind Prs Pl1) OR ("أ،llet" V TV Der/d V Imprt ConNeg) OR ("أ،llet" V TV Der/d V Imprt Sg2) OR ("أ،llet" V TV Der/d V Ind Prs ConNeg) OR ("أ،llet" V TV Der/h V Imprt ConNeg) OR ("أ،llet" V TV Der/h V Imprt Sg2) OR ("أ،llet" V TV Der/h V Ind Prs ConNeg) IF (*1 ConNeg OR VGen + CONNEG-VGEN-V OR (TV Imprt Sg2) BARRIER NOT-ADV-PCLE) ;
    ## Jus vأ،ssأ،nأ،igi livؤچؤچe earأ،lأ،gan, de livؤچؤچe maid min dأ،lأ،أ،igi ja boahtteأ،igi earأ،lأ،gan â€¦ Muhto أ،llet fal divtte ovttage dadjat didjiide ahte lea menddo maإ‹إ‹it! 
    
COPY:real-أ،llet-allet ("ii" V IV Neg Imprt Pl2 SUGGEST) EXCEPT ("أ،llet" Ex/V TV Der/d Inf) OR ("أ،llet" Ex/V TV Der/d Ind Prs Sg2 &real-أ،llet-allet) OR ("أ،llet" Ex/V TV Der/d Ind Prs Pl1 &real-أ،llet-allet) OR ("أ،llet" V TV Der/d V Imprt ConNeg &real-أ،llet-allet) OR ("أ،llet" V TV Der/d V Imprt Sg2 &real-أ،llet-allet) OR ("أ،llet" V TV Der/d V Ind Prs ConNeg &real-أ،llet-allet) OR ("أ،llet" V TV Der/h V Imprt ConNeg &real-أ،llet-allet) OR ("أ،llet" V TV Der/h V Imprt Sg2 &real-أ،llet-allet) OR ("أ،llet" V TV Der/h V Ind Prs ConNeg &real-أ،llet-allet) TARGET (&real-أ،llet-allet) ;		
