	## Rأ،issa joatkkaskuvllas leat badjelaإ، 20 oahpaheaddji ja vel girjerأ،jusbargi lohkkan Sأ،mi kulturmأ،htu.


    # adjectival reading

ADD:real-Ess-PrfPrc (&real-Ess-PrfPrc) TARGET CONC-2 + AT-VERBS IF (0 (V PrfPrc Err/Confused-Ess))(-1 GRADE-ADV-2)(NEGATE 0 Sem/Hum)(NEGATE 1 CC OR COMMA LINK 1 Ess)(NEGATE -1 CC OR COMMA LINK *-1 Ess BARRIER (*) - COMMA)(NEGATE *0 (<.*-Ess-.*>r) - BE OR (<.*-Acc-.*><.*-Ess-.*>r) BARRIER NOT-ADV-PCLE - OBJ OR @ADVL)(NEGATE -1 Attr OR Gen + Sem/Human);
    ## Sii ؤچuige gulul geaidnoguora ja skoalkaledje ain soppiin sabetvuؤ‘ؤ‘ui dohppan njأ،hcomuohttaga.

	# Aktio

ADD:real-Ess-PrfPrc (&real-Ess-PrfPrc) TARGET CONC-2 + AT-VERBS IF (0 (V PrfPrc Err/Confused-Ess))(-1 Gen)(1 N)(NEGATE 1 CC  OR COMMA LINK 1 Ess)(NEGATE -1 CC  OR COMMA LINK *-1 Ess BARRIER (*) - COMMA)(NEGATE -1 Attr OR Gen + Sem/Human)(NEGATE *0 (<.*-Ess-.*>r) - BE OR (<.*-Acc-.*><.*-Ess-.*>r) BARRIER NOT-ADV-PCLE - OBJ OR @ADVL);
    ## Tipsa : Jus geahؤچat dأ،rkilit, sأ،htأ،t oaidnit vأ،rrevilttiin skurؤچؤچuid lassin maiddأ،i ؤچأ،zi gohppan healbmerokkiid.

ADD:real-Ess-PrfPrc (&real-Ess-PrfPrc) TARGET CONC-2 + AT-VERBS IF (0 (V PrfPrc Err/Confused-Ess))(NEGATE 0 Sem/Hum)(1 (V Sg3) + COPULAS)(NEGATE 1 CC LINK 1 Ess)(NEGATE -1 CC OR COMMA LINK *-1 Ess BARRIER (*) - COMMA)(NEGATE *0 (<.*-Ess-.*>r) - BE OR (<.*-Acc-.*><.*-Ess-.*>r) BARRIER NOT-ADV-PCLE - OBJ OR @ADVL)(NEGATE -1 Attr OR Gen + Sem/Human);
    ## Iskkأ،riid dahje speidأ،riid hoahkkan lea nأ، : آ«أپlo gearggus! #NOUN!

	# coordination

ADD:real-Ess-PrfPrc (&real-Ess-PrfPrc) TARGET CONC-2 + AT-VERBS IF (0 (V PrfPrc Err/Confused-Ess))(-1 CC LINK -1 PrfPrc LINK *-1 COPULAS OR <TH-Acc-Any><TH-PrfPrc>)(NEGATE 1 CC  OR COMMA LINK 1 Ess);
    ## Isokoski muitala ahte son lea hأ،leإ،tan Amoc:in, ja lohkأ، artistta heahpanan ja gأ،httan daguidis ovddas.

    # Actio Gen instead of PrfPrc

ADD:real-Ess-PrfPrc (&real-Ess-PrfPrc) TARGET CONC-2 + AT-VERBS IF (0 (V PrfPrc Err/Confused-Ess))(1C Po OR Pr)(NEGATE 1 CC  OR COMMA LINK 1 Ess);
    ## "dihte" v1 Po â€“ Dan mii dahkat hأ،hkkan dihte duoؤ‘aإ،tusaid mat dأ،n rأ،djأ،i leat leamaإ،an vأ،ilevaؤچؤچat, dan ektui go ahte eanadoallit moitet dan go bohccot guhtot sin gittiin, lohkأ، Porsأ،إ‹ggu gieldda eanandoallohoavda, Ingrid Golten.

    # Actio Nom instead of PrfPrc

ADD:real-Ess-PrfPrc (&real-Ess-PrfPrc) TARGET CONC-2 + AT-VERBS IF (0 (V PrfPrc Err/Confused-Ess))(-1 (N Gen))(1 EOS OR CC)(NEGATE *0 (<.*-Ess-.*>r) - BE OR (<.*-Acc-.*><.*-Ess-.*>r) BARRIER NOT-ADV-PCLE - OBJ OR @ADVL)(NEGATE 1 CC  OR COMMA LINK 1 Ess);
    ## Materiأ،laid {hأ،hkkan}آ¢{hأ،hkan} ja personsuodjalus.
    ## Dieؤ‘uid {hأ،hkkan}آ¢{hأ،hkan}.
    ## 1.2 Diehtojuohkin lahtuide ja lahtuid {hأ،hkkan}آ¢{hأ،hkan}.
    ## Sأ،megielalaإ، giddagasbargiid {hأ،hkkan}آ¢{hأ،hkan}.

ADD:real-Ess-PrfPrc (&real-Ess-PrfPrc) TARGET CONC-2 + AT-VERBS IF (0 (V PrfPrc Err/Confused-Ess))(-1 (N Gen) LINK -1 BOS)(*1 (V Sg3) BARRIER GRAMCHK-S-BOUNDARY OR V)(NEGATE *0 (<.*-Ess-.*>r) - BE OR (<.*-Acc-.*><.*-Ess-.*>r) BARRIER NOT-ADV-PCLE - OBJ OR @ADVL)(NEGATE 1 CC  OR COMMA LINK 1 Ess);
    ## Bargiid {hأ،hkkan}آ¢{hأ،hkan} alit virggiide sأ،megielas lea leamaإ، vأ،ttis.
    ## 11.3.1 Mأ،nأ،idgأ،rdebargiid {hأ،hkkan}آ¢{hأ،hkan}.
    ## Kap. 684 Boazodoalu Riikkaidgaskasaإ، fأ،ga- ja gaskkustanguovddأ،إ،, poasta 1 Doaibmagolut ja 45 Stuorit dأ،vviriid {hأ،hkkan}آ¢{hأ،hkan} ja أ،immahuإ،إ،an, sأ،httأ، sirdojuvvot Rأ،ؤ‘ؤ‘ehus أ،rvala juolludit 3,3 mill. ruvnno guovddأ،إ¾a doibmii 2009:is.
    ## Jagi 2008 juolluduvvui 650 000 ruvdno kap. 682, poastta 45 stuorit dأ،vviriid {hأ،hkkan}آ¢{hأ،hkan} ja أ،immahuإ،إ،an bakte luvvodagaide ja dأ،vviriidda daid lanjaide mأ،id Gأ،ldu â€“ أپlgoأ،lbmotvuoigatvuoؤ‘aid Gelbbolaإ،vuoؤ‘aguovddأ،إ، galgأ، geavahit.
    ##  Kap. 682 أپlgoأ،lbmotvuoigatvuoؤ‘aid gelbbolaإ،vuoؤ‘aguovddأ،إ،, poasta 1 Doaibmagolut ja 45 Stuorit dأ،vviriid {hأ،hkkan}آ¢{hأ،hkan} ja أ،immahuإ،إ،an, sأ،httأ، sirdojuvvot Rأ،ؤ‘ؤ‘ehus أ،rvala 2,9 mill. ruvdnosaإ، juolludeami guovddأ،إ¾a 2009:i doibmii.

COPY:real-Ess-PrfPrc (SUGGEST) EXCEPT (Err/Confused-Ess &real-Ess-PrfPrc) TARGET (Err/Confused-Ess &real-Ess-PrfPrc) ;

COPY:real-Ess-PrfPrc (IV SUGGEST) EXCEPT (TV Err/Confused-Ess &real-Ess-PrfPrc) AFTER V TARGET (TV Err/Confused-Ess &real-Ess-PrfPrc) ;

COPY:real-Ess-PrfPrc (Actio Nom SUGGEST) EXCEPT (PrfPrc Err/Confused-Ess &real-Ess-PrfPrc) TARGET (Err/Confused-Ess &real-Ess-PrfPrc) ;

COPY:real-Ess-PrfPrc (Actio Gen SUGGEST) EXCEPT (PrfPrc Err/Confused-Ess &real-Ess-PrfPrc) TARGET (Err/Confused-Ess &real-Ess-PrfPrc) ;

	# ut-verbs
	# real-DerNomActSgGen-PrfPrc needs to be before real-DerNomActSgGen-PrsSg1
	# the correction can either be PrfPrc or ConNeg which are homonymous
	# --------------------------------------------------

	# "doarrun" آ§RO N <NomGenSg> Sem/Act Sg Nom

SET CLAUSE-END = CC OR CS OR COMMA OR HYPHEN OR EOS;

LIST DERNOMACT-CONFUSION = ("goargu" Ess) ("goargut" Ex/V TV Der/NomAct N Sg Nom) ("goargut" V TV PrfPrc) ("goargut" Ex/V TV Der/NomAct N Sg Gen Allegro) ("viessut" Ex/V TV Der/NomAct N Sg Nom) ("viessut" V IV Actio Nom) ("viessu" N Ess) ("viessut" Ex/V TV Der/NomAct N Sg Gen Allegro) ("viessut" V IV Actio Gen) ;


ADD:real-DerNomActSgGen-PrfPrc (&real-DerNomActSgGen-PrfPrc) TARGET UT-VERBS IF (0 (Actio Gen) OR (Actio Nom) OR (Der/NomAct N Sg Nom) OR (Der/NomAct N Sg Gen Allegro) OR (Der/NomAct N Ess) OR (Der/NomAct N Sg Loc South Err/Orth))(*-1 BE + Ind OR BE + Cond OR BE + (Pot) OR BE + (ConNeg) OR CAN + Ind OR CAN + Cond OR (V <TH-Acc-Any><TH-PrfPrc>) BARRIER NOT-ADV-PCLE - (Pers Nom) - (Adv Sem/Time) - (Adv Sem/Plc) - @OBJ> - SUBJ - @ADVL - (N Loc) - (N Ill) - (N Sg Acc PxSg3) - (N Sg Gen PxSg3) - ("dat") OR PrfPrc LINK NEGATE *-1 (N Sg Nom) OR (Dem Sg Nom) BARRIER NOT-ADV-PCLE - NOT-V + Ind LINK NOT 0 SUBJ OR Sem/Human)(NEGATE 1 CC LINK 1 N)(NEGATE -1 CC LINK -1 N)(NEGATE 0 Ess LINK 1 CC OR Foc/Neg-ge LINK *1 Ess BARRIER NPNHA)(NEGATE 1 Rel OR Interr)(NEGATE 1 Po LINK NOT 1 Gen OR EOS)(NEGATE 1 Gen OR Acc LINK 1 CC LINK 1 Gen OR Acc LINK 1 Po LINK NOT 1 Gen OR EOS)(NEGATE -1 (N Gen) OR (Pers Gen) OR (A Attr) OR BOS OR TV)(NEGATE 0 Der/l OR Der/h OR Der/Pass OR PrfPrc OR DERNOMACT-CONFUSION OR (N Sg Nom) + Sem/Plc)(NEGATE *1 @<SPRED BARRIER NOT-ADV-PCLE - BE + Ind)(NEGATE 1 BE + Ind LINK *1 Adv BARRIER NOT-ADV-PCLE)(NEGATE 1 BE + Ind LINK -2 (Pron Sg Nom) OR (N Sg Nom))(NEGATE -1 ConNeg LINK -1 Neg LINK -1 Loc)(NEGATE 1 PrfPrc)(NEGATE 0 <AG-Nom-Ani> LINK *-1 BE + Ind OR BE + Cond OR BE + (Pot) OR CAN + Ind OR CAN + Cond OR NOT-V + Ind BARRIER NOT-ADV-PCLE - (Pers Nom) - (Adv Sem/Time) - (Adv Sem/Plc) - @OBJ> - @ADVL - (N Loc) - (N Ill) - (N Sg Acc PxSg3) - (N Sg Gen PxSg3) LINK NOT *-1 SUBJ + Sem/Animate OR SUBJ + Sem/Org OR CS BARRIER NOT-ADV-PCLE)(NEGATE 0 (A Ess) LINK -1 GRADE-ADV)(NEGATE 0 @<SPRED OR (N Ess) LINK *1 CLAUSE-END BARRIER NOT-ADV-PCLE - @ADVL - Loc - Gen OR ("guhkأ،"))(NEGATE 0 @<SPRED LINK *1 @>P BARRIER NPNHA LINK 1 Po LINK 1 CLAUSE-END OR CC)(NEGATE 0 @<SPRED LINK 1 Adv - ("guhkأ،") OR Pcle LINK *1 @>N BARRIER NOT-ADV-PCLE LINK 1 @ADVL LINK 1 CLAUSE-END OR CC)(NEGATE 0 (N Sg Nom) OR (N Ess) LINK 1 Inf - <*Inf>)(NEGATE 0 (N Sg Nom) LINK *1 PrfPrc BARRIER S-BOUNDARY)(NEGATE *1 @<SPRED BARRIER NPNH - Attr)(NEGATE 0 <AG-Nom-Ani> LINK *-1 @SUBJ> - Sem/Human BARRIER S-BOUNDARY) ;
	#(NEGATE 0 (N Sem/Act Sg Nom) LINK NOT *0 SUBJ + Sem/Human BARRIER GRAMCHK-S-BOUNDARY)
	#$ ؤŒujuhuvvo lأ،vdegotti ؤچielggadeapmأ،i ؤچuoggأ،s 9.9.3.3 gos oaidnأ، ahte sأ،hkkocealkkus lea {gohؤچؤچun} dihto أ،igemearis ؤچaؤ‘ahit juo ovdalaؤچؤچas mearriduvvon gohؤچؤچuma.
    ## Danne go historjjأ،laؤچؤچat lea sأ،mi servodat ovdأ،nan politihkalaؤچؤچat, ii duإ،إ،e dainna go leat leamaإ، vuollegaإ،vuoؤ‘ain vأ،lddi luhtte, muhto go vel niehkkeruovddit vel beasadan leat ja sأ،mepolitihkalaإ، fأ،mut ieإ¾a leat أ،igun mearridit sأ،pmelaؤچؤچaid dili!
    #$ Dutnje ii heive leat nu njأ،igun, don gii leat Buhtesnieida, ja leage buoret go leat sihke searvvأ،laإ، ja movttet, juoga mii dus ii vأ،illo. #njأ،igun Essiv
    #$ Mأ،ؤ‘idja lea أ،rvvoإ،tallojuvvon vأ،ttisin, ja dan losimus oassi lea goargإ‹un Noaideduoddara ala. #goargإ‹un
    #$ Dأ،t lei baicce gohؤچؤچun, skuvladirektevrras ledje viiddis, dadjat juo buot fأ،pmudusat oahpaheddjiid virgأ،ibidjat dieid jagiid. #gohؤچؤچun
    ## â€“ Oؤ‘ؤ‘a skearrus lean mun hilgun buot mأ،id ovdal lean buvttadan ja أ،ibbas rievdadan stiilla, dadjأ، son ja muitala ahte musihkka su jeؤ‘ؤ‘e ja movttiida lأ،ittas أ،rgabeaivvis. #hilgun
    ## Mأ،إ‹ga nissona goddet fuolkkit, go leat rihkkun bearraإ،a sأ،valdagaiguin, ja nu maid sin gudni. #rihkkun
    ## Hأ،lddahus sأ،httأ، rihkkun Norgga lأ،gaid go dikte Almmuheaddji OS rأ،hkadit nissonaviissa. #rihkkun
    #$ ؤŒujuhuvvo lأ،vdegotti ؤچielggadeapmأ،i ؤچuoggأ،s 9.9.3.3 gos oaidnأ، ahte sأ،hkkocealkkus lea gohؤچؤچun dihto أ،igemearis ؤچaؤ‘ahit juo ovdalaؤچؤچas mearriduvvon gohؤچؤچuma. #gohؤچؤچun
    ## Sأ،mediggerأ،ؤ‘ؤ‘i lea gohؤچؤچun ؤچoahkkimii oؤ‘ؤ‘ajagimأ،nu 15. b. daid Sأ،medikki أ،irasiiguin geat leat Gasko- ja Davvi-Norgga regionأ،la dutkanfoanddaid stivrrain. #gohؤچؤچun ---> gohؤچؤچon
    #$ â€“ Dat mii suhtada mu lea ahte manin lea nuohttun bissehuvvon duإ،إ،e bajit osiin ؤچأ،zأ،dagas, jus lea unnأ،n goؤ‘ؤ‘oguolli. #nuohttun
    #$

