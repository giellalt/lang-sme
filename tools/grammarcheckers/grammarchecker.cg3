ADD:xreal-guhkĂĄ (&real-guhkĂĄ) TARGET ("guhkĂĄ" Err/Orth Adv) OR ("guhkkĂĄ" N Nom) OR ("guhkkat" Prs Sg3) IF (*0 GRAMCHK-VFIN BARRIER GRAMCHK-S-BOUNDARY2 OR COMMA)(NEGATE 0 Foc/bat OR Gram/Comp) ; 
ADD:xreal-guhkĂĄ (&real-guhkĂĄ) TARGET ("guhkĂĄ" Err/Orth Adv) OR ("guhkkĂĄ" N Nom) OR ("guhkkat" Prs Sg3) IF (-1 GRADE-ADV) (*0 GRAMCHK-VFIN BARRIER GRAMCHK-S-BOUNDARY2 OR COMMA) ;
    ## RĂĄhkisvuohta gal ii bistĂĄn beare guhkkĂĄ, muhto rĂĄhkisvuohta musihkkii buolligoÄii fas gulul. RĂĄhkisvuohta gal ii bistĂĄn beare guhkĂĄ, muhto rĂĄhkisvuohta musihkkii buolligoÄii fas gulul.
    ## Dat beare guhkkĂĄ doppe, iige daga maidege ieĆŸĂĄ.
    ## Dat lei guhkkĂĄ doppe, son gal ii hĂĄliidan vuolgit. - works (20.2.2014)
    ## GuhkkĂĄ dat boahtĂĄ bistit, dĂĄt vuosĂĄhus. - works (20.2.2014)
    ## Dat guhkkĂĄ boahtĂĄ bistit. - works (20.2.2014)
    # in errors.xml
	
ADD:xreal-guhkkĂĄ-guhkĂĄ (&real-guhkkĂĄ-guhkĂĄ) TARGET ("guhkĂĄ" Err/Orth Adv) OR ("guhkkĂĄ" N Nom) OR ("guhkkat" Prs Sg3) IF (*-1 (V <XT-Acc-Time>) BARRIER GRAMCHK-S-BOUNDARY2 OR V) ; 
COPY:real-guhkkĂĄ-guhkĂĄ ("guhkĂĄ" Adv SUGGEST) EXCEPT ("guhkĂĄ" Err/Orth Adv &real-guhkkĂĄ-guhkĂĄ) OR ("guhkkat" V IV Ind Prs Sg3 &real-guhkkĂĄ-guhkĂĄ) OR ("guhkkĂĄ" N Sg Nom &real-guhkkĂĄ-guhkĂĄ) OR ("guhkkat" V IV VGen &real-guhkkĂĄ-guhkĂĄ) OR ("guhkkat" V IV Imprt Sg2 &real-guhkkĂĄ-guhkĂĄ) OR ("guhkkat" V IV Imprt ConNeg &real-guhkkĂĄ-guhkĂĄ) OR ("guhkkat" V IV Ind Prs ConNeg &real-guhkkĂĄ-guhkĂĄ) TARGET (&real-guhkkĂĄ-guhkĂĄ) ;

COPY:real-guhkkĂĄ-guhkĂĄ ("guhkĂĄ" Adv SUGGEST) EXCEPT ("guhkĂĄ" Err/Orth Adv &real-guhkkĂĄ-guhkĂĄ) OR ("guhkkĂĄ" N Nom &real-guhkkĂĄ-guhkĂĄ) OR ("guhkkat" Prs Sg3 &real-guhkkĂĄ-guhkĂĄ) OR ("guhkkit" Prs Sg3 &real-guhkkĂĄ-guhkĂĄ) OR ("guhkkat" V IV VGen &real-guhkkĂĄ-guhkĂĄ) OR ("guhkkat" V IV Imprt &real-guhkĂĄ) OR ("guhkkit" ConNeg &real-guhkkĂĄ-guhkĂĄ) TARGET (V &real-guhkkĂĄ-guhkĂĄ) ;
    ## RĂĄhkisvuohta gal ii bistĂĄn guhkkĂĄ, muhto rĂĄhkisvuohta musihkkii buolligoÄii fas gulul.  
    # in errors.xml
	    
ADD:xreal-guhka-guhkĂĄ (&real-guhka-guhkĂĄ) TARGET ("guhkĂĄ" Err/Orth Adv) OR ("guhkkat" V IV Imprt Sg2) OR ("guhkkat" V IV Imprt ConNeg) OR ("guhkkat" V IV Ind Prs ConNeg) OR ("guhkkat" V IV VGen) IF (*0 VFIN)(NEGATE *0 V + Neg LINK NOT *1 ConNeg BARRIER GRAMCHK-S-BOUNDARY)(NEGATE 0 ("guhkĂĄ" Adv) - Err/Orth); #TIME-OBJ-VERB? <XT-Acc-Time>?
ADD:xreal-guhka-guhkĂĄ (&real-guhka-guhkĂĄ) TARGET ("guhkĂĄ" Err/Orth Adv) OR ("guhkkat" V IV Imprt Sg2) OR ("guhkkat" V IV Imprt ConNeg) OR ("guhkkat" V IV Ind Prs ConNeg) OR ("guhkkat" V IV VGen) IF (-1 ("nu"))(NEGATE 0 ("guhkĂĄ" Adv) - Err/Orth);
	## Ii dĂĄt galgĂĄ ĂĄdjanit nu guhka. - works (20.2.2014)
	## SĂĄmedikkis lea guhka leamaĆĄ ovttaoaivilvuohta boazodoallopolitihka vĂĄldolinjjĂĄid ektui.
	## Trollheimen boazodoallu lea guhka leamaĆĄ vĂĄttis dilis.
	## SĂĄmi mĂĄnĂĄid deaivvadeapmi mĂĄnĂĄidsuodjalusain lea guhka leamaĆĄ duhtatmeahttun.
COPY:real-guhka-guhkĂĄ ("guhkĂĄ" Adv SUGGEST) EXCEPT ("guhkĂĄ" Err/Orth Adv &real-guhka-guhkĂĄ) OR ("guhkkat" V IV Ind Prs Sg3 &real-guhka-guhkĂĄ) OR ("guhkkĂĄ" N Sg Nom &real-guhka-guhkĂĄ) OR ("guhkkat" V IV VGen &real-guhka-guhkĂĄ) OR ("guhkkat" V IV Imprt Sg2 &real-guhka-guhkĂĄ) OR ("guhkkat" V IV Imprt ConNeg &real-guhka-guhkĂĄ) OR ("guhkkat" V IV Ind Prs ConNeg &real-guhka-guhkĂĄ) TARGET (&real-guhka-guhkĂĄ) ;
	## Nu guhka go dĂĄn riikkas leat leamaĆĄ skuvllat, leat guovddĂĄĆĄ eisevĂĄlddit mearridan maid oahppit galget oahppat. Nu guhkĂĄ go dĂĄn riikkas leat leamaĆĄ skuvllat, leat guovddĂĄĆĄ eisevĂĄlddit mearridan maid oahppit galget oahppat.
	## Bellodat lea guhka leamaĆĄ ĂĄrvokonservatiiva ja liberĂĄlakonservatiiva. 
	## Guhka lean smiehtan rahkadit dakkĂĄr borramuĆĄ, muhto duĆĄĆĄe odne ollaĆĄuvvai smavvĂĄ niehku. - works (20.2.2014)
	## Biepmut eai ĂĄbut vurkkohuvvot nu guhka ahte billehuvvet/guohcagit/guhppot.




ADD:xreal-sĂĄrgon (&real-sĂĄrgon) TARGET 
 ("sĂĄrgut" Ex/V Der/NomAct N Sg Nom) OR 
 ("sĂĄrgut" Ex/V Ex/TV Der/NomAg N Ess) OR 
 ("sĂĄrgut" V TV Actio Nom) OR 
 ("sĂĄrgut" V IV Actio Gen) OR 
 ("sĂĄrgun" N Sem/Act Sg Gen Allegro) OR
 ("sĂĄrgut" Ex/V Ex/TV Der/NomAct N Sg Nom) OR 
 ("sĂĄrgun" N Sg Gen) OR 
 ("sĂĄrgun" N Sg Nom) OR 
 ("sĂĄrgu" N Ess) OR 
 ("sĂĄrgu" N NomAg Ess) OR 
 ("sĂĄrgu" N NomAg Sg Loc South Err/Orth) IF (*-1 BE + VFIN BARRIER V OR GRAMCHK-S-BOUNDARY);
 
COPY:real-sĂĄrgon ("sĂĄrgut" V TV PrfPrc SUGGEST) EXCEPT ("sĂĄrgu" N Ess &real-sĂĄrgon) OR 
 ("sĂĄrgun" N Sg Gen &real-sĂĄrgon) OR 
 ("sĂĄrgun" N Sg Nom &real-sĂĄrgon) OR 
 ("sĂĄrgun" N Sem/Act Sg Gen Allegro) OR 
 ("sĂĄrgut" Ex/V Der/NomAct N Sg Nom &real-sĂĄrgon) OR 
 ("sĂĄrgut" Ex/V Ex/TV Der/NomAg N Ess &real-sĂĄrgon) OR 
 ("sĂĄrgut" V TV Actio Nom &real-sĂĄrgon) OR 
 ("sĂĄrgut" V TV Actio Gen &real-sĂĄrgon) OR 
 ("sĂĄrgut" Ex/V Ex/TV Der/NomAct N Sg Nom &real-sĂĄrgon) OR ("sĂĄrgu" N NomAg Ess &real-sĂĄrgon) OR ("sĂĄrgu" N NomAg Sg Loc South Err/Orth &real-sĂĄrgon) TARGET (&real-sĂĄrgon) ;    
    ## Anne-Grethe Leine Bientie lea ÄĂĄllĂĄn teavstta ja su nieida Ellen Sara lea ges govaid sĂĄrgun.
    
    # vahkku iige vĂĄhku
    # -----------------

    
ADD:xreal-vahkku (&real-vahkku) TARGET ("vĂĄhku" N Sg Nom) OR ("vahkku" Err/Orth-a-ĂĄ N Sg Gen) OR ("vahkku" Err/Orth-a-ĂĄ N Sg Acc) IF (-1 (Num Sg));
COPY:real-vahkku (SUGGEST) EXCEPT (Err/Orth-a-ĂĄ) BEFORE N TARGET (Err/Orth-a-ĂĄ &real-vahkku) ;
