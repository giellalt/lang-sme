	# vallji compounds or valljugas
	# -------------------------------------
	# this should either be a compound (which would be fixed during mwe analysis) or if written appart in attributive form
	
ADD:xlex-vallji-valljugas (&lex-vallji-valljugas) TARGET  ("vallji" N Sg Nom) OR ("vallji" A Sg Nom) IF (*1 N BARRIER (*) - Attr - Gen LINK NEGATE 0 Sem/Ani OR Sem/Substnc OR Sem/Mat OR Sem/Ani-fish OR Sem/Food OR Prop - Nom)(NEGATE 0 &real OR &lex)(NEGATE 0 Sem/Human LINK 1 N + ADVLCASE) ;
	
COPY:lex-vallji-valljugas ("valljugas" A Attr SUGGEST) EXCEPT ("vallji" N Sg Nom &lex-vallji-valljugas) OR (N Sg Nom &lex-vallji-valljugas) OR (A Sg Nom &lex-vallji-valljugas) TARGET (&lex-vallji-valljugas) ;
