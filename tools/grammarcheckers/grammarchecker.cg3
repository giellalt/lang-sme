	#$ DĂĄl ĂĄigo ĂĄdjat dieÄihit ĂĄhkuide, go leat ĆĄaddan mĂĄĆggaid jagiid gierddahallat sin.


# Accusative numeral phrase

# Noun

ADD:xmsyn-numphrase-sgacc (&msyn-numphrase-sgacc) TARGET (N Pl Acc) IF (*-1 (Num Sg Nom) OR (Num Sg Acc) OR (Num Sg Gen) OR NUM-INDEF + (Sg Nom) OR NUM-INDEF + (Sg Acc) OR NUM-INDEF + (Sg Gen) BARRIER NOT-Attr - PrfPrc - GRADE-ADV  - (A <AttrPred> Sg Nom) - (A <AttrPred> Sg Gen) - (A <AttrPred> Sg Acc) - (Pcle Foc/Neg-ge) - (Pcle Foc/Pos-ge) OR JAHKASAS LINK NOT 0 <spelled> LINK NEGATE -1 KLASS)
(NEGATE 0 <spelled> LINK NEGATE 0 NP-HEAD)
(NEGATE 0 (Sg Gen) LINK *-1 (Num Sg Gen) OR NUM-INDEF + (Sg Gen))
(NEGATE 0 Attr LINK 1 ADVLCASE) # vihtta guovddĂĄĆĄ mihttosuorgĂĄi 
(NEGATE *-1 ("okta") OR ("1") BARRIER NOT-Attr - PrfPrc)
(NEGATE *-1 (Num Sem/Year) BARRIER NOT-Attr - PrfPrc)
(NEGATE *-1 (Num Rom) BARRIER NOT-Attr - PrfPrc)
(NEGATE *-1 Num BARRIER NOT-Attr - PrfPrc LINK -1 KLASS OR NUMMAR OR COUNTABLE)
(NEGATE *-1 (Arab Ord) BARRIER NPNHA OR Num)
(NEGATE *-1 (Num Sem/ID) BARRIER NPNHA OR Num)
(NEGATE *-1 Num BARRIER NPNHA LINK 0 ("aktan" Adv))
(NEGATE *-1 Num BARRIER NPNHA LINK 1 Dem)
(NEGATE *-1 (Num "<[Â§].*>"r) OR (Num "<.*%>"r) OR ("%") BARRIER NPNHA - Num)
(NEGATE *-1 (Num "<.*[0123456789]-.*>"r) BARRIER NPNHA OR Num)
(NEGATE *-1 (Num Sg Nom) BARRIER NPNHA LINK -1 BE + Sg3 OR BE + Du3 OR BE + Pl3 LINK -1 (Dem Pl Loc) OR (Pers Pl3 Loc) OR (Pers Pl2 Loc) OR (Pers Pl1 Loc)) 
(NEGATE -1 JAHKASAS LINK -1 (Num)) 
(NEGATE -1 NUMUNIT LINK -1 PLURAL-QUANTIFIERS OR Num)
(NEGATE -1 NUMUNIT LINK -1 Num OR ("moadde"))
(NEGATE -1 Sem/Time)
(NEGATE -1 COMMA OR CC)
(NEGATE -1 CLB)
(NEGATE -1 (PUNCT RIGHT) LINK -1 Num) 
(NEGATE 0 ABBR OR Prop)
(NEGATE 0 ("lohku"))
#(NEGATE 0 ("<[A-Z].*>"r) OR ("<Ă.*>"r) OR ("<Ă.*>"r) OR ("<Ă.*>"r) LINK -1 (Arab Nom))
#(NEGATE 0 (Der/NomAct Sg Nom) LINK 0 PrfPrc LINK *1 (N Pl Nom)  BARRIER NOT-Attr) 
(NEGATE 0 <spelled> OR &real)
(NEGATE 0 Symbol)
(NEGATE 0 ("luohkkĂĄ") LINK -1 (".*[a-z]"r Arab));
 
COPY:msyn-numphrase-sgacc (Sg SUGGEST) EXCEPT (Pl) BEFORE CASE TARGET (Pl N &msyn-numphrase-sgacc) ;
	## Fitnodaga ĂĄlggaheaddji ja sĂĄivaÄĂĄhcebiologa Rune Muladal muitala Ăvvirii ahte Deanu ÄĂĄzĂĄdagas lea nu guhkes gaska gaskal luossaveajehiid, ahte ĂĄdjĂĄna 5-6 geardde guhkit Äohket nu mĂĄĆga veajehiid go dĂĄrbbaĆĄit.
	#$ Muhtun bĂĄikkiin, ee. SĂĄllanis, nohkagoÄii meahccefuoÄÄariid Äohken 1930 jagiid loahpas.
	## Giitu ollu visot nuorat JĂ„hkĂ„mĂ„hkes geat serve leairras, ja giitu go mii {beasaime} leat ovttas dinguin daid guokte leairabeivviid!
	#$ EisevĂĄlddit leat juolludan miljovnnaid {rĂĄjĂĄid} rastĂĄ doaibmi oktasaĆĄ proĆĄeavttaide, muhto ii oro gĂĄvdnomin resursa addit lobi moadde mĂĄnĂĄ vuojihit skohteriin rastĂĄ joga.

	
# Num wrong Num

ADD:xmsyn-numphrase-sgacc (&msyn-numphrase-sgacc) TARGET (Num Sg Nom) OR NUM-INDEF + (Sg Nom) - <NomAccSg> OR NUM-INDEF + (Sg Gen) IF (*1 (N Acc &msyn-numphrase-sgacc) OR (N Sg Acc) - &msyn-numphrase-sgacc BARRIER NOT-Attr - PrfPrc - GRADE-ADV - (A <AttrPred> Sg Nom) - (A <AttrPred> Sg Gen) - (A <AttrPred> Sg Acc)  - (Pcle Foc/Neg-ge) - (Pcle Foc/Pos-ge) LINK NOT 0 (Sg Nom)) # ("okta" Sg Nom) OR ("1" Sg Nom) 
(NEGATE 0 (Sg Acc))
(NEGATE 0 ("<.*%>"r)) 
(NEGATE 0 (Num "<[0123456789]-.*>"r))
(NEGATE 0 (Num "<biel.*>"r))
(NEGATE 0 Sem/Date OR (N Coll Nom) OR ("tuvsĂĄn" Num Pl Nom) OR Sem/Year) 
(NEGATE 0 (Arab Nom) LINK 1 ("<[A-Z].*>"r) OR ("<Ă.*>"r) OR ("<Ă.*>"r) OR ("<Ă.*>"r))
(NEGATE 0 (Num Rom)) 
(NEGATE 0 &msyn-gen-numeral-jahkasaĆĄ)
(NEGATE 1 Prop)
(NEGATE 0 Arab LINK 1 ABBR )
(NEGATE 1 Num LINK NOT 0 NUMUNIT)
(NEGATE 1 Dem) 
(NEGATE 1 COMMA) 
(NEGATE 1 (PUNCT RIGHT))
(NEGATE 1 ("ja"))
(NEGATE 1 ("lĂ„hko"))
(NEGATE 1 JAHKASAS)
(NEGATE *1 (N <spelled>) BARRIER NPNHA) ;


# coordinated adjectives
# to the right
ADD:xmsyn-numphrase-sgnom (&msyn-numphrase-sgnom) TARGET ("akta" Sg Nom) OR ("1" Sg Nom) IF (*1 PRE-NP-HEAD BARRIER NOT-ADV OR JAHKASAS LINK 1 CC LINK 1 PRE-NP-HEAD LINK *1 (N Sg Nom) + &msyn-numphrase-sgnom BARRIER NOT-Attr - PrfPrc - GRADE-ADV  - (A <AttrPred> Sg Nom) - (A <AttrPred> Sg Gen) - (A <AttrPred> Sg Acc) - (Pcle Foc/Neg-ge) - (Pcle Foc/Pos-ge) LINK NOT 0 (N Coll Nom) OR ("tuvsĂĄn" Num Pl Nom)) # OR PL-PAIR-N) 
(NEGATE -1 NUMMAR)
(NEGATE -1 (Dem Acc))
(NEGATE 0 NUMUNIT LINK -1 Num OR NUM-INDEF) 
(NEGATE 0 (N Coll Nom) OR ("tuvsĂĄn" Num Pl Nom) OR Sem/Year OR Sem/Date OR Sem/Time-clock) 
(NEGATE 0 ONE + (Sg Gen) LINK 1 ("vuoras")) 
(NEGATE 0 (Num "<biel.*>"r))
(NEGATE 0 &msyn-gen-numeral-jahkasaĆĄ)
(NEGATE 0 (Num "<[0123456789]-.*>"r))
(NEGATE *1 (N <spelled>) BARRIER NPNHA) ;
	## 

	# incorrect noun
	
ADDRELATION ($2 LEFT) (N &msyn-numphrase-sgacc) OR NUMUNIT + &msyn-numphrase-sgacc OR NUM-INDEF + &msyn-numphrase-sgacc TO (*-1 (Num &msyn-numphrase-sgacc) OR (Num Sg Acc) - &msyn-numphrase-sgacc OR NUM-INDEF + (Sg &msyn-numphrase-sgacc));

	# correct noun wrong numeral
	
ADDRELATION ($2 RIGHT) (Num &msyn-numphrase-sgacc) OR NUM-INDEF + (Sg &msyn-numphrase-sgacc) TO (*1 (N Sg Acc)  - &msyn-numphrase-sgacc OR NUMUNIT + (Sg Acc) - &msyn-numphrase-sgacc OR NUM-INDEF + (Sg Acc) - &msyn-numphrase-sgacc) ;


COPY:msyn-numphrase-sgacc (Sg Acc SUGGEST) EXCEPT (Pl Acc) TARGET (Num Pl &msyn-numphrase-sgacc) OR NUM-INDEF + (Pl &msyn-numphrase-sgacc);



