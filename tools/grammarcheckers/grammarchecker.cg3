(NEGATE -1 Sem/Time) (NEGATE 0 NUMUNIT LINK 1 N)
(NEGATE -1 (PUNCT RIGHT) LINK -1 Num) 
(NEGATE 0 Symbol)
(NEGATE 0 (N Sg)) 
(NEGATE 0 Px LINK NOT 0 (Sg Acc PxSg3) OR (Sg Nom PxSg3) OR (Sg Gen PxSg3))
(NEGATE 0 <spelled>)
(NEGATE 0 PL-NOUN + (Pl Acc) LINK *-1 (Num Pl Acc) BARRIER NOT-Attr) ;
