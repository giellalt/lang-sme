#DELETE SECOND ROUND
ADD:xsyn-case-congruence-buorre (&syn-case-congruence-buorre) TARGET CONGRUENCE-A + (Nom Pl) IF (*1 (Pl Acc) OR (Pl Gen) BARRIER GRAMCHK-NPNHA OR Sg) (NEGATE 0 Gen + Cmp/SplitR OR &syn-number_congruence-moanat)(NEGATE -1 &syn-number_congruence-moanat)(NEGATE *-1 ("ii" Neg) BARRIER GRAMCHK-S-BOUNDARY) ;
	## Buorit ulbmiliid eai vأ،ldde vuhtii.
	#$ Ruؤ‘alaإ، ja earأ، buhtadusat eai	buorit dili	jus ieإ¾aset sajأ،iduvvan soardi doaibman- ja lأ،httenvuogit eai gieؤ‘ahallo.
	## â€“ Ledjen vuordأ،n	buorit bohtosiid.
	## Boazodoallu ii sأ،hte seailut sأ،mi kultuvrra guoddin jus nuoraide geat hأ،lidit أ،lggahit boazodoalu eai leat buorit rأ،mmaeavttuid.
	## Ferte baicce geavahit أ،iggi mii dأ،rbbaإ،uvvo vai ovttas gأ،vdnat buorit ؤچoavdagiid.
	## Ruoإ§a ruvkefitnodagas, Arctic_Gold, leat oإ¾إ¾on buorit iskanbohtosiid Biedjovأ،kkis Guovdageainnus, muhto galget ain joatkit golle- ja veaikkeohcamiid guovllus.
	## Dat lea hui	buorit bohtosiid go diehtit ahte Guruhis ii oba leat ge leamaإ، أ،irasat Sأ،medikkis maإ‹emus أ،igodagain.
	## Buenos Aires : Mitch orkأ،na bilideamit leat gأ،ibidahttأ،n sirdit meterologalaإ، teknologiija ja ؤچehppodaga geafes riikkaide, vai sihkkarastأ،إ،ivؤچؤچii buorit dأ،lkemihtidemiid.
	## Muhto maiddأ،i Gurut ja sorjjaskeahtes listu, ja Sosiأ،listtalaإ، Gurutbellodat leat dahkan buorit vأ،lggaid.
	## â€“ Sأ،tnejoؤ‘iheaddji geatnegasvuohta lea أ،lo mأ،rkanastit daid buorit beliid.
	## Lofoten XCR Gore-Tex-jأ،hkka lea heivehuvvon sidjiide geat hأ،lidit biktasa mas leat buorit vuoigإ‹anieإ،vuoؤ‘aid	ja lea geahpas.
	
		
ADD:xsyn-case-congruence-buorre (&syn-case-congruence-buorre) TARGET CONGRUENCE-A + ( Acc Sg) OR CONGRUENCE-A + ( Gen Sg) IF (*1 (Pl Acc) OR (Pl Gen) BARRIER GRAMCHK-NPNHA OR Sg) (NEGATE 0 Gen + Cmp/SplitR OR &syn-number_congruence-moanat)(NEGATE -1 &syn-number_congruence-moanat) ;
	## Plأ،na ja huksenlأ،hka oktan teknihkkalaإ، lأ،hkaأ،sahusain, bidjأ، gأ،ibأ،dusa dasa ahte lأ،hؤچؤچet dili olbmuide geain leat أ،iccan- ja lihkadanvأ،ttut, ja gأ،ibأ،dusat leat nu ahte galggaإ،ivؤچؤچii vuoؤ‘ؤ‘udit  {buori} ؤچovdosiid.
	## gullevaإ،vuoؤ‘a sأ،mi servodahkii, sihkkarastit buori bajأ،sإ،addaneavttuid go servodat rievdأ،
	## geahؤچؤچaluvvon ja addأ،n buori bohtosiid 
	## buori eavttuid mأ،nأ،idgأ،rddis, dأ،kko bokte
	#$ Boazodoallohأ،lddahus galgأ، leat mielde fuolaheamis ahte doarjjaortnegat adnojit vuogأ،laؤچؤچat vai أ،rvohأ،hkama lokte أ،lkit ja buoret njuolggadusaid bokte.
ADD:xsyn-case-congruence-buorre (&syn-case-congruence-buorre) TARGET CONGRUENCE-A + ( Ill Sg) IF (*1 (Pl Ill) BARRIER GRAMCHK-NPNHA OR Sg) (NEGATE 0 Gen + Cmp/SplitR OR &syn-number_congruence-moanat)(NEGATE -1 &syn-number_congruence-moanat) ;
ADD:xsyn-case-congruence-buorre (&syn-case-congruence-buorre) TARGET CONGRUENCE-A + ( Com Sg) IF (*1 (Pl Com) BARRIER GRAMCHK-NPNHA OR Sg) (NEGATE 0 Gen + Cmp/SplitR OR &syn-number_congruence-moanat)(NEGATE -1 &syn-number_congruence-moanat) ;
	## â€“ Buot lea sأ،hka dovdduid birra, dadjأ، Trygve Johansen ja dadjأ، : â€“ Buriin dovdduiguin olmmoإ، ovdأ،nahttأ، ieإ¾as. 
	
	## ؤŒoahkkimis oidne ahte seammأ،s go raportain leat bargan de leat أ،sahan buori oktavuoؤ‘aid oassalasttii suohkaniid gaskkas.
	## Go dأ،n digaإ،tallama loktejit guovllulaإ، dأ،ssأ،i de das lea buoret vuoؤ‘ؤ‘u gأ،vdnat vel eanet buori أ،kkaid ja buorebut sأ،httet oktiiؤچatnat fierpmأ،dagaid Norggas ja Suomas.
	## Plأ،na ja huksenlأ،hka oktan teknihkkalaإ، lأ،hkaأ،sahusain, bidjأ، gأ،ibأ،dusa dasa ahte lأ،hؤچؤچet dili olbmuide geain leat أ،iccan- ja lihkadanvأ،ttut, ja gأ،ibأ،dusat leat nu ahte galggaإ،ivؤچؤچii vuoؤ‘ؤ‘udit buori ؤچovdosiid.
	## Mii fertet vieإ¾إ¾at gelbbolaإ،vuoؤ‘a goappaإ،iin, ja ovttas hأ،bmet buori fأ،laldagaid divإ،إ،ohasaide.
	#$ Dan sadjأ،i go أ،lohii oؤ‘ؤ‘a doaimmaid bahkkehit mأ،nnأ،i, vaikko vel mii أ،iggoإ،eimmet ge buori mأ،nأ،ide.
	## Ovccis dieؤ‘ihedje eksamenii, gأ،vccis geahؤچؤچaledje ja ؤچieإ¾as cevcce buriin bohtosiiguin.
	#$ Lonuheapmi lei buorre olbmuide oaإ¾إ¾ut jأ،ffuid, sohkkariid, gأ،fiid ja ieإ¾أ، gأ،lvvuid mat sis eai lean.
	#$ Danne lei buorre mearrasأ،miide ahte ealut bohte sadjأ،i.
	
ADD:xsyn-case-congruence-buorre (&syn-case-congruence-buorre) TARGET CONGRUENCE-A + ( Acc Sg) OR CONGRUENCE-A + ( Gen Sg) IF (*1 (Pl Ill) OR (Pl Loc) OR (Pl Com) BARRIER GRAMCHK-NPNHA OR Sg LINK *-1 VFIN OR Inf OR ConNeg OR PrfPrc BARRIER VFIN OR GRAMCHK-S-BOUNDARY LINK NEGATE 0 TV LINK NONE c OBJ) (NEGATE 0 Gen + Cmp/SplitR OR &syn-number_congruence-moanat)(NEGATE -1 ("juoga" Pron Indef Sg Acc))(NEGATE -1 &syn-number_congruence-moanat) ;
	## Lea daddjon ahte dأ،t ortnet hui funet goziha sأ،mi beroإ،tumiid ja ahte hأ،lddaإ،anmأ،lle maid Statsskog SF ovddasta, ii soaba buori hأ،lddaإ،anvieruide. -- buriide hأ،lddaإ،anvieruide
	## Ortnet lea leamaإ، gأ،ibideaddji hأ،lddahuإ،laؤچؤچat ja 2006 ja 2007 vأ،sأ،husat eai leat nu buori beavttuin, go mii lei vurdojuvvon.	
	#$ â€“ Min mielas Beaivvأ،إ¾ii lea hui buorre go sأ،httit dahkat juoidأ، buori boarrأ،siidda ja dahkat veahأ،إ، earأ،lأ،gan beaivvi sidjiide, muitalusain, lأ،vlagiiguin ja divttaiguin. 
	## Leahkit buori olbmuiguin fأ،rrolagaid. 
	## â€“ Eai dأ،idde vأ،ilot Unjأ،rggas nissonat dأ،n bأ،lkkaإ،upmأ،i, dadjأ، lأ،vdegoddi ja bivdet vilppastit rأ،nnjأ،i, jus son lea bargan eaktodأ،htolaإ، barggu bأ،ikkأ،laإ، servodagas, dahje muhtun nisu gii أ،lo veahkeha, buorre bargoskibir buori jurdagiiguin, nisu mii lea ovdagovvan earأ،ide dahje nisu gii mأ،rkanfievrrida gielda bures ja أ،rvosaؤچؤچat. 
	## Mii veardidit dieؤ‘usge du fysalaإ، beali, muhto buohkat geat ؤچaؤ‘ahit militeara mannet dأ،ppe buori foarpmain, dadjأ، Myhre.  DOESNT WORK
	## Mu mihttu lea ahte pأ،ntalotteriija galgأ، luvvet bissovaإ، doarjaga buori fأ،laldagaide, nu go Rukses Russii, lohkأ، Olav Thon
	
ADD:xsyn-case-congruence-buorre (&syn-case-congruence-buorre) TARGET CONGRUENCE-A + ( Acc Sg) OR CONGRUENCE-A + ( Gen Sg) IF (*1 (Pl Ill) OR (Pl Loc) OR (Pl Com) BARRIER GRAMCHK-NPNHA OR Sg LINK NEGATE *0 VFIN OR Inf OR ConNeg OR PrfPrc) (NEGATE 0 Gen + Cmp/SplitR OR &syn-number_congruence-moanat)(NEGATE -1 ("juoga" Pron Indef Sg Acc))(NEGATE -1 &syn-number_congruence-moanat) ;	
