#DELETE uncommon	
ADD:xmsyn-valency-badjel-acc (&msyn-valency-badjel-acc) TARGET ("badjel") IF (-1 Gen LINK *0 ("sihkodit") OR ("sihkkut") OR ("njأ،vkkadit") BARRIER GRAMCHK-S-BOUNDARY)(NEGATE *1 Num OR Sem/Measr OR Sem/Curr OR Sem/Money BARRIER GRAMCHK-NPNH)(NEGATE -1 Num OR Sem/Measr OR Sem/Curr OR Sem/Money) ;
	# OLD: msyn-valency-badjel-acc

ADD:xmsyn-valency-badjel-acc (&msyn-valency-badjel-acc) TARGET Gen IF (1 ("badjel" &msyn-valency-badjel-acc)) ;

