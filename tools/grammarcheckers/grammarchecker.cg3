#LIST ADV-NOT-ARG2 = "aiddo" "ain" "aivve" "albma" "aÅkke" "ÃĄlggos" "ÃĄlgobÃĄliid" "ÃĄlo" "bÃĄifÃĄhkka" "beanta" "beare" "dakkaviÄe" "dal" "dan_dihte" "danne" "dasto" "dattetge" ("dÃĄbÃĄlaÅĄ" Adv) "dÃĄvjÃĄ" "de" "dieÄinge" "dieÄusge" "duoÄaid" "easkka" "fal" "fargga" "fas" "fÃĄrrolaga" "gal" "goas" "goasse" "gos" "gosa" "gostege" "govt" "gusto" "hedi" "juo" "justa" "loahpas" "maiddÃĄi"  "manin" "manne" "nuppes" "suige" "ÅĄat" "vel" "viimmat" "vuos" ;


