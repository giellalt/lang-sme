(NEGATE 0 ("<.*%>"r)) 
(NEGATE 0 (Num "<[0123456789]-.*>"r))
(NEGATE 0 (Num "<biel.*>"r))
(NEGATE 0 Sem/Date OR (N Coll Nom) OR ("tuvsأ،n" Num Pl Nom) OR Sem/Year) 
(NEGATE 0 (Arab Nom) LINK 1 ("<[A-Z].*>"r) OR ("<أ….*>"r) OR ("<أ†.*>"r) OR ("<أک.*>"r))
(NEGATE 0 (Num Rom)) 
(NEGATE 0 &msyn-gen-numeral-jahkasaإ،)
(NEGATE 1 Prop)
(NEGATE 0 Arab LINK 1 ABBR )
(NEGATE 1 Num LINK NOT 0 NUMUNIT)
(NEGATE 1 Dem) 
(NEGATE 1 COMMA) 
(NEGATE 1 (PUNCT RIGHT))
(NEGATE 1 ("ja"))
(NEGATE 1 ("lأ¥hko"))
(NEGATE 1 JAHKASAS)
(NEGATE *1 (N <spelled>) BARRIER NPNHA) ;


# coordinated adjectives
# to the right
ADD:xmsyn-numphrase-sgnom (&msyn-numphrase-sgnom) TARGET ("akta" Sg Nom) OR ("1" Sg Nom) IF (*1 PRE-NP-HEAD BARRIER NOT-ADV OR JAHKASAS LINK 1 CC LINK 1 PRE-NP-HEAD LINK *1 (N Sg Nom) + &msyn-numphrase-sgnom BARRIER NOT-Attr - PrfPrc - GRADE-ADV  - (A <AttrPred> Sg Nom) - (A <AttrPred> Sg Gen) - (A <AttrPred> Sg Acc) - (Pcle Foc/Neg-ge) - (Pcle Foc/Pos-ge) LINK NOT 0 (N Coll Nom) OR ("tuvsأ،n" Num Pl Nom)) # OR PL-PAIR-N) 
(NEGATE -1 NUMMAR)
(NEGATE -1 (Dem Acc))
(NEGATE 0 NUMUNIT LINK -1 Num OR NUM-INDEF) 
(NEGATE 0 (N Coll Nom) OR ("tuvsأ،n" Num Pl Nom) OR Sem/Year OR Sem/Date OR Sem/Time-clock) 
(NEGATE 0 ONE + (Sg Gen) LINK 1 ("vuoras")) 
(NEGATE 0 (Num "<biel.*>"r))
(NEGATE 0 &msyn-gen-numeral-jahkasaإ،)
(NEGATE 0 (Num "<[0123456789]-.*>"r))
(NEGATE *1 (N <spelled>) BARRIER NPNHA) ;
	## 


ADDRELATION ($2 LEFT) (N &msyn-numphrase-sgacc) OR NUMUNIT + &msyn-numphrase-sgacc OR NUM-INDEF + &msyn-numphrase-sgacc TO (*-1 (Num &msyn-numphrase-sgacc) OR NUM-INDEF + (Sg &msyn-numphrase-sgacc));


