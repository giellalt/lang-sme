SET IT-EVEN-VERBS = IT-VERBS - Gram/3syll - Der/h - Der/d - Der/st - Der/l - Der/Caus - Der/huvva - Der/stuvva - Der/PassS - Der/adda - Der/alla - Der/easti - Der/InchL ;
