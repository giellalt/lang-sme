# ========== #
# Delimiters #
# ========== #

DELIMITERS = "<.>" "<!>" "<?>" "<...>" "<Âķ>" "<\n\n>" ;

# ============= #
# Tags and sets #
# ============= #

SETS

# I define end of clause and beginning of clause in a way so that the file
# may be read both by the CG-2 and the vislcg formalisms.

LIST BOS = (>>>) (<s>);
LIST EOS = (<<<) (</s>);

# CG3 doesnÂīt function without >>> and <<< !

# Tags declared as single-membered LISTs
# ======================================

# Parts of speech
# ---------------

LIST N = N ;
LIST A = A ;
LIST Adv = Adv ;
LIST V = V ;
LIST Pron = Pron ;

LIST CS = CS ;
LIST CCC = CC ;
SET CC = CCC - ("sihke") ;
SET CC-CS = CC OR CS ;
LIST Po = Po ;
LIST Pr = Pr ;

LIST Pcle = Pcle ;
LIST Num = Num ;
LIST Arab = Arab ;
LIST Coll = Coll ;
LIST Span = Span ;
LIST Known = Known ;
LIST NomAg = NomAg ;
LIST Der/NomAg = Der/NomAg ;
LIST Gram/NomAg = Gram/NomAg ;
SET NOMAG = NomAg OR Der/NomAg ;
LIST G3 = G3 ;
LIST Gram/3syll = Gram/3syll ;
LIST Prop = Prop ;
LIST Symbol  = Symbol  ;

LIST LEFT = LEFT ;
LIST RIGHT = RIGHT ;
LIST WEB = WEB ;
LIST MWE = MWE ;


LIST Ex/V = Ex/V ;
LIST Ex/IV = Ex/IV ;
LIST Ex/TV = Ex/TV ;
LIST Ex/A = Ex/A ;
LIST Ex/N = Ex/N ;

LIST V* = V* ;
LIST A* = A* ;

# POS sub-categories
# ------------------

LIST Pers = Pers ;
LIST Dem = Dem ;
LIST Interr = Interr ;

LIST Indef = Indef ;

LIST Recipr = Recipr ;
LIST Refl = Refl ;
LIST Rel = Rel ;

LIST Interj = Interj ;


