	############################################################
	# GENERAL REAL WORD ERROR RULES	(based on morpho-phonology)#
	############################################################

	# Der/h  vs inf, -i, -a, -u; alla konsonantgrupper utom  1 och 4D, grad III-II, infinitive grade III
	# -----------------------------------------------------------------

	# {sĂĄhtit}Âą{verb,conc|sĂĄhttit}, {oahpat}Âą{verb,conc|oahppat}

	# set for idiosyncratic confusion partners

LIST CONFUSIONS-Der/h-Inf-NOUN = ("visti" N Pl Nom) ("vistit" Der/h) ("vuovdi" N Pl Nom) ("vuovdit" Der/h) ("goddi" N Pl Nom) ("goddit" Der/h) ("iÄit" N Sg Nom) ("ihtit" Der/h) ("ruska" N Pl Nom) ("ruskat" Der/h) ("lĂĄdda" N Pl Nom) ("lĂĄddat" Der/h) ("dĂĄhttu" N Pl Nom) ("dĂĄhttut" Der/h) ("osku" N Pl Nom) ("oskut" Der/h) ("Äivga" N Pl Nom) ("Äivgat" Der/h) ("Äuovga" N Pl Nom) ("Äuovgat" Der/h) ("bievla" N Pl Nom) ("bievlat" Der/h) ("doaibma" N Pl Nom) ("doaibmat" Der/h) ("ovttasdoaibma" N Pl Nom) ("ovttasdoaibmat" Der/h) ("Äuolbma" N Pl Nom) ("Äuolbmat" Der/h)  ("gazza" N Pl Nom)  ("gazzat" Der/h) ("lihppu" N Pl Nom) ("lihpput" Der/h) ("gĂĄlga" N Pl Nom) ("gĂĄlgat" Der/h) ("vĂĄlga" N Pl Nom) ("vĂĄlgat" Der/h) ("bircu" N Pl Nom) ("bircut" Der/h) ("ĆĄolĆŸa" N Pl Nom) ("ĆĄolĆŸat" Der/h)("duolva" N Pl Nom) ("duolvat" Der/h) ("Äorbma" N Pl Nom) ("Äorbmat" Der/h)  ("borga" N Pl Nom) ("borgat" Der/h) ("gaska" N Pl Nom) ("gaskat" Der/h) ("rĂĄvĆŸa" N Pl Nom) ("rĂĄvĆŸat" Der/h) ;

	#("vuoigĆa" N Pl Nom) ("vuoigĆat" Der/h)

LIST CONFUSIONS-Der/h-Inf-VERB = ("cĂĄbmit" Der/h) ("nohkkat" Der/h) ("Äahkkat" Der/h) ("vĂĄddut" Der/h) ("viibmat" Der/h) ("baikit" Der/h) ("rĂĄhÄÄat" Der/h) ("Äalbmat" Der/h) ("rĂĄggut" Der/h) ("vildat" Der/h) ("njuolgut" Der/h)  ("sealgat" Der/h) ("bĂĄrgut" Der/h) ("njuolgat" Der/h) ("njuolgat" Ind Prs Sg2);

LIST <*Inf> = <.*-?Inf>r <Inf> <.*-?-Acc-.*-?><.*-?Inf>r ;

LIST STOP-ADV = "de" "minddar" "muÄui" ;


ADD:real-Derh-Inf (&real-Derh-Inf) TARGET IT-EVEN-VERBS + CONC-1-2-3-4ABC-GRADE-II-III IF (0 (Der/h ConNeg) - Prt OR (Der/h Imprt Sg2) OR (Der/h Ind Prs ConNeg))(NEGATE 0 &real OR Inf - Err/Orth OR CONTRACT-VERBS OR Der/PassL OR Der/alla)(NEGATE *-1 NOT-V BARRIER <Inf> OR (V <TH-Inf>) OR (V <PU-Inf>) OR ConNeg OR PrfPrc)(NEGATE -1 CC LINK *-1 ConNeg  BARRIER <Inf> OR (V <TH-Inf>) OR (V <PU-Inf>) LINK -1 NOT-V)(NEGATE *-1 N + Sem/Hum BARRIER NOT-ADV-PCLE LINK -1 (Prt ConNeg) OR PrfPrc LINK *-1 NOT-V BARRIER <Inf> OR (V <TH-Inf>) OR (V <PU-Inf>) OR ConNeg OR PrfPrc)(NEGATE *1 ("!"))(NEGATE 0 <spelled> OR Inf - Err/Orth OR (N Pl Nom) OR CONFUSIONS-Der/h-Inf-NOUN OR CONFUSIONS-Der/h-Inf-VERB)(NEGATE -1 CC LINK *-1 (Imprt Sg2))(NEGATE 0 IT-VERBS LINK *-1 (Sem/Hum Pl3 Nom) OR (Sem/Hum Pl Nom))(NEGATE -1 (Dem Attr))(NEGATE 1 CC OR ("/") LINK 1 (Imprt Sg2))(NEGATE -1 BOS);
    #$ DieÄit maid ĂĄlo go vieÄÄat mĂĄnĂĄ. #DieÄit!
    #$ Jos BiggĂĄ ii goarkĆo almmi allodahkii dahje luoittit balvvaid mielde, de mĂĄraidahttĂĄ meara, meaĆĄĆĄu suinniid ja muoraid dahje bossu muohttagii Äastasiid, bohkolasaid ja goapmaskĂĄlvviid. #luoittit
    #$ ÄĂĄlit ja darvvit buoremus siidduid seaidnetĂĄvvalii. #darvvit
    #$ DakkĂĄr garvvit go reagas ledje, ledje duoppe dĂĄppe. #garvvit
    #$ Loga geahÄÄalemiide, ceavzze eksĂĄmena ja dieÄit munnje go mĂĄhcat vĂĄiban ruoktot ovtta beaivve, go dus lea ĂĄigi.. #dieÄit
    #$ Dasgo ii dĂĄbĂĄlaĆĄ Äuvggodan olmmoĆĄ vuosttamuĆŸĆŸan heaittit skuvlla.
    #$ DakkĂĄr garvvit go reagas ledje, ledje duoppe dĂĄppe.
	#$ Son baicce lohkĂĄ ahte visttit mat ledje GĂĄrasavvonis, livÄÄe sĂĄhtit dagahit dearvvaĆĄvuoÄa vĂĄttisvuoÄaid.  #   visttit!
    #$ SEmS â Mus lea niehku ollet guhkĂĄs dujiin, ja jurdda lea gazzat viidĂĄseappot duodjeoahpu, lohkĂĄ Magga. # ollet!
    #$ Son biddjui dĂĄvjĂĄ skuvlalanjas olggos go ii jeagadan lohkat Äuodjalit dahje dadjat dĂĄrogillii buorre idit skuvlaolbmĂĄi.  -  idit
	## Juos hĂĄliidat fĂĄktĂĄdieÄuid suohkana birra, gĂĄvnnat daid ja juos dovddat beroĆĄtumi bargagoahtit suohkanis, sĂĄvvamis sĂĄhtit addit maid dieÄuid rabas virggiid birra.
    #$ argumentere ovttaÄilggolaÄÄat iige ÄuoÄÄut ovttatlĂĄhkai.
    #$ Easka miessemĂĄnu ĂĄlggus lea vejolaĆĄ iskat ÄuoÄÄut go jienastuslogus.
