LIST CONC-1 = (".*ؤ‘ؤ‘.*"r) (".*ff.*"r) (".*ll.*"r) (".*mm.*"r) (".*nn.*"r) (".*إ‹إ‹.*"r) (".*rr.*"r)  (".*إ،إ،.*"r)  (".*إ§إ§.*"r)  (".*vv.*"r) ;
