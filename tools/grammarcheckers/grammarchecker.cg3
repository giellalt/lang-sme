    ## Veagat guvttiiguin mĂĄnĂĄiguin. Veagat guvttiin mĂĄnĂĄin.
    ## Veagat golmmaiguin dahje eanet mĂĄnĂĄiguin. Veagat golmmain dahje eanet mĂĄnĂĄin.
    ## SĂĄmi nuoraidorganisaĆĄuvnnat bovdejuvvojit oassĂĄlastit guvttiiguin (2) ĂĄirasiiguin ja guvttiiguin (2) vĂĄrreĂĄirasiiguin. SĂĄmi nuoraidorganisaĆĄuvnnat bovdejuvvojit oassĂĄlastit guvttiin (2) ĂĄirasiin ja guvttiin (2) vĂĄrreĂĄirasiin.	#$ DĂĄt mĂĄtki heive measta buohkaide ja lea rehkenaston ĂĄdjĂĄnit sullii golbma diimmu bottoĆŸiiguin go vĂĄzzet olles bĂĄlgĂĄ mii lea 10,8 km, muhto lea vejolaĆĄ maid jorggihit ÄohkkĂĄs ruovttoluotta jus hĂĄlidat oanehit mĂĄtkki.	

COPY:msyn-numphrase-sgcom (Sg SUGGEST) EXCEPT (Pl) BEFORE CASE TARGET (N &msyn-numphrase-sgcom) ;

# Num

ADD:msyn-numphrase-sgcom (&msyn-numphrase-sgcom) TARGET (Num Pl Com) OR (Num Sg Com) OR NUM-INDEF + (Sg Com) OR NUM-INDEF + (Pl Com) IF (*1 (N Com &msyn-numphrase-sgcom) BARRIER NOT-Attr - PrfPrc - GRADE-ADV - (A <AttrPred> Sg Nom) - (A <AttrPred> Sg Gen) - (A <AttrPred> Sg Acc)  - (Pcle Foc/Neg-ge) - (Pcle Foc/Pos-ge)) # ("okta" Sg Nom) OR ("1" Sg Nom) 
(NEGATE 0 ("<.*%>"r)) 
(NEGATE 0 (Num "<[0123456789]-.*>"r))
(NEGATE 0 (Num "<biel.*>"r))
(NEGATE 0 Sem/Date OR (N Coll Nom) OR ("tuvsĂĄn" Num Pl Nom) OR Sem/Year) 
(NEGATE 0 (Arab Nom) LINK 1 ("<[A-Z].*>"r) OR ("<Ă.*>"r) OR ("<Ă.*>"r) OR ("<Ă.*>"r))
(NEGATE 0 (Num Rom)) 
(NEGATE 0 &msyn-gen-numeral-jahkasaĆĄ)
(NEGATE 1 Prop)
(NEGATE 0 Arab LINK 1 ABBR )
(NEGATE 1 Num LINK NOT 0 NUMUNIT)
(NEGATE 1 Dem) 
(NEGATE 1 COMMA) 
(NEGATE 1 (PUNCT RIGHT))
(NEGATE 1 ("ja"))
(NEGATE 1 ("lĂ„hko"))
(NEGATE 1 JAHKASAS)
(NEGATE *1 (N <spelled>) BARRIER NPNHA) ;


# coordinated adjectives
# to the right
ADD:msyn-numphrase-sgnom (&msyn-numphrase-sgnom) TARGET ("akta" Sg Nom) OR ("1" Sg Nom) IF (*1 PRE-NP-HEAD BARRIER NOT-ADV OR JAHKASAS LINK 1 CC LINK 1 PRE-NP-HEAD LINK *1 (N Sg Nom) + &msyn-numphrase-sgnom BARRIER NOT-Attr - PrfPrc - GRADE-ADV  - (A <AttrPred> Sg Nom) - (A <AttrPred> Sg Gen) - (A <AttrPred> Sg Acc) - (Pcle Foc/Neg-ge) - (Pcle Foc/Pos-ge) LINK NOT 0 (N Coll Nom) OR ("tuvsĂĄn" Num Pl Nom)) # OR PL-PAIR-N) 
(NEGATE -1 NUMMAR)
(NEGATE -1 (Dem Acc))
(NEGATE 0 NUMUNIT LINK -1 Num OR NUM-INDEF) 
(NEGATE 0 (N Coll Nom) OR ("tuvsĂĄn" Num Pl Nom) OR Sem/Year OR Sem/Date OR Sem/Time-clock) 
(NEGATE 0 ONE + (Sg Gen) LINK 1 ("vuoras")) 
(NEGATE 0 (Num "<biel.*>"r))
(NEGATE 0 &msyn-gen-numeral-jahkasaĆĄ)
(NEGATE 0 (Num "<[0123456789]-.*>"r))
(NEGATE *1 (N <spelled>) BARRIER NPNHA) ;
	## 


ADDRELATION ($2 LEFT) (N &msyn-numphrase-sgcom) OR NUMUNIT + &msyn-numphrase-sgcom TO (*-1 (Num &msyn-numphrase-sgcom) OR NUM-INDEF + (Sg &msyn-numphrase-sgcom));


COPY:msyn-numphrase-sgcom (Sg Com SUGGEST) EXCEPT (Pl Com) TARGET (Num &msyn-numphrase-sgcom) IF (0 (Pl Com)) ;


# Dem

ADD:msyn-numphrase-sgcom (&msyn-numphrase-sgcom) TARGET (Pron Dem Pl) IF (*1 (Num Sg) OR NUM-INDEF + Sg OR (Nom SUGGEST) OR (A Arab) BARRIER (*) - ("maĆemus") - ("maĆep" Der/Superl <AttrPred>) - ("maĆĆe" Der/Superl <AttrPred>) LINK *1 (N &msyn-numphrase-sgcom) OR NUMUNIT + &msyn-numphrase-sgcom BARRIER NPNHA - CC OR JAHKASAS) 
(NEGATE 1 (Pron Dem)) ;


#COPY:msyn-numphrase-sgcom (SUGGEST) EXCEPT (&msyn-numphrase-sgcom) TARGET (Dem &msyn-numphrase-sgcom) ;

ADDRELATION ($3 LEFT) (N &msyn-numphrase-sgcom) OR NUMUNIT + &msyn-numphrase-sgcom TO (*-1 (Dem &msyn-numphrase-sgcom));

SUBSTITUTE (&msyn-numphrase-sgcom) (co&msyn-numphrase-sgcom) TARGET (SUGGEST);



# Locative numeral phrase

# Noun


ADD:msyn-numphrase-sgloc (&msyn-numphrase-sgloc) TARGET (N Pl Loc) IF (*-1 (Num Sg Loc) OR (Num Pl Loc) OR (Num Attr Loc) OR (Num Sg Gen) BARRIER NOT-Attr - PrfPrc - GRADE-ADV  - (A <AttrPred> Sg Nom) - (A <AttrPred> Sg Gen) - (A <AttrPred> Sg Acc) - (Pcle Foc/Neg-ge) - (Pcle Foc/Pos-ge) OR JAHKASAS LINK NEGATE -1 KLASS) 
(NEGATE *-1 ("okta") OR ("1") BARRIER NOT-Attr - PrfPrc)
(NEGATE *-1 (Num Sem/Year) BARRIER NOT-Attr - PrfPrc)
(NEGATE *-1 (Num Rom) BARRIER NOT-Attr - PrfPrc)
(NEGATE *-1 Num BARRIER NOT-Attr - PrfPrc LINK -1 KLASS OR NUMMAR OR COUNTABLE)
(NEGATE *-1 (Arab Ord) BARRIER NPNHA OR Num)
(NEGATE *-1 (Num Sem/ID) BARRIER NPNHA OR Num)
(NEGATE *-1 Num BARRIER NPNHA LINK 0 ("aktan" Adv))
(NEGATE *-1 Num BARRIER NPNHA LINK 1 Dem)
(NEGATE *-1 (Num "<[Â§].*>"r) OR (Num "<.*%>"r) OR ("%") BARRIER NPNHA - Num)
(NEGATE *-1 (Num "<.*[0123456789]-.*>"r) BARRIER NPNHA OR Num)
(NEGATE *-1 (Num Sg Nom) BARRIER NPNHA LINK -1 BE + Sg3 OR BE + Du3 OR BE + Pl3 LINK -1 (Dem Pl Loc) OR (Pers Pl3 Loc) OR (Pers Pl2 Loc) OR (Pers Pl1 Loc)) 
(NEGATE -1 JAHKASAS LINK -1 (Num)) 
(NEGATE -1 NUMUNIT LINK -1 PLURAL-QUANTIFIERS OR Num)
(NEGATE -1 NUMUNIT LINK -1 Num OR ("moadde"))
(NEGATE -1 Sem/Time)
(NEGATE -1 COMMA OR CC)
(NEGATE -1 CLB)
(NEGATE -1 (PUNCT RIGHT) LINK -1 Num) 
(NEGATE 0 ABBR OR Prop)
(NEGATE 0 ("lohku"))
##(NEGATE 0 ("<[A-Z].*>"r) OR ("<Ă.*>"r) OR ("<Ă.*>"r) OR ("<Ă.*>"r) LINK -1 (Arab Nom))
##(NEGATE 0 (Der/NomAct Sg Nom) LINK 0 PrfPrc LINK *1 (N Pl Nom)  BARRIER NOT-Attr) 
(NEGATE 0 <spelled> OR &real)
(NEGATE 0 (Sg Nom) LINK 0 GRAMCHK-NOM-GEN-N)
(NEGATE 0 Symbol)
(NEGATE 0 Gram/NomAg OR Der/NomAg)
(NEGATE 0 (Sg Gen) OR Acc)
(NEGATE 0 ("luohkkĂĄ") LINK -1 (".*[a-z]"r Arab));
