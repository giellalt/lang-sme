	# oainnat iige oainnÃĄt
	# --------------------

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 (Pron Sem/Hum Pers Nom) LINK NOT 0 Sg2);
	## Mun oainnÃĄt ÄohkkÃĄn ieÅĄ searvegotterÃĄÄis, muitala Johanne Gaup.
	## Mun oainnÃĄt maid ledjen gÃĄrtan duon mÃĄinnaÅĄuvvon geaidnobargui RuoÅĄÅĄa beallÃĄi.
	## Mun oainnÃĄt ballen dan ÃĄhkus, dat lÃĄvii ovtto

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 Nom - Sg2 OR (N Sg Gen Err/Orth-nom-gen) OR ( N Sg Gen Err/Orth-nom-acc) OR (N Sg Loc) OR (N Prop Sem/Fem Sg Gen) OR (N Prop Sem/Fem Sg Acc) OR (N Prop Sem/Mal Sg Gen) OR (N Prop Sem/Mal Sg Acc) OR (N Prop Sem/Sur Sg Gen) OR (N Prop Sem/Sur Sg Acc) OR (N Prop Sem/Org ACR Sg Acc) OR COMMA)(*1 VFIN - Neg OR COMMA BARRIER (*) - (N Nom) - (Pron Nom));
	#D? Nom-Gen Prop Sem/Fem Sem/Mal Sem/Sur ???
	#$ Dasto lea perseptuÃĄlalaÅĄ latnja, dovdanlatnja, gos oainnÃĄt, gulat, havssÃĄt, gamus dovddat jna..
	#$ Norggas gÃĄibiduvvo ahte oainnÃĄt ja nagodat lohkat biilagalbba mii lea 20 mehtera dus eret.
	## LÃĄhka oainnÃĄt gÃĄibida buohkaid boazologuid, dietnasiid ja vahÃĄgiid fievrredit âđ âđ ÃĄhÄiid âš âš boazodoallodieÄÃĄhussii ja sutnje dat mÃĄksojit nÃĄvdevahÃĄt buhtadusat ja boazodoalloÅĄiehtadusa doarjagat.
	## Liisa oainnÃĄt lea leamaÅĄ ÃĄlggu rÃĄjes mielde juo lÃĄgideamin filbmafestivÃĄla AnÃĄris, mii vuosttas geardde dollui 1997:s.
	## Mii leimmet, oainnÃĄt, ÄÃĄllÃĄn ahte mii doarjut oljo- ja gÃĄssabohkama BarentsÃĄbis.

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 Nom - Sg2 OR (N Sg Gen Err/Orth-nom-gen) OR (N Sg Gen Err/Orth-nom-acc) OR (N Sg Loc) OR (N Prop Sem/Fem Sg Gen) OR (N Prop Sem/Fem Sg Acc) OR (N Prop Sem/Mal Sg Gen) OR (N Prop Sem/Mal Sg Acc) OR (N Prop Sem/Sur Sg Gen) OR (N Prop Sem/Sur Sg Acc) OR (N Prop Sem/Org ACR Sg Acc) OR COMMA)(*1 VFIN + Neg BARRIER (*) - (N Nom) - (Pron Nom) LINK 1 ConNeg OR ("go" Pcle Qst));
	## - Gielda oainnÃĄt ii sÃĄhte ÃĄlgit olbmuin gÃĄibidit mÃĄvssu jus kloÃĄhkat eai leat gurrejuvvon.
	## Dainna lÃĄgin oainnÃĄt ii leat boazodoallalÃĄhka, oaivvilda BÃĶhr.
	## JahkeÄoahkkin oainnÃĄt ÃĄvÅūÅūuhii stivra bargat dainna ÃĄÅĄÅĄiin.
	## Soai oainnÃĄt eaba lean vuordÃĄn vuoitit, go eaba lean ÅĄaddan hÃĄrjehallat ovttas bearehaga.
	## ILO oainnÃĄt ÃĄlgÃĄ oÄÄasit vieÅūÅūat dieÄuid RÃĄÄÄehusas, ÃĄkkasta Nystad.
	## - SoaÄi ÃĄigge lÃĄvejin ieÅūan oappÃĄiguin ja vieljaguin doalvut suoli borramuÅĄa tuiska fÃĄÅggaide duos tuiskaguolbanis, oainnÃĄt sii gillÃĄjedje, muitala son.
	## Vuojahagas oainnÃĄt ferte ÃĄlo okta gii fÃĄkte.
	## - Mun in ÃĄdde mainna son smiehttÃĄ, oainnÃĄt ii go son galgÃĄ leat viehka guhkÃĄ juo ÄohkkÃĄn SÃĄmedikkis.

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 @OBJ> OR @ADVL> LINK -1 BOS)(*1 VFIN + Neg BARRIER (*) - (N Nom) - (Pron Nom) LINK 1 ConNeg OR ("go" Pcle Qst));
	## Dan oainnÃĄt ii dieÄe okta ge, go FinnmÃĄrkku KomiÅĄuvdna, mii galgÃĄ kÃĄrtet finnmÃĄrkkulaÄÄaid vuoigatvuoÄaid, ii leat boahtÃĄn vel johtui.

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (*-1 @OBJ> OR @ADVL> BARRIER NOT-PCLE LINK NOT 0 CS LINK -1 BOS)(*1 VFIN - Neg - <spelled> OR COMMA BARRIER (*) - (N Nom) - (Pron Nom));
	## Ihttin oainnÃĄt nohkÃĄ dÃĄn ÃĄÅĄÅĄi gulaskuddanÃĄigemearri.
	## Ollu han oainnÃĄt dÃĄhpÃĄhuvvÃĄ gitta Äoahkkimiin ja joatkkaÄoahkkimiin.
	## Nugo oainnÃĄt, de dien govas lea du ÃĄhkku ja govvaÄeahppi lea fÃĄhten hui bures daid dehÃĄleamos beliid ÃĄhkustat. 

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (*-1 VFIN - Err/Any OR BE + Inf BARRIER NOT-ADV-PCLE - ConNeg);
    ## Dat lea ovdal oainnÃĄt dÃĄhpÃĄhuvvan, go Sis-FinnmÃĄrkku suohkaniid vÃĄlljejeaddjit mobiliserejedje ja jienastedje 1993:s GuovddÃĄÅĄbellodaga Johanne Gaup StuorradiggÃĄi..
    #$ ÄalbmegeahÄestagain oidno, don modjestat sutnje, duoÄas oainnÃĄt su, doalahat ieÅūat su lahka dahje manat su lahka, bovdet su olggos omd. kiinoi, du ustibat muitalit sutnje ahte don leat rÃĄhkÃĄsnuvvan, jus ieÅĄ it duostta muitalit.

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (1 Neg LINK 1 ConNeg) ;
    ## Dan geasi oainnÃĄt eat ÅĄatta borrat maidege earÃĄ go luonddu njÃĄlgÃĄid.

ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 BUT-CC OR THEN-CS-ADV OR BOS)(*1 (N Nom) BARRIER NPNHAPcle LINK *1 VFIN BARRIER NOT-ADV-PCLE);
	## Dat leamaÅĄ olbmot ÄigÅÃĄi dalle, muhto oainnÃĄt dat soaÄi ÃĄigi hui ollu goaridii...
	
ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 COMMA LINK NEGATE *-1 (Ind Prs Sg2) OR (Pron Pers Sg2))(1 IF-CS LINK 1 Nom - Sg2);
	## Munnje lea mÃĄilmme dehÃĄlaÅĄ beassat Riddu RiÄÄui, oainnÃĄt jus mun dÃĄppe gulahalan riikkaidgaskasaÅĄ gehÄÄiiguin, de dalle mun gal gulahalan vaikko olles mÃĄilmmi gehÄÄiiguin, dadjala vel loahpas.
	
ADD:real-oainnat (&real-oainnat) TARGET ("oaidnit" V TV Ind Prs Sg2) IF (-1 COMMA LINK NEGATE *-1 (Ind Prs Sg2) OR (Pron Pers Sg2))(1 (N Nom) OR (<NomGenSg> Sg Acc) + Sem/Hum OR (<NomGenSg> Sg Gen) + Sem/Hum LINK 1 COMMA);
