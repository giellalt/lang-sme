	## JUSTA FĂRREN : Isabel ii leat orrun go moadde vĂĄhku Leavnnjas, muhto liiko jo Leavnnja hui bures.	

	# valjit/valjis not valji 
	# -----------------------
	
LIST VALJIT-SANIT = "bargu" "politihkka" "diehtu" "ĂĄigi" ;


ADD:xlex-vallji-valjit (&lex-vallji-valjit) TARGET ("vallji" N Sg Nom) OR ("vallji" A Sg Nom) IF (*-1 COPULAS BARRIER NOT-ADV-PCLE)(*1 N BARRIER (*) - Gen - Attr LINK 0 Sem/Substnc OR Sem/Mat OR Sem/Ani OR Sem/Ani-fish OR Sem/Food OR Sem/Drink OR Sem/Plc OR Sem/Cat OR VALJIT-SANIT) ;

	# to synonyme forslag
	
COPY:lex-vallji-valjit ("valjit" Adv SUGGEST) EXCEPT ("vallji" N Sg Nom) TARGET (&lex-vallji-valjit) ;

COPY:lex-vallji-valjit ("valjis" Adv) EXCEPT ("valjit" Adv) TARGET (&lex-vallji-valjit) ;
		
	## Vaikko diein leat vallji bohccot. Vaikko diein leat valjit bohccot. (nok reinsdyr vs. rike reinsdyr: valljibohccot)
	## Givssideapmi - lĂĄvlagis lea vallji anaforat ja alliteraĆĄuvdna lea eanaĆĄ m- ja d-jienain dahkkon


	# vallji compounds or valljugas
	# -------------------------------------
	# this should either be a compound (which would be fixed during mwe analysis) or if written appart in attributive form
	
ADD:xlex-vallji-valljugas (&lex-vallji-valljugas) TARGET  ("vallji" N Sg Nom) OR ("vallji" A Sg Nom) IF (*1 N BARRIER (*) - Attr - Gen LINK NEGATE 0 Sem/Ani OR Sem/Substnc OR Sem/Mat OR Sem/Ani-fish OR Sem/Food OR Prop - Nom)(NEGATE 0 &real OR &lex)(NEGATE 0 Sem/Human LINK 1 N + ADVLCASE) ;
	
COPY:lex-vallji-valljugas ("valljugas" A Attr SUGGEST) EXCEPT ("vallji" N Sg Nom &lex-vallji-valljugas) OR (N Sg Nom &lex-vallji-valljugas) OR (A Sg Nom &lex-vallji-valljugas) TARGET (&lex-vallji-valljugas) ;
	## Dasa lea sivvan ahte Josef Stalin siÄai atnit ĂĄvkin davviguovlluid vallji luondduriggodagaid ja ĂĄsahii danin gulag-leairraid dohko.
	## EallĂĄmuĆĄvallji eanan ĆĄaddĂĄ go gehppesmollĂĄneaddji bĂĄkteĆĄlĂĄjat, ĂĄbaida kĂĄlkavallji ĆĄlĂĄjat, vĂĄikkuhuvvojit ja nu hĂĄddjanit ( golladuvvojit ).
	## Seamulvallji // urtavallji goahccevuovdi
	#$ DoloĆĄ vallji dealljĂĄ ja ÄeavrĂĄ bivddus Oarje-FinnmĂĄrkku sulluin ledje duĆĄĆĄe bĂĄzahusat vel bĂĄhcĂĄn. 
	#$ Eai sii oro oaidnime mĂĄid boraspirevallji dagaha ealĂĄhusaide, eaige oainne mĂĄid boraspirevallji dagaha boraspiriide maid, oaivvilda NBR joÄiheaddji Niillas Heandarat Sara, iige ĂĄiggo muitalit mĂĄid NBR stivra lea evttohan riikaÄoahkkimii dĂĄn ĂĄĆĄĆĄis.
	#$ DĂĄlkkĂĄdatrievdama geaĆŸil liegga mearra ja mielddisbuktĂĄ mearehis olu dorskevallji BarentsĂĄbis.
	#$ AlbmĂĄi bĂĄhtara rastĂĄ jĂĄvrri ĂĄibbas ĂĄlĂĄs ja su oaguhit olmmoĆĄvallji sĂĄittiin. --- a crowd of people  oaguhit su with sĂĄittiin
	#$ Kulturbirrasiid vallji Davvin



    # valljugas vs. (valjis) vallji
    # ---------------------------------
    # condition:
 
   
ADD:xlex-valjis-valljugas (&lex-valjis-valljugas) TARGET ("vallji") IF (0 PxSg3 OR (A Sg Loc)) (*1 HNOUN BARRIER GRAMCHK-NPNHCCA LINK NEGATE 0 Sem/Ani OR Sem/Hum LINK NEGATE 0 Gen LINK *1 NP-HEAD BARRIER GRAMCHK-NPNHCCA) ;

COPY:lex-valjis-valljugas ("valljugas" A Sg Nom SUGGEST) EXCEPT ("vallji" N Sg Loc &lex-valjis-valljugas) OR ("vallji" A Sg Loc &lex-valjis-valljugas) OR ("vallji" N Sg Gen PxSg3 &lex-valjis-valljugas) OR ("vallji" N Sg Acc PxSg3 &lex-valjis-valljugas) OR ("valjis" Adv &lex-valjis-valljugas) TARGET (&lex-valjis-valljugas) ;
    ## Guovdageainnus lea valjis ja girjĂĄs kultureallin. Guovdageainnus lea valljugas ja girjĂĄs kultureallin.

    # vuodjit vs. vuoddjit (N)
    # -------------------------
    # condition: 

    
ADD:xreal-vuodjit (&real-vuodjit) TARGET ("vuoddji" A Pl Nom) OR ("vuodjit" Ex/V TV Der/NomAg N Pl Nom) OR ("vuodjat" Ex/V IV Der/NomAg N Pl Nom) OR ("vuodjit" V TV Imprt Pl2) OR ("vuodjat" V IV Imprt Pl2) OR ("vuoddji" Sem/Hum N NomAg Pl Nom) IF (NEGATE -1 Attr OR ("eanet"))(NEGATE 1 (V Ind Pl3) OR BE + Inf) ;    
COPY:real-vuodjit ("vuodjit" V TV Inf SUGGEST) EXCEPT ("vuoddji" A Pl Nom &real-vuodjit) OR ("vuodjit" Ex/V TV Der/NomAg N Pl Nom &real-vuodjit) OR ("vuodjat" Ex/V IV Der/NomAg N Pl Nom &real-vuodjit) OR ("vuodjit" V TV Imprt Pl2 &real-vuodjit) OR ("vuoddji" Sem/Hum N NomAg Pl Nom &real-vuodjit) TARGET (&real-vuodjit) ;
	#$ Iigo leatge ĂĄigi oaĆŸĆŸut mearredeaddjiid ĂĄddet ahte dĂĄrbbaĆĄuvvo rĂĄhkadit kalendara dan lĂĄhkai ahte buohkain lea vejolaĆĄvuohta vuodjit doppe gos leat eanet vuoddjit.
    ## Lei hui somĂĄ fas vuoddjit duoddara badjel Leavnnjas deike.
    #$ Dat lea oalle galmmas ja vuoddjit leat bidjan rĂĄjĂĄ 25 buolaĆĄgrĂĄdii, Äilge HĂŠtta.
    ## Dohko ii leat nu vĂĄttis beassat, go sĂĄhttĂĄ vuoddjit biillain meastta jĂĄvregĂĄddĂĄi.
    ## Mun hĂĄliidivÄÄen galledit Njeareveaji - ja ĂĄinnas hĂĄliidivÄÄen dohko vuoddjit biillain.

    # vuvdii (V Prt Sg3) vs. vuvdiid (N Pl Acc)
    # -----------------------------------------
    # condition: 
 
#DELETE uncommon   
ADD:xreal-vuvdii (&real-vuvdii) TARGET ("vuovdi" Sem/Hum N NomAg Pl Acc) OR ("vuovdi" A Pl Acc) OR ("vuovdi" A Pl Gen) OR ("vuovdi" Sem/Hum N NomAg Pl Gen) OR ("vuovdit" Ex/V Ex/TV Der/NomAg N Pl Gen) OR ("vuovdit" Ex/V Ex/TV Der/NomAg N Pl Acc) IF (1 (Pron Pl Acc)) ;    
COPY:real-vuvdii ("vuovdit" V TV Ind Prt Sg3 SUGGEST) EXCEPT ("vuovdi" Sem/Hum N NomAg Pl Acc  &real-vuvdii) OR ("vuovdi" A Pl Acc  &real-vuvdii) OR ("vuovdi" A Pl Gen  &real-vuvdii) OR ("vuovdi" Sem/Hum N NomAg Pl Gen  &real-vuvdii) OR ("vuovdit" Ex/V Ex/TV Der/NomAg N Pl Gen  &real-vuvdii) OR ("vuovdit" Ex/V Ex/TV Der/NomAg N Pl Acc &real-vuvdii) TARGET (&real-vuvdii) ;
    ## MannĂĄn  rĂĄhkadii son juo vuodjaskĂĄhppuid ja vuvdiid daid, nie tiinnii ĂĄlcces oÄÄa sk Mannan vahko  Äoagganedje 160 olbmo miehtĂĄ Suomabeale SĂĄmi Ohcejohkii ĂĄvvudit Ohcejoga soahteveterĂĄnaid searvvi 40-jagi.
    # more testing when korp works again
    
    
    # vĂĄlddii vs. vĂĄlddi (fullmakt, mandat)
    # -----------------------------------


ADD:xreal-vĂĄlddi-vĂĄldii (&real-vĂĄlddi-vĂĄldii) TARGET ("vĂĄldi" N Sg Acc) OR ("vĂĄldit" V TV VGen) OR ("vĂĄldi" N Sg Gen) IF (NEGATE *-1 VFIN OR Inf BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN)(*0 Gen OR Acc BARRIER TV);
COPY:real-vĂĄlddi-vĂĄldii ("vĂĄldit" V TV Ind Prt Sg3 SUGGEST) EXCEPT ("vĂĄldi" N Sg Acc &real-vĂĄlddi-vĂĄldii) OR ("vĂĄldit" V TV VGen &real-vĂĄlddi-vĂĄldii) OR ("vĂĄldi" N Sg Gen &real-vĂĄlddi-vĂĄldii) TARGET (&real-vĂĄlddi-vĂĄldii) ;
    ## DĂĄt ahte vĂĄldĂĄ nĂĄ guhkes ĂĄiggi dohkkehit sĂĄmi museaid, ÄĂĄjeha duĆĄĆĄe ahte mo sĂĄmi museaid meannudit, vaikko SĂĄmediggi juo logi jagi ĂĄigi vĂĄlddi badjelasas sĂĄmi museaid, dadjĂĄ Andreassen.
    #$ Lea olggobealde lĂĄvdegotti vĂĄlddi evttohit dĂĄid mearrrĂĄdusaid rievdaduvvot.
    #$ ĂĆĄĆĄit mat gusket ovttaskas olbmuid boazodollui leat olggobealde orohatstivrra vĂĄlddi.
    #$ SĂĄmi bĂĄikenamaid nammakonsuleanttat BĂĄikenammalĂĄga Â§ 11 addĂĄ SĂĄmediggĂĄ vĂĄlddi nammadit sĂĄmi bĂĄikenammakonsuleanttaid.
	#$ Sii doalahedje vĂĄlddi mearridit vearu sturrodaga.
     
    # varra vs. vĂĄrra
    # ----------------
    # condition: 

LIST VARRA-SUBJ-V = "addit" "bisĂĄnit" "boahtit" "bulljarastit" "cirgut" "Äoagganit" "Äoahkkanit" "doahkkut" "duldet" "duoldat" "earĂĄhuvvat" "giellut" "goaikut" "goaikkihit" "goikat" "golgat" "golggadit" "golggahit" "golggiidit" "guoÄÄit" "iskat" "iskkadit" "jĂĄpmasit" "jĂĄpmit" "johtit" "lihkadit" "luoitit" "ruohtadit" "ruohtastit" "ruohttat" "seaguhit" "seahkanit" "seahkĂĄnit" "spulĆŸut" "suohkut" "suvrut" "vardit" "vĂĄilut" "vĂĄldot"; # suohku	giellu=stirdu=garrĂĄ doahku gĂĄvdnot sisttisdoallĂĄ ÄĂĄhpoda dohpĂĄ darvĂĄna lassĂĄna;

LIST VARRA-OBJ-V = "vĂĄldit" ;
LIST VARRA-COMP-N = "bumpa" "dielku" "johtin" "johtu" "pumpa" "ruoksat"  ; 

LIST NON-VARRA-SUBJ-V = "almmuhit" "ĂĄssat" "ĂĄsahit" "bohciidahttit" "borgat" "ÄĂĄllit" "Äuohcat"  "gollat" "jurddaĆĄit" "juohkit" "dadjat" "heivet" "hirpmĂĄstuhttit" "goahcat" "ovdĂĄnit" "ballat" <EX-Nom-Ani> "dagahit" "geahÄÄat" "geavahit" "gĂĄibidit" "gĂĄvdnat" "gustot" "jĂĄhkkit" "maĆidit" "govvidit" "vuordit" "vuovdit";  
													 
	## VĂĄrra heive bures go nieiddain orrot jo liegga geahÄastagat min gĂĄnddaide, nĂĄrridastĂĄ ja lohkĂĄ ieĆŸaset bures nĂĄvddaĆĄan mĂĄtkkis. 


LIST NON-VARRA-SPRED-A = "ĂĄrtet" "somĂĄ" "suohtas" "vuoigatmeahttun" ; #A Sem/Hum Sg Nom
LIST VARRA-SPRED-A = "galmmas" "hĂĄrvvis" "ruoksat" "suohkat" "varas" ;
LIST VARRA-ATTR-A = ("ĂĄdel" Der/lasj A) ("giellut" V IV PrfPrc) ("goikat" V IV PrfPrc) (goikkis A Cmp/Attr) ("liekkas" A Attr) ("nanus" A Attr) ("njuoskkas" A Attr) ("oÄas" A Attr) ("ruoksat" A Attr) ("sitkat" A Attr) ("varas" A Attr) (".*-#sorta"r N Pl Nom);
    


ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (*0 GRAMCHK-VFIN - Sg3 BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess - Po - @>P)(NEGATE -1 (Gen @>N) + Sem/Hum OR (Gen @>N) + Sem/Mal OR (Gen @>N) + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Prop Sem/Plc Sg Gen @>N) OR Sem/Amount + Gen OR (Attr @>N))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH)(NEGATE *-1 Sg3 BARRIER NPNHA LINK NOT *-1 SUBJ OR (Pron Sem/Hum Sg3 Nom) BARRIER NPNHA)(NEGATE *0 (Ind Sg3) + VARRA-SUBJ-V OR (Ind Pl3) + VARRA-SUBJ-V BARRIER NOT-ADV-PCLE) ;   
    ## Ja ii dat leat vel duvdon, muhto varrage lean oahppan dainna eallit. Ja ii dat leat vel dovdon, muhto vĂĄrrage lean oahppan dainna eallit.
    #$ Ja dat galgĂĄ jorgalit velĂĄ guovtti guvlui, vai cuvke eambbo, ja vai boaÄĂĄle juobe golbma goaikkanasage varra
    #$ DĂĄs han cirgot varra, cuozza ja siskkiluĆĄat
    #$ Meksiko presideanta, Zedillo, ja su guatemalalaĆĄ bargoskibir, Arzu, leaba dĂĄl loahpaheamen barggu mĂĄhcahit dan 45 duhĂĄt olbmo, geat Guatemala varra, siskkĂĄldas riiddus bĂĄhtaredje Meksiko presideanta, Zedillo, ja su guatemalalaĆĄ bargoskibir, Arzu, leaba dĂĄl loahpaheamen barggu mĂĄhcahit dan 45 duhĂĄt olbmo, geat Guatemala {varra}, siskkĂĄldas riiddus bĂĄhtaredje

 
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (*1 (V Ind Sg3) BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN)(*-1 @SUBJ> + Sg OR (Pron Sem/Hum Sg3 Nom) BARRIER NPNHAPcle - @ADVL> - @>P - @P<)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;
	## De gal lohkĂĄ okta dain jiehtanasain ahte bussĂĄ gal varra geassĂĄ fatnasa, go sidjiide earĂĄide lea nu lossat. 
	## Sundi Paus, gii veahĂĄ maĆĆel 1700-logu gaskkamutto varra lei FinnmĂĄrkku ja ÄearddalaĆĄ ealĂĄhusvuoÄu heivehemiid oahppĂĄseamos olmmoĆĄ, Äilgii sĂĄpmelaÄÄaid ja dĂĄÄÄaid erohusa guovddĂĄĆĄ borramuĆĄriggodagaid geavaheami oktavuoÄas. 
    
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (*1 (V Ind Sg3) OR (V Cond Sg3) BARRIER NOT-ADV-PCLE LINK *1 @<SUBJ + Sg BARRIER NPNHAPcle - @ADVL> - @>P - @P< - ? - @>N)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	## Muhto 1600-logu mielde varra rievddai boazodoallu dan guvlui ahte ĆĄadde sierra doalut ja stuorit ealut, ja dĂĄt ovdĂĄnii ain maĆit jahkeÄuoÄis.
	## Â Varra boahtĂĄ dĂĄlĂĄ presideanta Egil Olli oidnot dĂĄn lĂĄhkkĂĄi.
	## Varra   biddjojuvvoĆĄii dĂĄt proĆĄeaktavirgi FinnmĂĄrkku fylkkagildii.
    
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (*1 SUBJ + Sg OR (Pron Sem/Hum Sg3 Nom) BARRIER NPNHAPcle - @ADVL> - @>P - @P< - ? LINK 1 Rel LINK *1 VFIN BARRIER NOT-ADV-PCLE LINK *1 (V Ind Sg3) BARRIER GRAMCHK-S-BOUNDARY OR COMMA OR VFIN)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	## Danin varra dat olmmoĆĄ gii lea ĂĄlgĂĄn girjeÄĂĄllin lea hĂĄlidan govvet ÄĂĄlalaÄÄat daid dovdduid
	
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (*-1 (V Ind Sg3) BARRIER NOT-ADV-PCLE)(*1 @<SUBJ + Sg OR @<SPRED + Sg OR (Pron Sem/Hum Sg3 Nom) OR Ess + @<SPRED BARRIER NPNHAPcle - @ADVL> - @>P - @P< - ? -  PrfPrc)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;
	## Son dovddaha dĂĄl ahte lea dan maÄe agis politihkkalaĆĄ vuogadagas ahte lea varra ĂĄigi loapahisgoahtit doaimmaid
	## MaiddĂĄi ĂĄibmu lea nuoskiduvvon, ja leage varra sivvan manne nu olu olbmot jĂĄbmet borasdĂĄvdii.
	## Dolin lei maiddĂĄi olles pyramiida mĂĄlejuvon ruoksadin olggobeal ja lea varra leamaĆĄ oalle oainnĂĄhus mii oidnui mĂĄĆgga miilla duohken.
	
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (-1 ("dat" Pron Dem Sg Nom @>N) OR ("dĂĄt" Pron Dem Sg Nom @>N))(*1 (V Ind Sg3) BARRIER NOT-ADV-PCLE LINK *1 @<SPRED + Sg BARRIER NPNHAPcle - ConNeg)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	## nu ahte dat varra ii ĆĄatta nu stuora ĂĄĆĄĆĄi	
    
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (-1 COPULAS + Sg3 LINK -1 ("dat" Pron Dem Sg Nom @SUBJ>) OR ("dĂĄt" Pron Dem Sg Nom @SUBJ>))(*1 @<SPRED + Sg OR ADJ_ATTR/NOM BARRIER NPNHAPcle - ConNeg)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	## DĂĄt lea  varra   hirbmat mĂĄvssolaĆĄ identitehtii ja ieĆĄĂĄrvui, ja ĂĄinnasge guovlluin main sĂĄmegiella ja identitehta leat leamaĆĄ erenoamĂĄĆŸit fuotnin adnon.

ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (*-1 BE + (V Ind Sg3) BARRIER NOT-ADV-PCLE LINK -1 Sem/Time + Loc OR Sem/Place + Loc OR Sem/Time + Adv OR Sem/Place + Adv)(*1 @<SPRED + Nom BARRIER NPNHAPcle - @ADVL> - @>P - @P< - ?)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;
	## DĂĄ lei varra maĆimus Norgga guovlu mas 
	
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (0 @SUBJ> OR @<SUBJ)(*1 BE + (V Ind Sg3) OR BE + (Prt ConNeg) BARRIER NOT-ADV-PCLE LINK *1 (N @<SPRED) BARRIER NPNHAPcle - @ADVL> - @>P - @P<)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess - Po - @>P)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	## Varra lei KamĂžyvĂŠra
	## Geaidnohuksemiidda ii varra lean vuostehĂĄhku soaÄi ovdal.	
	
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (*1 (IV Ind Sg3) BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN)(-1 ("gal") LINK *-1 ("dat" Pcle) OR (Pron Sg Nom) BARRIER NOT-ADV-PCLE)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	## Dat gal varra Äihkkui muhtun skuffii.
	## Manne lei nu deaĆ§alaĆĄ diktit fylkkamĂĄnni dĂĄn mearrĂĄdusa formĂĄlaÄÄat geahÄÄalit ( mii gal varra ii dahkkon ) ?
    
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (1 ("vel") OR ("maiddĂĄi") LINK 1 @>N)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	## OÄÄa, goalmmĂĄt ja varra vel maĆimuĆĄ essayÄoakkĂĄldat Â« cafe Boddu Â» rĂĄiddus lea dĂĄl ilbman.
	## GelddolaĆĄ, ja varra vel issoras vuordĂĄmuĆĄ.
    
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (1 ("danin") OR ("danin go"))(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	##  ) na varra danin go sii leat munnje dan sĂĄmegiela oahpahan nu, ahte dat dihtet ahte munnje sĂĄhttĂĄ jo muhtin veardde goittotge hĂĄllat dan.	
	
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (NEGATE *-1 (Ind Sg3) BARRIER GRAMCHK-S-BOUNDARY)(*1 ("danne") BARRIER (*) - BE + (Ind Sg3))(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	## Â Varra danne Canoa Quebradas lea veadjetmeahttun doapmat
	## Varra leige danne son ja su ustibat ĂĄlggahedje ge MĂĄrkomeanuid.
    
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (-1 ("gal"))(*1 (IV Ind Sg3) BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN LINK 1 @>N OR (A Attr) OR Adv OR Pcle LINK 1 @>N OR (A Attr) OR Adv OR Pcle LINK 1 SUBJ OR N + (Sg Nom))(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	## Gal varra lei veahĂĄ erenoamaĆĄ deaivvadeapmi mu ja Hedningarna joavkku gaskkas, mojohallĂĄ Wimme hilbeslĂĄhkai go mun joatkĂĄn sĂĄgastallama Hedningarna joavkku ovttasbarggus.
	
ADD:xreal-varra-vĂĄrra (&real-varra-vĂĄrra) TARGET ("varra" Sg Nom) OR ("vĂĄrra" Adv Err/Spellrelax) IF (-1 ("gal") LINK *-1 Sem/Place + Loc OR Sem/Place + Adv)(*1 (IV Ind Sg3) BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN)(NEGATE 1 Rel LINK *1 VFIN)(NEGATE 0* Sem/Body + Nom OR Sem/Aniprod + Nom OR Sem/Substnc + Nom BARRIER (*) - COMMA - CC - Ess)(NEGATE -1 (Gen @>N) + Sem/Hum OR Gen + Sem/Mal OR Gen + Sem/Fem OR (Gen @>N) + Sem/Ani OR (Gen @>N) + Sem/Lang OR (Attr @>N) OR (Pron Refl Gen))(NEGATE -1 COMMA LINK -1 (N Nom) LINK 3 COMMA OR CC LINK *1 (N Nom) BARRIER NPNH) ;	
	## Nuorta-FinnmĂĄrkkus gal varra lei veadjetmeahttun gortni ĆĄaddadit galbmĂĄ mearaĂĄimmu dihte. Â¶

	
