	# LATE FS-ARGUMENT MAPPING
	# ------------------------

SETCHILD (V <TH-FS>) (NONE c Â§TH) TO (*1 @FS-<ADVL BARRIER <mv>);
	## GaskaboddosaĆĄ presideanta SĂĄmedikkis, Laila Susanne Vars, liiko maid gullĂĄ.
SETCHILD (V <TH-FS-Qst>) (NONE c Â§TH) TO (*1 VFIN + Qst BARRIER <mv>);
SETCHILD (V <TH-FS-Qst>) (NONE c Â§TH) (NEGATE *3 VFIN BARRIER GRAMCHK-S-BOUNDARY OR CC LINK NOT 0 Inf) TO (2 BECAUSE-WHEN LINK -1 VFIN - Qst OR Inf - Qst);
	## Dasto jearaimet beroĆĄtit go oahppat sĂĄmegiela buorebut, ja jos nu, de man suorggis ja mo hĂĄliidit oahppat.
	#$ â Evy ii leat Äilgen maidege, sutnje lea leamaĆĄ ĂĄlkit bĂĄhtarit fatnasis, ballĂĄ {duĆĄĆĄat} go fanas vuodju, dan sadjĂĄi go ieĆŸas vĂĄrjalit, nu han dahkĂĄ go ii vĂĄstit.
	## Lea MearkalĂĄvdegotti duohken mearridit addet go mearka vai eai, lohkĂĄ son.

SETCHILD (V <TH-FS-Qst>) (NONE c Â§TH) TO (4 BECAUSE-WHEN LINK -1 VFIN - Qst OR Inf - Qst LINK -1 CC LINK -1 VFIN - Qst OR Inf - Qst);
	##

LIST FS-QPRON-ADV = ("gii" Pron Rel) "goas" "gokko" "gos" "gosa" "govt" ("got" Adv) "makkĂĄr" "man" "manne" "manin" ("mii" Pron Rel) ("mii" Pron Indef) "mo" "mot" "mov" "movt" ("nugo" @CVP) ;

SETCHILD (V <TH-FS-Qpron>) TO (*1 FS-QPRON-ADV BARRIER GRAMCHK-S-BOUNDARY OR VFIN OR Inf OR OBJ LINK *1 VFIN BARRIER VFIN);
	#$ Mii hĂĄlidit alcceseamet dakkĂĄr politihkkariid geain leat viidĂĄt jurdagat go hĂĄlbbes viidni, ja mii hĂĄstalit sin beroĆĄtit buohkaid daid olbmuid {geat} guddet alkoholnoÄiid ieĆŸaset olggiid alde.
	## Dolken ieĆŸan sĂĄniide, ja hĂĄlidin geahÄÄat maid earĂĄt ÄĂĄllet, muitala Mari Boine.

SETCHILD (V <TH-FS-Qpron>) TO (1 ("maid") LINK *1 VFIN BARRIER VFIN);
	## Seamma ĂĄigge earĂĄ sajis mĂĄilmmis Statoil ÄevllohallĂĄ ruonĂĄ politihkainis ja verddevuoÄainis eamiĂĄlbmogiiguin dego sĂĄmiin, geat eai oro diehtimin dahje beroĆĄteamen {maid} Statoil lea bargamin Kanadas ; mo dat lea mirkoheamen eamiĂĄlbmogiid eatnamiid ja jogaid dahje duĆĄĆĄadeamen sin eallinvugiid, ealĂĄhusaid ja dearvvaĆĄvuoÄa.

SETCHILD (V <RE-Loc-Ani><TH-FS-Qpron>) TO (c Loc + Sem/Animate LINK 1 ("maid") OR ("mii" Pron Pl Acc) LINK *1 VFIN BARRIER VFIN);
	## Stuorra buvda Steen & StrĂžm lea jearran 1600 olbmos maid sii ohcalit gĂĄvpeguovddĂĄĆŸis.


#SETCHILD (V <TH-Ill-Any>) (NEGATE c Â§TH) TO (*1 @FS-<ADVL BARRIER <mv>);
	## *GaskaboddosaĆĄ presideanta SĂĄmedikkis, Laila Susanne Vars, liiko maid gullĂĄ. - dasa maid gullĂĄ
