	# joatkkĂĄn ("joatkit" V+TV+Ind+Prs+Sg1) vs. joatkkan (joatkka N Ess)
	# -------------------------------------------
	
	
LIST ESS-PRSSG1-N = "joatkka" "vuolgga" ;
LIST ESS-PRSSG1-V = "joatkit" "vuolgit" ;
	

ADD:xreal-Ess-PrsSg1 (&real-Ess-PrsSg1) TARGET (N Ess) IF (0 ESS-PRSSG1-N)(*-1 (Pron Pers Sg1 Nom) BARRIER GRAMCHK-S-BOUNDARY OR <RO-Ess-Any> OR <TH-Acc-Any><RO-Ess-Any>) ;

ADD:xreal-Ess-PrsSg1 (&real-Ess-PrsSg1) TARGET (N Ess) IF (0 ESS-PRSSG1-N)(*-1 (V Sg1) BARRIER GRAMCHK-S-BOUNDARY OR <RO-Ess-Any> OR <TH-Acc-Any><RO-Ess-Any>) ;

COPY:real-Ess-PrsSg1 ("joatkit" V TV Ind Prs Sg1 SUGGEST) EXCEPT ("joatkka" N Ess &real-Ess-PrsSg1) TARGET ("joatkka" &real-Ess-PrsSg1) ;
COPY:real-Ess-PrsSg1 ("vuolgit" V TV Ind Prs Sg1 SUGGEST) EXCEPT ("vuolgga" N Ess &real-Ess-PrsSg1) TARGET ("vuolgga" &real-Ess-PrsSg1) ;
	## Go ĆĄie ÄÄ aluvan, de dalle mun Äohkkedan ja fas joatkkan mĂĄtki. 
	## Muhto ihttin lean fas sĂĄpmelaĆĄ, muhto juste dĂĄl melden olggos, vuolggan geahÄÄat Greys Anatomy.

	
		
	# johtui ("johtu" Sg Ill) vs. johttui ("johtit" Der/PassS Ind Prt Sg3)
	# ---------------------------------------------------------------------


ADD:xreal-johttui-johtui (&real-johttui-johtui) TARGET ("johtit" Der/PassS Ind Prt Sg3) IF (*-1 ("bidjat") OR ("boahtit") OR ("oaĆŸĆŸut") BARRIER NPNHA - OBJ) ;
	## DĂĄt analysajoavku biddjui johttui 2007:s ja sin bargu ii leat rĂĄhkadit statistihkaid, muhto gĂĄvdnat ovddeĆĄ statistihkaid sĂĄmi diliid birra ja buktit mearkkaĆĄumiid daidda.
	## Lea almmolaĆĄvuoÄa gĂĄibĂĄdus ahte doaimmat mat biddjojit johttui galget bidjot almmolaĆĄvuhtii, anne fitnodagat besset addit fĂĄlaldaga.
	## SĂĄmi allaskuvla ja Norges veterinĂŠrhĂžgskole hĂĄlideaba dĂĄinna seminĂĄrain boahtit johttui ovttasbargguin ealĂĄhusain, oaĆŸĆŸun dihte buriid reaidduid bohccobierggu kvalitehtaduoÄaĆĄtussii.
	## Son lea oĆŸĆŸon johttui barggu daiguin oÄÄa luossalobiiguin FinnmĂĄrkkus
	## DĂĄn vahkku leat hui doaimmalaĆĄ, eanet go leat leamaĆĄ goassege ovdal ja don fuobmĂĄt oÄÄa doaimmaid mat maid oĆŸĆŸot hormonaid johttui.
	## - Mii diehtit ahte jus lullisĂĄmegiella galgĂĄ seailut, de lea dĂĄl maĆemus ĂĄigi bidjat johttui doaimmaid, dadjĂĄ Hanssen vuoiggalaÄÄat.
	## Dat lea endorii ahte buohkaid bidjat johttui seammahat guovlluide, go dat ii leat buorre luonddugĂĄhtten, go seamma guovlluide ĆĄaddĂĄ garra deaddu.
	## GuovddĂĄĆĄbellodat ĂĄigu danne bidjat ĂĄlggu johttui farggamusat doallat ĂĄlbmotÄoahkkima ruvkedoaimmaid birra min gielddas.
	## MĂĄĆgga sajiin leat sii jo boahtĂĄn bures johttui. 
	
ADD:xreal-johttui-johtui (&real-johttui-johtui) TARGET ("johtit" Der/PassS Ind Prt Sg3) IF (*-1 (N Nom) + Sem/Human BARRIER NOT-ADV-PCLE LINK *-1 ("bidjat" Ind) BARRIER NPNHA - OBJ - @>N) ;	
	## Dalle bijai Norgga stĂĄdaministtar Oddvar Nordli SĂĄmi vuoigatvuoÄalĂĄvdegoddi johttui.


COPY:real-johttui-johtui ("johtu" N Sg Ill SUGGEST) EXCEPT ("johtit" Ex/V Ex/IV Der/PassS V IV Ind Prt Sg3 &real-johttui-johtui) TARGET (&real-johttui-johtui) ;
	## 


	# real-johttui-johtui
    # -------------------

ADD:real-johttui-johtui (&real-johttui-johtui) TARGET ("johtu" N Sg Ill Err/Confused-DerPassPrtSg3) OR ("johtit" Der/PassS IV Ind Prt Sg3) IF (*0 <johtui> OR <TH-Acc-Any><johtui> OR <*-Ill> BARRIER NPNHAPcle - OBJ - SUBJ)  ;
	## MĂĄĆgga sajiin leat sii jo boahtĂĄn bures johttui.

ADD:real-johttui-johtui (&real-johttui-johtui) TARGET ("johtu" N Sg Ill Err/Confused-DerPassPrtSg3) OR ("johtit" Der/PassS IV Ind Prt Sg3) IF (*-1 <johtui> OR <TH-Acc-Any><johtui> OR <*-Ill> BARRIER V LINK *-1 EOS BARRIER NOT-ADV-PCLE)  ;
    ## Dalle bijai Norgga stĂĄdaministtar Oddvar Nordli SĂĄmi vuoigatvuoÄalĂĄvdegoddi johttui.
    
ADD:real-johttui-johtui (&real-johttui-johtui) TARGET ("johtu" N Sg Ill Err/Confused-DerPassPrtSg3) OR ("johtit" Der/PassS IV Ind Prt Sg3) IF (-1 Acc LINK -1 <TH-Acc-Any><johtui>)  ;
	## DĂĄn vahkku leat hui doaimmalaĆĄ, eanet go leat leamaĆĄ goassege ovdal ja don fuobmĂĄt oÄÄa doaimmaid mat maid oĆŸĆŸot hormonaid johttui.

ADD:real-johttui-johtui (&real-johttui-johtui) TARGET ("johtu" N Sg Ill Err/Confused-DerPassPrtSg3) IF (-1 Attr OR (Pron Gen)) ;

COPY:real-johttui-johtui (SUGGEST) EXCEPT (Err/Confused-DerPassPrtSg3 &real-johttui-johtui) TARGET ("johtu" N Sg Ill Err/Confused-DerPassPrtSg3 &real-johttui-johtui) ;

COPY:real-johttui-johtui ("johtu" N Sg Ill SUGGEST) EXCEPT ("johtit" Der/PassS IV Ind Prt Sg3) TARGET ("johtit" Der/PassS IV Ind Prt Sg3 &real-johttui-johtui) ;

	# ĂĄddet vs. addit
    # ---------------

LIST ADDIT-OBJ = "ĂĄndagassii" (".*ĂĄrvu"r Sg Gen) (".*ĂĄrvu"r Sg Acc)  ("bĂĄrdni" Acc) ("bĂĄrdni" Gen) ("beaktu" Gen) ("beaktu" Acc) ("diehtu" Acc) ("diehtu" Gen) (".*fĂĄlaldat"r Gen) (".*fĂĄlaldat"r Acc) ("govva" Acc) ("informaĆĄuvdna" Sg Acc) ("kurs" Acc) (".*lohpi"r Acc) ("oahpahus" Acc) ("govva" Gen) ("kurs" Gen) (".*lohpi"r Gen) ("oahpahus" Sg Gen) ("oahpaheapmi" Sg Acc) ("oahpaheapmi" Acc) ("riekti" Acc) ("riekti" Gen) ("vĂĄldi" Acc) ("vĂĄldi" Gen) ("rĂĄdji"  Acc) ("rĂĄdji" Gen) ("ovdamunni" Acc) ("ovdamunni" Gen) (".*rĂĄÄÄi"r Gen) (".*rĂĄÄÄi"r Acc)
("bargosadji" Acc) ("bargosadji" Gen) ("bĂĄlvalus" N Pl Acc) ("bĂĄlvalus" N Pl Gen) ("boaÄus" N Acc) ("boaÄus" N Gen)
("ipmĂĄrdus" N Sg Acc) ("ipmĂĄrdus" N Sg Gen)
("vejolaĆĄvuohta" Acc) ("vejolaĆĄvuohta" Gen) ("rĂĄpmi" Sg Gen) ("rĂĄpmi" Sg Acc) ("rĂĄva" Acc) ("rĂĄva" Gen) ("varra" Sg Acc) ("vuoÄÄu" Sg Gen) ("vuoÄÄu" Sg Acc) ("varraiskkus" Sg Gen) ("varraiskkus" Sg Acc); #addit only with object)
	#$ Erohussan duodjegĂĄvppiid ja Sajosa bargobĂĄjiid gaskkas lea dat, ahte Sajosis mĂĄtkkĂĄlaĆĄ beassĂĄ ieĆĄ oassĂĄlastit duddjomii ja oahppĂĄ addet dan ĂĄrvvu.


SET DIA-DERIVATIONS = Der/Pass OR Der/h OR Der/ahtti OR Der/NomAct ;
	# Derivations which change the argument structure of the verb (diathesis) or by nominalizing the verb

ADD:real-ĂĄddet (&real-ĂĄddet) TARGET ("addit") IF (0 (Ind Prs Pl3) OR (Imprt Pl2) OR (Ind Prt Sg2) OR (Ind Prt Sg1)) (NOT 0 DIA-DERIVATIONS)  (*0 I + ( Pers Pl1 Nom) BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN OR COMMA OR (";")) (NEGATE *1 ("ĂĄndagassii") BARRIER CLB OR GRAMCHK-VFIN) (NEGATE *0 Ill OR DE-ILL-ADV OR DE-ILL-ADP OR ("eret") BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN) ;
	#$ Ooo, addet ĂĄndagassii, bivddii son.
	#$ Mii ĆĄiehtadalaimet dan ahte StĂĄdameahci bargit addet dieÄu midjiide dahje jerret mis ahte lea go heivvolaĆĄ boahtit hyttĂĄi.
	#$ Norgga SĂĄmiid ValĂĄĆĄtallanlihtu doaibmadoarjja veardiduvvo go SVL-N lea Äielggadan gaskavuoÄas Norges Idrettsforbund:ain, ja go Kulturdepartementa ja SĂĄmediggi / SĂĄmi KulturrĂĄÄÄi lea mearridan addet go doarjaga ĂĄsahit sierra hĂĄlddahusa SVL-N:i.

ADD:real-ĂĄddet (&real-ĂĄddet) TARGET ("addit") IF (0 (Ind Prs Pl3) OR (Imprt Pl2) OR (Ind Prt Sg2) OR (Ind Prt Sg1)) (NOT 0 DIA-DERIVATIONS)  (*-1 I + ( Pers Pl1 Nom) BARRIER NOT-ADV-PCLE) (NEGATE *1 ("ĂĄndagassii") BARRIER CLB OR GRAMCHK-VFIN) (NEGATE *0 Ill OR DE-ILL-ADV OR DE-ILL-ADP OR ("eret") BARRIER GRAMCHK-S-BOUNDARY OR GRAMCHK-VFIN) ;
	## Nugo mii addet, de juksĂĄ digitĂĄlarĂĄdio 50 % ĂĄlbmogis jagi 1999 loahpas
	## Bealisteamet mii addet doahpaga
	## Mii addet nu ahte ealĂĄhusovddidanplĂĄna vuosttaĆŸettiin galgĂĄ leat bagadeaddji huksejeddjiid, gielddaid ja guovddĂĄĆĄ eisevĂĄlddiid ektui.
	## Ii son ge leat oaivvildan, nugo mii addet, ahte sĂĄpmelaÄÄain lea eanariekte- ja hĂĄlddaĆĄanriekte vuoigatvuohta ILO-konvenĆĄuvnna artihkkala 14.1 vuoÄul, muhto baicce.Â 

