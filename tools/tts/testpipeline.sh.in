#!/bin/sh

hfst-tokenise -g 'tokeniser-disamb-gt-desc.pmhfst' \
 | divvun-blanktag 'analyser-gt-whitespace.hfst' \
 | vislcg3 -g 'valency.bin' \
 | vislcg3 -g 'mwe-dis.bin' \
 | cg-mwesplit \
 | vislcg3 -g 'disambiguator.bin' \
 | divvun-normaliser -n transcriptor-gt-desc.hfstol \
                     -g generator-gt-norm.hfstol \
                     -a analyser-gt-desc.hfstol \
                     --tags ABBR Arab
