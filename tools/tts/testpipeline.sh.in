#!/bin/sh

hfst-tokenise -g 'tools/tts/tokeniser-gramcheck-gt-desc.pmhfst' \
 | divvun-blanktag 'tools/tts/analyser-gt-whitespace.hfst' \
 | vislcg3 -g 'tools/tts/valency.bin' \
 | vislcg3 -g 'tools/tts/mwe-dis.bin' \
 | cg-mwesplit \
 | vislcg3 -g 'tools/tts/disambiguator.bin' \
 | divvun-normaliser -n transcriptor-gt-desc.hfstol \
                     -g src/generator-gt-norm.hfstol \
                     -a src/analyser-gt-desc.hfstol \
                     --tags ABBR
